  { label: 'SEO',             href: '/affordable-seo-auckland/' },
  { label: 'AI SEO & GEO',    href: '/ai-seo-for-auckland-small-businesses/' },
  { label: 'Paid Ads',        href: '/paid-ads/' },
  { label: 'Google Ads',      href: '/google-ads/' },
  { label: 'Meta Ads',        href: '/meta-ads/' },
  { label: 'ChatGPT Ads',     href: '/chatgpt-ads/' },
  { label: 'Website Hosting', href: '/website-hosting-auckland/' },
];

const zhServices = [
  { label: '网页设计',       href: '/zh/small-business-website-design-auckland/' },
  { label: 'SEO优化',        href: '/zh/seo-auckland/' },
  { label: 'AI SEO & GEO',   href: '/zh/ai-seo-for-auckland-small-businesses/' },
  { label: '付费广告',       href: '/zh/paid-ads/' },
  { label: 'Google广告',     href: '/zh/google-ads/' },
  { label: 'Meta广告',       href: '/zh/meta-ads/' },
  { label: '免费咨询',       href: '/zh/website-designer-auckland/' },
];

const enCompany = [
  { label: 'About Us',      href: '/about-us/' },
  { label: 'Our Process',   href: '/our-process/' },
  { label: 'Reviews',       href: '/testimonials-reviews/' },
  { label: 'Blog',          href: '/affordable-web-design-auckland/' },
  { label: 'FAQ',           href: '/faq/' },
  { label: 'Contact',       href: '/website-designer-auckland/' },
];

const zhCompany = [
  { label: '关于我们',       href: '/zh/about-us/' },
  { label: '客户评价',       href: '/testimonials-reviews/' },
  { label: '博客',           href: '/affordable-web-design-auckland/' },
  { label: '常见问题',       href: '/faq/' },
  { label: '联系我们',       href: '/zh/website-designer-auckland/' },
  { label: 'English',        href: '/' },
];

const services = isZh ? zhServices : enServices;
const company = isZh ? zhCompany : enCompany;
const logoHref = isZh ? '/zh/' : '/';
const tagline = isZh ? '为新西兰华人企业打造能带来客户的网站。' : 'Websites built to generate leads.';
const location = isZh ? '总部位于奥克兰，服务全新西兰' : 'Auckland, New Zealand';
const servicesHeading = isZh ? '服务' : 'Services';
const companyHeading = isZh ? '公司' : 'Company';
const privacyLabel = isZh ? '隐私政策' : 'Privacy Policy';

const social = [
  {
    label: 'Facebook',
    href: 'https://www.facebook.com/profile.php?id=61559560322941',
    viewBox: '0 0 24 24',
    path: '<path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.84c0-2.52 1.49-3.91 3.77-3.91 1.09 0 2.23.2 2.23.2v2.47h-1.26c-1.24 0-1.63.78-1.63 1.57v1.89h2.77l-.44 2.91h-2.33V22A10.03 10.03 0 0 0 22 12.06Z"/>',
  },
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/kiwi_web_design/',
    viewBox: '0 0 24 24',
    path: '<path d="M7.75 2h8.5A5.76 5.76 0 0 1 22 7.75v8.5A5.76 5.76 0 0 1 16.25 22h-8.5A5.76 5.76 0 0 1 2 16.25v-8.5A5.76 5.76 0 0 1 7.75 2Zm0 2A3.75 3.75 0 0 0 4 7.75v8.5A3.75 3.75 0 0 0 7.75 20h8.5A3.75 3.75 0 0 0 20 16.25v-8.5A3.75 3.75 0 0 0 16.25 4h-8.5Zm8.75 2.25a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z"/>',
  },
  {
    label: 'TikTok',
    href: 'https://www.tiktok.com/@kiwi_web_design',
    viewBox: '0 0 24 24',
    path: '<path d="M16.6 2c.24 2.1 1.42 3.35 3.4 3.49v3.05a6.82 6.82 0 0 1-3.42-.86v6.42c0 4.09-2.23 6.9-6.16 6.9C6.72 21 4 18.66 4 15.16c0-3.82 3.05-6.02 6.55-5.7v3.16c-1.66-.25-3.35.68-3.35 2.48 0 1.57 1.17 2.58 2.68 2.58 1.72 0 2.76-.97 2.76-3.2V2h3.96Z"/>',
  },
  {
    label: 'YouTube',
    href: 'https://www.youtube.com/@Kiwiwebdesign',
    viewBox: '0 0 24 24',
    path: '<path d="M23.5 6.2a3.01 3.01 0 0 0-2.12-2.13C19.5 3.57 12 3.57 12 3.57s-7.5 0-9.38.5A3.01 3.01 0 0 0 .5 6.2 31.23 31.23 0 0 0 0 12a31.23 31.23 0 0 0 .5 5.8 3.01 3.01 0 0 0 2.12 2.13c1.88.5 9.38.5 9.38.5s7.5 0 9.38-.5a3.01 3.01 0 0 0 2.12-2.13A31.23 31.23 0 0 0 24 12a31.23 31.23 0 0 0-.5-5.8ZM9.55 15.57V8.43L15.82 12l-6.27 3.57Z"/>',
  },
  {
    label: 'LinkedIn',
