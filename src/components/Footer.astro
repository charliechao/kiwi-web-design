---
const year = new Date().getFullYear();

const services = [
  { label: 'Web Design',      href: '/small-business-website-design-auckland/' },
  { label: 'SEO',             href: '/seo-auckland/' },
  { label: 'Google Ads',      href: '/google-ads/' },
  { label: 'eCommerce',       href: '/ecommerce-website-auckland/' },
  { label: 'WP Maintenance',  href: '/wordpress-maintenance-auckland/' },
  { label: 'Website Hosting', href: '/website-hosting-auckland/' },
];

const company = [
  { label: 'About Us',      href: '/about-us/' },
  { label: 'Our Process',   href: '/our-process/' },
  { label: 'Reviews',       href: '/testimonials-reviews/' },
  { label: 'Blog',          href: '/affordable-web-design-auckland/' },
  { label: 'FAQ',           href: '/faq/' },
  { label: 'Contact',       href: '/website-designer-auckland/' },
];

const social = [
  { label: 'Facebook',  href: 'https://www.facebook.com/profile.php?id=61559560322941' },
  { label: 'Instagram', href: 'https://www.instagram.com/kiwi_web_design/' },
  { label: 'TikTok',    href: 'https://www.tiktok.com/@kiwi_web_design' },
  { label: 'YouTube',   href: 'https://www.youtube.com/@Kiwiwebdesign' },
  { label: 'LinkedIn',  href: 'https://www.linkedin.com/company/108270459/' },
];
---

<footer>
  <div class="container footer-grid">

    <!-- Col 1: Brand -->
    <div class="col-brand">
      <a href="/" aria-label="Kiwi Web Design – home">
        <img
          src="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/04/android-chrome-512x512-1.png"
          alt="Kiwi Web Design"
          width="60"
          height="60"
          loading="lazy"
        />
      </a>
      <p class="tagline">Websites built to generate leads.</p>
      <p class="location">Auckland, New Zealand</p>
      <div class="social-links">
        {social.map(({ label, href }) => (
          <a href={href} target="_blank" rel="noopener noreferrer" aria-label={label}>
            {label}
          </a>
        ))}
      </div>
    </div>

    <!-- Col 2: Services -->
    <div>
      <h3>Services</h3>
      <ul>
        {services.map(({ label, href }) => (
          <li><a href={href}>{label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Col 3: Company -->
    <div>
      <h3>Company</h3>
      <ul>
        {company.map(({ label, href }) => (
          <li><a href={href}>{label}</a></li>
        ))}
      </ul>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>&copy; {year} Kiwi Web Design. All rights reserved.</p>
      <a href="/privacy-policy/">Privacy Policy</a>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--kwd-dark);
    color: var(--kwd-white);
    padding: 4rem 0 0;
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
  }

  .col-brand img {
    display: block;
    border-radius: 8px;
    margin-bottom: 1rem;
  }

  .tagline {
    font-size: 1rem;
    font-weight: 500;
    color: var(--kwd-cream);
    margin: 0 0 0.25rem;
  }

  .location {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0 0 1.25rem;
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .social-links a {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.8rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .social-links a:hover {
    color: var(--kwd-yellow);
  }

  h3 {
    font-family: var(--kwd-font-body);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-yellow);
    margin: 0 0 1rem;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  ul li {
    margin-bottom: 0.6rem;
  }

  ul a {
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  ul a:hover {
    color: var(--kwd-yellow);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 0;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
  }

  .footer-bottom-inner a {
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-bottom-inner a:hover {
    color: var(--kwd-yellow);
  }

  .footer-bottom-inner p {
    margin: 0;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-bottom-inner {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
