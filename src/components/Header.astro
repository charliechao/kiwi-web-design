---
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Web Design', href: '/small-business-website-design-auckland/' },
  { label: 'SEO',        href: '/seo-auckland/' },
  { label: 'Google Ads', href: '/google-ads/' },
  { label: 'About',      href: '/about-us/' },
  { label: 'Blog',       href: '/affordable-web-design-auckland/' },
];
---

<header>
  <div class="container nav-inner">
    <a href="/" class="logo" aria-label="Kiwi Web Design – home">
      <img
        src="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/04/android-chrome-512x512-1.png"
        alt="Kiwi Web Design"
        width="48"
        height="48"
      />
    </a>

    <button class="nav-toggle" aria-label="Open navigation menu" aria-expanded="false" aria-controls="main-nav">
      <span></span><span></span><span></span>
    </button>

    <nav id="main-nav" aria-label="Main navigation">
      <ul>
        {navLinks.map(({ label, href }) => (
          <li>
            <a
              href={href}
              aria-current={currentPath === href ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
      <a href="tel:+64210396580" class="btn-phone">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12 19.79 19.79 0 0 1 1.08 3.4 2 2 0 0 1 3 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16z"/></svg>
        021 039 6580
      </a>
      <a href="/website-designer-auckland/" class="btn-cta">Get a Quote</a>
    </nav>
  </div>
</header>

<!-- Mobile floating call button -->
<a href="tel:+64210396580" class="mobile-call-btn" aria-label="Call 021 039 6580">
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12 19.79 19.79 0 0 1 1.08 3.4 2 2 0 0 1 3 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16z"/></svg>
</a>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: transparent;
    border-bottom: 2px solid transparent;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  header.scrolled {
    background: var(--kwd-dark);
    border-bottom-color: var(--kwd-yellow);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }

  .logo img {
    display: block;
    border-radius: 4px;
  }

  /* hamburger */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 28px;
    height: 20px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .nav-toggle span {
    display: block;
    height: 2px;
    background: var(--kwd-white);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }
  .nav-toggle[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }

  nav {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 2rem;
  }

  nav a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: color 0.2s;
  }

  nav a:hover,
  nav a[aria-current='page'] {
    color: var(--kwd-yellow);
  }

  .btn-phone {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255,255,255,0.85) !important;
    font-size: 0.8rem;
    font-weight: 700;
    white-space: nowrap;
    letter-spacing: 0.03em;
    transition: color 0.2s;
  }
  .btn-phone:hover { color: var(--kwd-yellow) !important; }

  .mobile-call-btn {
    display: none;
  }

  .btn-cta {
    background: var(--kwd-yellow) !important;
    color: var(--kwd-dark) !important;
    padding: 0.5rem 1.25rem;
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.8rem;
    white-space: nowrap;
    transition: background 0.2s;
  }

  .btn-cta:hover {
    background: var(--kwd-gold) !important;
    color: var(--kwd-dark) !important;
  }

  /* mobile */
  @media (max-width: 921px) {
    .btn-phone { display: none; }

    .mobile-call-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      position: fixed;
      bottom: 1.5rem;
      left: 1.5rem;
      width: 52px;
      height: 52px;
      background: var(--kwd-yellow);
      color: var(--kwd-dark);
      border-radius: 50%;
      box-shadow: 0 4px 16px rgba(0,0,0,0.25);
      z-index: 99;
      transition: background 0.2s, transform 0.15s;
    }
    .mobile-call-btn:hover {
      background: var(--kwd-gold);
      transform: scale(1.07);
    }

    .nav-toggle {
      display: flex;
    }

    nav {
      position: fixed;
      inset: 0 0 0 auto;
      width: min(300px, 80vw);
      height: 100dvh;
      background: var(--kwd-dark);
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
      padding: 5rem 2rem 2rem;
      gap: 2rem;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      border-left: 2px solid var(--kwd-yellow);
    }

    nav.is-open {
      transform: translateX(0);
    }

    ul {
      flex-direction: column;
      gap: 1.25rem;
    }

    nav a {
      font-size: 1rem;
    }
  }
</style>

<script>
  const header = document.querySelector('header') as HTMLElement;

  // Transparent → solid on scroll
  const onScroll = () => header.classList.toggle('scrolled', window.scrollY > 20);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll(); // set correct state on page load

  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
  const nav = document.querySelector('#main-nav') as HTMLElement;

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    nav.classList.toggle('is-open', !expanded);
  });

  // Close nav when a link is clicked (mobile)
  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      nav.classList.remove('is-open');
    });
  });
</script>
