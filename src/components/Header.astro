---
const currentPath = Astro.url.pathname;
const isZh = currentPath.startsWith('/zh');

// Page-aware language switcher: maps each EN page to its ZH counterpart
const zhMap: Record<string, string> = {
  '/':                                          '/zh/',
  '/about-us/':                                 '/zh/about-us/',
  '/affordable-seo-auckland/':                  '/zh/seo-auckland/',
  '/ai-seo-for-auckland-small-businesses/':     '/zh/ai-seo-for-auckland-small-businesses/',
  '/local-seo-for-auckland-small-businesses/':  '/zh/local-seo-for-auckland-small-businesses/',
  '/paid-ads/':                                 '/zh/paid-ads/',
  '/google-ads/':                               '/zh/google-ads/',
  '/meta-ads/':                                 '/zh/meta-ads/',
  '/small-business-website-design-auckland/':   '/zh/small-business-website-design-auckland/',
  '/website-designer-auckland/':                '/zh/website-designer-auckland/',
  '/affordable-web-design-auckland/website-cost-new-zealand-small-business/': '/zh/website-cost-new-zealand-small-business/',
};
const enMap = Object.fromEntries(Object.entries(zhMap).map(([en, zh]) => [zh, en]));
const langSwitchHref = isZh ? (enMap[currentPath] ?? '/') : (zhMap[currentPath] ?? '/zh/');

const enNavLinks = [
  { label: 'Web Design', href: '/' },
  { label: 'SEO',        href: '/affordable-seo-auckland/' },
  { label: 'Google Ads', href: '/google-ads/' },
  { label: 'About',      href: '/about-us/' },
  { label: 'Blog',       href: '/affordable-web-design-auckland/' },
  { label: '中文',        href: langSwitchHref },
];

const zhNavLinks = [
  { label: '网页设计',   href: '/zh/small-business-website-design-auckland/', children: [
    { label: '费用计算器', href: '/zh/website-cost-new-zealand-small-business/' },
  ]},
  { label: 'SEO优化',    href: '/zh/seo-auckland/' },
  { label: 'Google广告', href: '/zh/google-ads/' },
  { label: '关于我们',   href: '/zh/about-us/' },
  { label: '博客',       href: '/affordable-web-design-auckland/' },
  { label: 'EN',         href: langSwitchHref },
];

const navLinks = isZh ? zhNavLinks : enNavLinks;
const ctaHref  = isZh ? '/zh/website-designer-auckland/' : '/website-designer-auckland/';
const ctaLabel = isZh ? '免费咨询' : 'Get a Quote';
const logoHref = isZh ? '/zh/' : '/';
---

<header>
  <div class="container nav-inner">
    <a href={logoHref} class="logo" aria-label="Kiwi Web Design – home">
      <img
        src="/logo-96.webp"
        alt="Kiwi Web Design"
        width="48"
        height="48"
        fetchpriority="high"
        decoding="async"
      />
    </a>

    <button class="nav-toggle" aria-label="Open navigation menu" aria-expanded="false" aria-controls="main-nav">
      <span></span><span></span><span></span>
    </button>

    <nav id="main-nav" aria-label="Main navigation">
      <ul>
        {navLinks.map(({ label, href, children }) => (
          <li class:list={[children && 'has-dropdown']}>
            <a
              href={href}
              aria-current={currentPath === href ? 'page' : undefined}
            >
              {label}
              {children && <svg class="dd-chevron" xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>}
            </a>
            {children && (
              <ul class="dropdown">
                {children.map((child: {label: string; href: string}) => (
                  <li>
                    <a
                      href={child.href}
                      aria-current={currentPath === child.href ? 'page' : undefined}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
      <a href="tel:+64210396580" class="btn-phone">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12 19.79 19.79 0 0 1 1.08 3.4 2 2 0 0 1 3 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16z"/></svg>
        021 039 6580
      </a>
      <a href={ctaHref} class="btn-cta">{ctaLabel}</a>
    </nav>
  </div>
</header>

<!-- Mobile floating call button -->
<a href="tel:+64210396580" class="mobile-call-btn" aria-label="Call 021 039 6580">
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12 19.79 19.79 0 0 1 1.08 3.4 2 2 0 0 1 3 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16z"/></svg>
</a>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: transparent;
    border-bottom: 2px solid transparent;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  header.scrolled {
    background: var(--kwd-dark);
    border-bottom-color: var(--kwd-yellow);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }

  .logo img {
    display: block;
    border-radius: 4px;
  }

  /* hamburger */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 28px;
    height: 20px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .nav-toggle span {
    display: block;
    height: 2px;
    background: var(--kwd-white);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }
  .nav-toggle[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }

  nav {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 2rem;
  }

  nav a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: color 0.2s;
  }

  nav a:hover,
  nav a[aria-current='page'] {
    color: var(--kwd-yellow);
  }

  .btn-phone {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255,255,255,0.85) !important;
    font-size: 0.8rem;
    font-weight: 700;
    white-space: nowrap;
    letter-spacing: 0.03em;
    transition: color 0.2s;
  }
  .btn-phone:hover { color: var(--kwd-yellow) !important; }

  .mobile-call-btn {
    display: none;
  }

  .btn-cta {
    background: var(--kwd-yellow) !important;
    color: var(--kwd-dark) !important;
    padding: 0.5rem 1.25rem;
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.8rem;
    white-space: nowrap;
    transition: background 0.2s;
  }

  .btn-cta:hover {
    background: var(--kwd-gold) !important;
    color: var(--kwd-dark) !important;
  }

  /* dropdown */
  .has-dropdown {
    position: relative;
  }
  .has-dropdown > a {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .dd-chevron {
    transition: transform 0.2s;
    flex-shrink: 0;
  }
  .has-dropdown:hover .dd-chevron {
    transform: rotate(180deg);
  }
  .dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    min-width: 200px;
    background: var(--kwd-dark);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 0.5rem 0;
    margin-top: 0.75rem;
    flex-direction: column;
    gap: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s, visibility 0.2s;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .has-dropdown:hover .dropdown {
    opacity: 1;
    visibility: visible;
  }
  .dropdown li {
    margin: 0;
  }
  .dropdown a {
    display: block;
    padding: 0.5rem 1.25rem;
    font-size: 0.78rem !important;
    text-transform: none !important;
    letter-spacing: 0.01em !important;
    white-space: nowrap;
    color: rgba(255,255,255,0.7) !important;
    transition: background 0.15s, color 0.15s;
  }
  .dropdown a:hover {
    background: rgba(255,255,255,0.06);
    color: var(--kwd-yellow) !important;
  }

  /* mobile */
  @media (max-width: 921px) {
    .btn-phone { display: none; }

    .mobile-call-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      position: fixed;
      bottom: 1.5rem;
      left: 1.5rem;
      width: 52px;
      height: 52px;
      background: var(--kwd-yellow);
      color: var(--kwd-dark);
      border-radius: 50%;
      box-shadow: 0 4px 16px rgba(0,0,0,0.25);
      z-index: 99;
      transition: background 0.2s, transform 0.15s;
    }
    .mobile-call-btn:hover {
      background: var(--kwd-gold);
      transform: scale(1.07);
    }

    .nav-toggle {
      display: flex;
    }

    nav {
      position: fixed;
      inset: 0 0 0 auto;
      width: min(300px, 80vw);
      height: 100dvh;
      background: var(--kwd-dark);
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
      padding: 5rem 2rem 2rem;
      gap: 2rem;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      border-left: 2px solid var(--kwd-yellow);
    }

    nav.is-open {
      transform: translateX(0);
    }

    ul {
      flex-direction: column;
      gap: 1.25rem;
    }

    nav a {
      font-size: 1rem;
    }

    .dropdown {
      position: static;
      transform: none;
      min-width: 0;
      background: transparent;
      border: none;
      border-radius: 0;
      padding: 0.5rem 0 0 1rem;
      margin-top: 0.5rem;
      opacity: 1;
      visibility: visible;
      box-shadow: none;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .dropdown a {
      padding: 0 !important;
      font-size: 0.9rem !important;
    }
    .dd-chevron { display: none; }
  }
</style>

<script>
  const header = document.querySelector('header') as HTMLElement;

  // Transparent → solid on scroll
  const onScroll = () => header.classList.toggle('scrolled', window.scrollY > 20);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll(); // set correct state on page load

  const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement;
  const nav = document.querySelector('#main-nav') as HTMLElement;

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    nav.classList.toggle('is-open', !expanded);
  });

  // Close nav when a link is clicked (mobile)
  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      nav.classList.remove('is-open');
    });
  });
</script>
