---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/privacy-policy/",
      "url": "https://www.kiwiwebdesign.co.nz/privacy-policy/",
      "name": "Privacy Policy | Kiwi Web Design",
      "description": "Learn how Kiwi Web Design protects your data. Our privacy policy explains what information we collect, how we use it, and your rights under the NZ Privacy Act 2020.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/privacy-policy/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/privacy-policy/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Privacy Policy" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/04/android-chrome-512x512-1.png"
      }
    }
  ]
};
---

<Layout
  title="Privacy Policy | Kiwi Web Design"
  description="Learn how Kiwi Web Design protects your data. Our privacy policy explains what information we collect, how we use it, and your rights under the NZ Privacy Act 2020."
  canonicalURL="https://www.kiwiwebdesign.co.nz/privacy-policy/"
  schema={schema}
>

  <div class="policy-wrap">

    <header class="policy-header">
      <nav class="policy-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true"> / </span>
        <span aria-current="page">Privacy Policy</span>
      </nav>
      <h1>Privacy Policy</h1>
      <p class="policy-last-updated">Last updated: October 2025</p>
    </header>

    <div class="policy-body">

      <p>At <strong>Kiwi Web Design</strong>, we respect your privacy and are committed to protecting your personal information. This Privacy Policy explains how we collect, use, store, and disclose your personal information in accordance with the <a href="https://www.legislation.govt.nz/act/public/2020/0031/latest/LMS23223.html" target="_blank" rel="noopener noreferrer"><strong>New Zealand Privacy Act 2020</strong></a>.</p>

      <hr />

      <h2>1. Information We Collect</h2>
      <p>We may collect the following types of personal information when you interact with us:</p>
      <ul>
        <li>Name, phone number, and email address (e.g. via our contact form or lead forms).</li>
        <li>Business details (such as company name, website, or service requirements).</li>
        <li>Any other information you choose to provide when communicating with us.</li>
      </ul>
      <p>We also use website analytics tools (such as Google Analytics) that collect non-identifiable information such as pages visited, time spent on site, and browser type.</p>

      <hr />

      <h2>2. How We Use Your Information</h2>
      <p>We use your personal information to:</p>
      <ul>
        <li>Respond to your enquiries and provide web design services.</li>
        <li>Send you proposals, invoices, and updates about your project.</li>
        <li>Improve our website, marketing, and customer experience.</li>
        <li>Communicate with you about new services or promotions (you can opt out anytime).</li>
      </ul>
      <p>We do <strong>not</strong> sell, rent, or trade your personal information to third parties.</p>

      <hr />

      <h2>3. Storage &amp; Security</h2>
      <p>We take reasonable steps to keep your personal information safe from misuse, loss, and unauthorised access. Information is stored securely in electronic form, with restricted access to authorised personnel only.</p>

      <hr />

      <h2>4. Disclosure</h2>
      <p>We may share your personal information with trusted service providers who help us deliver our services (e.g. hosting providers, contractors). In rare cases, we may also be required by law to disclose your information.</p>

      <hr />

      <h2>5. Your Rights</h2>
      <p>Under the <a href="https://www.privacy.org.nz/privacy-principles/" target="_blank" rel="noopener noreferrer"><strong>NZ Privacy Act 2020</strong></a>, you have the right to:</p>
      <ul>
        <li>Access the personal information we hold about you.</li>
        <li>Request correction of any incorrect or outdated information.</li>
      </ul>
      <p>To exercise these rights, please <a href="/work-with-us/">contact us</a>.</p>

      <hr />

      <h2>6. Contact</h2>
      <p>If you have questions about this Privacy Policy or how we handle your personal information, get in touch:</p>
      <p>
        <strong>Kiwi Web Design</strong><br />
        Auckland, New Zealand<br />
        <a href="/work-with-us/">Contact us here</a>
      </p>

    </div>

  </div>

</Layout>

<style>
  .policy-wrap {
    max-width: 780px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 5rem;
  }

  .policy-breadcrumb {
    font-size: 0.8rem;
    color: var(--kwd-brown);
    margin-bottom: 1.5rem;
  }
  .policy-breadcrumb a {
    color: var(--kwd-brown);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .policy-breadcrumb a:hover { color: var(--kwd-dark); }

  .policy-header {
    border-bottom: 2px solid rgba(0,0,0,0.08);
    padding-bottom: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .policy-header h1 {
    font-family: var(--kwd-font-heading);
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    color: var(--kwd-dark);
    line-height: 1.15;
    margin: 0 0 0.5rem;
  }
  .policy-last-updated {
    font-size: 0.82rem;
    color: var(--kwd-brown);
    margin: 0;
  }

  /* Body prose */
  .policy-body p {
    font-size: 0.9375rem;
    color: #333;
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .policy-body ul {
    padding-left: 1.4rem;
    margin: 0.25rem 0 1rem;
    list-style: disc;
  }
  .policy-body li {
    font-size: 0.9375rem;
    color: #333;
    line-height: 1.75;
    margin-bottom: 0.4rem;
  }
  .policy-body hr {
    border: none;
    border-top: 1px solid rgba(0,0,0,0.1);
    margin: 2rem 0;
  }
  .policy-body h2 {
    font-family: var(--kwd-font-heading);
    font-size: 1.35rem;
    color: var(--kwd-dark);
    border-left: 4px solid var(--kwd-yellow);
    padding-left: 0.75rem;
    margin: 2rem 0 0.75rem;
    line-height: 1.3;
  }
  .policy-body a {
    color: var(--kwd-dark);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .policy-body a:hover { color: var(--kwd-brown); }
  .policy-body strong { color: var(--kwd-dark); }
</style>
