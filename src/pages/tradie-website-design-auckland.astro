---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import StatsRow from '../components/StatsRow.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/tradie-website-design-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/tradie-website-design-auckland/",
      "name": "Tradie Website Design Auckland | Websites for NZ Tradies",
      "description": "Kiwi Web Design builds affordable websites for Auckland tradies including plumbers and builder. Packages start from $1290 and free consults.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/tradie-website-design-auckland/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/tradie-website-design-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Tradie Website Design" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const stats = [
  { number: "70%", label: "of people research a tradie online before calling" },
  { number: "82%", label: "of local mobile searches lead to a same-day contact" },
  { number: "From $1,290", label: "Tradie website packages" },
  { number: "2–3 wks", label: "Typical delivery time" },
];

const features = [
  {
    icon: "📞",
    title: "Click-to-Call Front and Centre",
    desc: "Your phone number is the most important element on a tradie site. We make it visible on every page, every device — so customers can call with one tap.",
    items: ["Sticky call button on mobile", "Header phone number", "Contact form backup", "Google call tracking"],
  },
  {
    icon: "🗺️",
    title: "Local SEO Built In",
    desc: "Google Maps, local search, and suburb-level landing pages to make sure you show up when someone searches 'plumber Grey Lynn' or 'electrician Remuera'.",
    items: ["Google Business Profile setup", "Local keyword targeting", "Suburb landing pages", "Maps embed"],
  },
  {
    icon: "⭐",
    title: "Reviews & Social Proof",
    desc: "Your Google reviews are your best sales tool. We display them prominently, make it easy for new customers to leave reviews, and build your reputation page by page.",
    items: ["Google review display", "Review request strategy", "Trust badges", "Before/after galleries"],
  },
  {
    icon: "🖼️",
    title: "Work Portfolio Gallery",
    desc: "Show don't tell. A gallery of your completed jobs — kitchens, decks, driveways, fit-outs — builds confidence in your workmanship before the first conversation.",
    items: ["Before & after photos", "Project case studies", "Service area images", "Mobile-optimised gallery"],
  },
  {
    icon: "📋",
    title: "Service Pages That Rank",
    desc: "Dedicated pages for each service you offer — each optimised for the search terms your customers use. More pages = more chances to rank = more enquiries.",
    items: ["Individual service pages", "Keyword-targeted content", "Schema markup", "Internal linking"],
  },
  {
    icon: "⚡",
    title: "Fast Load on Mobile",
    desc: "Most of your customers are searching on their phone on a jobsite. A slow site means lost leads. We build for mobile-first performance as a non-negotiable.",
    items: ["Sub-2 second load time", "Compressed images", "Mobile-first layout", "Core Web Vitals"],
  },
];

const trades = [
  { icon: "🔧", label: "Plumbers" },
  { icon: "⚡", label: "Electricians" },
  { icon: "🏗️", label: "Builders" },
  { icon: "🎨", label: "Painters" },
  { icon: "🌿", label: "Landscapers" },
  { icon: "❄️", label: "HVAC / Heat Pumps" },
  { icon: "🪟", label: "Glaziers" },
  { icon: "🚿", label: "Gasfitters" },
  { icon: "🔩", label: "Roofers" },
  { icon: "🏠", label: "Renovators" },
  { icon: "🧹", label: "Cleaners" },
  { icon: "🛡️", label: "Pest Control" },
];

const process = [
  { step: "1", title: "Free Discovery Call", desc: "We talk about your trade, your service area, and the types of jobs you want more of. No generic templates — we build around your specific business." },
  { step: "2", title: "Site Structure & Plan", desc: "We map out your pages: home, services (one per trade), about, reviews, and contact. You approve the structure before we design anything." },
  { step: "3", title: "Design, Build & Review", desc: "Built on WordPress, designed around your brand colours and logo. You get a staging link to review and request changes before go-live." },
  { step: "4", title: "Launch & Setup", desc: "We go live, set up Google Analytics, Google Search Console, and your Google Business Profile — and walk you through how to update it yourself." },
];

const faqs = [
  { q: "Do tradies really need a website in 2025?", a: "Yes — more than ever. 70% of homeowners research a tradie online before calling. Without a website, you're invisible to that majority. A Facebook page isn't enough — Google doesn't show Facebook pages in local search results the way it shows websites. See our <a href=\"/small-business-website-design-auckland/\">tradie web design packages</a> to get started." },
  { q: "How is a tradie website different from a standard business website?", a: "A tradie site is built around calls and quote requests. The phone number is front and centre, there's a gallery of completed work, individual service pages for each trade type, and <a href=\"/local-seo-for-auckland-small-businesses/\">local SEO</a> targeting the suburbs you work in. It's a lead machine, not a brochure." },
  { q: "What photos do I need to provide?", a: "Before and after photos of your work are ideal. We can also source stock imagery as a placeholder while you build up your own photo library. We'll advise you on the best shots to take on your phone — it doesn't need to be professional photography. Your site is built on <a href=\"/wordpress-maintenance-auckland/\">WordPress</a> so you can add photos yourself once live." },
  { q: "Can you include a quote request form?", a: "Yes. Every tradie site we build includes a contact form with fields relevant to your trade (job type, address, preferred timeframe). We can also set up email notifications so you're alerted immediately when a new enquiry comes in. For service businesses that need scheduling, we can also integrate <a href=\"/booking-appointment-websites-with-wordpress/\">appointment booking</a>." },
  { q: "Do you handle Google Business Profile too?", a: "We include a basic Google Business Profile setup with every website build. For ongoing GBP management (weekly posts, review responses, Q&A), that's available as part of our <a href=\"/local-seo-for-auckland-small-businesses/\">local SEO service</a>." },
  { q: "How much does a tradie website cost?", a: "Our <a href=\"/small-business-website-design-auckland/\">tradie packages</a> start from $1,290 + GST for a 5-page website. A typical tradie site with a home page, 3–4 service pages, gallery, and contact page runs $1,290–$1,990 + GST. We give you a fixed quote before we start. You can also add <a href=\"/google-ads/\">Google Ads</a> to generate immediate leads while your SEO builds." },
];
---

<Layout
  title="Tradie Website Design Auckland | Websites for NZ Tradies"
  description="Kiwi Web Design builds affordable websites for Auckland tradies including plumbers and builder. Packages start from $1290 and free consults."
  canonicalURL="https://www.kiwiwebdesign.co.nz/tradie-website-design-auckland/"
  schema={schema}
>

  <PageHero
    eyebrow="Tradie Website Design Auckland"
    title="Get your phone ringing with a website that works."
    subtitle="Affordable WordPress websites built specifically for Auckland tradies. Click-to-call, local SEO, work galleries, and quote forms — everything a trade business needs to win more jobs."
    badgeText="From $1,290 + GST"
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See What's Included", href: "#features" }}
    imgSrc="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/09/pexels-photo-1396122-1396122.jpg"
    imgAlt="Tradie website design Auckland"
  />

  <StatsRow items={stats} />

  <!-- Trades served -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="Trades We Work With"
        title="We've built websites for these trades — and more."
        light={true}
      />
      <div class="tradie-trades">
        {trades.map(({ icon, label }) => (
          <div class="tradie-trade-pill">
            <span>{icon}</span>
            <span>{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section" id="features">
    <div class="container">
      <SectionHeader
        eyebrow="Built for Tradies"
        title="Everything a trade business needs to generate leads."
        subtitle="We don't use generic templates. Tradie websites have specific requirements — and we've built them all in from day one."
      />
      <ServiceGrid items={features} cols={3} />
    </div>
  </section>

  <!-- Why tradies need a site -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <div class="tradie-why-grid">
        <div class="tradie-why-text">
          <p class="tradie-eyebrow">Why It Matters</p>
          <h2>Your competitors are online. Are you?</h2>
          <p>The days of word-of-mouth alone are over. When a pipe bursts at 9pm, the homeowner searches Google. When someone wants a new deck quote, they compare three websites before calling. Without a professional website, you're not in the running.</p>
          <p>A well-built tradie website doesn't just look good — it actively generates enquiries. The right structure, the right keywords, click-to-call, and a gallery of your work can mean the difference between a full diary and a quiet week.</p>
          <a href="/website-designer-auckland/" class="tradie-cta-link">Book a free consult →</a>
        </div>
        <div class="tradie-why-cards">
          <div class="tradie-why-card">
            <span class="twc-icon">📱</span>
            <h3>Most searches happen on mobile</h3>
            <p>Over 60% of tradie searches happen on a mobile device. We build mobile-first so your phone number is always one tap away.</p>
          </div>
          <div class="tradie-why-card">
            <span class="twc-icon">🗺️</span>
            <h3>Google Maps drives local calls</h3>
            <p>Appearing in the Google Maps 3-Pack for your suburb dramatically increases the volume of inbound calls — and we optimise for exactly that.</p>
          </div>
          <div class="tradie-why-card">
            <span class="twc-icon">💬</span>
            <h3>Reviews win the job</h3>
            <p>Customers compare reviews before calling. A professional site displaying your Google reviews builds the trust that turns searches into enquiries.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="From brief to live in 2–3 weeks."
        light={true}
        subtitle="A clear process so you always know what's happening — and can get back to the tools."
      />
      <ProcessSteps items={process} dark={true} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Tradie Website Questions Answered"
        subtitle="Common questions from Auckland tradies before getting started."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design Packages</a>
        <a href="/local-seo-for-auckland-small-businesses/" class="rps-link">Local SEO</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
        <a href="/wordpress-maintenance-auckland/" class="rps-link">WordPress Maintenance</a>
        <a href="/booking-appointment-websites-with-wordpress/" class="rps-link">Booking Websites</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to get your phone ringing?"
    subtitle="Free consultation — we'll plan your tradie site, give you a fixed quote, and have it live in 2–3 weeks."
    ctaPrimary={{ text: "Book a Free Consult", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "View Pricing", href: "/small-business-website-design-auckland/#packages" }}
  />

</Layout>

<style>
  .tradie-trades {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
    justify-content: center;
  }
  .tradie-trade-pill {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 100px;
    padding: 0.5rem 1.1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
  }

  .tradie-why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .tradie-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-brown);
    margin-bottom: 0.75rem;
  }
  .tradie-why-text h2 { font-size: clamp(1.6rem, 3vw, 2.25rem); margin-bottom: 1rem; }
  .tradie-why-text p { font-size: 0.95rem; color: var(--kwd-brown); line-height: 1.7; margin-bottom: 0.75rem; }
  .tradie-cta-link { font-size: 0.9rem; font-weight: 700; color: var(--kwd-dark); text-decoration: underline; }

  .tradie-why-cards { display: flex; flex-direction: column; gap: 1rem; }
  .tradie-why-card {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 14px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .twc-icon { font-size: 1.5rem; }
  .tradie-why-card h3 { font-family: var(--kwd-font-body); font-size: 0.95rem; font-weight: 700; color: var(--kwd-dark); margin: 0; }
  .tradie-why-card p { font-size: 0.85rem; color: var(--kwd-brown); line-height: 1.6; margin: 0; }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
  @media (max-width: 860px) {
    .tradie-why-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
