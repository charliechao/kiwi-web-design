---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/east-auckland-web-design/",
      "url": "https://www.kiwiwebdesign.co.nz/east-auckland-web-design/",
      "name": "East Auckland Web Design | Websites for Howick, Botany & Pakuranga",
      "description": "Professional web design for East Auckland businesses. Serving Howick, Botany, Pakuranga, and Flat Bush. Affordable WordPress websites that generate local enquiries.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/east-auckland-web-design/#breadcrumb" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": [".loc-snippet", ".loc-hero-text"] }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/east-auckland-web-design/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "East Auckland Web Design", "item": "https://www.kiwiwebdesign.co.nz/east-auckland-web-design/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "Place", "name": "Howick, Auckland" },
        { "@type": "Place", "name": "Botany, Auckland" },
        { "@type": "Place", "name": "Pakuranga, Auckland" },
        { "@type": "Place", "name": "Flat Bush, Auckland" },
        { "@type": "Place", "name": "Bucklands Beach, Auckland" },
        { "@type": "Place", "name": "Beachlands, Auckland" },
        { "@type": "Place", "name": "East Auckland" }
      ],
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -36.8985,
        "longitude": 174.9184
      },
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "ratingCount": "50", "bestRating": "5" },
      "logo": { "@type": "ImageObject", "url": "https://www.kiwiwebdesign.co.nz/favicon.png", "width": 512, "height": 512 }
    },
    {
      "@type": "Service",
      "@id": "https://www.kiwiwebdesign.co.nz/east-auckland-web-design/#service",
      "name": "Web Design, East Auckland",
      "serviceType": "Website Design",
      "provider": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "areaServed": { "@type": "Place", "name": "East Auckland" },
      "offers": { "@type": "Offer", "price": "1290", "priceCurrency": "NZD", "priceSpecification": { "@type": "PriceSpecification", "price": "1290", "priceCurrency": "NZD", "valueAddedTaxIncluded": false } }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "East Auckland is competitive, can you help us stand out?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The East Auckland market is well-served by competition in most categories, healthcare, education, and professional services in particular. Standing out requires genuine quality content (practice area pages, service descriptions, real practitioner information) and local SEO that targets the specific suburbs your clients come from." } },
        { "@type": "Question", "name": "We run a tutoring centre in Botany. What does our website need?", "acceptedAnswer": { "@type": "Answer", "text": "East Auckland tutoring centres benefit from clearly structured subject and year-level pages, tutor credentials and bio pages, a prominent enrolment enquiry form, and parent testimonials. Google ranks tutoring businesses that have detailed, specific content about what they teach, not just a generic homepage." } },
        { "@type": "Question", "name": "Can you build a website that works for both Howick locals and wider Auckland?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We often build sites with a hybrid approach: suburb-specific landing pages for local search, alongside broader service pages that work for region-wide searches. The content and targeting are planned in the discovery phase." } },
        { "@type": "Question", "name": "Do East Auckland clients have higher design expectations?", "acceptedAnswer": { "@type": "Answer", "text": "East Auckland has one of Auckland's highest median household incomes. Clients are accustomed to quality, they notice when a website looks cheap or outdated. A professionally designed small business website signals credibility and justifies premium pricing." } },
        { "@type": "Question", "name": "How quickly can you build a website for an East Auckland business?", "acceptedAnswer": { "@type": "Answer", "text": "Most builds take 2–4 weeks. For simpler brochure sites, we can often go live in under 2 weeks. We agree on a timeline in the discovery call and stick to it." } }
      ]
    }
  ]
};

const services = [
  {
    icon: "📚",
    title: "Education & Tutoring",
    desc: "East Auckland has one of Auckland's highest concentrations of tutoring centres and educational services. Parents research thoroughly before choosing. A clean, professional website with results, qualifications, and enrolment paths builds the trust that converts.",
    items: ["Subject and level pages", "Tutor profiles", "Enrolment enquiry form", "Parent testimonials"],
  },
  {
    icon: "⚕️",
    title: "Medical, Dental & Allied Health",
    desc: "East Auckland communities are health-conscious and research-driven. Medical, dental, and allied health practices in Howick and Botany need practitioner profiles, online booking, and patient information that instils confidence.",
    items: ["Practitioner profiles", "Online appointment booking", "Patient information hub", "Healthcare SEO"],
  },
  {
    icon: "🏠",
    title: "Property & Real Estate",
    desc: "East Auckland's property market is active and well-serviced. Whether you're an agent, property manager, or building inspector, buyers and tenants in the area research online extensively before making contact.",
    items: ["Property listing integration", "Agent profiles", "Market commentary blog", "Suburb-specific content"],
  },
  {
    icon: "🍜",
    title: "Restaurants & Hospitality",
    desc: "From Botany Town Centre to Howick Village, East Auckland's restaurant scene is competitive. Online menus, reservation capability, and function enquiry pages help you fill tables from local searches.",
    items: ["HTML menu pages", "Table reservation", "Function enquiry form", "Google Business integration"],
  },
  {
    icon: "🔍",
    title: "Local SEO, East Auckland",
    desc: "East Auckland residents search by suburb, Howick, Botany, Pakuranga, Flat Bush. We build suburb-specific content that puts your business in front of the right local searchers.",
    items: ["Suburb landing pages", "Google Business Profile", "East Auckland citations", "Competitor gap analysis"],
  },
  {
    icon: "🏪",
    title: "Professional & Trade Services",
    desc: "Accountants, lawyers, and tradespeople serving East Auckland residential clients compete in a market where the quality of your website signals the quality of your work. We build sites that hold up to scrutiny.",
    items: ["Service area pages", "Credentials display", "Enquiry forms", "Review integration"],
  },
];

const areas = [
  { name: "Howick", note: "Established suburb with village character. Services, healthcare, and hospitality." },
  { name: "Botany", note: "Major retail and business hub. High-traffic location with strong service demand." },
  { name: "Pakuranga", note: "Professional and commercial centre. High concentration of services and trades." },
  { name: "Flat Bush", note: "Rapidly growing newer suburb with young families and emerging local services." },
  { name: "Bucklands & Half Moon Bay", note: "Coastal, affluent. Premium services and niche hospitality." },
  { name: "Beachlands & Maraetai", note: "Semi-rural coastal communities. Local services with growing residential base." },
];

const faqs = [
  { q: "East Auckland is competitive, can you help us stand out?", a: "Yes. The East Auckland market is well-served by competition in most categories, healthcare, education, and professional services in particular. Standing out requires a combination of genuine quality content (practice area pages, service descriptions, real practitioner information) and <a href=\"/local-seo-for-auckland-small-businesses/\">local SEO</a> that targets the specific suburbs your clients come from." },
  { q: "We run a tutoring centre in Botany. What does our website need?", a: "East Auckland tutoring centres benefit from clearly structured subject and year-level pages, tutor credentials and bio pages, a prominent enrolment enquiry form, and parent testimonials. Google ranks tutoring businesses that have detailed, specific content about what they teach, not just a generic 'we help students succeed' homepage. Our <a href=\"/small-business-website-design-auckland/\">web design packages</a> include all of this." },
  { q: "Can you build a website that works for both Howick locals and wider Auckland?", a: "Yes. We often build sites with a hybrid approach: suburb-specific landing pages for <a href=\"/local-seo-for-auckland-small-businesses/\">local search</a>, alongside broader service pages that work for region-wide searches. The content and targeting are planned in the discovery phase." },
  { q: "Do East Auckland clients have higher design expectations?", a: "East Auckland has one of Auckland's highest median household incomes. Clients are accustomed to quality, they notice when a website looks cheap or outdated. A professionally designed <a href=\"/small-business-website-design-auckland/\">small business website</a> signals credibility and justifies premium pricing. We build to that standard." },
  { q: "How quickly can you build a website for an East Auckland business?", a: "Most builds take 2–4 weeks. For simpler brochure sites, we can often go live in under 2 weeks. We agree on a timeline in the discovery call and stick to it. We also offer <a href=\"/wordpress-website-design-auckland/\">WordPress websites</a> that you can manage yourself after launch." },
];
---

<Layout
  title="East Auckland Web Design | Websites for Howick, Botany & Pakuranga"
  description="Professional web design for East Auckland businesses. Serving Howick, Botany, Pakuranga, and Flat Bush. Affordable WordPress websites that generate local enquiries."
  canonicalURL="https://www.kiwiwebdesign.co.nz/east-auckland-web-design/"
  schema={schema}
>

  <!-- Hero -->
  <section class="loc-hero">
    <div class="container">
      <div class="loc-hero-inner">
        <div class="loc-hero-text">
          <p class="loc-hero-eyebrow">East Auckland Web Design</p>
          <h1>East Auckland clients research before they call. Your website has to hold up.</h1>
          <p class="loc-hero-sub">Web design for Howick, Botany, Pakuranga, Flat Bush, and East Auckland. In one of Auckland's most well-educated catchments, a professional online presence isn't optional, it's expected.</p>
          <div class="loc-hero-btns">
            <a href="/website-designer-auckland/" class="loc-btn-primary">Get a Free Quote</a>
            <a href="/small-business-website-design-auckland/" class="loc-btn-outline">View Packages</a>
          </div>
        </div>
        <div class="loc-hero-card">
          <p class="lhc-label">Serving East Auckland</p>
          <ul class="lhc-areas">
            <li>Howick</li>
            <li>Botany</li>
            <li>Pakuranga</li>
            <li>Flat Bush</li>
            <li>Bucklands Beach</li>
            <li>Beachlands</li>
          </ul>
          <p class="lhc-note">Remote-first. In-person consultations available for East Auckland clients.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AI citability snippet -->
  <div class="loc-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> builds websites for East Auckland businesses, Howick, Botany, Pakuranga, Flat Bush, and Bucklands Beach, from <strong>$1,290 + GST</strong>. Designed for Auckland's most research-driven market: education, healthcare, and professional services. Delivered in 2–4 weeks. 4.9★ Google rating from 50+ clients.</p>
    </div>
  </div>

  <!-- East Auckland context -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="The East Auckland Market"
        title="East Auckland residents are among Auckland's most research-driven buyers."
        subtitle="High household incomes, high educational attainment, and community-oriented purchasing decisions mean East Auckland clients form opinions about your business from your website before they've had any other contact."
      />
      <div class="loc-context">
        <div class="loc-context-text">
          <p>Howick and Botany represent one of Auckland's most education-focused, family-oriented markets. Parents in this area research tutoring centres, dentists, GPs, and childcare providers with the same thoroughness they'd apply to a major purchase.</p>
          <p>That behaviour extends to most purchase and service decisions. An accountant in Howick, a physio in Pakuranga, a restaurant in Botany, each competes in a market where clients compare several options online before choosing. Your website's quality, content clarity, and user experience are direct proxies for service quality in the client's mind.</p>
          <p>We build East Auckland websites that answer the questions a discerning local client would ask, and remove every barrier to making contact.</p>
        </div>
        <div class="loc-areas-grid">
          {areas.map(({ name, note }) => (
            <div class="loc-area-card">
              <strong class="lac-name">{name}</strong>
              <p class="lac-note">{note}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Services"
        title="What East Auckland businesses need from a website."
        subtitle="Industry-specific features for the most common business types in the East Auckland market."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="East Auckland Web Design Questions"
        subtitle="What Howick, Botany, and Pakuranga businesses ask about working with us."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design</a>
        <a href="/local-seo-for-auckland-small-businesses/" class="rps-link">Local SEO</a>
        <a href="/south-auckland-web-design/" class="rps-link">South Auckland</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Build a website East Auckland clients will trust."
    subtitle="Free consultation, no obligation. Fixed-price quote within 24 hours."
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Our Process", href: "/our-process/" }}
  />

</Layout>

<style>
  .loc-hero { background: var(--kwd-dark); color: #fff; padding: 4rem 0 3.5rem; }
  .loc-hero-inner { display: grid; grid-template-columns: 1fr auto; gap: 3rem; align-items: start; }
  .loc-hero-eyebrow { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--kwd-yellow); margin: 0 0 1rem; }
  .loc-hero-text h1 { font-family: var(--kwd-font-heading); font-size: clamp(1.75rem, 3.5vw, 2.75rem); line-height: 1.18; margin: 0 0 1.1rem; color: #fff; }
  .loc-hero-sub { font-size: 1rem; color: rgba(255,255,255,0.7); line-height: 1.65; max-width: 540px; margin: 0 0 2rem; }
  .loc-hero-btns { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .loc-btn-primary { background: var(--kwd-yellow); color: var(--kwd-dark); padding: 0.75rem 1.75rem; border-radius: 6px; font-weight: 700; text-decoration: none; font-size: 0.95rem; }
  .loc-btn-outline { border: 2px solid rgba(255,255,255,0.35); color: rgba(255,255,255,0.85); padding: 0.75rem 1.75rem; border-radius: 6px; font-weight: 600; text-decoration: none; font-size: 0.95rem; }
  .loc-hero-card { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); border-radius: 16px; padding: 1.75rem; min-width: 220px; flex-shrink: 0; }
  .lhc-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-yellow); margin: 0 0 0.875rem; }
  .lhc-areas { list-style: none; padding: 0; margin: 0 0 1rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .lhc-areas li { font-size: 0.875rem; color: rgba(255,255,255,0.82); padding-left: 1.1rem; position: relative; }
  .lhc-areas li::before { content: "✓"; position: absolute; left: 0; color: var(--kwd-yellow); font-size: 0.72rem; top: 0.15rem; }
  .lhc-note { font-size: 0.72rem; color: rgba(255,255,255,0.35); margin: 0; line-height: 1.55; }
  .loc-context { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; margin-top: 2.5rem; align-items: start; }
  .loc-context-text p { font-size: 0.9rem; color: var(--kwd-brown); line-height: 1.75; margin-bottom: 0.875rem; }
  .loc-areas-grid { display: flex; flex-direction: column; gap: 0.75rem; }
  .loc-area-card { background: #fff; border: 1.5px solid rgba(0,0,0,0.07); border-radius: 10px; padding: 0.875rem 1.125rem; }
  .lac-name { font-size: 0.875rem; font-weight: 700; color: var(--kwd-dark); display: block; margin-bottom: 0.2rem; }
  .lac-note { font-size: 0.78rem; color: var(--kwd-brown); margin: 0; line-height: 1.5; }
  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
  .loc-snippet { background: #fff8e1; border-left: 4px solid var(--kwd-yellow); padding: 1rem 0; }
  .loc-snippet p { margin: 0; font-size: 0.95rem; line-height: 1.65; color: var(--kwd-dark); }
  @media (max-width: 900px) {
    .loc-hero-inner { grid-template-columns: 1fr; }
    .loc-hero-card { display: none; }
    .loc-context { grid-template-columns: 1fr; }
  }
</style>
