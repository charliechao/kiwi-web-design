---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import heroImg from '../assets/general/pexels-photo-8145247-8145247-scaled.jpg';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/analytics-reporting-for-auckland-small-business-websites/",
      "url": "https://www.kiwiwebdesign.co.nz/analytics-reporting-for-auckland-small-business-websites/",
      "name": "Website Analytics & Reporting Auckland | Kiwi Web Design",
      "description": "GA4 and Google Search Console set up, conversion tracking, and monthly reporting for Auckland small businesses. Know exactly what your website is doing.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/analytics-reporting-for-auckland-small-business-websites/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/analytics-reporting-for-auckland-small-business-websites/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Website Analytics & Reporting Auckland" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const services = [
  {
    icon: "📊",
    title: "GA4 Setup & Configuration",
    desc: "Google Analytics 4 installed and configured correctly — with events, goals, and conversion tracking set up so you're capturing the data that actually matters to your business.",
    items: ["GA4 property setup", "Event configuration", "Goal & conversion tracking", "Cross-device tracking"],
  },
  {
    icon: "🔍",
    title: "Google Search Console",
    desc: "Search Console connected, sitemap submitted, and coverage issues resolved. See exactly which search queries are bringing people to your site — and which pages are underperforming.",
    items: ["Property verification", "Sitemap submission", "Coverage error fixes", "Search query analysis"],
  },
  {
    icon: "📞",
    title: "Conversion Tracking",
    desc: "Track what matters: form submissions, phone call clicks, quote requests, bookings, and purchases. Know which traffic sources are actually generating leads.",
    items: ["Form submission tracking", "Phone click tracking", "Button & CTA tracking", "eCommerce conversion setup"],
  },
  {
    icon: "📋",
    title: "Monthly Reporting",
    desc: "A plain-English monthly report covering traffic, top pages, search queries, conversions, and any changes worth noting. No jargon, no dashboards to figure out — just the key numbers.",
    items: ["Traffic overview", "Top performing pages", "Keyword & query data", "Conversion summary"],
  },
  {
    icon: "🔗",
    title: "Campaign Tracking",
    desc: "UTM parameters configured for all your campaigns — Google Ads, social media, email — so you can see exactly which channels are driving leads and at what cost.",
    items: ["UTM setup & templates", "Google Ads linking", "Campaign attribution", "Source/medium reporting"],
  },
  {
    icon: "⚡",
    title: "Analytics Audits",
    desc: "Already have analytics set up but not sure if it's working properly? We audit your existing setup, find tracking gaps, and fix anything that's recording incorrectly.",
    items: ["Existing GA4 audit", "Duplicate tracking check", "Data accuracy review", "Tag Manager audit"],
  },
];

const faqs = [
  { q: "Do I need analytics if I already have a website?", a: "Yes — without analytics, you're flying blind. You won't know how many people visit your site, where they come from, which pages they read, or whether they're converting into enquiries. Analytics is the foundation of any data-driven marketing decision." },
  { q: "What's the difference between GA4 and Google Search Console?", a: "GA4 measures what happens on your website — how many visitors, which pages they read, how long they stay, and whether they complete goals like filling out a form. Google Search Console measures how your site appears in Google search results — which keywords you rank for, how many impressions and clicks you get, and any indexing issues. Both are essential and both are free." },
  { q: "Is GA4 hard to understand?", a: "The raw GA4 interface can be confusing if you're not familiar with it. That's why we send a simplified monthly report that pulls out the most important numbers — traffic, top pages, conversions, and search queries — in a format that's easy to read and act on." },
  { q: "Can you set up analytics on a site you didn't build?", a: "Yes. We can install and configure GA4, Search Console, and conversion tracking on any website — <a href=\"/wordpress-website-design-auckland/\">WordPress</a>, <a href=\"/shopify-website-design-auckland/\">Shopify</a>, Squarespace, or custom-built. We just need access to the site's admin or codebase." },
  { q: "How do I know if my tracking is working correctly?", a: "We verify every tracking setup by testing all conversions manually before signing off. If you already have tracking in place, our audit checks for duplicate pageviews, missing goals, incorrect filters, and other common problems that corrupt your data." },
];
---

<Layout
  title="Website Analytics & Reporting Auckland | Kiwi Web Design"
  description="GA4 and Google Search Console set up, conversion tracking, and monthly reporting for Auckland small businesses. Know exactly what your website is doing."
  canonicalURL="https://www.kiwiwebdesign.co.nz/analytics-reporting-for-auckland-small-business-websites/"
  schema={schema}
>

  <PageHero
    eyebrow="Analytics & Reporting"
    title="Know exactly what your website is doing — and why."
    subtitle="GA4 setup, conversion tracking, Google Search Console, and monthly plain-English reporting for Auckland small businesses. Stop guessing, start deciding."
    imgSrc={heroImg.src}
    imgAlt="Website analytics dashboard for Auckland small business"
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View SEO Services", href: "/seo-auckland/" }}
  />

  <!-- Services -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="What We Set Up"
        title="Everything you need to measure what matters."
        subtitle="From basic traffic tracking to full conversion attribution — we set it up once and it runs forever."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- Why it matters -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <SectionHeader
        eyebrow="Why Analytics Matter"
        title="You can't improve what you can't measure."
        align="left"
      />
      <div class="analytics-body">
        <p>Most Auckland small business websites have analytics installed but not properly configured. GA4 fires a script, records some pageviews, and that's it — no goals, no conversion tracking, no idea which contact form submissions actually came from organic search versus a Facebook ad.</p>
        <p>Proper analytics setup means you know: which pages generate the most enquiries, which traffic source delivers the highest-quality leads, which blog posts are bringing in organic search traffic, and whether that <a href="/seo-auckland/">SEO</a> or <a href="/google-ads/">Google Ads</a> investment is actually working.</p>
        <p>We set up the full stack — GA4 with proper conversion events, Google Search Console connected and verified, campaign UTMs configured — and then send you a simple monthly report covering the numbers you need to make decisions.</p>
        <ul class="analytics-checklist">
          <li>Works with any website — WordPress, Shopify, or custom</li>
          <li>Monthly plain-English report included</li>
          <li>All tracking verified before handover</li>
          <li>Can integrate with Google Ads for full attribution</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Analytics Questions Answered"
        subtitle="Common questions from Auckland business owners about website tracking and reporting."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/seo-auckland/" class="rps-link">SEO Services Auckland</a>
        <a href="/google-ads/" class="rps-link">Google Ads Management</a>
        <a href="/wordpress-seo-optimisation/" class="rps-link">WordPress SEO</a>
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design Packages</a>
        <a href="/wordpress-maintenance-auckland/" class="rps-link">WordPress Maintenance</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to understand your website traffic?"
    subtitle="Free consultation — we'll check your current tracking setup and show you what's missing."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View SEO Services", href: "/seo-auckland/" }}
  />

</Layout>

<style>
  .analytics-body p {
    font-size: 0.9375rem;
    color: var(--kwd-brown);
    line-height: 1.75;
    margin-bottom: 0.9rem;
  }
  .analytics-checklist {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .analytics-checklist li {
    font-size: 0.9rem;
    color: var(--kwd-dark);
    font-weight: 600;
    padding-left: 1.5rem;
    position: relative;
  }
  .analytics-checklist li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--kwd-brown);
    font-weight: 700;
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
