---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import Icon from '../components/Icon.astro';
import PageVisual from '../components/PageVisual.astro';
import faqImage from '../assets/services/kiwi-web-design-testimonials-auckland.jpg';

const categories = [
  {
    id: "pricing",
    label: "Pricing & Packages",
    icon: "💰",
    faqs: [
      { q: "How much does a website cost in Auckland?", a: "Our websites start from $1,290 + GST for a WordPress site. Growth packages run $2,690–$3,500 depending on complexity. eCommerce stores start from $3,890. We give you a fixed quote upfront, no surprises, no hidden extras." },
      { q: "What's included in the website price?", a: "Every package includes: custom WordPress design, mobile-responsive layout, contact form, basic SEO setup (meta tags, sitemap, Search Console), SSL certificate, and a handover training session. Additional services like copywriting, ongoing SEO, and hosting are quoted separately." },
      { q: "Do you charge monthly fees?", a: "Not for the website build, that's a one-off cost. After launch, you'll need <a href=\"/website-hosting-auckland/\">website hosting</a> (from $49/mo), and we recommend a <a href=\"/wordpress-maintenance-auckland/\">WordPress maintenance plan</a> (from $99/mo) to keep your site updated and secure. These are optional but strongly recommended." },
      { q: "Do you offer payment plans?", a: "We typically structure payment as 50% upfront and 50% on launch. For larger projects, we can discuss milestone-based payment structures. Get in touch to discuss what works for your situation." },
      { q: "Why are your prices lower than some other agencies?", a: "We're a lean, local team without the overhead of a large agency. We don't have account managers, project managers, and layers of process between you and the person doing the work. You pay for the output, not the structure." },
    ],
  },
  {
    id: "process",
    label: "Process & Timeline",
    icon: "📋",
    faqs: [
      { q: "How long does it take to build a website?", a: "Most projects are complete in 2–3 weeks from when we receive your content and sign-off on the brief. Complex sites with custom features or large content volumes may take 4–6 weeks. We'll give you a timeline upfront and stick to it." },
      { q: "What do I need to provide?", a: "Ideally: your logo, brand colours, text content for each page, and any photos you want to use. We help with content guidance and structure throughout, and can provide copywriting or photography sourcing as add-ons." },
      { q: "How do revisions work?", a: "Starter packages include 1 round of revisions; Growth packages include 2 rounds. A 'round' means one consolidated set of feedback after reviewing the staging site. Additional revision rounds can be arranged at our hourly rate." },
      { q: "Do you offer in-person meetings?", a: "Yes. We're based at 147 Great North Road, Grey Lynn. We're happy to meet in person anywhere in Auckland, or on a video call if that's easier. We start every project with a conversation, not a quote form." },
      { q: "What happens after my website launches?", a: "We set up Google Analytics and Search Console, submit your sitemap to Google, and walk you through how to make basic updates yourself. After that, you can manage it independently, or take up one of our maintenance and hosting plans." },
    ],
  },
  {
    id: "technical",
    label: "Technical & Platform",
    icon: "⚙️",
    faqs: [
      { q: "What platform do you build on?", a: "We primarily build on <a href=\"/wordpress-website-design-auckland/\">WordPress</a>, the world's most popular CMS, powering 43% of all websites. For eCommerce, we build on <a href=\"/woocommerce-website-design-auckland/\">WooCommerce</a> (WordPress) or <a href=\"/shopify-website-design-auckland/\">Shopify</a> depending on your requirements." },
      { q: "Will I be able to update my website myself?", a: "Yes. WordPress's block editor (Gutenberg) makes updating text, images, and pages straightforward, no technical knowledge needed. We include a handover training session with every build." },
      { q: "Can you redesign my existing website?", a: "Yes. We do full <a href=\"/wordpress-website-rebuilds-auckland/\">WordPress rebuilds and redesigns</a>, and migrations from Wix, Squarespace, old WordPress themes, and other platforms. We preserve your content and SEO during the migration." },
      { q: "Do you build Wix or Squarespace websites?", a: "No. We recommend WordPress because you own your site completely, no monthly platform fees, no lock-in, and maximum flexibility for SEO and future growth. We're happy to explain why in a free consultation." },
      { q: "Do you do custom development?", a: "Yes. We build custom WordPress plugins, WooCommerce extensions, and custom integrations. If your project requires something beyond standard WordPress capability, let's talk about what's needed." },
    ],
  },
  {
    id: "seo",
    label: "SEO & Marketing",
    icon: "🔍",
    faqs: [
      { q: "Does my website come with SEO?", a: "Every website includes basic SEO foundations, proper meta titles and descriptions, sitemap, robots.txt, heading structure, schema markup, and Search Console setup. Ongoing <a href=\"/affordable-seo-auckland/\">SEO services</a> (monthly keyword targeting, content, and link building) is a separate service." },
      { q: "How long does SEO take to work?", a: "For local and less competitive searches, you might see improvements in 4–8 weeks. For competitive industries, 3–6 months is more realistic. SEO is a long-term investment, results compound over time rather than arriving all at once." },
      { q: "Do you manage Google Ads?", a: "Yes. Our <a href=\"/google-ads/\">Google Ads management</a> includes campaign setup, keyword research, ad copy, conversion tracking, and monthly reporting. Setup from $499, management from $399/month." },
      { q: "Can you help with Google Business Profile?", a: "Yes. We include a basic GBP setup with website builds. Ongoing GBP management (posts, review responses, Q&A) is available as part of our <a href=\"/local-seo-for-auckland-small-businesses/\">local SEO service</a>. See our full <a href=\"/google-business-profile-guide-for-auckland-businesses/\">Google Business Profile guide</a> for setup tips." },
      { q: "What is local SEO and do I need it?", a: "<a href=\"/local-seo-for-auckland-small-businesses/\">Local SEO</a> is the process of appearing in Google Maps and local search results for your suburb and service area. If you serve customers in specific Auckland areas, local SEO is often the highest-ROI digital investment you can make." },
    ],
  },
  {
    id: "ai-seo",
    label: "AI SEO & GEO",
    icon: "🤖",
    faqs: [
      { q: "What is AI SEO (GEO) and do I need it?", a: "AI SEO, also called Generative Engine Optimisation (GEO), is the practice of optimising your website so AI tools like ChatGPT, Google AI Overviews, Perplexity, Gemini, and Claude cite or recommend your business. As more customers use AI to research services, appearing in AI-generated answers is becoming as important as appearing in Google search results. See our <a href=\"/ai-seo-for-auckland-small-businesses/\">AI SEO service</a> for details." },
      { q: "How is AI SEO different from regular SEO?", a: "Traditional <a href=\"/affordable-seo-auckland/\">SEO</a> focuses on ranking in Google's blue-link results. AI SEO (GEO) focuses on getting your content cited or featured in AI-generated answers from ChatGPT, Google AI Overviews, Perplexity, and similar tools. The techniques partially overlap, structured content, schema markup, authority signals, but GEO adds new layers like entity optimisation, citability structuring, and llms.txt setup." },
      { q: "How much does AI SEO cost?", a: "Our AI SEO packages start from $500/month for a foundational GEO setup (schema markup, llms.txt, Google Business Profile optimisation, AI crawler configuration, monthly reporting). Full AI SEO strategy with content production runs $1,000–$2,500/month. See our <a href=\"/ai-seo-for-auckland-small-businesses/#pricing\">AI SEO pricing</a> for a full breakdown." },
      { q: "What is llms.txt and does my website need one?", a: "llms.txt is an emerging standard, similar to robots.txt, that tells AI systems what your website does and what pages matter most. It helps AI tools like ChatGPT, Claude, and Perplexity understand and cite your site correctly. We implement llms.txt for all clients on our AI SEO plans. Most NZ agencies don't offer this yet." },
      { q: "Can you help my business get cited by ChatGPT or Google AI Overviews?", a: "Yes. AI systems draw from crawlable web content, third-party mentions, and structured data. We improve your citability through answer-first content structuring, comprehensive JSON-LD schema markup, authoritative third-party mentions, and llms.txt setup. See our full <a href=\"/ai-seo-for-auckland-small-businesses/\">AI SEO & GEO service</a>." },
    ],
  },
  {
    id: "hosting",
    label: "Hosting & Maintenance",
    icon: "🔧",
    faqs: [
      { q: "Do I need to host my website with you?", a: "No, you can host anywhere. But we strongly recommend our managed hosting for sites we've built, because we know your setup, can troubleshoot quickly, and ensure the right WordPress stack is configured." },
      { q: "What is managed WordPress hosting?", a: "Our <a href=\"/website-hosting-auckland/\">managed WordPress hosting</a> means we handle server management, WordPress updates, security monitoring, daily backups, and performance optimisation, rather than a generic shared hosting plan where you're on your own." },
      { q: "What happens if my website gets hacked?", a: "Under our Standard and Premium maintenance plans, malware removal and site restoration are covered. We respond quickly, clean the infection, and harden the site to prevent reoccurrence." },
      { q: "Do I need a maintenance plan?", a: "You don't have to have one, but we strongly recommend it. Outdated WordPress plugins are the #1 cause of website hacks. Our <a href=\"/wordpress-maintenance-auckland/\">WordPress maintenance plan</a> keeps your site updated, monitored, and backed up so you don't face an emergency." },
      { q: "Can you take over maintenance of a site you didn't build?", a: "Yes. We start with a site audit to understand what's there, identify any issues, and then bring it under our care plan. We do this regularly for clients who've had bad experiences with previous developers." },
    ],
  },
  {
    id: "ecommerce",
    label: "eCommerce",
    icon: "🛒",
    faqs: [
      { q: "WooCommerce or Shopify, which should I choose?", a: "<a href=\"/woocommerce-website-design-auckland/\">WooCommerce</a> if you want full ownership, no monthly platform fees, and the ability to scale with complex content or NZ-specific integrations. <a href=\"/shopify-website-design-auckland/\">Shopify</a> if you want the easiest possible day-to-day management and excellent multi-channel selling. We build both and will recommend based on your situation." },
      { q: "Can you set up AfterPay and Laybuy?", a: "Yes. We configure AfterPay, Laybuy, Zip, and POLi as standard for NZ eCommerce stores. Buy Now Pay Later options are popular with NZ shoppers and can meaningfully increase average order value." },
      { q: "Do your eCommerce prices include GST configuration?", a: "Yes. GST-inclusive pricing, NZ tax class setup, and automated invoice generation are all included in our eCommerce builds as standard." },
      { q: "Can you migrate my existing store to WooCommerce?", a: "Yes. We handle full migrations from Shopify, Wix eCommerce, Squarespace Commerce, and old WooCommerce installations. Products, customers, and order history are migrated where possible." },
    ],
  },
];

// Helper: strip HTML tags for schema answer text
function stripHtml(html: string): string {
  return html.replace(/<[^>]+>/g, '');
}

const allFaqs = categories.flatMap(c => c.faqs);

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/faq/",
      "url": "https://www.kiwiwebdesign.co.nz/faq/",
      "name": "FAQ, Web Design, SEO & Google Ads Auckland | Kiwi Web Design",
      "description": "Honest answers to every question about website design, SEO, AI SEO, and Google Ads in Auckland. Pricing, timelines, platform choice, and more, from Kiwi Web Design.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/faq/#breadcrumb" }
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.kiwiwebdesign.co.nz/faq/#faqpage",
      "mainEntity": allFaqs.map(({ q, a }) => ({
        "@type": "Question",
        "name": q,
        "acceptedAnswer": { "@type": "Answer", "text": stripHtml(a) }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/faq/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "FAQ", "item": "https://www.kiwiwebdesign.co.nz/faq/" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};
---

<Layout
  title="FAQ, Web Design, SEO & Google Ads Auckland | Kiwi Web Design"
  description="Honest answers to every question about website design, SEO, AI SEO, and Google Ads in Auckland. Pricing, timelines, platform choice, and more."
  canonicalURL="https://www.kiwiwebdesign.co.nz/faq/"
  schema={schema}
>

  <!-- Hero -->
  <section class="faq-page-hero hero-section">
    <div class="container faq-hero-inner">
      <p class="faq-hero-eyebrow">Help & Support</p>
      <h1>Frequently Asked Questions</h1>
      <p class="faq-hero-sub">Every common question about web design, SEO, AI SEO, pricing, and our process, answered honestly. Can't find what you need? <a href="/website-designer-auckland/">Get in touch →</a></p>

      <!-- Trust stats -->
      <div class="faq-trust-row">
        <div class="faq-trust-item"><span class="fti-num">4.9★</span><span class="fti-lbl">Google rating</span></div>
        <div class="faq-trust-sep"></div>
        <div class="faq-trust-item"><span class="fti-num">50+</span><span class="fti-lbl">NZ businesses served</span></div>
        <div class="faq-trust-sep"></div>
        <div class="faq-trust-item"><span class="fti-num">34</span><span class="fti-lbl">questions answered below</span></div>
        <div class="faq-trust-sep"></div>
        <div class="faq-trust-item"><span class="fti-num">Free</span><span class="fti-lbl">first consultation</span></div>
      </div>

      <!-- Category nav -->
      <div class="faq-cat-nav">
        {categories.map(({ id, label, icon }) => (
          <a href={`#${id}`} class="faq-cat-btn">
            <span><Icon name={icon} size={24} /></span>
            <span>{label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <PageVisual
    imgSrc={faqImage.src}
    imgAlt="Kiwi Web Design consultation and support for Auckland website questions"
    imgTitle="Web design FAQ and consultation support Auckland"
    eyebrow="Clear Answers"
    title="A calmer way to compare your options."
    caption="The FAQ page now has a visual pause before the long question list, helping visitors scan pricing, process, SEO, hosting, and AI SEO topics with more confidence."
  />

  <!-- FAQ sections -->
  <section class="section">
    <div class="container faq-page-wrap">
      {categories.map(({ id, label, icon, faqs }) => (
        <div class="faq-category" id={id}>
          <div class="faq-category-header">
            <span class="faq-cat-icon"><Icon name={icon} size={24} /></span>
            <h2 class="faq-cat-title">{label}</h2>
          </div>
          <FAQAccordion items={faqs} title="" />
        </div>
      ))}
    </div>
  </section>

  <!-- Still have questions -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container faq-still-wrap">
      <div class="faq-still-text">
        <h2>Still have questions?</h2>
        <p>We're always happy to have a conversation before you commit to anything. No pressure, no sales pitch, just honest advice about what your business needs.</p>
      </div>
      <div class="faq-still-contact">
        <a href="/website-designer-auckland/" class="faq-still-btn-primary">Book a Free Consult</a>
        <div class="faq-still-direct">
          <a href="mailto:Hi@KiwiWebDesign.co.nz">Hi@KiwiWebDesign.co.nz</a>
          <a href="tel:+64210396580">021 039 6580</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Explore our services</p>
      <div class="rps-links">
        <a href="/" class="rps-link">Web Design Auckland</a>
        <a href="/affordable-seo-auckland/" class="rps-link">SEO Services</a>
        <a href="/ai-seo-for-auckland-small-businesses/" class="rps-link">AI SEO & GEO</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
        <a href="/google-ads-budget-calculator-nz/" class="rps-link">Google Ads Budget Calculator</a>
        <a href="/wordpress-maintenance-auckland/" class="rps-link">WordPress Maintenance</a>
        <a href="/website-hosting-auckland/" class="rps-link">Website Hosting</a>
        <a href="/ecommerce-website-auckland/" class="rps-link">eCommerce Websites</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to get started?"
    subtitle="Free consultation, in person in Grey Lynn or on a video call. We'll answer all your questions and give you a fixed quote."
    ctaPrimary={{ text: "Book a Free Consult", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Our Services", href: "/solutions-auckland-kiwi-web-design/" }}
  />

</Layout>

<style>
  /* Hero */
  .faq-page-hero {
    background: var(--kwd-dark);
    padding: 5rem 0 4rem;
  }
  .faq-hero-inner { max-width: 780px; margin-inline: auto; text-align: center; }
  .faq-hero-eyebrow {
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--kwd-yellow); margin-bottom: 1rem;
  }
  .faq-page-hero h1 { font-size: clamp(2.25rem, 5vw, 3.75rem); color: #fff; line-height: 1.1; margin-bottom: 1rem; }
  .faq-hero-sub { font-size: 1rem; color: rgba(255,255,255,0.65); line-height: 1.7; margin-bottom: 2rem; }
  .faq-hero-sub a { color: var(--kwd-yellow); font-weight: 600; }

  /* Trust stats row */
  .faq-trust-row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding: 1.25rem 1.5rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
  }
  .faq-trust-item { display: flex; flex-direction: column; align-items: center; gap: 0.15rem; }
  .fti-num { font-family: var(--kwd-font-heading); font-size: 1.4rem; color: var(--kwd-yellow); line-height: 1; }
  .fti-lbl { font-size: 0.72rem; color: rgba(255,255,255,0.5); white-space: nowrap; }
  .faq-trust-sep { width: 1px; height: 2rem; background: rgba(255,255,255,0.12); flex-shrink: 0; }

  /* Category nav */
  .faq-cat-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
  }
  .faq-cat-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 100px;
    padding: 0.5rem 1rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: rgba(255,255,255,0.8);
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    text-decoration: none;
  }
  .faq-cat-btn:hover,
  .faq-cat-btn.is-active {
    background: var(--kwd-yellow);
    border-color: var(--kwd-yellow);
    color: var(--kwd-dark);
  }

  /* FAQ sections */
  .faq-page-wrap {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    max-width: 860px;
  }
  .faq-category-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--kwd-cream);
  }
  .faq-cat-icon { }
  .faq-cat-title { font-size: clamp(1.25rem, 2vw, 1.75rem); color: var(--kwd-dark); margin: 0; }

  /* Still have questions */
  .faq-still-wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2.5rem;
    flex-wrap: wrap;
  }
  .faq-still-text h2 { font-size: clamp(1.25rem, 2vw, 1.75rem); margin-bottom: 0.5rem; }
  .faq-still-text p { font-size: 0.9rem; color: var(--kwd-brown); max-width: 480px; }
  .faq-still-contact { display: flex; flex-direction: column; gap: 0.75rem; flex-shrink: 0; }
  .faq-still-btn-primary {
    display: inline-block; background: var(--kwd-dark); color: #fff;
    padding: 0.875rem 2rem; border-radius: 8px; font-weight: 700; font-size: 0.875rem;
    text-transform: uppercase; letter-spacing: 0.07em; text-align: center;
    transition: background 0.2s;
  }
  .faq-still-btn-primary:hover { background: #3e3633; }
  .faq-still-direct { display: flex; flex-direction: column; gap: 0.25rem; }
  .faq-still-direct a { font-size: 0.875rem; font-weight: 600; color: var(--kwd-dark); transition: opacity 0.2s; }
  .faq-still-direct a:hover { opacity: 0.65; }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }

  @media (max-width: 760px) {
    .faq-still-wrap { flex-direction: column; align-items: flex-start; }
    .faq-trust-sep { display: none; }
    .faq-trust-row { gap: 1rem; }
  }
</style>

<!-- Vanta.js TOPOLOGY background for hero -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/vanta@0.5.24/dist/vanta.topology.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    VANTA.TOPOLOGY({
      el: '.hero-section',
      mouseControls: true,
      touchControls: true,
      gyroControls: false,
      minHeight: 200,
      minWidth: 200,
      scale: 1.0,
      scaleMobile: 0.75,
      color: 0xf3d97a,
      backgroundColor: 0x2c2927,
    });

    // Active category highlight on scroll
    const sections = document.querySelectorAll('.faq-category');
    const navBtns = document.querySelectorAll('.faq-cat-btn');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          navBtns.forEach(btn => {
            btn.classList.toggle('is-active', btn.getAttribute('href') === `#${entry.target.id}`);
          });
        }
      });
    }, { rootMargin: '-30% 0px -60% 0px' });
    sections.forEach(s => observer.observe(s));
  });
</script>
