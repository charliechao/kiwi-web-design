---
import Layout from '../layouts/Layout.astro';
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/faq/",
      "url": "https://www.kiwiwebdesign.co.nz/faq/",
      "name": "FAQ",
      "description": "All the questions you have about website design in Auckland. Kiwi Web Design helps you to answer them. On time, on budget and affordable.",
      "inLanguage": "en-NZ",
      "isPartOf": {
        "@id": "https://www.kiwiwebdesign.co.nz/#website"
      },
      "breadcrumb": {
        "@id": "https://www.kiwiwebdesign.co.nz/faq/#breadcrumb"
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/faq/#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://www.kiwiwebdesign.co.nz/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "FAQ"
        }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/04/android-chrome-512x512-1.png"
      }
    }
  ]
};
---
<Layout title="FAQ" description="All the questions you have about website design in Auckland. Kiwi Web Design helps you to answer them. On time, on budget and affordable." schema={schema}>
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <p class="eyebrow">Help & Support</p>
        <h1>Frequently Asked Questions — Web Design Auckland</h1>
        <p class="hero-sub">All the questions you have about website design in Auckland. Kiwi Web Design helps you to answer them. On time, on budget and affordable.</p>
        <div class="hero-btns">
          <a href="/website-designer-auckland/#contact" class="btn-primary">Book Free Consultation</a>
          <a href="/small-business-website-design-auckland/#packages" class="btn-outline">View Packages</a>
        </div>
      </div>
      <div class="hero-img">
        <img src="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/10/web-design-process-kiwi-web-design-auckland.jpg" alt="Frequently Asked Questions — Web Design Auckland" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="page-content">
    <div class="prose">
<p>
 <a href="/website-design-auckland/">Auckland tradies</a>,
 <a href="/affordable-web-design-auckland/">small business</a> owners,
 and <a href="/web-designs-auckland/">eCommerce</a> teams ask us these questions all the time — here’s what you can expect when we build your site.
 </p>

<details>
 <summary>How much does a website cost in Auckland?</summary>
 
 <p>Most small business sites we build start from $1,290. eCommerce or larger sites typically range from $2,000–$3,000 depending on pages, features, and content. We’ll send a fixed, transparent quote before we start — no surprises.</p>
 
 </details>

 <details>
 <summary>How long does it take to build a website?</summary>
 
 <p>For most tradies and small business websites, our turnaround is about 2–3 weeks including design, content setup, testing, and revisions. Complex/eCommerce builds can take a little longer — we’ll give you a realistic timeline on day one.</p>
 
 </details>

 <details>
 <summary>Do you design websites for tradies?Tradies</summary>
 
 <p>Absolutely. We’ve built sites for builders, plumbers, electricians, painters, and scaffolding companies across Auckland. Pages are simple, fast, and built to get calls. See our <a href="/website-design-auckland/">Tradie Web Design page</a>.</p>
 
 </details>

 <details>
 <summary>Can you build an online store for my business?eCommerce</summary>
 
 <p>Yes — we build WordPress + WooCommerce stores so you can add products, manage orders, and take payments with ease. If you’re starting out, we’ll help with categories, product photos, and shipping rules.</p>
 
 </details>

 <details>
 <summary>Will my website show up on Google?</summary>
 
 <p>Yes. We follow <a href="https://www.google.com">Google</a>-friendly on-page best practices (fast load, clean structure, mobile-first, schema, and metadata) so your site is ready to rank from day one. We also guide your <a href="https://www.google.com">Google</a> Business Profile and basic copy to target “web design Auckland” naturally.</p>
 
 </details>

 <details>
 <summary>Do you work with small businesses only?</summary>
 
 <p>We specialise in Auckland small businesses and tradies that want a professional site without agency-level pricing. We’re nimble, local, and practical — perfect for growing companies that need results, not jargon.</p>
 
 </details>

 <details>
 <summary>Can I update my website myself later?</summary>
 
 <p>100%. We build on WordPress so you can edit text, images, services, and prices without touching code. We’ll record a quick handover or show you live how to make changes.</p>
 
 </details>

 <details>
 <summary>Do you help with domain, email, and hosting?</summary>
 
 <p>Yes. We can register your .co.nz domain, set up email, and place you on fast, reliable local hosting. Prefer to bring your own? No worries — we’ll deploy wherever you like.</p>
 
 </details>

 <details>
 <summary>Are your websites mobile-friendly?</summary>
 
 <p>Every site we build is responsive — great on phones, tablets, and desktops. With most Auckland visitors browsing on mobile, we prioritise speed, tap targets, and legible typography.</p>
 
 </details>

 <details>
 <summary>Can you redesign my old website?</summary>
 
 <p>Absolutely. We can refresh your current content with a modern layout or rebuild from scratch if that’s the better value. Expect cleaner visuals, clearer messaging, and more enquiries.</p>
 
 </details>

 <details>
 <summary>What if I don’t know what content to write?</summary>
 
 <p>We’ll guide your page structure and provide copy prompts that fit your industry. Short on time? We can help tidy your wording so it’s clear and customer-friendly.</p>
 
 </details>

 <details>
 <summary>Do you meet clients in person?Auckland-wide</summary>
 
 <p>Yes — we’re Auckland-based and can meet locally, or jump on Zoom. We regularly work from <a href="https://nsrodney.org.nz/">Rodney</a>, <a href="https://en.wikipedia.org/wiki/Waitakere_City">Waitākere</a>, <a href="https://www.explorenorthshore.nz/">North Shore</a>, <a href="https://heartofthecity.co.nz/">Auckland CBD</a>, <a href="https://www.aucklandeastcommunitynetwork.org.nz/">East</a> & <a href="https://www.nzherald.co.nz/topic/south-auckland/">South Auckland</a>.</p>
 
 </details>

 <details>
 <summary>Do you offer website maintenance after launch?</summary>
 
 <p>Yes. We provide affordable monthly care (updates, backups, security checks, and small content edits). Or we can train you to self-manage and jump in on request.</p>
 
 </details>

 <details>
 <summary>Why choose Kiwi Web Design?</summary>
 
 <p>We’re a local, family-run team focused on affordability, transparency, and quick turnaround. No fluff — just a good-looking site that helps Auckland customers find and trust you.</p>
 
 </details>

 <details>
 <summary>How do we get started?</summary>
 
 <p>Easy — contact us or call 021 039 6580. We’ll have a quick chat about your goals, suggest the right package, and send a free, no-pressure quote.</p>
 
 </details>

<h2>Ready to build your Auckland website?</h2>
 <p>Choose the package that fits your business and lean on our local team for friendly advice, fast turnaround, and a site that works as hard as you do.</p>
 <ul>
 <li><a href="/website-design-auckland/">Tradie Web Design</a></li>
 <li><a href="/web-designs-auckland/">eCommerce Web Design</a></li>
 <li><a href="/affordable-web-design-auckland/">Affordable Web Design Auckland</a></li>
 </ul>
 <a href="/website-designer-auckland/">Contact us</a>
 <p>We cover Rodney, Waitākere, North Shore, Auckland CBD, and East & South Auckland — onsite or over Zoom.</p>

<!-- If your theme blocks inline scripts, move the JSON-LD into the site header -->
    </div>
  </section>

  <section class="cta-strip">
    <h2>Ready to grow your business online?</h2>
    <p>Let's build something that works for you. Free consultation, no obligation.</p>
    <div class="cta-btns">
      <a href="/website-designer-auckland/#contact" class="btn-primary">Book Free Consultation</a>
      <a href="/small-business-website-design-auckland/#packages" class="btn-outline">View Our Packages</a>
    </div>
  </section>
</Layout>

<style>
  /* ── hero ── */
  .hero { background: var(--kwd-dark); color: var(--kwd-white); padding: 4rem 0 3rem; }
  .hero-inner { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; display: flex; gap: 3rem; align-items: center; }
  .hero-text { flex: 1; min-width: 0; }
  .eyebrow { font-size: .75rem; letter-spacing: .12em; text-transform: uppercase; color: var(--kwd-yellow); font-weight: 700; margin: 0 0 .6rem; }
  .hero-text h1 { font-family: var(--kwd-font-heading); font-size: clamp(1.8rem, 4vw, 2.8rem); margin: 0 0 1rem; line-height: 1.2; }
  .hero-sub { font-size: 1.05rem; opacity: .85; max-width: 580px; margin: 0 0 2rem; line-height: 1.65; }
  .hero-btns { display: flex; flex-wrap: wrap; gap: .75rem; }
  .btn-primary { background: var(--kwd-yellow); color: var(--kwd-dark); padding: .75rem 1.75rem; border-radius: 6px; font-weight: 700; text-decoration: none; display: inline-block; font-size: .95rem; }
  .btn-outline { border: 2px solid rgba(255,255,255,.6); color: var(--kwd-white); padding: .75rem 1.75rem; border-radius: 6px; font-weight: 700; text-decoration: none; display: inline-block; font-size: .95rem; }
  .hero-img { flex: 0 0 42%; }
  .hero-img img { width: 100%; border-radius: 10px; object-fit: cover; max-height: 380px; display: block; }
  /* ── prose content ── */
  .page-content { padding: 3.5rem 0; }
  .prose { max-width: 900px; margin: 0 auto; padding: 0 1.5rem; }
  .prose h1 { font-family: var(--kwd-font-heading); font-size: 2rem; margin: 0 0 1rem; color: var(--kwd-dark); }
  .prose h2 { font-family: var(--kwd-font-heading); font-size: 1.6rem; margin: 2.5rem 0 .75rem; color: var(--kwd-dark); border-bottom: 2px solid var(--kwd-yellow); padding-bottom: .3rem; }
  .prose h3 { font-family: var(--kwd-font-heading); font-size: 1.2rem; margin: 1.75rem 0 .5rem; color: var(--kwd-dark); }
  .prose h4 { font-size: 1rem; font-weight: 700; margin: 1.25rem 0 .4rem; color: #222; }
  .prose h5, .prose h6 { font-size: .95rem; font-weight: 700; margin: 1rem 0 .35rem; color: #333; }
  .prose p { margin: 0 0 1rem; line-height: 1.75; color: #333; }
  .prose ul { padding-left: 1.4rem; margin: 0 0 1rem; list-style: disc; }
  .prose ol { padding-left: 1.4rem; margin: 0 0 1rem; }
  .prose li { margin-bottom: .4rem; line-height: 1.65; color: #333; }
  .prose img { max-width: 100%; height: auto; border-radius: 8px; margin: 1.75rem 0; display: block; }
  .prose blockquote { border-left: 4px solid var(--kwd-yellow); padding: .75rem 1.25rem; margin: 1.75rem 0; background: #f8f6f0; font-style: italic; color: #444; border-radius: 0 6px 6px 0; }
  .prose a { color: var(--kwd-dark); text-decoration: underline; font-weight: 600; }
  .prose a:hover { color: var(--kwd-brown); }
  .prose strong { color: var(--kwd-dark); }
  .prose table { width: 100%; border-collapse: collapse; margin: 1.75rem 0; font-size: .9rem; overflow-x: auto; display: block; }
  .prose th, .prose td { padding: .65rem 1rem; border: 1px solid #ddd; text-align: left; white-space: nowrap; }
  .prose th { background: var(--kwd-dark); color: var(--kwd-white); }
  .prose tr:nth-child(even) td { background: #fafafa; }
  /* ── faq ── */
  .faq-section { background: var(--kwd-cream); padding: 4rem 0; }
  .faq-inner { max-width: 860px; margin: 0 auto; padding: 0 1.5rem; }
  .faq-inner > h2 { font-family: var(--kwd-font-heading); font-size: 1.8rem; margin: 0 0 2rem; color: var(--kwd-dark); }
  .faq-item { border-bottom: 1px solid #d8d0c0; }
  .faq-item summary { cursor: pointer; padding: 1.1rem 0; font-weight: 600; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; color: var(--kwd-dark); }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; font-size: 1.4rem; color: var(--kwd-yellow); flex-shrink: 0; margin-left: .75rem; }
  .faq-item[open] summary::after { content: '−'; }
  .faq-answer { padding: .25rem 0 1.25rem; line-height: 1.7; color: #444; }
  .faq-answer p { margin: 0 0 .6rem; }
  .faq-answer ul, .faq-answer ol { padding-left: 1.3rem; margin: 0 0 .6rem; }
  /* ── cta ── */
  .cta-strip { background: var(--kwd-dark); color: var(--kwd-white); text-align: center; padding: 4rem 1.5rem; }
  .cta-strip h2 { font-family: var(--kwd-font-heading); font-size: 2rem; margin: 0 0 .75rem; }
  .cta-strip p { opacity: .85; margin: 0 0 2rem; font-size: 1.05rem; }
  .cta-btns { display: flex; flex-wrap: wrap; gap: .75rem; justify-content: center; }
  /* ── contact form ── */
  .contact-section { padding: 4rem 0; background: var(--kwd-cream); }
  .contact-inner { max-width: 720px; margin: 0 auto; padding: 0 1.5rem; }
  .contact-inner h2 { font-family: var(--kwd-font-heading); font-size: 1.8rem; margin: 0 0 .5rem; color: var(--kwd-dark); }
  .contact-inner > p { margin: 0 0 2rem; color: #555; line-height: 1.65; }
  .contact-form { display: grid; gap: 1.25rem; }
  .form-group { display: flex; flex-direction: column; gap: .4rem; }
  .form-group label { font-weight: 600; font-size: .9rem; color: var(--kwd-dark); }
  .form-group input, .form-group textarea, .form-group select { padding: .7rem 1rem; border: 2px solid #ddd; border-radius: 6px; font-size: 1rem; font-family: inherit; background: #fff; transition: border-color .2s; }
  .form-group input:focus, .form-group textarea:focus { outline: none; border-color: var(--kwd-yellow); }
  .form-group textarea { resize: vertical; min-height: 130px; }
  .form-submit { margin-top: .5rem; }
  /* ── responsive ── */
  @media (max-width: 768px) {
    .hero-inner { flex-direction: column; }
    .hero-img { display: none; }
    .hero-text h1 { font-size: 1.75rem; }
  }
</style>
