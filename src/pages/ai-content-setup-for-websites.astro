---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import Icon from '../components/Icon.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/ai-content-setup-for-websites/",
      "url": "https://www.kiwiwebdesign.co.nz/ai-content-setup-for-websites/",
      "name": "AI Content Setup for Websites",
      "description": "Set up AI content workflows for your website: tone, templates, internal links, SEO structure, and a review process built for NZ small businesses.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/ai-content-setup-for-websites/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/ai-content-setup-for-websites/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "AI Content Setup" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const services = [
  {
    icon: "🎙️",
    title: "Brand Voice & Tone Guide",
    desc: "A documented guide to how your business sounds in writing, formal or casual, direct or warm, technical or plain-English. Given to any AI tool as a system prompt so every output sounds like you.",
    items: ["Tone & voice documentation", "Example sentences & patterns", "What to avoid list", "AI system prompt template"],
  },
  {
    icon: "📋",
    title: "Content Templates",
    desc: "Reusable AI prompt templates for your most common content types: service page updates, blog posts, social captions, email newsletters, and FAQs.",
    items: ["Service page template", "Blog post prompt", "Social caption template", "FAQ generation prompt"],
  },
  {
    icon: "🔗",
    title: "Internal Linking Strategy",
    desc: "A documented internal linking map so when AI tools generate content, they know which pages to link to, and every piece of content reinforces your SEO architecture.",
    items: ["Pillar-to-cluster link map", "Anchor text guidelines", "Priority page hierarchy", "AI linking instructions"],
  },
  {
    icon: "🔍",
    title: "SEO Content Structure",
    desc: "Templates that bake SEO into every AI-generated piece: correct heading hierarchy, keyword placement, meta title/description patterns, and schema-ready formatting.",
    items: ["H1–H3 structure templates", "Meta title formula", "Keyword placement guide", "Schema-ready FAQ format"],
  },
  {
    icon: "✅",
    title: "AI Review Workflow",
    desc: "A practical human-review checklist so AI-generated content gets fact-checked, personalised, and quality-assured before it goes live on your site.",
    items: ["Content review checklist", "Fact-check protocol", "Brand voice check", "Pre-publish SEO review"],
  },
  {
    icon: "🛠️",
    title: "Tool Setup & Training",
    desc: "We set up ChatGPT, Claude, or your preferred AI tool with custom instructions, saved prompts, and a short training session so your team can use it confidently from day one.",
    items: ["Custom AI instructions setup", "Saved prompt library", "1-hour training session", "Written usage guide"],
  },
];

const whyIt = [
  { icon: "⏱️", title: "Save hours each week", desc: "AI can draft a blog post in minutes, but without the right setup it sounds generic and off-brand. The right templates fix that." },
  { icon: "📣", title: "Stay consistent on every channel", desc: "Your website, blog, and social all sound the same when they're driven by the same voice guide and templates." },
  { icon: "🔍", title: "Generate content that actually ranks", desc: "Most AI content fails SEO because it ignores heading structure, keyword intent, and internal linking. Our templates fix this at the source." },
  { icon: "👤", title: "Still sounds like you", desc: "Good AI content isn't detectable as AI, because it's been trained on your voice, reviewed by a human, and personalised for your audience." },
];

const process = [
  { step: "1", title: "Brand & Content Audit", desc: "We review your existing website copy, any brand guidelines you have, and your target audience to understand your voice before we document it." },
  { step: "2", title: "Voice Guide & Templates", desc: "We write your brand voice guide and create a library of AI prompt templates tailored to your content types." },
  { step: "3", title: "SEO Structure Setup", desc: "We create content structure templates and an internal linking map that bake SEO into everything your AI tool generates." },
  { step: "4", title: "Tool Setup & Handover", desc: "We configure your AI tool with custom instructions, walk your team through the workflow, and hand over the written guide." },
];

const faqs = [
  { q: "Which AI tools do you set this up for?", a: "We primarily set up workflows for ChatGPT (OpenAI) and Claude (Anthropic), as these are the most widely used by small businesses. We can adapt the setup for Gemini, Copilot, or any tool your team prefers." },
  { q: "Do I need any technical knowledge to use the AI tools after setup?", a: "No. We set everything up with simple prompts and a written guide that anyone can follow. If you can paste text into a chat box, you can use the workflow." },
  { q: "Will Google penalise AI-generated content?", a: "Google has stated it doesn't penalise AI content, it penalises low-quality content. Content that's accurate, useful, and well-structured ranks fine regardless of how it was produced. Our templates and review checklist are designed to ensure quality, not just speed." },
  { q: "How is this different from just using ChatGPT myself?", a: "Using ChatGPT without setup produces generic, off-brand, SEO-unfriendly content. Our setup gives you a customised system prompt with your brand voice, SEO-structured templates, an internal linking map, and a review checklist, so every output is consistent, on-brand, and built to rank. This complements our <a href=\"/ai-seo-for-auckland-small-businesses/\">AI SEO service</a>, which handles the technical side of visibility while this service handles content production." },
  { q: "Can you also write the content for me?", a: "Yes. If you'd prefer us to produce content rather than set up your team to do it, our <a href=\"/website-copywriting-auckland/\">website copywriting service</a> handles that. We also offer a hybrid, we set up the system and produce the first 2–3 pieces as examples. And if your <a href=\"/wordpress-website-design-auckland/\">WordPress site</a> needs a proper content structure to begin with, that can be scoped as part of a build project." },
  { q: "How much does AI content setup cost?", a: "Our AI content setup package is a one-off engagement starting from $490 + GST. It includes the brand voice guide, prompt template library, SEO structure templates, internal linking map, and a 1-hour training session. Ongoing content production is available separately." },
];
---

<Layout
  title="AI Content Setup for Websites | Auckland Small Business AI Workflows"
  description="Set up AI content workflows for your website: tone, templates, internal links, SEO structure, and a review process built for NZ small businesses."
  canonicalURL="https://www.kiwiwebdesign.co.nz/ai-content-setup-for-websites/"
  schema={schema}
>

  <PageHero
    eyebrow="AI Content Setup"
    title="Use AI to create content that sounds like you, and ranks."
    subtitle="We set up your AI content workflow: brand voice guide, prompt templates, SEO structure, internal linking map, and a review process. Your team produces great content in a fraction of the time."
    badgeText="One-off setup from $490"
    ctaPrimary={{ text: "Book a Free Consult", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See What's Included", href: "#services" }}
    centered={true}
  />

  <!-- Why it matters -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="Why It Matters"
        title="AI content without a system produces junk. With a system, it's a superpower."
        subtitle="The difference between good and bad AI content is the setup, not the tool."
      />
      <div class="aics-why-grid">
        {whyIt.map(({ icon, title, desc }) => (
          <div class="aics-why-card">
            <span class="aics-why-icon"><Icon name={icon} size={24} /></span>
            <h3 class="aics-why-title">{title}</h3>
            <p class="aics-why-desc">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" id="services">
    <div class="container">
      <SectionHeader
        eyebrow="What's Included"
        title="Everything in the AI content setup."
        subtitle="A complete system, not just a ChatGPT account."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- Before / After -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="Before vs After"
        title="What changes with proper AI content setup."
        light={true}
      />
      <div class="aics-ba-grid">
        <div class="aics-ba-col aics-ba-col--before">
          <p class="aics-ba-label">Without setup</p>
          <ul>
            <li>Generic, off-brand content</li>
            <li>Wrong keywords and structure</li>
            <li>No internal links</li>
            <li>Team doesn't know which prompts to use</li>
            <li>Every output needs heavy editing</li>
            <li>Google flags as thin content</li>
          </ul>
        </div>
        <div class="aics-ba-col aics-ba-col--after">
          <p class="aics-ba-label aics-ba-label--after">With our setup</p>
          <ul>
            <li>Consistent brand voice on every draft</li>
            <li>SEO-structured headings and keywords baked in</li>
            <li>Correct internal links suggested automatically</li>
            <li>Saved prompts for every content type</li>
            <li>Review checklist for fast quality approval</li>
            <li>Content that ranks and reads like it was human-written</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="Four steps to a working AI content system."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="AI Content Questions Answered"
        subtitle="Common questions from Auckland businesses about setting up AI content workflows."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress Design</a>
        <a href="/ai-seo-for-auckland-small-businesses/" class="rps-link">AI SEO</a>
        <a href="/wordpress-ai-tools-integration-auckland/" class="rps-link">WordPress AI Tools</a>
        <a href="/website-copywriting-auckland/" class="rps-link">Web Copywriting</a>
        <a href="/affordable-seo-auckland/" class="rps-link">SEO Services</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to produce content 5× faster, without sacrificing quality?"
    subtitle="One-off setup from $490, we'll have your AI content system ready in a week."
    ctaPrimary={{ text: "Book a Free Consult", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See AI SEO Too", href: "/ai-seo-for-auckland-small-businesses/" }}
  />

</Layout>

<style>
  .aics-why-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .aics-why-card {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 14px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .aics-why-icon { }
  .aics-why-title { font-family: var(--kwd-font-body); font-size: 0.95rem; font-weight: 700; color: var(--kwd-dark); margin: 0; }
  .aics-why-desc { font-size: 0.83rem; color: var(--kwd-brown); line-height: 1.6; margin: 0; }

  .aics-ba-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .aics-ba-col {
    border-radius: 16px;
    padding: 2rem;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
  }
  .aics-ba-col--after {
    background: rgba(251,232,166,0.07);
    border-color: rgba(251,232,166,0.2);
  }
  .aics-ba-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.35);
    margin-bottom: 1.25rem;
  }
  .aics-ba-label--after { color: var(--kwd-yellow); }
  .aics-ba-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .aics-ba-col ul li {
    font-size: 0.875rem;
    line-height: 1.5;
    padding-left: 1.4rem;
    position: relative;
  }
  .aics-ba-col--before li { color: rgba(255,255,255,0.5); }
  .aics-ba-col--before li::before { content: "✗"; position: absolute; left: 0; color: rgba(255,255,255,0.25); font-weight: 700; }
  .aics-ba-col--after li { color: rgba(255,255,255,0.82); }
  .aics-ba-col--after li::before { content: "✓"; position: absolute; left: 0; color: var(--kwd-yellow); font-weight: 700; }

  @media (max-width: 900px) {
    .aics-why-grid { grid-template-columns: repeat(2, 1fr); }
    .aics-ba-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 580px) {
    .aics-why-grid { grid-template-columns: 1fr; }
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
