---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';

const stats = [
  { fig: "4x", label: "Increase in patient enquiries" },
  { fig: "6x", label: "Organic visibility growth" },
  { fig: "85%", label: "Improved mobile trust signals" },
];

const deliverables = [
  "Specialist profile pages",
  "Condition & treatment information pages",
  "Online appointment enquiry form",
  "MedicalOrganization schema markup",
  "WCAG AA accessible design",
  "Patient information hub",
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/melanoma-specialists-website/",
      "url": "https://www.kiwiwebdesign.co.nz/melanoma-specialists-website/",
      "name": "Melanoma Specialists — Website Case Study | Kiwi Web Design",
      "description": "How Kiwi Web Design built a trust-first specialist healthcare website for Auckland Melanoma Specialists — delivering 4x patient enquiries and 6x organic visibility.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/melanoma-specialists-website/#breadcrumb" }
    },
    {
      "@type": "CreativeWork",
      "@id": "https://www.kiwiwebdesign.co.nz/melanoma-specialists-website/#case-study",
      "name": "Case Study: Melanoma Specialists",
      "description": "How Kiwi Web Design helped Auckland Melanoma Specialists build patient trust online with accessible, clearly structured healthcare website design.",
      "url": "https://www.kiwiwebdesign.co.nz/melanoma-specialists-website/",
      "creator": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "about": { "@type": "LocalBusiness", "name": "Auckland Melanoma Specialists", "address": { "@type": "PostalAddress", "addressLocality": "Auckland", "addressCountry": "NZ" } },
      "genre": "Case Study",
      "keywords": "healthcare website design Auckland, dermatology website, medical specialist website"
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/melanoma-specialists-website/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Melanoma Specialists" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz"
    }
  ]
};
---

<Layout
  title="Melanoma Specialists — Website Case Study | Kiwi Web Design"
  description="How Kiwi Web Design built a trust-first specialist healthcare website for Auckland Melanoma Specialists — delivering 4x patient enquiries and 6x organic visibility."
  canonicalURL="https://www.kiwiwebdesign.co.nz/melanoma-specialists-website/"
  schema={schema}
>

  <!-- Hero -->
  <section class="cs-hero">
    <div class="container">
      <div class="cs-hero-inner">
        <div class="cs-hero-text">
          <div class="cs-tags">
            <span class="cs-tag">Case Study</span>
            <span class="cs-industry">Healthcare — Dermatology</span>
          </div>
          <h1>Melanoma Specialists — 4x More Patient Enquiries</h1>
          <p>A specialist Auckland dermatology practice with advanced diagnostic capability — and a website that wasn't building the patient trust that high-stakes healthcare decisions require. We rebuilt it for clarity, access, and credibility.</p>
        </div>
        <div class="cs-hero-img">
          <img
            src="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/07/Specialist-e1753415885359.jpg"
            alt="Auckland Melanoma Specialists website by Kiwi Web Design"
            width="700"
            height="500"
            loading="eager"
          />
        </div>
      </div>
    </div>
    <div class="cs-stat-strip">
      <div class="container cs-stat-grid">
        {stats.map(s => (
          <div class="cs-stat-item">
            <span class="cs-stat-fig">{s.fig}</span>
            <span class="cs-stat-lbl">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <div class="cs-overview">
        <div class="cs-client-card">
          <div class="cs-client-row">
            <span class="cs-client-label">Client</span>
            <span class="cs-client-value">Auckland Melanoma Specialists</span>
          </div>
          <div class="cs-client-row">
            <span class="cs-client-label">Industry</span>
            <span class="cs-client-value">Healthcare — Dermatology</span>
          </div>
          <div class="cs-client-row">
            <span class="cs-client-label">Location</span>
            <span class="cs-client-value">Auckland, New Zealand</span>
          </div>
          <div class="cs-client-row">
            <span class="cs-client-label">Project Type</span>
            <span class="cs-client-value">Healthcare Website Rebuild</span>
          </div>
          <div class="cs-client-row">
            <span class="cs-client-label">Results</span>
            <span class="cs-client-value">4x patient enquiries</span>
          </div>
        </div>
        <div class="cs-overview-body">
          <p class="cs-sub-eyebrow">Project Overview</p>
          <h2>Expert dermatologists focused on melanoma — with a website that wasn't communicating their expertise.</h2>
          <p>Auckland Melanoma Specialists is a New Zealand-based medical practice led by expert dermatologists focused on early detection and comprehensive care for melanoma and other skin cancers. The practice uses advanced diagnostic technology and offers specialist consultation across Auckland.</p>
          <p>The existing website was outdated, difficult to navigate on mobile, and lacked clarity around key services. For patients researching a skin cancer diagnosis — often in a stressful and vulnerable situation — the website wasn't answering the questions they needed answered before making an appointment.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Challenge -->
  <section class="section">
    <div class="container cs-content-narrow">
      <p class="cs-sub-eyebrow">The Challenge</p>
      <h2 class="cs-section-h2">Patients researching skin cancer need trust signals that a cluttered website can't provide.</h2>
      <p class="cs-section-p">Someone who has found an unusual mole, received a GP referral, or is researching melanoma treatment options for a family member is making a high-stakes decision. They research specialists carefully — looking for qualifications, experience with specific conditions, diagnostic technology used, and whether the practice is accepting new patients.</p>
      <p class="cs-section-p">The old site had no specialist profile pages, no clear information about the diagnostic process, and no accessible patient information. The contact option was a basic form. Mobile navigation was difficult for older users — a significant portion of dermatology patients. The site wasn't ranking for any local search terms related to melanoma or skin cancer specialists in Auckland.</p>
    </div>
  </section>

  <!-- Solution -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container cs-content-narrow">
      <p class="cs-sub-eyebrow">What We Built</p>
      <h2 class="cs-section-h2">A calm, clinical website built for patient trust and accessibility.</h2>
      <p class="cs-section-p">We designed a clean, clinical aesthetic with high-contrast text, large readable typography, and a calm colour palette that communicates care and professionalism. Specialist profile pages were built for each dermatologist — qualifications, areas of expertise, and a personal statement that helps patients feel confident about who they'll be seeing.</p>
      <p class="cs-section-p">Condition and treatment information pages were structured to answer the questions patients actually ask — what is melanoma, what happens at a first appointment, what diagnostic technology is used, what does treatment involve. A patient information hub contains downloadable forms, referral information, and FAQ content. MedicalOrganization schema markup was applied to improve search visibility for specialist skin cancer terms in Auckland.</p>
      <div class="cs-deliverables">
        {deliverables.map(d => <span class="cs-chip">{d}</span>)}
      </div>
    </div>
  </section>

  <!-- Screenshot -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <div class="cs-screenshot-wrap">
        <img
          src="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/07/Specialist-e1753415885359.jpg"
          alt="Auckland Melanoma Specialists website design by Kiwi Web Design"
          width="1200"
          height="700"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Results -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <p class="cs-sub-eyebrow cs-sub-eyebrow-light">The Results</p>
      <h2 class="cs-section-h2 cs-section-h2-light">4x patient enquiries — from a website patients actually trust.</h2>
      <p class="cs-section-p cs-section-p-light">The rebuilt site immediately improved conversion — patients arriving via Google search were finding clear, reassuring information and completing the appointment enquiry form at four times the previous rate. Organic search visibility increased sixfold as the specialist and condition pages began ranking for local dermatology and skin cancer searches. Patients now tell the practice the website made them feel confident before their first appointment.</p>
      <div class="cs-results-grid">
        {stats.map(s => (
          <div class="cs-result-card">
            <div class="cs-result-fig">{s.fig}</div>
            <div class="cs-result-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="section">
    <div class="container">
      <div class="cs-testimonial-wrap">
        <blockquote>"Kiwi Web Design made our website feel trustworthy and modern — patients now tell us it's easy to navigate and understand. We're very happy with the result."</blockquote>
        <p class="cs-testimonial-author">— Auckland Melanoma Specialists</p>
      </div>
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design</a>
        <a href="/booking-appointment-websites-with-wordpress/" class="rps-link">Booking Websites</a>
        <a href="/local-seo-for-auckland-small-businesses/" class="rps-link">Local SEO</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress</a>
        <a href="/testimonials-reviews/" class="rps-link">Case Studies</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Need a healthcare website patients will trust?"
    subtitle="Free consultation — we'll review your current site and identify the highest-impact improvements for patient trust."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "See More Case Studies", href: "/testimonials-reviews/" }}
  />

</Layout>

<style>
  .cs-hero { background: var(--kwd-dark); padding: 5rem 0 0; }
  .cs-hero-inner { display: grid; grid-template-columns: 55% 45%; gap: 3rem; align-items: center; padding-bottom: 3rem; }
  .cs-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
  .cs-tag { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 0.3rem 0.85rem; border-radius: 999px; background: var(--kwd-yellow); color: var(--kwd-dark); }
  .cs-industry { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; padding: 0.3rem 0.85rem; border-radius: 999px; background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.75); }
  .cs-hero-text h1 { font-family: var(--kwd-font-heading); font-size: clamp(2rem, 4vw, 3rem); color: #fff; line-height: 1.15; margin-bottom: 1rem; }
  .cs-hero-text p { font-size: 1rem; color: rgba(255,255,255,0.7); line-height: 1.7; }
  .cs-hero-img img { width: 100%; height: 400px; object-fit: cover; border-radius: 12px; display: block; box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
  .cs-stat-strip { border-top: 1px solid rgba(255,255,255,0.1); }
  .cs-stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); }
  .cs-stat-item { padding: 1.5rem 2rem; border-right: 1px solid rgba(255,255,255,0.1); display: flex; flex-direction: column; gap: 0.25rem; }
  .cs-stat-item:last-child { border-right: none; }
  .cs-stat-fig { font-family: var(--kwd-font-heading); font-size: 2.25rem; color: var(--kwd-yellow); line-height: 1; }
  .cs-stat-lbl { font-size: 0.8rem; color: rgba(255,255,255,0.55); line-height: 1.4; }
  .cs-overview { display: grid; grid-template-columns: 260px 1fr; gap: 3.5rem; align-items: start; }
  .cs-client-card { background: #fff; border: 1.5px solid rgba(0,0,0,0.07); border-radius: 14px; padding: 1.75rem; }
  .cs-client-row { margin-bottom: 1rem; }
  .cs-client-row:last-child { margin-bottom: 0; }
  .cs-client-label { display: block; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.2rem; }
  .cs-client-value { font-size: 0.9rem; color: var(--kwd-dark); font-weight: 600; line-height: 1.4; }
  .cs-sub-eyebrow { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--kwd-brown); margin-bottom: 0.75rem; }
  .cs-sub-eyebrow-light { color: var(--kwd-yellow); }
  .cs-overview-body h2 { font-family: var(--kwd-font-heading); font-size: clamp(1.5rem, 2.5vw, 2rem); color: var(--kwd-dark); line-height: 1.2; margin-bottom: 0.75rem; }
  .cs-overview-body p { font-size: 0.9375rem; color: var(--kwd-brown); line-height: 1.75; margin-bottom: 0.75rem; }
  .cs-section-h2 { font-family: var(--kwd-font-heading); font-size: clamp(1.5rem, 2.5vw, 2rem); color: var(--kwd-dark); line-height: 1.2; margin-bottom: 0.75rem; }
  .cs-section-h2-light { color: #fff; }
  .cs-section-p { font-size: 0.9375rem; color: var(--kwd-brown); line-height: 1.75; margin-bottom: 0.75rem; }
  .cs-section-p-light { color: rgba(255,255,255,0.7); }
  .cs-content-narrow { max-width: 760px; }
  .cs-deliverables { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.5rem; }
  .cs-chip { font-size: 0.8rem; font-weight: 600; padding: 0.4rem 1rem; border-radius: 999px; background: var(--kwd-dark); color: #fff; }
  .cs-results-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-top: 2.5rem; }
  .cs-result-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 2rem 1.5rem; text-align: center; }
  .cs-result-fig { font-family: var(--kwd-font-heading); font-size: 2.75rem; color: var(--kwd-yellow); line-height: 1; margin-bottom: 0.5rem; }
  .cs-result-label { font-size: 0.875rem; color: rgba(255,255,255,0.65); line-height: 1.5; }
  .cs-screenshot-wrap { margin-top: 2rem; }
  .cs-screenshot-wrap img { width: 100%; border-radius: 12px; border: 1.5px solid rgba(0,0,0,0.07); display: block; box-shadow: 0 8px 32px rgba(0,0,0,0.1); }
  .cs-testimonial-wrap { max-width: 760px; margin: 0 auto; text-align: center; }
  .cs-testimonial-wrap blockquote { font-family: var(--kwd-font-heading); font-size: clamp(1.2rem, 2.5vw, 1.625rem); color: var(--kwd-dark); line-height: 1.4; font-style: italic; margin: 0 0 1.5rem; }
  .cs-testimonial-author { font-size: 0.875rem; font-weight: 600; color: var(--kwd-brown); }
  @media (max-width: 900px) {
    .cs-hero-inner { grid-template-columns: 1fr; }
    .cs-hero-img { display: none; }
    .cs-overview { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .cs-stat-grid { grid-template-columns: repeat(2, 1fr); }
    .cs-stat-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .cs-stat-item:last-child { border-bottom: none; }
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
