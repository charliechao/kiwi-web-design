---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import StatsRow from '../components/StatsRow.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/ai-seo-for-auckland-small-businesses/",
      "url": "https://www.kiwiwebdesign.co.nz/ai-seo-for-auckland-small-businesses/",
      "name": "AI SEO for Auckland Small Businesses",
      "description": "AI-powered SEO for Auckland small businesses. Rank higher on Google and get cited by ChatGPT, Perplexity and AI Overviews with Kiwi Web Design.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/ai-seo-for-auckland-small-businesses/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/ai-seo-for-auckland-small-businesses/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "AI SEO Auckland" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const stats = [
  { number: "58%", label: "of searches now return AI-generated answers (Google AI Overviews)" },
  { number: "3×", label: "faster results with AI-assisted content and SEO workflows" },
  { number: "27%", label: "of US adults use ChatGPT for product research" },
  { number: "Day 1", label: "AI SEO foundations built into every new site" },
];

const services = [
  {
    icon: "🤖",
    title: "Generative Engine Optimisation (GEO)",
    desc: "Structure your content so it gets cited by ChatGPT, Perplexity, Google AI Overviews, and Gemini — not just ranked in blue-link results.",
    items: ["AI-citability content audits", "Answer-first content structuring", "Entity & topic coverage", "llms.txt setup"],
  },
  {
    icon: "🏷️",
    title: "AI-Ready Schema Markup",
    desc: "Comprehensive JSON-LD structured data that tells AI systems who you are, what you do, and why you're authoritative.",
    items: ["LocalBusiness & Service schema", "FAQ & HowTo schema", "speakable properties", "sameAs entity linking"],
  },
  {
    icon: "📝",
    title: "AI-Assisted Content Strategy",
    desc: "We use AI tools to research competitor content gaps, identify question clusters, and produce content that matches search intent at scale.",
    items: ["Keyword & topic clustering", "Competitor content gap analysis", "AI-drafted, human-reviewed copy", "Content calendar planning"],
  },
  {
    icon: "⚡",
    title: "Technical SEO & Core Web Vitals",
    desc: "Fast-loading, crawlable, mobile-first WordPress sites that satisfy Google's technical ranking requirements from day one.",
    items: ["Core Web Vitals optimisation", "Crawl efficiency", "Sitemap & robots.txt", "Page speed audit & fixes"],
  },
  {
    icon: "🗺️",
    title: "Local AI SEO",
    desc: "Appear in Google Maps, local AI Overviews, and 'near me' searches. We optimise your Google Business Profile and local content footprint.",
    items: ["Google Business Profile optimisation", "Local schema markup", "Suburb landing pages", "Review velocity strategy"],
  },
  {
    icon: "📊",
    title: "AI Search Visibility Tracking",
    desc: "We track not just rankings, but how your brand appears in AI-generated answers — a new metric most agencies ignore.",
    items: ["AI mention monitoring", "GBP insights reporting", "Search Console integration", "Monthly AI visibility report"],
  },
];

const aiBenefit = [
  { icon: "🔍", title: "Google AI Overviews", desc: "Google now shows AI-generated summaries above organic results. We structure your content to be pulled into these overviews for your target queries." },
  { icon: "💬", title: "ChatGPT & Perplexity", desc: "When customers ask AI chatbots about local services, your business should appear. We build the content authority signals that make that happen." },
  { icon: "⭐", title: "Gemini & Bing Copilot", desc: "AI assistants increasingly cite structured, authoritative local businesses. We create the entity clarity and schema markup that drives citations." },
  { icon: "📈", title: "Traditional SEO Too", desc: "AI SEO doesn't replace traditional SEO — it extends it. Rankings, links, and speed still matter. We do both, together." },
];

const process = [
  { step: "1", title: "AI Visibility Audit", desc: "We audit your current visibility across Google, AI Overviews, and AI chat tools. You get a clear picture of where you appear — and where you're missing." },
  { step: "2", title: "Strategy & Content Plan", desc: "We identify the highest-impact keyword clusters, AI-answer opportunities, and schema gaps. A prioritised roadmap tailored to your industry." },
  { step: "3", title: "Implementation", desc: "Technical fixes, schema markup, content production, GBP optimisation, and on-page SEO — deployed in a structured monthly sprint." },
  { step: "4", title: "Track & Report", desc: "Monthly reporting covering rankings, organic traffic, AI citations, and GBP insights — so you can see the return on every dollar spent." },
];

const faqs = [
  { q: "What is AI SEO and how is it different from regular SEO?", a: "Traditional <a href=\"/seo-auckland/\">SEO</a> focuses on ranking in Google's blue-link results. AI SEO (also called Generative Engine Optimisation or GEO) focuses on getting your content cited or featured in AI-generated answers from Google AI Overviews, ChatGPT, Perplexity, and similar tools. The techniques partially overlap — structured content, schema markup, authority signals — but GEO adds new layers like entity optimisation, citability structuring, and llms.txt setup." },
  { q: "Do Auckland small businesses really need to worry about AI search?", a: "Increasingly, yes. Google AI Overviews now appear on more than 58% of searches in the US and are rolling out globally. If someone asks 'best plumber in Ponsonby' and Google generates an AI answer, your business either appears in it or doesn't. We help you appear." },
  { q: "How do you get a business cited in ChatGPT or Perplexity?", a: "AI systems draw from crawlable web content, third-party mentions, and structured data. We improve your citability by: structuring content as direct answers, adding comprehensive schema markup, building authoritative mentions on third-party sites, and ensuring your GBP and directory presence is strong and consistent." },
  { q: "What is a GEO score?", a: "A GEO (Generative Engine Optimisation) score measures how likely AI systems are to cite your content. We assess factors like content citability, schema completeness, technical crawlability for AI bots, and brand mention presence across AI-training sources." },
  { q: "Does AI SEO replace traditional SEO?", a: "No — it extends it. Traditional ranking signals (links, speed, mobile performance, keyword relevance) still matter. AI SEO adds new optimisation layers on top. We do both together — see our full <a href=\"/seo-auckland/\">SEO services Auckland</a> and <a href=\"/local-seo-for-auckland-small-businesses/\">local SEO</a> offerings." },
  { q: "How much does AI SEO cost?", a: "Our AI SEO packages start from $500/month for a foundational local SEO + GEO setup. Full AI SEO strategy and content production runs $1,000–$2,500/month depending on industry competitiveness and content volume. We give you a clear quote based on your specific goals." },
];
---

<Layout
  title="AI SEO for Auckland Small Businesses | GEO & Google Rankings"
  description="AI-powered SEO for Auckland small businesses. Rank higher on Google and get cited by ChatGPT, Perplexity and AI Overviews with Kiwi Web Design."
  canonicalURL="https://www.kiwiwebdesign.co.nz/ai-seo-for-auckland-small-businesses/"
  schema={schema}
>

  <PageHero
    eyebrow="AI SEO Auckland"
    title="Rank on Google. Get cited by AI. Both."
    subtitle="SEO for the next era of search. We optimise Auckland small businesses for traditional Google rankings and AI-generated answers — so you get found however your customers are searching."
    badgeText="GEO + Traditional SEO"
    ctaPrimary={{ text: "Get a Free AI SEO Audit", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See How It Works", href: "#services" }}
  />

  <StatsRow items={stats} />

  <!-- Why AI search matters -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="The AI Search Shift"
        title="Search is changing. Your SEO strategy should too."
        subtitle="AI-generated answers now appear above organic results for more than half of all searches. Here's what that means for your business."
      />
      <div class="aiseo-engines">
        {aiBenefit.map(({ icon, title, desc }) => (
          <div class="aiseo-engine-card">
            <span class="aiseo-eng-icon">{icon}</span>
            <h3 class="aiseo-eng-title">{title}</h3>
            <p class="aiseo-eng-desc">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" id="services">
    <div class="container">
      <SectionHeader
        eyebrow="AI SEO Services"
        title="Every layer of modern search optimisation."
        subtitle="From technical foundations to AI-citability content — we cover every ranking signal that matters in 2025 and beyond."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- What traditional vs AI SEO looks like -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="Traditional vs AI SEO"
        title="What we do differently."
        light={true}
        subtitle="Standard SEO agencies optimise for blue links. We optimise for the full search landscape."
      />
      <div class="aiseo-compare">
        <div class="aiseo-compare-col">
          <p class="aiseo-compare-label">Traditional SEO only</p>
          <ul class="aiseo-compare-list aiseo-compare-list--old">
            <li>Optimise page titles & meta descriptions</li>
            <li>Build backlinks</li>
            <li>Target keyword rankings</li>
            <li>Improve page speed</li>
          </ul>
        </div>
        <div class="aiseo-compare-divider">+</div>
        <div class="aiseo-compare-col aiseo-compare-col--new">
          <p class="aiseo-compare-label aiseo-compare-label--new">What we add with AI SEO</p>
          <ul class="aiseo-compare-list aiseo-compare-list--new">
            <li>Structure content as direct answers AI can cite</li>
            <li>Add comprehensive JSON-LD schema (speakable, FAQ, HowTo)</li>
            <li>Build entity authority via third-party mentions</li>
            <li>Set up llms.txt and AI crawler access</li>
            <li>Optimise for AI Overviews and featured snippets</li>
            <li>Track AI citation mentions monthly</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="Audit, plan, build, report."
        subtitle="A structured monthly engagement that compounds over time."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="AI SEO Questions Answered"
        subtitle="Common questions from Auckland businesses about AI search and GEO."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/seo-auckland/" class="rps-link">SEO Services Auckland</a>
        <a href="/local-seo-for-auckland-small-businesses/" class="rps-link">Local SEO Auckland</a>
        <a href="/wordpress-seo-optimisation/" class="rps-link">WordPress SEO</a>
        <a href="/analytics-reporting-for-auckland-small-business-websites/" class="rps-link">Analytics & Reporting</a>
        <a href="/google-business-profile-guide-for-auckland-businesses/" class="rps-link">Google Business Profile</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to rank on Google and in AI answers?"
    subtitle="Free AI SEO audit — we'll show you exactly where you appear, and where you're missing out."
    ctaPrimary={{ text: "Get a Free AI SEO Audit", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See All SEO Services", href: "/seo-auckland/" }}
  />

</Layout>

<style>
  .aiseo-engines {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .aiseo-engine-card {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 14px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .aiseo-eng-icon { font-size: 1.75rem; }
  .aiseo-eng-title { font-family: var(--kwd-font-body); font-size: 0.95rem; font-weight: 700; color: var(--kwd-dark); margin: 0; }
  .aiseo-eng-desc { font-size: 0.83rem; color: var(--kwd-brown); line-height: 1.6; margin: 0; }

  .aiseo-compare {
    display: grid;
    grid-template-columns: 1fr auto 1.4fr;
    gap: 2rem;
    align-items: start;
    margin-top: 2.5rem;
  }
  .aiseo-compare-col {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 1.75rem;
  }
  .aiseo-compare-col--new {
    background: rgba(251,232,166,0.08);
    border-color: rgba(251,232,166,0.25);
  }
  .aiseo-compare-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.4);
    margin-bottom: 1rem;
  }
  .aiseo-compare-label--new { color: var(--kwd-yellow); }
  .aiseo-compare-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .aiseo-compare-list li {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }
  .aiseo-compare-list--old li::before { content: "–"; position: absolute; left: 0; color: rgba(255,255,255,0.3); }
  .aiseo-compare-list--new li { color: rgba(255,255,255,0.8); }
  .aiseo-compare-list--new li::before { content: "✓"; position: absolute; left: 0; color: var(--kwd-yellow); font-weight: 700; }
  .aiseo-compare-divider {
    font-family: var(--kwd-font-heading);
    font-size: 2.5rem;
    color: var(--kwd-yellow);
    display: flex;
    align-items: center;
    padding-top: 1.75rem;
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }

  @media (max-width: 960px) {
    .aiseo-engines { grid-template-columns: repeat(2, 1fr); }
    .aiseo-compare { grid-template-columns: 1fr; }
    .aiseo-compare-divider { display: none; }
  }
  @media (max-width: 580px) {
    .aiseo-engines { grid-template-columns: 1fr; }
  }
</style>
