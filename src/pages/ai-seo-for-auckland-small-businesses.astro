---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import StatsRow from '../components/StatsRow.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import TestimonialGrid from '../components/TestimonialGrid.astro';
import { Image } from 'astro:assets';
import consultImg from '../assets/general/about5.webp';
import aucklandCBD from '../assets/general/Auckland-CBD.jpg';
import Icon from '../components/Icon.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/ai-seo-for-auckland-small-businesses/",
      "url": "https://www.kiwiwebdesign.co.nz/ai-seo-for-auckland-small-businesses/",
      "name": "AI SEO Agency Auckland | GEO & AI Search, From $500/mo",
      "description": "AI SEO agency Auckland: rank on Google, get cited by ChatGPT & AI Overviews. GEO from $500/month, no lock-in. Free AI visibility audit.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/ai-seo-for-auckland-small-businesses/#breadcrumb" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": [".aiseo-snippet", "h1"] }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/ai-seo-for-auckland-small-businesses/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "SEO Auckland", "item": "https://www.kiwiwebdesign.co.nz/affordable-seo-auckland/" },
        { "@type": "ListItem", "position": 3, "name": "AI SEO Auckland", "item": "https://www.kiwiwebdesign.co.nz/ai-seo-for-auckland-small-businesses/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "Place", "name": "Auckland" },
        { "@type": "Place", "name": "New Zealand" }
      ],
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5", "ratingCount": "50", "bestRating": "5" },
      "logo": { "@type": "ImageObject", "url": "https://www.kiwiwebdesign.co.nz/favicon.png", "width": 512, "height": 512 }
    },
    {
      "@type": "Service",
      "@id": "https://www.kiwiwebdesign.co.nz/ai-seo-for-auckland-small-businesses/#service",
      "name": "AI SEO & Generative Engine Optimisation (GEO) Auckland",
      "serviceType": "AI SEO",
      "category": "Digital Marketing",
      "description": "AI-powered SEO and GEO for Auckland businesses. Get ranked on Google and cited by ChatGPT, Perplexity, Gemini, Claude, and Google AI Overviews. From $500/month.",
      "provider": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "areaServed": [
        { "@type": "Place", "name": "Auckland" },
        { "@type": "Place", "name": "New Zealand" }
      ],
      "url": "https://www.kiwiwebdesign.co.nz/ai-seo-for-auckland-small-businesses/",
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "500",
        "highPrice": "2500",
        "priceCurrency": "NZD",
        "priceSpecification": { "@type": "PriceSpecification", "valueAddedTaxIncluded": false, "unitCode": "MON" }
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is AI SEO and how is it different from regular SEO?",
          "acceptedAnswer": { "@type": "Answer", "text": "Traditional SEO focuses on ranking in Google's blue-link results. AI SEO (also called Generative Engine Optimisation or GEO) focuses on getting your content cited or featured in AI-generated answers from Google AI Overviews, ChatGPT, Perplexity, and similar tools. GEO adds new layers like entity optimisation, citability structuring, and llms.txt setup." }
        },
        {
          "@type": "Question",
          "name": "Do Auckland small businesses really need to worry about AI search?",
          "acceptedAnswer": { "@type": "Answer", "text": "Google AI Overviews now appear on more than 58% of searches and are rolling out globally. If someone asks 'best plumber in Ponsonby' and Google generates an AI answer, your business either appears in it or doesn't. We help you appear." }
        },
        {
          "@type": "Question",
          "name": "How do you get a business cited in ChatGPT or Perplexity?",
          "acceptedAnswer": { "@type": "Answer", "text": "AI systems draw from crawlable web content, third-party mentions, and structured data. We improve your citability by structuring content as direct answers, adding comprehensive schema markup, building authoritative mentions on third-party sites, and ensuring your GBP and directory presence is strong and consistent." }
        },
        {
          "@type": "Question",
          "name": "What is a GEO score?",
          "acceptedAnswer": { "@type": "Answer", "text": "A GEO (Generative Engine Optimisation) score measures how likely AI systems are to cite your content. We assess factors like content citability, schema completeness, technical crawlability for AI bots, and brand mention presence across AI-training sources." }
        },
        {
          "@type": "Question",
          "name": "Does AI SEO replace traditional SEO?",
          "acceptedAnswer": { "@type": "Answer", "text": "No, it extends it. Traditional ranking signals (links, speed, mobile performance, keyword relevance) still matter. AI SEO adds new optimisation layers on top." }
        },
        {
          "@type": "Question",
          "name": "How much does AI SEO cost?",
          "acceptedAnswer": { "@type": "Answer", "text": "AI SEO packages start from $500/month for foundational GEO setup. Full AI SEO strategy and content production runs $1,000–$2,500/month depending on industry competitiveness and content volume." }
        },
        {
          "@type": "Question",
          "name": "What is the difference between GEO and AEO (Answer Engine Optimization)?",
          "acceptedAnswer": { "@type": "Answer", "text": "GEO (Generative Engine Optimisation) focuses on getting cited in AI-generated content from tools like ChatGPT and Perplexity. AEO (Answer Engine Optimisation) focuses on appearing in answer boxes and featured snippets in traditional search. Both target similar content strategies, structured answers, schema markup, and authority signals. We cover both." }
        },
        {
          "@type": "Question",
          "name": "What is llms.txt and does my website need one?",
          "acceptedAnswer": { "@type": "Answer", "text": "llms.txt is an emerging standard, similar to robots.txt, that helps AI systems understand your website's structure and key content. It tells AI crawlers what your business does, what pages matter most, and how to interpret your site. Most NZ agencies don't implement this yet. We do." }
        },
        {
          "@type": "Question",
          "name": "How do you track AI citations and mentions?",
          "acceptedAnswer": { "@type": "Answer", "text": "We monitor how your brand appears across AI platforms including Google AI Overviews, ChatGPT, Perplexity, and Gemini. Monthly reports show where you're being cited, which queries trigger mentions, and where there are gaps to target." }
        },
        {
          "@type": "Question",
          "name": "Can you help my business appear on Reddit and Quora?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. AI systems heavily weight community platforms like Reddit and Quora when generating answers. We build authentic presence on these platforms through helpful, authoritative content that positions your business as a trusted source in your industry." }
        }
      ]
    }
  ]
};

const stats = [
  { number: "58%", label: "of searches now return AI-generated answers (Google AI Overviews)" },
  { number: "40%", label: "of consumers use AI tools for product and service research" },
  { number: "50+", label: "NZ businesses ranked with Kiwi Web Design" },
  { number: "5★", label: "Google rating across all client reviews" },
];

const services = [
  {
    icon: "🤖",
    title: "Generative Engine Optimisation (GEO)",
    desc: "Structure your content so it gets cited by ChatGPT, Perplexity, Google AI Overviews, and Gemini, not just ranked in blue-link results.",
    items: ["AI-citability content audits", "Answer-first content structuring", "Entity & topic coverage", "llms.txt setup"],
  },
  {
    icon: "🏷️",
    title: "AI-Ready Schema Markup",
    desc: "Comprehensive JSON-LD structured data that tells AI systems who you are, what you do, and why you're authoritative.",
    items: ["LocalBusiness & Service schema", "FAQ & HowTo schema", "speakable properties", "sameAs entity linking"],
  },
  {
    icon: "📝",
    title: "AI-Assisted Content Strategy",
    desc: "We use AI tools to research competitor content gaps, identify question clusters, and produce content that matches search intent at scale.",
    items: ["Keyword & topic clustering", "Competitor content gap analysis", "AI-drafted, human-reviewed copy", "Content calendar planning"],
  },
  {
    icon: "⚡",
    title: "Technical SEO & Core Web Vitals",
    desc: "Fast-loading, crawlable, mobile-first sites that satisfy Google's technical ranking requirements from day one.",
    items: ["Core Web Vitals optimisation", "Crawl efficiency", "Sitemap & robots.txt", "Page speed audit & fixes"],
  },
  {
    icon: "🗺️",
    title: "Local AI SEO",
    desc: "Appear in Google Maps, local AI Overviews, and 'near me' searches. We optimise your Google Business Profile and local content footprint.",
    items: ["Google Business Profile optimisation", "Local schema markup", "Suburb landing pages", "Review velocity strategy"],
  },
  {
    icon: "📊",
    title: "AI Search Visibility Tracking",
    desc: "We track not just rankings, but how your brand appears in AI-generated answers, a new metric most agencies ignore.",
    items: ["AI mention monitoring", "GBP insights reporting", "Search Console integration", "Monthly AI visibility report"],
  },
  {
    icon: "💬",
    title: "Community & Platform Visibility",
    desc: "AI systems heavily weight Reddit, Quora, and forums when generating answers. We build your presence on the platforms AI models trust most.",
    items: ["Reddit & Quora authority building", "YouTube video SEO", "Industry forum presence", "Platform-specific content"],
  },
  {
    icon: "📰",
    title: "Digital PR & Brand Authority",
    desc: "Earned mentions on trusted sites build the entity authority that AI systems use to decide who to cite. We get your brand named where it matters.",
    items: ["NZ media & directory outreach", "Industry publication mentions", "Brand entity clarification", "Authority signal building"],
  },
];

const aiBenefit = [
  { icon: "🔍", title: "Google AI Overviews", desc: "AI-generated summaries appear above organic results for most searches. We structure your content with answer-first paragraphs and FAQ schema to get pulled in.", items: ["Answer-first content structuring", "FAQ & HowTo schema", "Featured snippet targeting"] },
  { icon: "💬", title: "ChatGPT & SearchGPT", desc: "When customers ask ChatGPT about local services, your business should appear. We build entity authority and third-party citations that ChatGPT draws from.", items: ["Entity authority building", "Third-party citation development", "Structured data for context"] },
  { icon: "🔗", title: "Perplexity", desc: "Perplexity cites sources with links, making it the most direct traffic driver among AI tools. We optimise your content for source attribution.", items: ["Source attribution optimisation", "Authoritative linked content", "Citation-worthy formatting"] },
  { icon: "⭐", title: "Gemini & Bing Copilot", desc: "Google Gemini and Microsoft Copilot both weight structured data and Bing Webmaster signals. We ensure your schema and indexing covers both ecosystems.", items: ["Bing Webmaster setup", "Schema emphasis for Copilot", "Cross-platform structured data"] },
  { icon: "🤖", title: "Claude", desc: "Anthropic's Claude uses llms.txt and crawlable content to understand businesses. We configure crawler access and content structure for Claude's indexing.", items: ["llms.txt configuration", "ClaudeBot crawler access", "AI-readable content structure"] },
];

const process = [
  { step: "1", title: "AI Visibility Audit", desc: "We audit your current visibility across Google, AI Overviews, and AI chat tools. You get a clear picture of where you appear, and where you're missing." },
  { step: "2", title: "Strategy & Content Plan", desc: "We identify the highest-impact keyword clusters, AI-answer opportunities, and schema gaps. A prioritised roadmap tailored to your industry." },
  { step: "3", title: "Implementation", desc: "Technical fixes, schema markup, content production, GBP optimisation, and on-page SEO, deployed in a structured monthly sprint." },
  { step: "4", title: "Track & Report", desc: "Monthly reporting covering rankings, organic traffic, AI citations, and GBP insights, so you can see the return on every dollar spent." },
];

const reviews = [
  { name: "Marcus Tane", company: "Tane Scaffolding Ltd", text: "Charlie built our site from scratch in under two weeks. We went from having nothing online to ranking on page one for 'scaffolding Auckland'. Enquiries started coming in within the first month. Worth every dollar." },
  { name: "Raj Sharma", company: "Sharma Electrical", text: "I was getting zero enquiries online. Within three months of launching the new site, I'm getting two to three calls a week from the website alone. Charlie set up Google Ads at the same time and it's paid for itself many times over." },
  { name: "Tom Blackwood", company: "Blackwood Plumbing", text: "Had a basic site that wasn't generating anything. Charlie fixed the SEO, rewrote the homepage, and set up a Google Ads campaign targeting emergency plumber searches. Best business investment I've made this year. The phone rings every day now." },
];

const faqs = [
  { q: "What is AI SEO and how is it different from regular SEO?", a: "Traditional <a href=\"/affordable-seo-auckland/\">SEO</a> focuses on ranking in Google's blue-link results. AI SEO (also called Generative Engine Optimisation or GEO) focuses on getting your content cited or featured in AI-generated answers from Google AI Overviews, ChatGPT, Perplexity, and similar tools. The techniques partially overlap, structured content, schema markup, authority signals, but GEO adds new layers like entity optimisation, citability structuring, and llms.txt setup." },
  { q: "Do Auckland small businesses really need to worry about AI search?", a: "Increasingly, yes. Google AI Overviews now appear on more than 58% of searches in the US and are rolling out globally. If someone asks 'best plumber in Ponsonby' and Google generates an AI answer, your business either appears in it or doesn't. We help you appear." },
  { q: "How do you get a business cited in ChatGPT or Perplexity?", a: "AI systems draw from crawlable web content, third-party mentions, and structured data. We improve your citability by: structuring content as direct answers, adding comprehensive schema markup, building authoritative mentions on third-party sites, and ensuring your GBP and directory presence is strong and consistent." },
  { q: "What is a GEO score?", a: "A GEO (Generative Engine Optimisation) score measures how likely AI systems are to cite your content. We assess factors like content citability, schema completeness, technical crawlability for AI bots, and brand mention presence across AI-training sources." },
  { q: "Does AI SEO replace traditional SEO?", a: "No, it extends it. Traditional ranking signals (links, speed, mobile performance, keyword relevance) still matter. AI SEO adds new optimisation layers on top. We do both together, see our full <a href=\"/affordable-seo-auckland/\">SEO services Auckland</a> and <a href=\"/local-seo-for-auckland-small-businesses/\">local SEO</a> offerings." },
  { q: "How much does AI SEO cost?", a: "Our AI SEO packages start from $500/month for a foundational GEO setup. Full AI SEO strategy and content production runs $1,000–$2,500/month depending on industry competitiveness and content volume. See our <a href=\"#pricing\">pricing section</a> for full details." },
  { q: "What is the difference between GEO and AEO (Answer Engine Optimisation)?", a: "GEO (Generative Engine Optimisation) focuses on getting cited in AI-generated content from tools like ChatGPT and Perplexity. AEO (Answer Engine Optimisation) focuses on appearing in answer boxes and featured snippets in traditional search. Both target similar content strategies, structured answers, schema markup, and authority signals. We cover both under our AI SEO service." },
  { q: "What is llms.txt and does my website need one?", a: "llms.txt is an emerging standard, similar to robots.txt, that helps AI systems understand your website's structure and key content. It tells AI crawlers what your business does, what pages matter most, and how to interpret your site. Most NZ agencies don't implement this yet. We do, our own site has one, and we set them up for every client." },
  { q: "How do you track AI citations and mentions?", a: "We monitor how your brand appears across AI platforms including Google AI Overviews, ChatGPT, Perplexity, and Gemini. Monthly reports show where you're being cited, which queries trigger mentions, and where there are gaps to target next." },
  { q: "Can you help my business appear on Reddit and Quora?", a: "Yes. AI systems heavily weight community platforms like Reddit and Quora when generating answers. We build authentic presence on these platforms through helpful, authoritative content that positions your business as a trusted source, which directly increases your chances of being cited by AI tools." },
