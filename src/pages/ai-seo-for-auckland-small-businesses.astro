---

<Layout
  title="AI SEO Agency Auckland | GEO & AI Search, From $500/mo"
  description="AI SEO agency Auckland: rank on Google, get cited by ChatGPT & AI Overviews. GEO from $500/month, no lock-in. Free AI visibility audit."
  canonicalURL="https://www.kiwiwebdesign.co.nz/ai-seo-for-auckland-small-businesses/"
  schema={schema}
  alternateUrl="https://www.kiwiwebdesign.co.nz/zh/ai-seo-for-auckland-small-businesses/"
>

  <PageHero
    eyebrow="AI SEO Agency Auckland"
    title="Rank on Google. Get cited by AI. Both."
    subtitle="We optimise Auckland businesses for Google AI Overviews, ChatGPT, Perplexity, Gemini, and Claude, so you get found and cited however your customers search."
    badgeText="Auckland's AI SEO & GEO Specialists"
    ctaPrimary={{ text: "Get a Free AI SEO Audit", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See How It Works", href: "#services" }}
  />

  <StatsRow items={stats} />

  <!-- AI citability snippet -->
  <div class="aiseo-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> provides AI SEO and Generative Engine Optimisation (GEO) for Auckland businesses, from <strong>$500/month</strong>. Services include schema markup, llms.txt setup, AI crawler configuration, entity authority building, and content structured for citation by ChatGPT, Perplexity, Gemini, Google AI Overviews, and Claude. Based in Grey Lynn, Auckland, 5★ Google rating from 50+ clients. No lock-in contracts.</p>
    </div>
  </div>

  <!-- Authority / Trust strip -->
  <section class="aiseo-trust-strip">
    <div class="container">
      <div class="aiseo-trust-inner">
        <div class="aiseo-trust-text">
          <p class="aiseo-trust-eyebrow">Why Kiwi Web Design for AI SEO</p>
          <h2>Auckland's AI search specialists, not a bolt-on service.</h2>
          <p>Most agencies treat AI SEO as an afterthought. We build it into every site and strategy from day one. Our own site runs on Astro, a modern static framework that loads faster and is easier for AI crawlers to parse than WordPress. We've deployed llms.txt, configured AI crawler access, and implemented comprehensive schema markup before most agencies even knew these existed.</p>
        </div>
        <div class="aiseo-trust-badges">
          <div class="aiseo-trust-badge">
            <span class="atb-num">50+</span>
            <span class="atb-lbl">NZ businesses ranked</span>
          </div>
          <div class="aiseo-trust-badge">
            <span class="atb-num">5★</span>
            <span class="atb-lbl">Google rating</span>
          </div>
          <div class="aiseo-trust-badge">
            <span class="atb-num">llms.txt</span>
            <span class="atb-lbl">Deployed on our own site</span>
          </div>
          <div class="aiseo-trust-badge">
            <span class="atb-num">$0</span>
            <span class="atb-lbl">Lock-in contracts</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why AI search matters, platform-specific strategies -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="The AI Search Shift"
        title="Search is changing. Your SEO strategy should too."
        subtitle="AI-generated answers now appear above organic results for more than half of all searches. We optimise for every platform your customers use."
      />
      <div class="aiseo-engines">
        {aiBenefit.map(({ icon, title, desc, items }) => (
          <div class="aiseo-engine-card">
            <span class="aiseo-eng-icon"><Icon name={icon} size={24} /></span>
            <h3 class="aiseo-eng-title">{title}</h3>
            <p class="aiseo-eng-desc">{desc}</p>
            {items && (
              <ul class="aiseo-eng-items">
                {items.map((item: string) => <li>{item}</li>)}
              </ul>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" id="services">
    <div class="container">
      <SectionHeader
        eyebrow="AI SEO Services"
        title="Every layer of modern search optimisation."
        subtitle="From technical foundations to AI-citability content and digital PR, we cover every ranking signal that matters in 2026 and beyond."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- Results strip (dark) -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader eyebrow="Real Results" title="What our clients achieve." light={true} />
      <div class="seo-results">
        <div class="seo-result">
          <span class="sr-num">+125%</span>
          <span class="sr-label">Quote Requests</span>
          <span class="sr-industry">Scaffolding Business</span>
        </div>
        <div class="seo-result">
          <span class="sr-num">3.8×</span>
          <span class="sr-label">More Qualified Leads</span>
          <span class="sr-industry">Trades & Construction</span>
        </div>
        <div class="seo-result">
          <span class="sr-num">+87%</span>
          <span class="sr-label">Organic Traffic</span>
          <span class="sr-industry">Plumbing Business</span>
        </div>
        <div class="seo-result">
          <span class="sr-num">3–6 mo</span>
          <span class="sr-label">Average time to results</span>
          <span class="sr-industry">Most Auckland businesses</span>
        </div>
      </div>
    </div>
  </section>

  <!-- What traditional vs AI SEO looks like -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="Traditional vs AI SEO"
        title="What we do differently."
        light={true}
        subtitle="Standard SEO agencies optimise for blue links. We optimise for the full search landscape."
      />
      <div class="aiseo-compare">
        <div class="aiseo-compare-col">
          <p class="aiseo-compare-label">Traditional SEO only</p>
          <ul class="aiseo-compare-list aiseo-compare-list--old">
            <li>Optimise page titles & meta descriptions</li>
            <li>Build backlinks</li>
            <li>Target keyword rankings</li>
            <li>Improve page speed</li>
          </ul>
        </div>
        <div class="aiseo-compare-divider">+</div>
        <div class="aiseo-compare-col aiseo-compare-col--new">
          <p class="aiseo-compare-label aiseo-compare-label--new">What we add with AI SEO</p>
          <ul class="aiseo-compare-list aiseo-compare-list--new">
            <li>Structure content as direct answers AI can cite</li>
            <li>Add comprehensive JSON-LD schema (speakable, FAQ, HowTo)</li>
            <li>Build entity authority via third-party mentions</li>
            <li>Set up llms.txt and AI crawler access</li>
            <li>Optimise for AI Overviews and featured snippets</li>
            <li>Track AI citation mentions monthly</li>
            <li>Build community presence on Reddit, Quora & YouTube</li>
            <li>Configure AI crawler access (ChatGPT-User, PerplexityBot, ClaudeBot)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section aiseo-process-section" style="background: var(--kwd-cream);">
    <div class="container">
      <div class="aiseo-process-split">
        <div class="aiseo-process-content">
          <SectionHeader
            eyebrow="How It Works"
            title="Audit, plan, build, report."
            subtitle="A structured monthly engagement that compounds over time."
          />
          <ProcessSteps items={process} />
        </div>
        <div class="aiseo-process-img-wrap">
          <Image src={consultImg} alt="SEO strategy consultation, Kiwi Web Design Auckland" width={600} height={700} class="aiseo-process-img" />
          <div class="aiseo-process-pill">Free AI visibility audit included</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section">
    <div class="container">
      <SectionHeader eyebrow="Client Reviews" title="What our SEO clients say." />
      <TestimonialGrid items={reviews} cols={3} />
    </div>
  </section>

  <!-- Pricing -->
  <section class="section" style="background: var(--kwd-cream);" id="pricing">
    <div class="container">
      <SectionHeader
        eyebrow="Pricing"
        title="AI SEO Pricing for Auckland Businesses"
        subtitle="No lock-in contracts. Every engagement starts with a free AI visibility audit."
      />
      <div class="seo-pkg-grid">
        <div class="seo-pkg">
          <h3>AI SEO Foundations</h3>
          <p class="seo-price">From $500<span class="seo-period">/mo</span></p>
          <p class="seo-pkg-desc">For businesses wanting AI-ready technical setup alongside foundational SEO.</p>
          <ul class="seo-pkg-list">
            <li>AI-ready schema markup (JSON-LD)</li>
            <li>llms.txt setup & configuration</li>
