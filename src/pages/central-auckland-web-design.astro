---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import PageVisual from '../components/PageVisual.astro';
import centralAucklandImage from '../assets/general/Auckland-CBD.jpg';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/central-auckland-web-design/",
      "url": "https://www.kiwiwebdesign.co.nz/central-auckland-web-design/",
      "name": "Central Auckland Web Design | CBD, Ponsonby, Parnell & Newmarket",
      "description": "Web design for central Auckland businesses. Serving the CBD, Ponsonby, Grey Lynn, Parnell, Newmarket, and Mount Eden. Competitive websites for NZ's most demanding market.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/central-auckland-web-design/#breadcrumb" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": [".loc-snippet", ".loc-hero-text"] }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/central-auckland-web-design/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Central Auckland Web Design", "item": "https://www.kiwiwebdesign.co.nz/central-auckland-web-design/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "Place", "name": "Auckland CBD" },
        { "@type": "Place", "name": "Ponsonby, Auckland" },
        { "@type": "Place", "name": "Grey Lynn, Auckland" },
        { "@type": "Place", "name": "Parnell, Auckland" },
        { "@type": "Place", "name": "Newmarket, Auckland" },
        { "@type": "Place", "name": "Mount Eden, Auckland" },
        { "@type": "Place", "name": "Kingsland, Auckland" }
      ],
      "geo": { "@type": "GeoCoordinates", "latitude": -36.8523, "longitude": 174.7691 },
      "priceRange": "$$",
      "logo": { "@type": "ImageObject", "url": "https://www.kiwiwebdesign.co.nz/favicon.png", "width": 512, "height": 512 }
    },
    {
      "@type": "Service",
      "@id": "https://www.kiwiwebdesign.co.nz/central-auckland-web-design/#service",
      "name": "Web Design, Central Auckland",
      "serviceType": "Website Design",
      "category": "Web Development",
      "description": "WordPress website design for Auckland CBD, Ponsonby, Parnell, Newmarket, and Grey Lynn businesses. From $1,290 + GST.",
      "provider": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "areaServed": [
        { "@type": "Place", "name": "Auckland CBD" },
        { "@type": "Place", "name": "Ponsonby, Auckland" },
        { "@type": "Place", "name": "Parnell, Auckland" },
        { "@type": "Place", "name": "Newmarket, Auckland" }
      ],
      "url": "https://www.kiwiwebdesign.co.nz/central-auckland-web-design/",
      "offers": { "@type": "Offer", "price": "1290", "priceCurrency": "NZD", "priceSpecification": { "@type": "PriceSpecification", "price": "1290", "priceCurrency": "NZD", "valueAddedTaxIncluded": false } }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Central Auckland has massive agencies. Why would I use Kiwi Web Design?", "acceptedAnswer": { "@type": "Answer", "text": "Central Auckland agencies typically charge $15,000–$50,000+ for the same website we build from $1,990 + GST. That premium goes to account managers, project coordinators, and office rent, not to the quality of your site. You work directly with Charlie, and the output is the same quality website at a fraction of the price." } },
        { "@type": "Question", "name": "Is Google Ads viable for a small CBD business given the high CPCs?", "acceptedAnswer": { "@type": "Answer", "text": "It depends on your margins and conversion rate. For a law firm or financial adviser where a single client is worth $5,000+, even a $30 CPC campaign is viable if the landing page converts. For a café competing on $15 coffees, Google Ads is usually not the right play, local SEO and Google Business Profile are a better investment." } },
        { "@type": "Question", "name": "Can you help a Ponsonby restaurant get more Google visibility?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Ponsonby restaurant SEO combines Google Business Profile optimisation (photos, reviews, menu URL, regular posts), an HTML menu page on your website (which Google can index and understand), and local citation consistency. These three things together make a meaningful difference to where you appear in local restaurant searches." } },
        { "@type": "Question", "name": "We're a CBD startup, we need a website fast. How fast is fast?", "acceptedAnswer": { "@type": "Answer", "text": "A simple brochure site or launch page can be live in 5–7 business days. A full multi-page site with services, about, and contact sections typically takes 2–3 weeks. If speed is your primary constraint, tell us in the discovery call and we'll prioritise accordingly." } },
        { "@type": "Question", "name": "We've had bad experiences with Auckland web agencies. What's different here?", "acceptedAnswer": { "@type": "Answer", "text": "No account managers, no scope creep, no 'we'll add that for an extra $500'. You get a fixed price before we start, direct communication with Charlie throughout, and a clean handover at launch. If something isn't right, we fix it, not add it to a new quote." } }
      ]
    }
  ]
};

const services = [
  {
    icon: "🏢",
    title: "Corporate & Professional Services",
    desc: "CBD and Parnell professional services firms, consultancies, law firms, accountants, financial advisers, compete in NZ's most saturated market. We build sites that communicate credibility and convert at the highest possible rate.",
    items: ["Authority-first design", "Service/practice area pages", "Team profile pages", "B2B-focused copy and CTAs"],
  },
  {
    icon: "🍽️",
    title: "Hospitality, CBD to Ponsonby",
    desc: "Central Auckland hospitality is intensely competitive. Ponsonby Road restaurants, CBD bars, and Newmarket cafes all compete for the same diners. A website that loads fast, shows your menu, and takes reservations is the minimum threshold.",
    items: ["HTML menu (not PDF)", "Online reservations", "Food photography showcase", "Function enquiry page"],
  },
  {
    icon: "🛍️",
    title: "Retail & Fashion",
    desc: "Newmarket, Parnell, and Grey Lynn boutiques are competing with international online retailers. A well-built website, and optionally a WooCommerce store, keeps local customers buying local.",
    items: ["Product showcase or shop", "Lookbook / gallery", "Click & collect", "Instagram integration"],
  },
  {
    icon: "🎯",
    title: "Google Ads, Central Auckland",
    desc: "Central Auckland Google Ads are the most expensive in NZ, competitive categories can run $15–$40+ per click. We build campaigns that maximise quality score and conversion rate so every dollar works harder.",
    items: ["Quality Score optimisation", "Dedicated landing pages per campaign", "Negative keyword management", "Conversion tracking"],
  },
  {
    icon: "🔍",
    title: "CBD & Suburb SEO",
    desc: "Ranking in central Auckland requires more sophisticated SEO than the suburbs. Higher competition means more content depth, stronger link profiles, and technical SEO that's been done properly from the ground up.",
    items: ["Technical SEO foundations", "Content depth (1,500+ word pages)", "Ponsonby / Newmarket suburb targeting", "Competitor gap analysis"],
  },
  {
    icon: "🏨",
    title: "Tourism & Accommodation",
    desc: "Auckland CBD hotels, boutique accommodation, and tourism operators compete for direct bookings against OTAs. We build booking-capable sites with schema markup that Google uses to display rich results.",
    items: ["Direct booking integration", "Hotel or activity schema", "Guest review showcase", "Tour and itinerary pages"],
  },
];

const areas = [
  { name: "Auckland CBD", note: "NZ's commercial centre. Every industry, highest competition, highest stakes." },
  { name: "Ponsonby & Grey Lynn", note: "Premium hospitality, boutique retail, creative and professional services." },
  { name: "Parnell", note: "Heritage precinct, galleries, restaurants, and established professional firms." },
  { name: "Newmarket", note: "Retail and fashion hub. High foot traffic and strong digital search intent." },
  { name: "Mount Eden & Kingsland", note: "Neighbourhood commercial strips. Independent hospitality and services." },
  { name: "Grafton & Epsom", note: "Medical, legal, and educational precinct. High-trust services and specialists." },
];

const faqs = [
  { q: "Central Auckland has massive agencies. Why would I use Kiwi Web Design?", a: "Central Auckland agencies typically charge $15,000–$50,000+ for the same website we build from $1,990 + GST. That premium goes to account managers, project coordinators, and office rent, not to the quality of your site. You work directly with Charlie, and the output is the same quality website at a fraction of the price. See our <a href=\"/small-business-website-design-auckland/\">web design packages</a> for transparent pricing." },
  { q: "Is Google Ads viable for a small CBD business given the high CPCs?", a: "It depends on your margins and conversion rate. For a law firm or financial adviser where a single client is worth $5,000+, even a $30 CPC campaign is viable if the landing page converts. For a café competing on $15 coffees, Google Ads is usually not the right play, <a href=\"/local-seo-for-auckland-small-businesses/\">local SEO</a> and Google Business Profile are a better investment." },
  { q: "Can you help a Ponsonby restaurant get more Google visibility?", a: "Yes. Ponsonby restaurant SEO combines Google Business Profile optimisation (photos, reviews, menu URL, regular posts), an HTML menu page on your website (which Google can index and understand), and local citation consistency. These three things together make a meaningful difference to where you appear in local restaurant searches. Our <a href=\"/local-seo-for-auckland-small-businesses/\">local SEO service</a> covers all of this." },
  { q: "We're a CBD startup, we need a website fast. How fast is fast?", a: "A simple brochure site or launch page can be live in 5–7 business days. A full multi-page site with services, about, and contact sections typically takes 2–3 weeks. Check our <a href=\"/small-business-website-design-auckland/\">small business packages</a> for scope and turnaround details. If speed is your primary constraint, tell us in the discovery call and we'll prioritise accordingly." },
  { q: "We've had bad experiences with Auckland web agencies. What's different here?", a: "No account managers, no scope creep, no 'we'll add that for an extra $500'. You get a fixed price before we start, direct communication with Charlie throughout, and a clean handover at launch. We also offer ongoing <a href=\"/affordable-seo-auckland/\">SEO services</a> post-launch to keep your site growing. If something isn't right, we fix it, not add it to a new quote." },
];
---

<Layout
  title="Central Auckland Web Design | CBD, Ponsonby, Parnell & Newmarket"
  description="Web design for central Auckland businesses. Serving the CBD, Ponsonby, Grey Lynn, Parnell, Newmarket, and Mount Eden. Competitive websites for NZ's most demanding market."
  canonicalURL="https://www.kiwiwebdesign.co.nz/central-auckland-web-design/"
  schema={schema}
>

  <!-- Hero -->
  <section class="loc-hero">
    <div class="container">
      <div class="loc-hero-inner">
        <div class="loc-hero-text">
          <p class="loc-hero-eyebrow">Central Auckland Web Design</p>
          <h1>In central Auckland, your website is always competing with the best.</h1>
          <p class="loc-hero-sub">Web design for Auckland CBD, Ponsonby, Parnell, Newmarket, and Grey Lynn. NZ's most competitive market demands professional design, sharp copy, and SEO that's been done properly from the ground up.</p>
          <div class="loc-hero-btns">
            <a href="/website-designer-auckland/" class="loc-btn-primary">Get a Free Quote</a>
            <a href="/small-business-website-design-auckland/" class="loc-btn-outline">View Packages</a>
          </div>
        </div>
        <div class="loc-hero-card">
          <p class="lhc-label">Serving Central Auckland</p>
          <ul class="lhc-areas">
            <li>Auckland CBD</li>
            <li>Ponsonby & Grey Lynn</li>
            <li>Parnell</li>
            <li>Newmarket</li>
            <li>Mount Eden</li>
            <li>Kingsland & Grafton</li>
          </ul>
          <p class="lhc-note">Remote-first. In-person meetings available for CBD and central Auckland clients.</p>
        </div>
      </div>
    </div>
  </section>

  <PageVisual
    imgSrc={centralAucklandImage.src}
    imgAlt="Central Auckland skyline representing CBD web design clients"
    imgTitle="Central Auckland web design for CBD and inner-suburb businesses"
    eyebrow="Local Context"
    title="Built for Auckland's most competitive business districts."
    caption="A stronger visual presence helps CBD, Ponsonby, Parnell, and Newmarket businesses communicate trust before a buyer ever makes contact."
  />

  <!-- AI citability snippet -->
  <div class="loc-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> builds websites for central Auckland businesses, CBD, Ponsonby, Parnell, Newmarket, and Grey Lynn, from <strong>$1,290 + GST</strong>. Designed for NZ's most competitive market, sites are delivered in 2–3 weeks with local SEO built in. Based in Grey Lynn, Auckland, with a 5★ Google rating.</p>
    </div>
  </div>

  <!-- Central Auckland context -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="The Central Auckland Market"
        title="NZ's most competitive digital market, and the most rewarding to get right."
        subtitle="The CBD and inner suburbs are where NZ's most sophisticated consumers, businesses, and decision-makers are concentrated. Getting your online presence right here has an outsized return."
      />
      <div class="loc-context">
        <div class="loc-context-text">
          <p>Central Auckland is where NZ's most competitive categories play out: corporate services, hospitality, retail, and professional services all competing for clients who have abundant alternatives and high standards.</p>
          <p>The bar for what a 'good' website looks like in central Auckland is set by the well-funded agencies and established brands operating here. A small business in Ponsonby or the CBD is implicitly judged against that standard, not against what the average NZ small business website looks like.</p>
          <p>That doesn't mean you need to spend $30,000. It means you need a professional who understands the market and builds to the right standard. We do that, at small business prices.</p>
        </div>
        <div class="loc-areas-grid">
          {areas.map(({ name, note }) => (
            <div class="loc-area-card">
              <strong class="lac-name">{name}</strong>
              <p class="lac-note">{note}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Services"
        title="What central Auckland businesses need online."
        subtitle="From CBD corporate sites to Ponsonby restaurant websites, built for the most demanding market in NZ."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Central Auckland Web Design Questions"
        subtitle="What CBD, Ponsonby, and Newmarket businesses ask about working with us."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design Packages</a>
        <a href="/local-seo-for-auckland-small-businesses/" class="rps-link">Local SEO</a>
        <a href="/west-auckland-web-design/" class="rps-link">West Auckland</a>
        <a href="/north-shore-website-design/" class="rps-link">North Shore</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Build a central Auckland website that competes."
    subtitle="Free consultation, we'll tell you exactly what it takes to stand out in your specific market."
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Our Work", href: "/testimonials-reviews/" }}
  />

</Layout>

<style>
  .loc-hero { background: var(--kwd-dark); color: #fff; padding: 4rem 0 3.5rem; }
  .loc-hero-inner { display: grid; grid-template-columns: 1fr auto; gap: 3rem; align-items: start; }
  .loc-hero-eyebrow { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--kwd-yellow); margin: 0 0 1rem; }
  .loc-hero-text h1 { font-family: var(--kwd-font-heading); font-size: clamp(1.75rem, 3.5vw, 2.75rem); line-height: 1.18; margin: 0 0 1.1rem; color: #fff; }
  .loc-hero-sub { font-size: 1rem; color: rgba(255,255,255,0.7); line-height: 1.65; max-width: 540px; margin: 0 0 2rem; }
  .loc-hero-btns { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .loc-btn-primary { background: var(--kwd-yellow); color: var(--kwd-dark); padding: 0.75rem 1.75rem; border-radius: 6px; font-weight: 700; text-decoration: none; font-size: 0.95rem; }
  .loc-btn-outline { border: 2px solid rgba(255,255,255,0.35); color: rgba(255,255,255,0.85); padding: 0.75rem 1.75rem; border-radius: 6px; font-weight: 600; text-decoration: none; font-size: 0.95rem; }
  .loc-hero-card { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); border-radius: 16px; padding: 1.75rem; min-width: 220px; flex-shrink: 0; }
  .lhc-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-yellow); margin: 0 0 0.875rem; }
  .lhc-areas { list-style: none; padding: 0; margin: 0 0 1rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .lhc-areas li { font-size: 0.875rem; color: rgba(255,255,255,0.82); padding-left: 1.1rem; position: relative; }
  .lhc-areas li::before { content: "✓"; position: absolute; left: 0; color: var(--kwd-yellow); font-size: 0.72rem; top: 0.15rem; }
  .lhc-note { font-size: 0.72rem; color: rgba(255,255,255,0.35); margin: 0; line-height: 1.55; }
  .loc-context { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; margin-top: 2.5rem; align-items: start; }
  .loc-context-text p { font-size: 0.9rem; color: var(--kwd-brown); line-height: 1.75; margin-bottom: 0.875rem; }
  .loc-areas-grid { display: flex; flex-direction: column; gap: 0.75rem; }
  .loc-area-card { background: #fff; border: 1.5px solid rgba(0,0,0,0.07); border-radius: 10px; padding: 0.875rem 1.125rem; }
  .lac-name { font-size: 0.875rem; font-weight: 700; color: var(--kwd-dark); display: block; margin-bottom: 0.2rem; }
  .lac-note { font-size: 0.78rem; color: var(--kwd-brown); margin: 0; line-height: 1.5; }
  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
  .loc-snippet { background: #fff8e1; border-left: 4px solid var(--kwd-yellow); padding: 1rem 0; }
  .loc-snippet p { margin: 0; font-size: 0.95rem; line-height: 1.65; color: var(--kwd-dark); }
  @media (max-width: 900px) {
    .loc-hero-inner { grid-template-columns: 1fr; }
    .loc-hero-card { display: none; }
    .loc-context { grid-template-columns: 1fr; }
  }
</style>
