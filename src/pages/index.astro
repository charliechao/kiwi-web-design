};

const services = [
  {
    icon: 'WD',
    title: 'Website Design',
    role: 'Convert',
    desc: 'The foundation of the system: a fast, credible website engineered to turn visitors into calls, quote requests, and bookings.',
    href: '/small-business-website-design-auckland/',
  },
  {
    icon: 'SEO',
    title: 'SEO Auckland',
    role: 'Compound',
    desc: 'Local SEO and AI SEO that grow your Google and Maps visibility month over month, so qualified traffic keeps arriving without paying per click.',
    href: '/affordable-seo-auckland/',
  },
  {
    icon: 'ADS',
    title: 'Google Ads',
    role: 'Accelerate',
    desc: 'Buying-intent traffic from day one. Campaigns and landing pages tuned to a cost per lead that makes sense for your margins.',
    href: '/google-ads/',
  },
];

const stats = [
  { number: '50+', label: 'NZ businesses helped' },
  { number: '5\u2605', label: 'Google rating' },
  { number: '$28', label: 'Cost per lead on a live client Ads campaign' },
  { number: '2-3 wks', label: 'Typical website launch' },
];

const whyUs = [
  'Direct with Charlie Chao from strategy through launch, no account managers, no offshore handoff',
  'Website, SEO, and Google Ads under one roof, all pointing at the same conversion goal',
  'Clear pricing upfront: websites from $1,290, SEO from $500/month, no lock-in contracts',
  'Grey Lynn based with real Auckland suburb intent and local search knowledge',
];

const process = [
  { step: '1', title: 'Free growth plan', desc: 'We audit your website, rankings, and ad opportunity, then map the fastest path to more enquiries. No cost, no pressure.' },
  { step: '2', title: 'Foundation: the website', desc: 'We build or tune the site so visitors convert. Clear offer, trust signals, fast pages, and enquiry tracking wired in from day one.' },
  { step: '3', title: 'Visibility: SEO + Google Ads', desc: 'Local SEO compounds your organic reach while Google Ads brings buying-intent traffic immediately. Each channel feeds the same pipeline.' },
  { step: '4', title: 'Report and scale', desc: 'Monthly plain-English reporting tied to enquiries, not vanity metrics. We scale what works and cut what does not.' },
];

// Verbatim 5-star Google reviews (kiwiwebdesign.co.nz Business Profile). Shared with /web-design-auckland-lp/.
const reviews = [
  { name: "Eduardo Arnez", company: "Aesthetic Painting & Deco", text: "Charlie from Kiwi Web Design did an outstanding job designing our website. He was incredibly helpful throughout the entire process, offering great ideas and maintaining excellent communication. We're extremely happy with both the look and functionality of the final result. Highly recommend!" },
  { name: "Francesco Moretti", text: "Kiwi Web Design doesn't just build website, they actually focus on getting you found online. Their approach to SEO and AI search made a big difference for us. We're now showing up in more places and getting more enquires." },
  { name: "Charles Haddix", avatar: "/images/reviews/charles-haddix.png", text: "We recently got our website rebuilt by Kiwi Web Design in Auckland, and honestly, it was such a good experience. Charlie made everything really easy to understand and kept us in the loop the whole way through. The new site looks great on both phone and desktop, and we've already noticed more people finding us on Google and getting in touch. Couldn't recommend Kiwi Web Design enough if you're after an affordable, professional web designer in Auckland." },
  { name: "Deborah Shaw", company: "Deborah Shaw Editing", avatar: "/images/reviews/deborah-shaw.png", text: "Charlie is fantastic to work with! I got stuck fiddling around with WordPress blocks, but Charlie came to the rescue. He understood what I was wanting with my website and made my ideas come together. Thank you!" },
  { name: "Zane Barrett", company: "Barrett Access Scaffolding", text: "We recently worked with Kiwiweb to design and launch our new website, and we couldn't be happier with the results. The team was professional, responsive, and really took the time to understand our business. They helped us create a modern, easy-to-navigate site and incorporated some amazing features, including a scaffold cost calculator – the first of its kind in NZ! This has already set us apart in our industry and made quoting so much easier for our clients. Communication was clear and efficient throughout, and any tweaks we needed were handled quickly. I highly recommend Kiwiweb to anyone looking for a web design team that delivers both creativity and functionality." },
  { name: "Steven Liu", company: "Kiwiland Constructions", avatar: "/images/reviews/steven-liu.png", text: "Outstanding Experience with Kiwi Web Design and Charlie! I couldn't be happier with the website that Kiwi Web Design created for me. From start to finish, Charlie was professional, responsive, and incredibly easy to work with. He took the time to understand exactly what I wanted, offered helpful suggestions, and delivered a final product that exceeded my expectations. The design is clean, modern, and user-friendly — exactly what I was hoping for. Charlie made the whole process smooth and stress-free, and he was always quick to answer any questions I had. His attention to detail and commitment to quality really stood out. If you're looking for a reliable, talented web designer who truly cares about your vision, I highly recommend Kiwi Web Design and Charlie. Five stars all the way!" },
  { name: "Jack at Show Me Shorts", avatar: "/images/reviews/jack-show-me-shorts.png", text: "Kiwi Web Design were fantastic to work with. From the very beginning they really took the time to understand what I needed and offered smart, practical solutions. The team were professional, friendly and quick to respond whenever I had questions. If you're looking for a reliable, creative, and genuinely helpful web design team in New Zealand, I'd definitely recommend Kiwi Web Design." },
  { name: "Tony S", company: "Streetfood Network", avatar: "/images/reviews/tony-s.png", text: "Charlie from Kiwi Web Design has been great to work with. He communicates clearly, responds promptly, and makes the process easy to understand. The pricing has been reasonable, and I've appreciated his practical approach to building and improving our Streetfood Network website. I would recommend Kiwi Web Design to any small business looking for reliable website support. Business has since taken off and the Website is amazing!" },
  { name: "Iby V.", company: "Yoga Teacher", text: "Charlie from Kiwi Web Design helped me design a flyer for my studio, and I'm really happy with the result. He was easy to communicate with, understood what I needed, and created something professional, clean, and aligned with the feeling of my business. The process was smooth and thoughtful, and I appreciated the care he put into making the flyer look polished and effective. I'd happily recommend Charlie and Kiwi Web Design to any small business owner who needs help with design, websites, or digital marketing." },
  { name: "Elisabeth Krull", text: "Kiwi Web Design is helping me with an international website. I can highly recommend working with Charlie — both professionally and personally!" },
  { name: "Gina Dellabarca", company: "Showme Short Film Festival", avatar: "/images/reviews/gina-dellabarca.png", text: "They provided a comprehensive and helpful website audit for us. Clear information. Great communication." },
  { name: "Dave G", text: "Charlie was very responsive to my concerns and demonstrated a strong understanding of the issues I raised. Excellent service and support — thank you." },
];

// Full-colour Google "G" logo (official 4-colour mark).
const googleG = '<path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34C2.85 17.09 2 20.45 2 24s.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/>';
const avatarColors = ['#d93b8f', '#5b8def', '#8b5cf6', '#0ea5a4', '#e0672c', '#3f7d4f', '#c0392b', '#2f6f9f'];

const portfolio = [
  { src: '/portfolio/prime-industrial.webp', alt: 'Prime Industrial website', caption: 'Prime Industrial', href: 'https://primeindustrial.co.nz/' },
  { src: '/portfolio/barrett-access-scaffolding.webp', alt: 'Barrett Access Scaffolding website', caption: 'Barrett Access Scaffolding', href: 'https://www.barrettaccessscaffolding.com/' },
  { src: beautyTouchPreview.src, alt: 'Beauty Touch Auckland website', caption: 'Beauty Touch Auckland', href: 'https://www.beautytouch.co.nz/' },
  { src: '/portfolio/gom.webp', alt: 'Goldwing website', caption: 'Goldwing', href: 'https://gom.co.nz/' },
  { src: '/portfolio/the-framers-guild.webp', alt: 'The Framers Guild framing website', caption: 'The Framers Guild', href: 'https://theframersguild.co.nz/' },
  { src: '/portfolio/kebudel.webp', alt: 'Kebudel website', caption: 'Kebudel', href: 'https://kebudel.com/' },
  { src: '/portfolio/asc-homes.webp', alt: 'ASC Homes website', caption: 'ASC Homes', href: 'https://asc-homes.pages.dev/' },
  { src: '/portfolio/aesthetic-painting.webp', alt: 'Aesthetic Painting website', caption: 'Aesthetic Painting', href: 'https://aestheticpainting.co.nz/' },
  { src: '/portfolio/mt-albert-business.jpg', alt: 'Mt Albert Business Association website', caption: 'Mt Albert Business Assoc.', href: 'https://mtalbert.org.nz/' },
  { src: '/blog/600-21B675F7-8EB5-45A5-99242870729DC26D.png', alt: 'TopRated.nz platform', caption: 'TopRated.nz', href: 'https://www.toprated.nz/' },
];

const portfolioLoop = [...portfolio, ...portfolio];

const faqs = [
  { q: 'Do you just build websites, or run the marketing too?', a: 'Both. The website is the foundation, then we run <a href="/affordable-seo-auckland/">SEO</a> and <a href="/google-ads/">Google Ads</a> on top of it as one system. You can start with just a website, and add the growth channels when you want steady lead flow.' },
  { q: 'How much does a small business website cost in Auckland?', a: 'Our packages start from $1,290 for a lead-focused website. More complex builds are priced accordingly, and you know the cost upfront. Use our <a href="/affordable-web-design-auckland/website-cost-new-zealand-small-business/">free website cost calculator</a> to get an instant NZ estimate.' },
  { q: 'What does a full lead generation system cost per month?', a: 'A typical setup: website from $1,290 one-off, <a href="/affordable-seo-auckland/">SEO from $500/month</a>, and Google Ads management scoped to your budget and goals. No lock-in contracts on any of it. Every engagement starts with a free growth plan so you only pay for what your business actually needs.' },
  { q: 'How fast will I see leads?', a: 'Google Ads can generate enquiries within days of launch. SEO typically shows meaningful movement in 3-6 months and compounds from there. A conversion-focused website improves enquiry rates immediately. That is why the system uses all three: fast results while the long-term channels build.' },
  { q: 'Can a web design company in Auckland help with leads, not just design?', a: 'Yes. Good web design should improve enquiries by making the offer clearer, building trust faster, and giving SEO and Google Ads traffic a stronger page to land on. That is exactly how we build.' },
];

const exploreGroups = [
  {
    label: 'Popular services',
    links: [
      { text: 'Website design packages', href: '/small-business-website-design-auckland/' },
      { text: 'Local SEO Auckland', href: '/local-seo-for-auckland-small-businesses/' },
      { text: 'AI SEO & GEO', href: '/ai-seo-for-auckland-small-businesses/' },
      { text: 'Google Ads Auckland', href: '/google-ads/' },
    ],
  },
  {
    label: 'Industries',
    links: [
      { text: 'Tradies', href: '/tradie-website-design-auckland/' },
      { text: 'Beauty & Wellness', href: '/how-kiwi-web-design-helps-auckland-beauty-industry/' },
      { text: 'Restaurants & Cafes', href: '/how-kiwi-web-design-helps-auckland-restaurants/' },
      { text: 'Healthcare', href: '/how-kiwi-web-design-helps-auckland-healthcare/' },
    ],
  },
  {
    label: 'Auckland areas',
    links: [
      { text: 'North Shore', href: '/north-shore-website-design/' },
      { text: 'South Auckland', href: '/south-auckland-web-design/' },
      { text: 'West Auckland', href: '/west-auckland-web-design/' },
      { text: 'East Auckland', href: '/east-auckland-web-design/' },
    ],
  },
];
---

<Layout
  title="Web Design & Digital Marketing Auckland | Kiwi Web Design"
  description="Auckland web design and digital marketing agency for service businesses. Website, local SEO, and Google Ads built as one lead generation system. Grey Lynn based."
  canonicalURL="https://www.kiwiwebdesign.co.nz/"
  schema={schema}
  alternateUrl="https://www.kiwiwebdesign.co.nz/zh/"
>
  <section class="hp-hero">
    <div class="hp-hero-glow hp-hero-glow-one" aria-hidden="true"></div>
    <div class="hp-hero-glow hp-hero-glow-two" aria-hidden="true"></div>
    <div class="container hp-hero-shell">
      <div class="hp-hero-copy">
        <div class="hp-kicker-row">
          <p class="hp-eyebrow hp-hero-seq" style="--hero-delay: 0.04s;">Web Design &amp; Digital Marketing Auckland</p>
          <span class="hp-location-pill hp-hero-seq" style="--hero-delay: 0.12s;">Grey Lynn, Auckland</span>
        </div>
        <h1 class="hp-headline hp-hero-seq" style="--hero-delay: 0.18s;">Web design and digital marketing that turn Auckland businesses into lead machines.</h1>
        <p class="hp-lead hp-hero-seq" style="--hero-delay: 0.3s;">Kiwi Web Design is an Auckland digital marketing agency for service businesses. We build the website, rank it with local SEO and AI SEO, and drive buying-intent traffic with Google Ads. One system, one goal: steady, qualified enquiries.</p>
        <div class="hp-ctas hp-hero-seq" style="--hero-delay: 0.42s;">
          <a href="/website-designer-auckland/" class="hp-btn-primary">Get a Free Growth Plan</a>
          <a href="#results" class="hp-btn-secondary">See Client Results</a>
        </div>
        <div class="hp-proof-row hp-hero-seq" style="--hero-delay: 0.52s;">
          <a href="https://share.google/nciRqe4rK6ywabSVx" target="_blank" rel="noopener" class="hp-review-pill">
            <div class="review-pill-badge">Google</div>
            <div>
              <p class="htc-text"><strong>5/5</strong> Google Reviews</p>
              <p class="htc-sub">Read verified reviews from Auckland clients</p>
            </div>
          </a>
          <p class="hp-mini-note">Work directly with Charlie Chao. Free growth plan, no obligation. Websites live in 2-3 weeks.</p>
        </div>
      </div>

      <div class="hp-stage" data-stage-parallax>
        <div class="hp-stage-window-shell hp-hero-seq" style="--hero-delay: 0.24s;">
          <div class="hp-stage-window">
            <div class="hp-stage-topline">
              <span>Conversion-first build</span>
            </div>
            <video class="hp-stage-video" autoplay muted loop playsinline preload="none" poster="/hero-poster.webp">
              <source src={aucklandVideo} type="video/mp4" />
            </video>
            <div class="hp-stage-overlay" aria-hidden="true"></div>
            <div class="hp-stage-caption">
              <p class="hp-stage-label">Launch faster, convert harder</p>
              <p class="hp-stage-title">Auckland website design should feel credible in five seconds and convert cleanly when SEO or ad traffic arrives.</p>
            </div>
          </div>
        </div>

        <div class="hp-stage-cards">
          {stats.map(({ number, label }, index) => (
            <div class="hp-stat-card hp-hero-seq" style={`--hero-delay: ${0.58 + index * 0.08}s;`}>
              <span class="hp-stat-number">{number}</span>
              <span class="hp-stat-label">{label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- The lead generation system — the repositioning made visible -->
  <section class="section hp-system-section" id="system">
    <div class="container" data-reveal>
      <div class="hp-motion-heading" style="--motion-delay: 0ms;">
        <SectionHeader
          eyebrow="The Lead Generation System"
          title="One system. Three engines. Steady enquiries."
          subtitle="A website alone is not a marketing strategy. We build all three parts to point at the same goal: qualified leads for your business."
        />
      </div>
      <div class="hp-system-flow">
        <div class="hp-sys-stage hp-motion-item" style="--motion-delay: 140ms;">
          <span class="hp-sys-num">01</span>
          <span class="hp-sys-role">Convert</span>
          <h3>Website</h3>
          <p>A fast, credible site that explains your offer in seconds and turns visitors into calls and quote requests.</p>
        </div>
        <span class="hp-sys-arrow" aria-hidden="true">→</span>
        <div class="hp-sys-stage hp-motion-item" style="--motion-delay: 240ms;">
          <span class="hp-sys-num">02</span>
          <span class="hp-sys-role">Compound</span>
          <h3>SEO</h3>
          <p>Local and AI search visibility that grows month over month, bringing free, qualified traffic that keeps arriving.</p>
        </div>
        <span class="hp-sys-arrow" aria-hidden="true">→</span>
        <div class="hp-sys-stage hp-motion-item" style="--motion-delay: 340ms;">
          <span class="hp-sys-num">03</span>
          <span class="hp-sys-role">Accelerate</span>
          <h3>Google Ads</h3>
          <p>Buying-intent traffic from day one, tuned to a cost per lead that makes sense while the SEO compounds.</p>
        </div>
      </div>
      <div class="hp-sys-outcome hp-motion-item" style="--motion-delay: 440ms;">
        <p>The output is not a website. It is a pipeline of <strong>steady, qualified enquiries</strong> you can plan a business around.</p>
        <a href="/website-designer-auckland/" class="hp-sys-outcome-cta">Get a Free Growth Plan →</a>
      </div>
    </div>
  </section>

  <section class="section hp-services-section" id="services">
    <div class="container" data-reveal>
      <div class="hp-motion-heading" style="--motion-delay: 0ms;">
        <SectionHeader
          eyebrow="Services"
          title="Three services. One conversion goal."
          subtitle="Start with the part your business needs most. Every service is built to work with the others, not sold as a separate silo."
        />
      </div>
      <div class="service-grid">
        {services.map(({ icon, title, role, desc, href }, index) => (
          <a href={href} class="service-card hp-motion-item" style={`--motion-delay: ${140 + index * 110}ms;`}>
            <div class="service-icon"><Icon name={icon} size={24} /></div>
            <span class="service-role">{role}</span>
            <h3>{title}</h3>
            <p>{desc}</p>
            <span>Learn more -&gt;</span>
          </a>
        ))}
      </div>
    </div>
  </section>
  <section class="section hp-studio-section">
    <div class="container hp-studio-grid" data-reveal>
      <div class="hp-studio-photos">
        <div class="hp-studio-photo hp-studio-photo-large hp-photo-drift-one hp-motion-item" style="--motion-delay: 80ms;">
          <Image src={office1} alt="Kiwi Web Design studio - Auckland web design workspace" width={800} height={540} class="office-img" />
        </div>
        <div class="hp-studio-photo hp-studio-photo-small hp-photo-drift-two hp-motion-item" style="--motion-delay: 180ms;">
          <Image src={office2} alt="Kiwi Web Design team at work in Grey Lynn Auckland" width={800} height={540} class="office-img" />
        </div>
      </div>

      <div class="hp-studio-copy">
        <div class="hp-motion-heading" style="--motion-delay: 0ms;">
          <SectionHeader
            eyebrow="Local and hands-on"
            title="An Auckland agency without the agency overhead."
            subtitle="Direct communication, clear pricing, and marketing decisions tied to what your business needs to rank, convert, and grow."
            align="left"
          />
        </div>
        <p class="hp-intro-text hp-motion-item" style="--motion-delay: 150ms;">You are not passed through layers of account managers. Charlie Chao works with you directly on strategy, the website, the SEO, and the ad campaigns, so decisions are fast and nothing gets lost in translation.</p>
        <ul class="hp-checklist">
          {whyUs.map((point, index) => (
            <li class="hp-motion-item" style={`--motion-delay: ${230 + index * 80}ms;`}>{point}</li>
          ))}
        </ul>
        <div class="hp-studio-note hp-motion-item" style="--motion-delay: 560ms;">
          <strong>Best fit:</strong> service businesses, professional firms, tradies, restaurants, clinics, and local brands that want steady enquiries, not just a nicer website.
          <a href="https://www.youtube.com/watch?v=n9BFps8DyRY" target="_blank" rel="noopener noreferrer" class="hp-studio-video-link">Watch how we work on YouTube →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section hp-work-section" id="results">
    <div class="container hp-work-shell">
      <div class="hp-work-intro" data-reveal>
        <div class="hp-motion-heading" style="--motion-delay: 0ms;">
          <SectionHeader
            eyebrow="Client Results"
            title="Real projects. Real enquiries."
            subtitle="From tradies to restaurants to professional firms, every project is designed around clarity, credibility, and lead generation."
            align="left"
