---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import TestimonialGrid from '../components/TestimonialGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { Image } from 'astro:assets';
import aucklandVideo from '../assets/general/Auckland_Video.mp4';
import office1 from '../assets/general/office1.jpg';
import office2 from '../assets/general/office2.jpg';
import beautyTouchPreview from '../assets/general/beauty-salon-website-design-seo-auckland.jpg';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/",
      url: 'https://www.kiwiwebdesign.co.nz/',
      name: 'Auckland Web Design That Generates Leads | Kiwi Web Design',
      description: 'Kiwi Web Design helps Auckland small businesses get more leads through conversion-focused websites, local SEO, and Google Ads. Based in Grey Lynn. From $1,290.',
      isPartOf: { '@id': 'https://www.kiwiwebdesign.co.nz/#website' },
      about: { '@id': 'https://www.kiwiwebdesign.co.nz/#organization' },
      inLanguage: 'en-NZ'
    },
    {
      '@type': 'Organization',
      '@id': 'https://www.kiwiwebdesign.co.nz/#organization',
      name: 'Kiwi Web Design',
      url: 'https://www.kiwiwebdesign.co.nz/',
      telephone: '+64210396580',
      email: 'hi@kiwiwebdesign.co.nz'
    }
  ]
};

const services = [
  {
    icon: 'WD',
    title: 'Website Design',
    desc: 'Conversion-focused websites for Auckland small businesses. Fast, mobile-first, and designed to turn visits into enquiries.',
    href: '/small-business-website-design-auckland/',
  },
  {
    icon: 'SEO',
    title: 'SEO Auckland',
    desc: 'Local SEO that targets the searches your customers actually make, with a structure built to bring qualified traffic.',
    href: '/seo-auckland/',
  },
  {
    icon: 'ADS',
    title: 'Google Ads',
    desc: 'Paid campaigns built around buying intent so you get more calls and quote requests without wasting ad spend.',
    href: '/google-ads/',
  },
];

const stats = [
  { number: '50+', label: 'Projects completed' },
  { number: '4.9\u2605', label: 'Average Google rating' },
  { number: '98%', label: 'Client satisfaction' },
  { number: '2-3 wks', label: 'Average delivery' },
];

const whyUs = [
  {
    icon: '01',
    title: 'Free consultation, online or in person',
    desc: 'We learn the business first, then recommend the right scope. No hard sell and no vague package logic.',
  },
  {
    icon: '02',
    title: 'Clear pricing from $1,290',
    desc: 'Smaller businesses need clarity. We price for momentum, not procurement theatre.',
  },
  {
    icon: '03',
    title: 'Fast launch cycles',
    desc: 'Most projects go live in 2-3 weeks, so the site starts working before the opportunity goes cold.',
  },
  {
    icon: '04',
    title: 'Actually based in Auckland',
    desc: 'Grey Lynn-based and tuned to local search intent, local proof, and local buying behaviour.',
  },
];

const process = [
  { step: '1', title: 'Consultation', desc: 'We map the offer, the customer, and the best path to conversion before touching design.' },
  { step: '2', title: 'Strategy', desc: 'You get a clear scope, a practical direction, and pricing that lines up with the actual work.' },
  { step: '3', title: 'Build', desc: 'We design and build quickly, keeping the page structure focused on trust and action.' },
  { step: '4', title: 'Launch', desc: 'The site goes live with a clear next-step plan for SEO, ads, or ongoing optimisation.' },
];

const packages = [
  {
    name: 'Launch & Get Found',
    price: 'From $1,290',
    desc: 'For new businesses that need a professional presence and early visibility online.',
    features: ['5-page website', 'Mobile-first design', 'On-page local SEO', 'Speed optimisation', 'Contact form setup'],
    highlight: false,
    tag: '',
  },
  {
    name: 'Lead Growth Engine',
    price: 'From $2,690',
    desc: 'A full lead-generation setup combining website, SEO, and Google Ads foundations.',
    features: ['Conversion-focused website', 'Local SEO targeting buyer keywords', 'Google Ads setup', 'Landing pages', 'Tracking setup'],
    highlight: true,
    tag: 'Most Popular',
  },
  {
    name: 'Sales Accelerator',
    price: 'From $3,890',
    desc: 'Ongoing SEO, Google Ads management, and conversion optimisation for faster growth.',
    features: ['Ongoing optimisation', 'Lead landing pages', 'Monthly reporting', 'Priority support', 'Growth recommendations'],
    highlight: false,
    tag: '',
  },
];

const reviews = [
  { name: 'Zane Barrett', company: 'Barrett Access Scaffolding', text: 'Professional, responsive, and they really took the time to understand our business.' },
  { name: 'Jack', company: 'Show Me Shorts', text: 'They understood what I needed from the beginning and offered smart, practical solutions.' },
  { name: 'Steven Liu', company: 'Client', text: 'Clean, modern, and user-friendly. The attention to detail really stood out.' },
  { name: 'Gina Dellabarca', company: 'Client', text: 'Clear information, great communication, and a genuinely helpful audit.' },
];

const portfolio = [
  { src: '/portfolio/topline-services.jpg', alt: 'Auckland cleaning company website', caption: 'Top Line Services', href: '/topline-services-cleaning-website/' },
  { src: 'https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/08/30317.jpg', alt: 'Barrett Access Scaffolding website', caption: 'Barrett Access Scaffolding', href: '/case-study-scaffolding/' },
  { src: beautyTouchPreview.src, alt: 'Beauty Touch Auckland website', caption: 'Beauty Touch Auckland', href: '/beauty-touch-case-study/' },
  { src: '/portfolio/inspector-guys.jpg', alt: 'Auckland building inspector website', caption: 'Inspector Guys', href: '/inspector-guys-building-inspections-website/' },
  { src: '/portfolio/la-veranda.jpg', alt: 'Auckland restaurant website', caption: 'La Veranda Restaurant', href: '/la-veranda-restaurant-website/' },
  { src: '/portfolio/fl-legal.jpg', alt: 'Auckland law firm website', caption: 'FL Legal', href: '/fl-legal-website/' },
  { src: 'https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/07/Kiwiland-e1753410581810.jpg', alt: 'Kiwiland Construction website', caption: 'Kiwiland Construction', href: '/kiwiland-construction-website/' },
  { src: 'https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/07/Specialist-e1753415885359.jpg', alt: 'Melanoma Specialists website', caption: 'Melanoma Specialists', href: '/melanoma-specialists-website/' },
  { src: '/portfolio/mt-albert-business.jpg', alt: 'Mt Albert Business Association website', caption: 'Mt Albert Business Assoc.' },
  { src: '/blog/600-21B675F7-8EB5-45A5-99242870729DC26D.png', alt: 'TopRated.nz platform', caption: 'TopRated.nz', href: '/affordable-web-design-auckland/toprated-auckland-web-design/' },
];

const portfolioLoop = [...portfolio, ...portfolio];

const faqs = [
  { q: 'How much does a small business website cost in Auckland?', a: 'Our packages start from $1,290 for a lead-focused website. More complex builds are priced accordingly, and you know the cost upfront.' },
  { q: 'Will my website actually generate enquiries?', a: 'That is the goal. We design around conversion with clear calls to action, trust signals, and a buyer-focused structure.' },
  { q: 'How long does SEO take to show results?', a: 'Most Auckland businesses see early movement in 2-3 months, with stronger results building over 6-12 months.' },
  { q: 'Do you offer websites, SEO, and Google Ads together?', a: 'Yes. Combining all three is usually the strongest setup because the website handles conversion while SEO and ads bring demand.' },
];

const exploreGroups = [
  {
    label: 'Popular services',
    links: [
      { text: 'WordPress websites', href: '/wordpress-website-design-auckland/' },
      { text: 'Local SEO Auckland', href: '/local-seo-for-auckland-small-businesses/' },
      { text: 'Google Ads', href: '/google-ads/' },
      { text: 'Website hosting', href: '/website-hosting-auckland/' },
    ],
  },
  {
    label: 'Industries',
    links: [
      { text: 'Tradies', href: '/tradie-website-design-auckland/' },
      { text: 'Beauty & Wellness', href: '/how-kiwi-web-design-helps-auckland-beauty-industry/' },
      { text: 'Restaurants & Cafes', href: '/how-kiwi-web-design-helps-auckland-restaurants/' },
      { text: 'Healthcare', href: '/how-kiwi-web-design-helps-auckland-healthcare/' },
    ],
  },
  {
    label: 'Auckland areas',
    links: [
      { text: 'North Shore', href: '/north-shore-website-design/' },
      { text: 'South Auckland', href: '/south-auckland-web-design/' },
      { text: 'West Auckland', href: '/west-auckland-web-design/' },
      { text: 'East Auckland', href: '/east-auckland-web-design/' },
    ],
  },
];
---

<Layout
  title="Auckland Web Design That Generates Leads | Kiwi Web Design"
  description="Kiwi Web Design helps Auckland small businesses get more leads through conversion-focused websites, local SEO, and Google Ads. Based in Grey Lynn. From $1,290."
  canonicalURL="https://www.kiwiwebdesign.co.nz/"
  schema={schema}
>
  <section class="hp-hero">
    <div class="hp-hero-glow hp-hero-glow-one" aria-hidden="true"></div>
    <div class="hp-hero-glow hp-hero-glow-two" aria-hidden="true"></div>
    <div class="container hp-hero-shell">
      <div class="hp-hero-copy">
        <div class="hp-kicker-row">
          <p class="hp-eyebrow">Auckland web design studio</p>
          <span class="hp-location-pill">Grey Lynn, Auckland</span>
        </div>
        <h1 class="hp-headline">Websites, SEO, and Google Ads designed to make the phone ring.</h1>
        <p class="hp-lead">Kiwi Web Design helps Auckland small businesses turn traffic into quote requests, booked calls, and steady enquiries. Strategy-first, local, and built to convert.</p>
        <div class="hp-ctas">
          <a href="/website-designer-auckland/" class="hp-btn-primary">Book a Free Consultation</a>
          <a href="#packages" class="hp-btn-secondary">See Pricing</a>
        </div>
        <div class="hp-proof-row">
          <a href="https://share.google/nciRqe4rK6ywabSVx" target="_blank" rel="noopener" class="hp-review-pill">
            <div class="review-pill-badge">Google</div>
            <div>
              <p class="htc-text"><strong>4.9/5</strong> Google Reviews</p>
              <p class="htc-sub">47 verified reviews from Auckland clients</p>
            </div>
          </a>
          <p class="hp-mini-note">Free consultation online or in person. Typical launch timeline: 2-3 weeks.</p>
        </div>
      </div>

      <div class="hp-stage">
        <div class="hp-stage-window">
          <div class="hp-stage-topline">
            <span>Recent Auckland work</span>
            <span>Conversion-first build</span>
          </div>
          <video class="hp-stage-video" autoplay muted loop playsinline preload="auto">
            <source src={aucklandVideo} type="video/mp4" />
          </video>
          <div class="hp-stage-overlay" aria-hidden="true"></div>
          <div class="hp-stage-caption">
            <p class="hp-stage-label">Launch faster, convert harder</p>
            <p class="hp-stage-title">A homepage should feel credible in five seconds, not after a long scroll.</p>
          </div>
        </div>

        <div class="hp-stage-cards">
          {stats.map(({ number, label }) => (
            <div class="hp-stat-card">
              <span class="hp-stat-number">{number}</span>
              <span class="hp-stat-label">{label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section hp-intro-section">
    <div class="container hp-intro-grid">
      <div class="hp-intro-copy">
        <SectionHeader
          eyebrow="Why businesses switch to us"
          title="You do not need another pretty brochure site."
          subtitle="You need a clear offer, a persuasive first impression, and a path that makes calling or enquiring feel obvious."
          align="left"
        />
        <p class="hp-intro-text">That is the gap most small-business websites miss. They look acceptable, but they do not explain the value fast enough, they bury trust signals, and they give buyers too much to think about. We build around decision-making, not decoration.</p>
        <ul class="hp-checklist">
          <li>Sharper messaging above the fold so visitors understand the offer immediately.</li>
          <li>Proof-led layouts with reviews, case studies, and local trust signals in the right places.</li>
          <li>Conversion paths tuned for quote requests, calls, bookings, and repeat enquiries.</li>
        </ul>
      </div>

      <div class="hp-adv-grid">
        {whyUs.map(({ icon, title, desc }) => (
          <article class="hp-adv-card">
            <div class="hp-adv-icon">
              {icon}
            </div>
            <h3>{title}</h3>
            <p>{desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section hp-services-section">
    <div class="container">
      <SectionHeader
        eyebrow="What We Do"
        title="Three services. One lead-generation system."
        subtitle="The strongest results come when your website, search visibility, and paid traffic all point at the same conversion goal."
      />
      <div class="service-grid">
        {services.map(({ icon, title, desc, href }) => (
          <a href={href} class="service-card">
            <div class="service-icon">{icon}</div>
            <h3>{title}</h3>
            <p>{desc}</p>
            <span>Learn more -&gt;</span>
          </a>
        ))}
      </div>
    </div>
  </section>
  <section class="section hp-studio-section">
    <div class="container hp-studio-grid">
      <div class="hp-studio-photos">
        <div class="hp-studio-photo hp-studio-photo-large">
          <Image src={office1} alt="Kiwi Web Design studio - Auckland web design workspace" width={800} height={540} class="office-img" />
        </div>
        <div class="hp-studio-photo hp-studio-photo-small">
          <Image src={office2} alt="Kiwi Web Design team at work in Grey Lynn Auckland" width={800} height={540} class="office-img" />
        </div>
      </div>

      <div class="hp-studio-copy">
        <SectionHeader
          eyebrow="Local and hands-on"
          title="Auckland strategy. Fast execution. No agency bloat."
          subtitle="We keep the process direct, the pricing clear, and the work close to the actual goals of your business."
          align="left"
        />
        <p class="hp-intro-text">You are not passed through layers of account managers. We work close to the brief, move quickly, and keep the project grounded in what your customers need to see before they trust you enough to enquire.</p>
        <div class="hp-studio-note">
          <strong>Best fit:</strong> service businesses, professional firms, tradies, restaurants, clinics, and local brands that need more than a generic template.
        </div>
      </div>
    </div>
  </section>

  <section class="section hp-work-section">
    <div class="container hp-work-shell">
      <div class="hp-work-intro">
        <SectionHeader
          eyebrow="Selected Work"
          title="Built for real Auckland businesses."
          subtitle="From tradies to restaurants to law firms, every project is designed around clarity, credibility, and conversion."
          align="left"
        />
        <a href="/website-designer-auckland/" class="hp-btn-primary">Start Your Project</a>
      </div>

      <div class="portfolio-carousel" data-portfolio-carousel>
        <div class="portfolio-viewport">
          <div class="portfolio-track">
            {portfolioLoop.map(({ src, alt, caption, href }, index) => {
              const isClone = index >= portfolio.length;

              return href ? (
                <a
                  href={href}
                  class:list={['portfolio-item', isClone && 'is-clone']}
                  aria-hidden={isClone ? 'true' : undefined}
                  tabindex={isClone ? '-1' : undefined}
                >
                  <img src={src} alt={isClone ? '' : alt} width="400" height="280" loading="lazy" class="portfolio-img" />
                  <span class="portfolio-caption">
                    <span>{caption}</span>
                    <span class="portfolio-arrow">View project -&gt;</span>
                  </span>
                </a>
              ) : (
                <figure
                  class:list={['portfolio-item', 'portfolio-item-static', isClone && 'is-clone']}
                  aria-hidden={isClone ? 'true' : undefined}
                >
                  <img src={src} alt={isClone ? '' : alt} width="400" height="280" loading="lazy" class="portfolio-img" />
                  <figcaption class="portfolio-caption">
                    <span>{caption}</span>
                    <span class="portfolio-arrow">Featured project</span>
                  </figcaption>
                </figure>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section hp-proof-section">
    <div class="container hp-proof-layout">
      <div class="hp-proof-copy">
        <SectionHeader
          eyebrow="Client Reviews"
          title="Trusted by business owners who need leads, not fluff."
          subtitle="A good homepage should feel credible before anyone clicks deeper. Reviews do a lot of that work."
          align="left"
        />
        <div class="reviews-trust">
          <div class="reviews-stars" aria-label="5 stars">
            <svg viewBox="0 0 20 20" fill="#f5a523" aria-hidden="true"><path d="m10 1 2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.44.91-5.32L2.27 6.62l5.34-.78z"/></svg>
            <svg viewBox="0 0 20 20" fill="#f5a523" aria-hidden="true"><path d="m10 1 2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.44.91-5.32L2.27 6.62l5.34-.78z"/></svg>
            <svg viewBox="0 0 20 20" fill="#f5a523" aria-hidden="true"><path d="m10 1 2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.44.91-5.32L2.27 6.62l5.34-.78z"/></svg>
            <svg viewBox="0 0 20 20" fill="#f5a523" aria-hidden="true"><path d="m10 1 2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.44.91-5.32L2.27 6.62l5.34-.78z"/></svg>
            <svg viewBox="0 0 20 20" fill="#f5a523" aria-hidden="true"><path d="m10 1 2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.44.91-5.32L2.27 6.62l5.34-.78z"/></svg>
            <span class="reviews-google-label">Google</span>
          </div>
          <p>4.9 stars across 47 verified Google reviews</p>
        </div>
      </div>

      <div class="hp-proof-cards">
        <TestimonialGrid items={reviews} cols={2} />
      </div>
    </div>
  </section>

  <section class="section hp-process-section">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="Simple process. Real momentum."
        subtitle="Clear scope, quick execution, and a site that is built to start working from day one."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <section class="section hp-packages-section" id="packages">
    <div class="container">
      <SectionHeader
        eyebrow="Pricing"
        title="Packages with a clear commercial point of view."
        subtitle="Structured for businesses that need better presentation, stronger lead flow, or both."
      />
      <div class="packages-grid">
        {packages.map(({ name, price, desc, features, highlight, tag }) => (
          <div class:list={['pkg-card', highlight && 'pkg-highlight']}>
            {tag && <span class="pkg-tag">{tag}</span>}
            <h3 class="pkg-name">{name}</h3>
            <p class="pkg-price">{price}</p>
            <p class="pkg-desc">{desc}</p>
            <ul class="pkg-features">
              {features.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
            <a href="/website-designer-auckland/" class:list={['pkg-cta', highlight && 'pkg-cta-accent']}>Get Started -&gt;</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section hp-faq-section">
    <div class="container faq-layout">
      <div>
        <p class="faq-eyebrow">FAQs</p>
        <h2 class="faq-sidebar-title">Common questions from Auckland business owners.</h2>
        <p class="faq-sidebar-sub">If you do not see your question here, reach out and we will answer directly.</p>
        <a href="/website-designer-auckland/" class="hp-btn-dark" style="margin-top: 1.5rem; display: inline-flex;">Ask a Question</a>
      </div>
      <FAQAccordion items={faqs} title="" />
    </div>
  </section>

  <section class="section hp-explore-section">
    <div class="container">
      <SectionHeader
        eyebrow="Explore More"
        title="Browse the path that matches your business."
        subtitle="Start with the service, industry, or area that is closest to what you need."
      />
      <div class="explore-grid">
        {exploreGroups.map(({ label, links }) => (
          <section class="explore-card">
            <p class="explore-label">{label}</p>
            <div class="explore-links">
              {links.map(({ text, href }) => (
                <a href={href} class="explore-link">{text}</a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to grow your Auckland business online?"
    subtitle="Free consultation - online or in person, Auckland wide. No commitment, no pressure."
    ctaPrimary={{ text: 'Book a Free Consultation', href: '/website-designer-auckland/' }}
    ctaSecondary={{ text: 'See Our Packages', href: '/small-business-website-design-auckland/' }}
  />

  <script is:inline>
    const portfolioCarousel = document.querySelector('[data-portfolio-carousel]');

    if (portfolioCarousel instanceof HTMLElement) {
      const viewport = portfolioCarousel.querySelector('.portfolio-viewport');
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

      if (viewport instanceof HTMLElement) {
        let paused = prefersReducedMotion.matches;
        let frameId = 0;
        let lastFrame = 0;

        const getSpeed = () => (window.innerWidth < 720 ? 22 : 34);
        const getResetPoint = () => viewport.scrollWidth / 2;

        const tick = (time) => {
          if (!paused) {
            if (!lastFrame) lastFrame = time;

            const delta = (time - lastFrame) / 1000;
            viewport.scrollLeft += getSpeed() * delta;

            const resetPoint = getResetPoint();
            if (viewport.scrollLeft >= resetPoint) {
              viewport.scrollLeft -= resetPoint;
            }
          }

          lastFrame = time;
          frameId = window.requestAnimationFrame(tick);
        };

        const setPaused = (value) => {
          paused = value || prefersReducedMotion.matches;
          if (!paused) lastFrame = 0;
        };

        portfolioCarousel.addEventListener('mouseenter', () => setPaused(true));
        portfolioCarousel.addEventListener('mouseleave', () => setPaused(false));
        portfolioCarousel.addEventListener('focusin', () => setPaused(true));
        portfolioCarousel.addEventListener('focusout', () => {
          if (!portfolioCarousel.contains(document.activeElement)) {
            setPaused(false);
          }
        });

        prefersReducedMotion.addEventListener('change', (event) => {
          setPaused(event.matches);
        });

        frameId = window.requestAnimationFrame(tick);

        window.addEventListener('pagehide', () => {
          window.cancelAnimationFrame(frameId);
        }, { once: true });
      }
    }
  </script>
</Layout>

<style>
  .hp-hero {
    position: relative;
    overflow: hidden;
    padding: 8.5rem 0 5rem;
    background:
      radial-gradient(circle at 10% 20%, rgba(243, 217, 122, 0.14), transparent 28%),
      radial-gradient(circle at 85% 18%, rgba(243, 217, 122, 0.08), transparent 26%),
      linear-gradient(180deg, #171412 0%, #211d1a 48%, #f6f1e6 100%);
  }

  .hp-hero-glow {
    position: absolute;
    border-radius: 999px;
    filter: blur(60px);
    opacity: 0.28;
    pointer-events: none;
  }

  .hp-hero-glow-one {
    width: 18rem;
    height: 18rem;
    top: 4rem;
    right: -4rem;
    background: rgba(251, 232, 166, 0.7);
  }

  .hp-hero-glow-two {
    width: 16rem;
    height: 16rem;
    left: -5rem;
    bottom: 8rem;
    background: rgba(251, 232, 166, 0.38);
  }

  .hp-hero-shell,
  .hp-intro-grid,
  .hp-studio-grid,
  .hp-proof-layout {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 3rem;
    align-items: center;
  }

  .hp-kicker-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 1.25rem;
