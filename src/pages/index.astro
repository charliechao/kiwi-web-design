    viewBox: '0 0 16 16',
  },
  { name: 'Claude', desc: 'AI-assisted strategy, writing, planning, and implementation support.', logo: siClaude, viewBox: '0 0 24 24' },
  { name: 'Google', desc: 'Search visibility, business discovery, and performance marketing.', logo: siGoogle, viewBox: '0 0 24 24' },
  { name: 'Cloudflare', desc: 'Fast hosting, CDN, security, and modern deployment workflows.', logo: siCloudflare, viewBox: '0 0 24 24' },
  { name: 'Google Analytics', desc: 'Traffic and lead tracking so decisions are based on real data.', logo: siGoogleanalytics, viewBox: '0 0 24 24' },
  { name: 'Search Console', desc: 'SEO diagnostics for indexing, queries, and search performance.', logo: siGooglesearchconsole, viewBox: '0 0 24 24' },
