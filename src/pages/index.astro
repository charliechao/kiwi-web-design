      ctaSecondary={{ text: 'See Our Packages', href: '/small-business-website-design-auckland/' }}
    />
  </div>

  <script is:inline>
    (() => {
      const root = document.documentElement;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      const revealSections = Array.from(document.querySelectorAll('[data-reveal]'));
      const portfolioCarousel = document.querySelector('[data-portfolio-carousel]');
      const stage = document.querySelector('[data-stage-parallax]');
      const desktopParallax = window.matchMedia('(min-width: 1081px) and (hover: hover) and (pointer: fine)');

      let revealObserver;
      let carouselFrame = 0;
      let lastCarouselFrame = 0;
      let carouselHoverPaused = false;
      let carouselFocusPaused = false;
      let carouselPointerActivated = false;
      let carouselPointerTimer = 0;
      let parallaxFrame = 0;
      let parallaxCurrentX = 0;
      let parallaxCurrentY = 0;
      let parallaxTargetX = 0;
      let parallaxTargetY = 0;
      let syncCarouselMotion = () => {};
      let syncParallaxMotion = () => {};

      const motionActive = () => !prefersReducedMotion.matches;

      const syncMotionClass = () => {
        root.classList.toggle('motion-enabled', motionActive());
      };

      const initReveals = () => {
        revealObserver?.disconnect();

        if (!motionActive()) {
          revealSections.forEach((section) => section.classList.add('is-visible'));
          return;
        }

        revealObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            revealObserver?.unobserve(entry.target);
          });
        }, {
          threshold: 0.18,
          rootMargin: '0px 0px -10% 0px',
        });

        revealSections.forEach((section) => {
          if (section.classList.contains('is-visible')) return;

          const sectionTop = section.getBoundingClientRect().top;
          if (sectionTop < window.innerHeight * 0.88) {
            section.classList.add('is-visible');
          } else {
            revealObserver?.observe(section);
          }
        });
      };

      const initCarousel = () => {
        if (!(portfolioCarousel instanceof HTMLElement)) return;

        const viewport = portfolioCarousel.querySelector('.portfolio-viewport');
        if (!(viewport instanceof HTMLElement)) return;

        const getSpeed = () => (window.innerWidth < 720 ? 22 : 34);
        const getResetPoint = () => viewport.scrollWidth / 2;
        const carouselPaused = () => !motionActive() || carouselHoverPaused || carouselFocusPaused;

        const resumeCarousel = () => {
          carouselHoverPaused = false;
          carouselFocusPaused = false;
          lastCarouselFrame = 0;
          syncCarouselMotion();
        };

        const stepCarousel = (time) => {
          if (!carouselPaused()) {
            if (!lastCarouselFrame) lastCarouselFrame = time;

            const delta = (time - lastCarouselFrame) / 1000;
            viewport.scrollLeft += getSpeed() * delta;

            const resetPoint = getResetPoint();
            if (viewport.scrollLeft >= resetPoint) {
              viewport.scrollLeft -= resetPoint;
            }
          }

          lastCarouselFrame = time;
          carouselFrame = window.requestAnimationFrame(stepCarousel);
        };

        syncCarouselMotion = () => {
          if (!motionActive()) {
            if (carouselFrame) {
              window.cancelAnimationFrame(carouselFrame);
              carouselFrame = 0;
            }
            lastCarouselFrame = 0;
            return;
          }

          if (!carouselFrame) {
            carouselFrame = window.requestAnimationFrame(stepCarousel);
          }
        };

        portfolioCarousel.addEventListener('mouseenter', () => {
          carouselHoverPaused = true;
        });

        portfolioCarousel.addEventListener('mouseleave', () => {
          carouselHoverPaused = false;
          resumeCarousel();
        });

        portfolioCarousel.addEventListener('pointerdown', () => {
          carouselPointerActivated = true;
          if (carouselPointerTimer) window.clearTimeout(carouselPointerTimer);
          carouselPointerTimer = window.setTimeout(() => {
            carouselPointerActivated = false;
          }, 500);
        });

        portfolioCarousel.addEventListener('click', (event) => {
          if (!carouselPointerActivated) return;

          const target = event.target instanceof Element ? event.target.closest('.portfolio-item') : null;
          if (!(target instanceof HTMLElement)) return;

          target.blur();
          resumeCarousel();
          if (carouselPointerTimer) window.clearTimeout(carouselPointerTimer);
          window.setTimeout(() => {
            carouselPointerActivated = false;
            resumeCarousel();
          }, 150);
        });

        portfolioCarousel.addEventListener('focusin', () => {
          if (carouselPointerActivated) return;
          carouselFocusPaused = true;
        });

        portfolioCarousel.addEventListener('focusout', () => {
          if (!portfolioCarousel.contains(document.activeElement)) {
            carouselFocusPaused = false;
            resumeCarousel();
          }
        });

        syncCarouselMotion();

        return () => {
          if (carouselFrame) {
            window.cancelAnimationFrame(carouselFrame);
          }
          if (carouselPointerTimer) {
            window.clearTimeout(carouselPointerTimer);
          }
        };
      };

      const initStageParallax = () => {
        if (!(stage instanceof HTMLElement)) return;

        const setParallax = () => {
          parallaxCurrentX += (parallaxTargetX - parallaxCurrentX) * 0.12;
          parallaxCurrentY += (parallaxTargetY - parallaxCurrentY) * 0.12;

          stage.style.setProperty('--stage-window-x', `${parallaxCurrentX * 14}px`);
          stage.style.setProperty('--stage-window-y', `${parallaxCurrentY * 12}px`);
          stage.style.setProperty('--stage-window-rotate-x', `${parallaxCurrentY * -3.5}deg`);
          stage.style.setProperty('--stage-window-rotate-y', `${parallaxCurrentX * 4.5}deg`);
          stage.style.setProperty('--stage-cards-x', `${parallaxCurrentX * -10}px`);
          stage.style.setProperty('--stage-cards-y', `${parallaxCurrentY * -8}px`);

          if (
            Math.abs(parallaxTargetX - parallaxCurrentX) > 0.002 ||
            Math.abs(parallaxTargetY - parallaxCurrentY) > 0.002
          ) {
            parallaxFrame = window.requestAnimationFrame(setParallax);
          } else {
            parallaxFrame = 0;
          }
        };

        const queueParallax = () => {
          if (!parallaxFrame) {
            parallaxFrame = window.requestAnimationFrame(setParallax);
          }
        };

        const resetParallax = () => {
          parallaxTargetX = 0;
          parallaxTargetY = 0;
          stage.classList.remove('is-parallax-active');
          queueParallax();
        };

        syncParallaxMotion = () => {
          if (!motionActive() || !desktopParallax.matches) {
            resetParallax();
          }
        };

        stage.addEventListener('pointermove', (event) => {
          if (!motionActive() || !desktopParallax.matches) return;

          const rect = stage.getBoundingClientRect();
          const ratioX = (event.clientX - rect.left) / rect.width - 0.5;
          const ratioY = (event.clientY - rect.top) / rect.height - 0.5;

          parallaxTargetX = Math.max(-1, Math.min(1, ratioX * 2));
          parallaxTargetY = Math.max(-1, Math.min(1, ratioY * 2));

          stage.classList.add('is-parallax-active');
          queueParallax();
        });

        stage.addEventListener('pointerleave', resetParallax);
        stage.addEventListener('pointercancel', resetParallax);

        return () => {
          if (parallaxFrame) {
            window.cancelAnimationFrame(parallaxFrame);
          }
        };
      };

      syncMotionClass();
      initReveals();

      const destroyCarousel = initCarousel();
      const destroyParallax = initStageParallax();

      const handleMotionChange = () => {
        syncMotionClass();
        initReveals();
        syncCarouselMotion();
        syncParallaxMotion();
      };

      prefersReducedMotion.addEventListener('change', handleMotionChange);
      desktopParallax.addEventListener('change', handleMotionChange);

      // Clean up on every navigation away (not once: true, must also run after bfcache restore)
      window.addEventListener('pagehide', () => {
        revealObserver?.disconnect();
        destroyCarousel?.();
        destroyParallax?.();
      });

      // bfcache restore: browser thaws the frozen page instead of re-running the script.
      // revealObserver was disconnected on pagehide, rAF IDs are stale, re-initialise everything.
      window.addEventListener('pageshow', (event) => {
        if (!event.persisted) return;
        carouselFrame = 0;   // reset stale rAF ID so syncCarouselMotion restarts the loop
        parallaxFrame = 0;   // reset stale rAF ID
        syncMotionClass();
        initReveals();       // re-attach observer + immediately show anything now in viewport
        syncCarouselMotion();
        syncParallaxMotion();
      });
    })();
  </script>
