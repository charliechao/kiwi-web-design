---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "name": "Auckland Web Design That Generates Leads | Kiwi Web Design",
      "description": "We build websites for Auckland small businesses that generate real enquiries. Strategy-first web design focused on leads, not just looks.",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "datePublished": "2025-04-09T22:43:08+00:00",
      "dateModified": "2026-03-05T21:19:05+00:00",
      "inLanguage": "en-NZ",
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/#breadcrumb",
      "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home" }]
    },
    {
      "@type": "WebSite",
      "@id": "https://www.kiwiwebdesign.co.nz/#website",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "name": "Kiwi Web Design",
      "description": "Websites built to generate leads",
      "alternateName": "Web Design Auckland",
      "publisher": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "inLanguage": "en-NZ"
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "logo": {
        "@type": "ImageObject",
        "@id": "https://www.kiwiwebdesign.co.nz/#/schema/logo/image/",
        "url": "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/04/android-chrome-512x512-1.png",
        "width": 512,
        "height": 512,
        "caption": "Kiwi Web Design"
      },
      "sameAs": [
        "https://www.facebook.com/profile.php?id=61559560322941",
        "https://x.com/charliechao",
        "https://www.tiktok.com/@kiwi_web_design",
        "https://www.youtube.com/@Kiwiwebdesign",
        "https://www.instagram.com/kiwi_web_design/",
        "https://www.linkedin.com/company/108270459/",
        "https://clutch.co/profile/kiwi-web-design-0",
        "https://nz.trustpilot.com/review/kiwiwebdesign.co.nz"
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "How much does it cost to generate leads online for a small Auckland business?", "acceptedAnswer": { "@type": "Answer", "text": "Starting from $1,290 for a lead-focused website with basic SEO." } },
        { "@type": "Question", "name": "Will my website actually generate enquiries?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every site we build is designed around conversion with clear calls to action." } },
        { "@type": "Question", "name": "How long does SEO take to bring leads?", "acceptedAnswer": { "@type": "Answer", "text": "You can expect early movement in 2 to 3 months, with stronger results building over 6–12 months." } },
        { "@type": "Question", "name": "Why choose your agency over other Auckland agencies?", "acceptedAnswer": { "@type": "Answer", "text": "Free consultations, AI-driven efficiency, 50–70% lower cost than traditional agencies, transparent pricing, fast turnaround." } }
      ]
    }
  ]
};

const packages = [
  {
    name: "Launch & Get Found",
    price: "From $1,290",
    desc: "For new businesses that need visibility and early enquiries.",
    features: [
      "Lead-focused website",
      "Mobile-first design",
      "Local on-page SEO",
      "Speed optimisation",
      "Contact forms and call button",
      "Email support",
    ],
  },
  {
    name: "Lead Growth Engine",
    subtitle: "(Best Value)",
    price: "From $2,690",
    desc: "A complete lead system combining a high-converting website, SEO strategy, and Google Ads setup.",
    features: [
      "Conversion-optimised website",
      "Local SEO targeting buyer keywords",
      "Google Ads campaign setup",
      "Dedicated landing pages for ads",
      "Speed optimisation",
      "Conversion tracking setup",
      "Ongoing optimisation recommendations",
    ],
  },
  {
    name: "Sales Accelerator",
    price: "From $3,890",
    desc: "Built for businesses that want faster growth through ongoing traffic, ads, and conversion optimisation.",
    features: [
      "Advanced conversion optimisation",
      "Ongoing SEO and Google Ads management",
      "Dedicated lead landing pages",
      "Monthly performance tracking",
      "Priority support",
    ],
  },
];

const stats = [
  { number: "50+", label: "Projects Completed" },
  { number: "10",  label: "Industries Served" },
  { number: "98%", label: "Satisfied Clients" },
];

const whyUs = [
  {
    title: "Free and Easy Consultation",
    text: "We totally understand that getting a website for your small business can seem overwhelming. Our team is here to listen and learn about your business needs before we dive in. Your free consultation can happen over the phone, via video call, or in person anywhere across Auckland.",
  },
  {
    title: "Affordability",
    text: "We understand small businesses in New Zealand have a limited budget. That's why we aim to be the most affordable web design agency in Auckland. We can get your business online with as little as $1,290 — so you can start reaching potential customers today.",
  },
  {
    title: "Results Focused",
    text: "We don't build websites just to look good. We build them to generate enquiries. Every website is structured to guide visitors toward action — calling you, submitting a form, or booking a consultation. Your website should work as a sales tool, not just an online brochure.",
  },
];

const reviews = [
  {
    name: "Zane Barrett",
    company: "Barrett Access Scaffolding",
    text: "We recently worked with Kiwiweb to design and launch our new website, and we couldn't be happier with the results. Professional, responsive, and really took the time to understand our business. They included a scaffold cost calculator — the first of its kind in NZ!",
  },
  {
    name: "Jack",
    company: "Show Me Shorts",
    text: "Kiwi Web Design were fantastic to work with. From the very beginning they really took the time to understand what I needed and offered smart, practical solutions. Professional, friendly and quick to respond whenever I had questions.",
  },
  {
    name: "Steven Liu",
    company: "Client",
    text: "Outstanding experience with Kiwi Web Design and Charlie! I couldn't be happier with the website created for me. The design is clean, modern, and user-friendly — exactly what I was hoping for. Charlie's attention to detail and commitment to quality really stood out.",
  },
  {
    name: "Gina Dellabarca",
    company: "Client",
    text: "They provided a comprehensive and helpful website audit for us. Clear information. Great communication.",
  },
];

const industries = [
  {
    name: "Tradies",
    desc: "We work closely with tradies across Auckland to build websites that bring in steady local leads. Whether you're a builder, electrician, or scaffolder, we'll design a site that shows your services clearly and helps customers contact you quickly.",
    href: "/tradie-website-design-auckland/",
  },
  {
    name: "E-Commerce",
    desc: "For small businesses selling online, we build e-commerce websites that are simple to manage and ready to scale. Our packages cover product catalogues, secure payment systems, and training so you can run your store with confidence.",
    href: "/ecommerce-website-auckland/",
  },
  {
    name: "Other Small Businesses",
    desc: "From dentists to cafés, we create websites that highlight what makes your business unique. Each site is designed to be user-friendly, mobile-ready, and SEO-friendly so local customers can find you easily.",
    href: "/small-business-website-design-auckland/",
  },
];

const leadMachine = [
  "Traffic without conversions",
  "Design must drive action",
  "SEO needs conversion",
  "Ads require landing strategy",
  "Clear calls to action",
  "Built for buyer intent",
  "Mobile-first decision making",
  "Trust converts visitors",
  "Data-driven improvements",
];

const expertise = [
  {
    title: "Lead-Focused Website Design",
    desc: "We build websites for small businesses and e-commerce that are designed to turn visitors into enquiries. Every site is structured around clear messaging, strong calls to action, and conversion paths that encourage phone calls, form submissions, and bookings.",
    href: "/small-business-website-design-auckland/",
  },
  {
    title: "SEO That Brings Buyers",
    desc: "SEO is only valuable if it attracts the right people. We focus on local and service-based search intent so your business appears when customers are actively looking to buy. Our SEO strategy targets visibility, trust, and conversions.",
    href: "/seo-auckland/",
  },
  {
    title: "Google Ads for Immediate Enquiries",
    desc: "Google Ads is the fastest way to generate demand when done properly. We create and manage campaigns that send high-intent traffic to dedicated landing pages built to convert. Fewer wasted clicks, more calls and enquiries.",
    href: "/google-ads/",
  },
];

const works = [
  { src: "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/06/Auckland_Cleaner-e1750284778292.jpg", caption: "Auckland Cleaning Company", alt: "Web design for Auckland cleaning company – Top Line Services" },
  { src: "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/06/Auckland_Building_Inspector-e1750284793590.jpg", caption: "Auckland Building Inspector", alt: "Auckland building inspector website – Inspector Guys" },
  { src: "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/07/Specialist-e1753415885359.jpg", caption: "Auckland Melanoma Specialist", alt: "Auckland medical specialists website" },
  { src: "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/07/Lavaranda-e1753415431519.jpg", caption: "Auckland Restaurant", alt: "Auckland restaurant website – La Veranda" },
  { src: "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/10/Mt-Albert-Business-Association-Website.jpg", caption: "Mt Albert Business Association", alt: "Mt Albert Business Association website" },
  { src: "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/07/Kiwiland-e1753410581810.jpg", caption: "Auckland Building Company", alt: "Auckland construction company website – Kiwiland Construction" },
  { src: "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/07/Legal-e1753416217381.jpg", caption: "FL Legal", alt: "Auckland law firm website – FL Legal" },
  { src: "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2026/01/600-21B675F7-8EB5-45A5-99242870729DC26D.png", caption: "TopRated.nz", alt: "TopRated.nz Auckland business directory" },
];

const faqs = [
  { q: "How much does it cost to generate leads online for a small Auckland business?", a: "The cost depends on how fast you want results and how competitive your market is. A lead-focused website with basic SEO starts from around $1,290. For consistent enquiries, most businesses combine SEO and Google Ads, which requires a higher upfront investment but delivers stronger results." },
  { q: "Will my website actually generate enquiries?", a: "A website alone does not guarantee leads. That's why we design websites around conversion, search intent, and clear calls to action. When combined with SEO or Google Ads, your site becomes a system built to turn visitors into enquiries." },
  { q: "How long does SEO take to bring leads?", a: "SEO is a medium- to long-term strategy. Most Auckland businesses start seeing early movement within 2 to 3 months, with stronger lead flow building over time. We focus on local buyer keywords, not vanity traffic." },
  { q: "Can you help with Google Ads as well?", a: "Yes. Google Ads is often the fastest way to generate enquiries. We set up campaigns that target high-intent searches and send traffic to landing pages designed to convert, so you are not paying for wasted clicks." },
  { q: "Do you offer website, SEO, and Google Ads together?", a: "Yes. Our most effective projects combine all three. The website handles conversion, SEO builds long-term visibility, and Google Ads drives immediate demand. This approach gives you both short- and long-term lead growth." },
  { q: "Will my website rank well on Google in Auckland?", a: "Ranking depends on competition, location, and industry. We don't promise instant rankings, but we build every site with proper on-page SEO, local signals, and a strategy designed to compete in Auckland search results." },
  { q: "Do you work with tradies and service businesses?", a: "Yes. We regularly work with trades, service providers, and local businesses that rely on phone calls and enquiries. Our focus is on making it easy for customers to contact you when they are ready to buy." },
  { q: "Can you add e-commerce or booking features?", a: "Absolutely. Whether you're launching an online store or need bookings, memberships, or inventory management, we can build a fully tailored solution with secure payment gateways and any custom functionality your business requires." },
  { q: "Can you migrate my site from Wix or Squarespace?", a: "Yes. We can rebuild and improve your site on a platform better suited for SEO, speed, and lead generation, while preserving important content and improving conversion performance." },
  { q: "What happens after my website goes live?", a: "Launch is just the start. Depending on your package, we continue improving visibility, tracking conversions, refining SEO, and optimising ads so your website performs better over time instead of sitting idle." },
  { q: "Why choose your agency over other Auckland agencies?", a: "We offer free in-person or online consultations before you commit to anything. We combine AI-driven efficiency with local Auckland knowledge, delivering premium-looking, fully-customised websites at up to 50–70% lower cost. Transparent pricing, fast turnaround, and full support." },
];
---

<Layout
  title="Auckland Web Design That Generates Leads | Kiwi Web Design"
  description="We build websites for Auckland small businesses that generate real enquiries. Strategy-first web design focused on leads, not just looks."
  canonicalURL="https://www.kiwiwebdesign.co.nz/"
  schema={schema}
>

  <!-- Hero -->
  <section class="hero section-dark">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="eyebrow">Web Design · SEO · Google Ads · Auckland</p>
        <h1>Our Websites, SEO and Google Ads generate real leads for Auckland small businesses</h1>
        <p class="lead">Kiwi Web Design helps Auckland small businesses drive traffic, enquiries, and sales online — not just build websites.</p>
        <div class="hero-ctas">
          <a href="/website-designer-auckland/" class="btn-primary">Get a Free Quote</a>
          <a href="/small-business-website-design-auckland/" class="btn-ghost">See Our Packages</a>
        </div>
      </div>
      <div class="hero-image">
        <img
          src="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/08/Auckland.jpg"
          alt="Auckland city skyline at dusk"
          width="760"
          height="400"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Services tagline -->
  <section class="section section-cream">
    <div class="container text-center">
      <h2>We provide professional websites, SEO and Google Ads services to generate more leads for you</h2>
    </div>
  </section>

  <!-- Packages -->
  <section class="section" id="services">
    <div class="container">
      <h2>Lead Generation Packages for Auckland Small Businesses</h2>
      <p class="section-intro">Choose a growth path based on how quickly you want enquiries, not just a website.</p>
      <div class="packages-grid">
        {packages.map(({ name, subtitle, price, desc, features }) => (
          <div class="package-card">
            <h3>{name}{subtitle && <span class="best-value"> {subtitle}</span>}</h3>
            <p class="price">{price}</p>
            <p class="package-desc">{desc}</p>
            <ul class="feature-list">
              {features.map((f) => <li>{f}</li>)}
            </ul>
            <a href="/website-designer-auckland/" class="btn-primary">Get Started</a>
          </div>
        ))}
      </div>
      <div class="text-center" style="margin-top: 2rem;">
        <a href="/website-designer-auckland/" class="btn-primary">Free Audit</a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="section section-dark">
    <div class="container stats-row">
      {stats.map(({ number, label }) => (
        <div class="stat">
          <span class="stat-number">{number}</span>
          <span class="stat-label">{label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section">
    <div class="container">
      <h2>Why Small Businesses Choose Us</h2>
      <div class="why-grid">
        {whyUs.map(({ title, text }) => (
          <div class="why-card">
            <h4>{title}</h4>
            <p>{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="section section-cream">
    <div class="container">
      <h2>What Our Clients Say</h2>
      <div class="reviews-grid">
        {reviews.map(({ name, company, text }) => (
          <div class="review-card">
            <div class="stars" aria-label="5 stars">★★★★★</div>
            <p class="review-text">{text}</p>
            <p class="reviewer"><strong>{name}</strong> · {company}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Industries We Serve -->
  <section class="section section-dark">
    <div class="container">
      <h2>Industries We Serve</h2>
      <p class="section-intro-light">Websites tailored for trades, e-commerce, and local businesses across Auckland.</p>
      <div class="industries-grid">
        {industries.map(({ name, desc, href }) => (
          <div class="industry-card-dark">
            <h3>{name}</h3>
            <p>{desc}</p>
            <a href={href}>Learn more →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Lead Machine -->
  <section class="section section-cream">
    <div class="container">
      <h2>Why Your Website Must Be a Lead Machine, Not Just a Brochure</h2>
      <div class="lead-machine-grid">
        {leadMachine.map((item) => (
          <div class="lead-item">
            <span class="check-icon">✓</span>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Areas of Expertise -->
  <section class="section">
    <div class="container">
      <h2>Our Areas of Expertise</h2>
      <div class="expertise-grid">
        {expertise.map(({ title, desc, href }) => (
          <div class="expertise-card">
            <h4>{title}</h4>
            <p>{desc}</p>
            <a href={href}>Learn more →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Recent Works -->
  <section class="section section-dark">
    <div class="container">
      <h2>Recent Works</h2>
      <div class="works-grid">
        {works.map(({ src, caption, alt }) => (
          <figure class="work-item">
            <img src={src} alt={alt} width="400" height="280" loading="lazy" />
            <figcaption>{caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Grow Your Business -->
  <section class="section section-cream">
    <div class="container grow-grid">
      <div>
        <h2>Grow Your Business With Kiwi Web Design</h2>
        <p>We help Auckland small businesses get more enquiries, calls, and customers online. A website is only the starting point. What matters is traffic, visibility, and conversion.</p>
        <a href="/website-designer-auckland/" class="btn-primary" style="margin-top: 1rem; display: inline-block;">Book a Free Consultation</a>
      </div>
      <div class="grow-points">
        <div class="grow-point">
          <h4>Websites Built to Generate Leads</h4>
          <p>We design websites with one clear goal: turning visitors into enquiries. Every page is structured around buyer intent, clear calls to action, and trust signals that encourage people to pick up the phone or get in touch.</p>
        </div>
        <div class="grow-point">
          <h4>SEO and Google Ads That Drive Enquiries</h4>
          <p>Getting online is easy. Getting found by the right customers is not. We combine local SEO and Google Ads to put your business in front of people who are actively searching for your services.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container">
      <h2>Frequently Asked Questions</h2>
      <p class="section-intro">These are the most common questions we get from Auckland small businesses looking to generate more leads online.</p>
      <div class="faq-list">
        {faqs.map(({ q, a }) => (
          <details class="faq-item">
            <summary>{q}</summary>
            <p>{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA strip -->
  <section class="section section-dark text-center">
    <div class="container">
      <h2>Ready to generate more leads?</h2>
      <p>Free consultation — online or in person, Auckland wide.</p>
      <a href="/website-designer-auckland/" class="btn-primary">Book a Free Consultation</a>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ── */
  .hero { padding: 6rem 0; }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .hero-image img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
  }
  .eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--kwd-yellow);
    margin-bottom: 1rem;
  }
  .hero h1 { color: var(--kwd-white); max-width: 800px; }
  .lead { font-size: 1.1rem; color: rgba(255,255,255,0.8); max-width: 600px; }
  .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 2rem; }
  .btn-ghost {
    display: inline-block;
    border: 2px solid var(--kwd-yellow);
    color: var(--kwd-yellow);
    padding: 0.7rem 1.75rem;
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: background 0.2s, color 0.2s;
  }
  .btn-ghost:hover { background: var(--kwd-yellow); color: var(--kwd-dark); }

  /* ── Shared ── */
  .text-center { text-align: center; }
  .section-intro { color: var(--kwd-brown); margin-bottom: 2rem; }
  .section-intro-light { color: rgba(255,255,255,0.7); margin-bottom: 2rem; }

  /* ── Packages ── */
  .packages-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }
  .package-card {
    border: 2px solid var(--kwd-cream);
    border-radius: 8px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .package-card h3 { margin: 0; font-family: var(--kwd-font-body); font-size: 1.1rem; font-weight: 700; }
  .best-value { font-size: 0.8rem; color: var(--kwd-brown); font-weight: 400; }
  .price { font-size: 1.5rem; font-family: var(--kwd-font-heading); color: var(--kwd-dark); margin: 0; }
  .package-desc { color: var(--kwd-brown); font-size: 0.9rem; margin: 0; }
  .feature-list {
    list-style: none;
    padding: 0;
    margin: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .feature-list li {
    font-size: 0.875rem;
    color: var(--kwd-brown);
    padding-left: 1.25rem;
    position: relative;
  }
  .feature-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--kwd-dark);
    font-weight: 700;
  }

  /* ── Stats ── */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: center;
    padding: 1rem 0;
  }
  .stat { display: flex; flex-direction: column; gap: 0.5rem; }
  .stat-number { font-family: var(--kwd-font-heading); font-size: 3.5rem; color: var(--kwd-yellow); line-height: 1; }
  .stat-label { font-size: 0.9rem; color: rgba(255,255,255,0.7); }

  /* ── Why Choose Us ── */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }
  .why-card {
    border-left: 4px solid var(--kwd-yellow);
    padding: 1.5rem;
    background: var(--kwd-cream);
    border-radius: 0 8px 8px 0;
  }
  .why-card h4 { font-size: 1.05rem; margin-bottom: 0.75rem; }
  .why-card p { color: var(--kwd-brown); font-size: 0.9rem; margin: 0; }

  /* ── Reviews ── */
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .review-card {
    background: var(--kwd-white);
    border-radius: 8px;
    padding: 1.5rem;
    border: 1px solid rgba(0,0,0,0.08);
    display: flex;
