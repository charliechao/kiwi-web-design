---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import TestimonialGrid from '../components/TestimonialGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { Image } from 'astro:assets';
import aucklandVideo from '../assets/general/Auckland_Video.mp4';
import office1 from '../assets/general/office1.jpg';
import office2 from '../assets/general/office2.jpg';
import beautyTouchPreview from '../assets/general/beauty-salon-website-design-seo-auckland.jpg';
import Icon from '../components/Icon.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/",
      url: 'https://www.kiwiwebdesign.co.nz/',
      name: 'Web Design Auckland | Website Design, SEO & Google Ads | Kiwi Web Design',
      description: 'Kiwi Web Design offers AI-ready web design Auckland small businesses can grow with: conversion-focused website design, local SEO, AI SEO, and Google Ads. Grey Lynn, Auckland.',
      isPartOf: { '@id': 'https://www.kiwiwebdesign.co.nz/#website' },
      about: { '@id': 'https://www.kiwiwebdesign.co.nz/#organization' },
      inLanguage: 'en-NZ'
    },
    {
      '@type': 'Organization',
      '@id': 'https://www.kiwiwebdesign.co.nz/#organization',
      name: 'Kiwi Web Design',
      url: 'https://www.kiwiwebdesign.co.nz/',
      telephone: '+64210396580',
      email: 'hi@kiwiwebdesign.co.nz'
    }
  ]
};

const services = [
  {
    icon: 'WD',
    title: 'Website Design',
    desc: 'AI-ready, conversion-focused web design Auckland small businesses can use as the foundation for SEO, AI SEO, and Google Ads.',
    href: '/small-business-website-design-auckland/',
  },
  {
    icon: 'SEO',
    title: 'SEO Auckland',
    desc: 'Local SEO and AI SEO for Auckland businesses that need better Google visibility, stronger Maps coverage, and qualified organic traffic.',
    href: '/affordable-seo-auckland/',
  },
  {
    icon: 'ADS',
    title: 'Google Ads',
    desc: 'Google Ads campaigns and landing-page systems built to turn buying-intent clicks into calls, quote requests, and booked jobs.',
    href: '/google-ads/',
  },
];

const stats = [
  { number: '50+', label: 'Projects completed' },
  { number: '4.9\u2605', label: 'Average Google rating' },
  { number: '98%', label: 'Client satisfaction' },
  { number: '2-3 wks', label: 'Average delivery' },
];

const whyUs = [
  {
    icon: '01',
    title: 'Direct with Charlie Chao',
    desc: 'You work directly with Charlie from strategy through launch, so the message stays sharp and the project keeps moving.',
  },
  {
    icon: '02',
    title: 'Website first, growth system second',
    desc: 'We build the website as the AI-ready conversion foundation, then layer local SEO, AI SEO, and Google Ads around it.',
  },
  {
    icon: '03',
    title: 'Clear pricing from $1,290',
    desc: 'Small businesses need momentum, not vague retainers. We scope around real commercial goals and explain the numbers upfront.',
  },
  {
    icon: '04',
    title: 'Grey Lynn based, Auckland focused',
    desc: 'We understand local search intent, suburb-level trust signals, and the way Auckland buyers decide who to contact.',
  },
];

const process = [
  { step: '1', title: 'Consultation', desc: 'We map the offer, the customer, and the best path to conversion before touching design.' },
  { step: '2', title: 'Website strategy', desc: 'You get a clear web design direction, practical scope, and pricing that line up with how the business actually wins leads.' },
  { step: '3', title: 'Build', desc: 'We design and build quickly, keeping the website structure focused on trust, clarity, action, and AI-ready content signals.' },
  { step: '4', title: 'Launch and grow', desc: 'The site goes live with the next-step plan for local SEO, AI SEO, Google Ads, or ongoing optimisation.' },
];

const packages = [
  {
    name: 'Launch & Get Found',
    price: 'From $1,290',
    desc: 'For Auckland businesses that need a professional, AI-ready website foundation and clean local-search basics.',
    features: ['Conversion-focused web design', 'AI-ready website structure', 'On-page local SEO', 'Mobile-first speed optimisation', 'Contact and lead-capture setup'],
    highlight: false,
    tag: '',
  },
  {
    name: 'Lead Growth Engine',
    price: 'From $2,690',
    desc: 'Auckland web design plus SEO, AI-ready content foundations, and Google Ads working together as one lead-generation system.',
    features: ['Conversion-focused website', 'Local SEO and AI SEO setup', 'AI-ready content and schema foundations', 'Google Ads campaign foundation', 'Lead landing pages', 'Tracking and call measurement'],
    highlight: true,
    tag: 'Most Popular',
  },
  {
    name: 'Sales Accelerator',
    price: 'From $3,890',
    desc: 'For Auckland businesses ready to scale with ongoing SEO, Google Ads management, and conversion improvement.',
    features: ['Monthly SEO and AI search optimisation', 'Lead landing pages', 'Monthly reporting', 'Priority support', 'Growth recommendations'],
    highlight: false,
    tag: '',
  },
];

const reviews = [
  { name: 'Zane Barrett', company: 'Barrett Access Scaffolding', text: 'Professional, responsive, and they really took the time to understand our business.' },
  { name: 'Jack', company: 'Show Me Shorts', text: 'They understood what I needed from the beginning and offered smart, practical solutions.' },
  { name: 'Steven Liu', company: 'Client', text: 'Clean, modern, and user-friendly. The attention to detail really stood out.' },
  { name: 'Gina Dellabarca', company: 'Client', text: 'Clear information, great communication, and a genuinely helpful audit.' },
];

const portfolio = [
  { src: '/portfolio/prime-industrial.webp', alt: 'Prime Industrial website', caption: 'Prime Industrial', href: 'https://primeindustrial.co.nz/' },
  { src: '/portfolio/barrett-access-scaffolding.webp', alt: 'Barrett Access Scaffolding website', caption: 'Barrett Access Scaffolding', href: 'https://www.barrettaccessscaffolding.com/' },
  { src: beautyTouchPreview.src, alt: 'Beauty Touch Auckland website', caption: 'Beauty Touch Auckland', href: 'https://www.beautytouch.co.nz/' },
  { src: '/portfolio/gom.webp', alt: 'Goldwing website', caption: 'Goldwing', href: 'https://gom.co.nz/' },
  { src: '/portfolio/the-framers-guild.webp', alt: 'The Framers Guild framing website', caption: 'The Framers Guild', href: 'https://theframersguild.co.nz/' },
  { src: '/portfolio/kebudel.webp', alt: 'Kebudel website', caption: 'Kebudel', href: 'https://kebudel.com/' },
  { src: '/portfolio/asc-homes.webp', alt: 'ASC Homes website', caption: 'ASC Homes', href: 'https://asc-homes.pages.dev/' },
  { src: '/portfolio/aesthetic-painting.webp', alt: 'Aesthetic Painting website', caption: 'Aesthetic Painting', href: 'https://aestheticpainting.co.nz/' },
  { src: '/portfolio/mt-albert-business.jpg', alt: 'Mt Albert Business Association website', caption: 'Mt Albert Business Assoc.', href: 'https://mtalbert.org.nz/' },
  { src: '/blog/600-21B675F7-8EB5-45A5-99242870729DC26D.png', alt: 'TopRated.nz platform', caption: 'TopRated.nz', href: 'https://www.toprated.nz/' },
];

const portfolioLoop = [...portfolio, ...portfolio];

const faqs = [
  { q: 'How much does a small business website cost in Auckland?', a: 'Our packages start from $1,290 for a lead-focused website. More complex builds are priced accordingly, and you know the cost upfront. Use our <a href="/affordable-web-design-auckland/website-cost-new-zealand-small-business/">free website cost calculator</a> to get an instant NZ estimate.' },
  { q: 'Do I need just a website, or website + SEO + Google Ads?', a: 'If you need a credible online presence fast, start with the website. Every build starts with an AI-ready foundation, then <a href="/affordable-seo-auckland/">SEO</a>, <a href="/ai-seo-for-auckland-small-businesses/">AI SEO</a>, and sometimes <a href="/google-ads/">Google Ads</a> can build on top when you need steady lead flow.' },
  { q: 'Can a web design company in Auckland help with leads, not just design?', a: 'Yes. Good web design should improve enquiries by making the offer clearer, building trust faster, and giving SEO and Google Ads traffic a stronger page to land on.' },
  { q: 'What is the difference between web design and SEO for Auckland small businesses?', a: 'Web design improves how well your website converts visitors. SEO improves how often qualified people find you in Google and Maps. The strongest local setup is usually both together.' },
];

const exploreGroups = [
  {
    label: 'Popular services',
    links: [
      { text: 'Website design packages', href: '/small-business-website-design-auckland/' },
      { text: 'Local SEO Auckland', href: '/local-seo-for-auckland-small-businesses/' },
      { text: 'AI SEO & GEO', href: '/ai-seo-for-auckland-small-businesses/' },
      { text: 'Google Ads Auckland', href: '/google-ads/' },
    ],
  },
  {
    label: 'Industries',
    links: [
      { text: 'Tradies', href: '/tradie-website-design-auckland/' },
      { text: 'Beauty & Wellness', href: '/how-kiwi-web-design-helps-auckland-beauty-industry/' },
      { text: 'Restaurants & Cafes', href: '/how-kiwi-web-design-helps-auckland-restaurants/' },
      { text: 'Healthcare', href: '/how-kiwi-web-design-helps-auckland-healthcare/' },
    ],
  },
  {
    label: 'Auckland areas',
    links: [
      { text: 'North Shore', href: '/north-shore-website-design/' },
      { text: 'South Auckland', href: '/south-auckland-web-design/' },
      { text: 'West Auckland', href: '/west-auckland-web-design/' },
      { text: 'East Auckland', href: '/east-auckland-web-design/' },
    ],
  },
];
---

<Layout
  title="Web Design Auckland | Website Design, SEO & Google Ads | Kiwi Web Design"
  description="Kiwi Web Design offers AI-ready web design Auckland small businesses can grow with: conversion-focused website design, local SEO, AI SEO, and Google Ads. Grey Lynn, Auckland."
  canonicalURL="https://www.kiwiwebdesign.co.nz/"
  schema={schema}
  alternateUrl="https://www.kiwiwebdesign.co.nz/zh/"
>
  <section class="hp-hero">
    <div class="hp-hero-glow hp-hero-glow-one" aria-hidden="true"></div>
    <div class="hp-hero-glow hp-hero-glow-two" aria-hidden="true"></div>
    <div class="container hp-hero-shell">
      <div class="hp-hero-copy">
        <div class="hp-kicker-row">
          <p class="hp-eyebrow hp-hero-seq" style="--hero-delay: 0.04s;">Web Design Auckland</p>
          <span class="hp-location-pill hp-hero-seq" style="--hero-delay: 0.12s;">Grey Lynn, Auckland</span>
        </div>
        <h1 class="hp-headline hp-hero-seq" style="--hero-delay: 0.18s;">Web design Auckland businesses can use to generate more leads.</h1>
        <p class="hp-lead hp-hero-seq" style="--hero-delay: 0.3s;">Kiwi Web Design is a Grey Lynn studio offering AI-ready website design Auckland small businesses can build on with local SEO, AI SEO, and Google Ads. We create conversion-focused systems that turn clicks into calls, quote requests, and steady enquiries.</p>
        <div class="hp-ctas hp-hero-seq" style="--hero-delay: 0.42s;">
          <a href="/website-designer-auckland/" class="hp-btn-primary">Book a Free Consultation</a>
          <a href="#packages" class="hp-btn-secondary">See Pricing</a>
        </div>
        <div class="hp-proof-row hp-hero-seq" style="--hero-delay: 0.52s;">
          <a href="https://share.google/nciRqe4rK6ywabSVx" target="_blank" rel="noopener" class="hp-review-pill">
            <div class="review-pill-badge">Google</div>
            <div>
              <p class="htc-text"><strong>4.9/5</strong> Google Reviews</p>
              <p class="htc-sub">47 verified reviews from Auckland clients</p>
            </div>
          </a>
          <p class="hp-mini-note">Work directly with Charlie Chao. Free consultation online or in person. Typical launch timeline: 2-3 weeks.</p>
        </div>
      </div>

      <div class="hp-stage" data-stage-parallax>
        <div class="hp-stage-window-shell hp-hero-seq" style="--hero-delay: 0.24s;">
          <div class="hp-stage-window">
            <div class="hp-stage-topline">
              <span>Conversion-first build</span>
            </div>
            <video class="hp-stage-video" autoplay muted loop playsinline preload="none" poster="/hero-poster.webp">
              <source src={aucklandVideo} type="video/mp4" />
            </video>
            <div class="hp-stage-overlay" aria-hidden="true"></div>
            <div class="hp-stage-caption">
              <p class="hp-stage-label">Launch faster, convert harder</p>
              <p class="hp-stage-title">Auckland website design should feel credible in five seconds and convert cleanly when SEO or ad traffic arrives.</p>
            </div>
          </div>
        </div>

        <div class="hp-stage-cards">
          {stats.map(({ number, label }, index) => (
            <div class="hp-stat-card hp-hero-seq" style={`--hero-delay: ${0.58 + index * 0.08}s;`}>
              <span class="hp-stat-number">{number}</span>
              <span class="hp-stat-label">{label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section hp-intro-section">
    <div class="container hp-intro-grid" data-reveal>
      <div class="hp-intro-copy">
        <div class="hp-motion-heading" style="--motion-delay: 0ms;">
          <SectionHeader
            eyebrow="Why Auckland businesses switch"
            title="Web design Auckland businesses can rely on."
            subtitle="Your website should explain the offer fast, build trust quickly, and make calling or enquiring feel like the obvious next step."
            align="left"
          />
        </div>
        <p class="hp-intro-text hp-motion-item" style="--motion-delay: 160ms;">That is the gap most small-business websites miss. They may look acceptable, but they do not explain the value fast enough, they bury trust signals, and they give buyers too much to think about. We build the website as an AI-ready conversion foundation, then support it with <a href="/affordable-seo-auckland/">SEO</a>, <a href="/ai-seo-for-auckland-small-businesses/">AI SEO</a>, and <a href="/google-ads/">Google Ads</a> when growth needs more fuel.</p>
        <ul class="hp-checklist">
          <li class="hp-motion-item" style="--motion-delay: 260ms;">Sharper above-the-fold messaging so buyers understand your service and suburb coverage immediately.</li>
          <li class="hp-motion-item" style="--motion-delay: 340ms;">Proof-led layouts with reviews, case studies, schema foundations, and local trust signals that support Google Maps and AI search visibility.</li>
          <li class="hp-motion-item" style="--motion-delay: 420ms;">Conversion paths tuned for quote requests, calls, bookings, and paid or organic traffic from Auckland search.</li>
        </ul>
      </div>

      <div class="hp-adv-grid">
        {whyUs.map(({ icon, title, desc }, index) => (
          <article class="hp-adv-card hp-motion-item" style={`--motion-delay: ${220 + index * 100}ms;`}>
            <div class="hp-adv-icon">
              {icon}
            </div>
            <h3>{title}</h3>
            <p>{desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section hp-services-section">
    <div class="container" data-reveal>
      <div class="hp-motion-heading" style="--motion-delay: 0ms;">
        <SectionHeader
          eyebrow="The system"
          title="Your website is the foundation. SEO and Google Ads scale it."
          subtitle="The strongest results come when your web design, local search visibility, AI-ready website structure, and paid traffic all point at the same conversion goal."
        />
      </div>
      <div class="service-grid">
        {services.map(({ icon, title, desc, href }, index) => (
          <a href={href} class="service-card hp-motion-item" style={`--motion-delay: ${140 + index * 110}ms;`}>
            <div class="service-icon"><Icon name={icon} size={24} /></div>
            <h3>{title}</h3>
            <p>{desc}</p>
            <span>Learn more -&gt;</span>
          </a>
        ))}
      </div>
    </div>
  </section>
  <section class="section hp-studio-section">
    <div class="container hp-studio-grid" data-reveal>
      <div class="hp-studio-photos">
        <div class="hp-studio-photo hp-studio-photo-large hp-photo-drift-one hp-motion-item" style="--motion-delay: 80ms;">
          <Image src={office1} alt="Kiwi Web Design studio - Auckland web design workspace" width={800} height={540} class="office-img" />
        </div>
        <div class="hp-studio-photo hp-studio-photo-small hp-photo-drift-two hp-motion-item" style="--motion-delay: 180ms;">
          <Image src={office2} alt="Kiwi Web Design team at work in Grey Lynn Auckland" width={800} height={540} class="office-img" />
        </div>
      </div>

      <div class="hp-studio-copy">
        <div class="hp-motion-heading" style="--motion-delay: 0ms;">
          <SectionHeader
            eyebrow="Local and hands-on"
            title="Grey Lynn based. Built for Auckland small businesses."
            subtitle="We keep the process direct, the pricing clear, and the work tied to what your business needs to rank, convert, and grow."
            align="left"
          />
        </div>
        <p class="hp-intro-text hp-motion-item" style="--motion-delay: 150ms;">You are not passed through layers of account managers. Charlie Chao works closely with you to shape the message, tighten the offer, and build a website that gives Auckland buyers enough confidence to call, enquire, or request a quote.</p>
        <div class="hp-studio-note hp-motion-item" style="--motion-delay: 260ms;">
          <strong>Best fit:</strong> service businesses, professional firms, tradies, restaurants, clinics, and local brands that need more than a generic template and want a practical path into SEO or Google Ads.
        </div>
      </div>
    </div>
  </section>

  <section class="section hp-work-section">
    <div class="container hp-work-shell">
      <div class="hp-work-intro" data-reveal>
        <div class="hp-motion-heading" style="--motion-delay: 0ms;">
          <SectionHeader
            eyebrow="Selected Work"
            title="Website design for real Auckland businesses."
            subtitle="From tradies to restaurants to law firms, every project is designed around clarity, credibility, and lead generation."
            align="left"
          />
        </div>
        <a href="/website-designer-auckland/" class="hp-btn-primary hp-motion-item" style="--motion-delay: 140ms;">Start Your Project</a>
      </div>

      <div class="portfolio-carousel" data-portfolio-carousel data-reveal>
        <div class="portfolio-viewport">
          <div class="portfolio-track">
            {portfolioLoop.map(({ src, alt, caption, href }, index) => {
              const isClone = index >= portfolio.length;
              const isExternal = href?.startsWith('http');
              const motionDelay = Math.min(index, portfolio.length - 1) * 90 + 100;

              return href ? (
                <a
                  href={href}
                  target={isExternal ? '_blank' : undefined}
                  rel={isExternal ? 'noopener noreferrer' : undefined}
                  class:list={['portfolio-item', !isClone && 'hp-motion-item', isClone && 'is-clone']}
                  aria-hidden={isClone ? 'true' : undefined}
                  tabindex={isClone ? '-1' : undefined}
                  style={!isClone ? `--motion-delay: ${motionDelay}ms;` : undefined}
                >
                  <img src={src} alt={isClone ? '' : alt} width="400" height="280" loading="lazy" class="portfolio-img" />
                  <span class="portfolio-caption">
                    <span>{caption}</span>
                    <span class="portfolio-arrow">Visit website -&gt;</span>
                  </span>
                </a>
              ) : (
                <figure
                  class:list={['portfolio-item', 'portfolio-item-static', !isClone && 'hp-motion-item', isClone && 'is-clone']}
                  aria-hidden={isClone ? 'true' : undefined}
                  style={!isClone ? `--motion-delay: ${motionDelay}ms;` : undefined}
                >
                  <img src={src} alt={isClone ? '' : alt} width="400" height="280" loading="lazy" class="portfolio-img" />
                  <figcaption class="portfolio-caption">
                    <span>{caption}</span>
                    <span class="portfolio-arrow">Featured project</span>
                  </figcaption>
                </figure>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section hp-proof-section">
    <div class="container hp-proof-layout" data-reveal>
      <div class="hp-proof-copy">
        <div class="hp-motion-heading" style="--motion-delay: 0ms;">
          <SectionHeader
            eyebrow="Client Reviews"
            title="Trusted by Auckland businesses that need leads, not fluff."
        
            align="left"
          />
        </div>
        <div class="reviews-trust hp-motion-item" style="--motion-delay: 180ms;">
          <div class="reviews-stars" aria-label="5 stars">
            <svg viewBox="0 0 20 20" fill="#f5a523" aria-hidden="true"><path d="m10 1 2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.44.91-5.32L2.27 6.62l5.34-.78z"/></svg>
            <svg viewBox="0 0 20 20" fill="#f5a523" aria-hidden="true"><path d="m10 1 2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.44.91-5.32L2.27 6.62l5.34-.78z"/></svg>
            <svg viewBox="0 0 20 20" fill="#f5a523" aria-hidden="true"><path d="m10 1 2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.44.91-5.32L2.27 6.62l5.34-.78z"/></svg>
            <svg viewBox="0 0 20 20" fill="#f5a523" aria-hidden="true"><path d="m10 1 2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.44.91-5.32L2.27 6.62l5.34-.78z"/></svg>
            <svg viewBox="0 0 20 20" fill="#f5a523" aria-hidden="true"><path d="m10 1 2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.44.91-5.32L2.27 6.62l5.34-.78z"/></svg>
            <span class="reviews-google-label">Google</span>
          </div>
          <p>4.9/5 Google rating across 47 verified Auckland client reviews</p>
        </div>
      </div>

      <div class="hp-proof-cards hp-motion-testimonials" style="--motion-delay: 180ms;">
        <TestimonialGrid items={reviews} cols={2} />
      </div>
    </div>
  </section>

  <section class="section hp-process-section">
    <div class="container" data-reveal>
      <div class="hp-motion-heading" style="--motion-delay: 0ms;">
        <SectionHeader
          eyebrow="How It Works"
          title="A practical web design process with growth built in."
          subtitle="Clear scope, quick execution, and an AI-ready website that can grow into SEO, AI SEO, or Google Ads when you are ready."
        />
      </div>
      <div class="hp-motion-process" style="--motion-delay: 140ms;">
        <ProcessSteps items={process} />
      </div>
    </div>
  </section>

  <section class="section hp-packages-section" id="packages">
    <div class="container" data-reveal>
      <div class="hp-motion-heading" style="--motion-delay: 0ms;">
        <SectionHeader
          eyebrow="Pricing"
          title="Start with website design. Grow into SEO and Google Ads."
          subtitle="Structured for Auckland businesses that need better presentation, stronger lead flow, and an AI-ready website foundation."
        />
      </div>
      <div class="packages-grid">
        {packages.map(({ name, price, desc, features, highlight, tag }, index) => (
          <div class:list={['pkg-card', 'hp-motion-item', highlight && 'pkg-highlight']} style={`--motion-delay: ${140 + index * 120}ms;`}>
            {tag && <span class="pkg-tag">{tag}</span>}
            <h3 class="pkg-name">{name}</h3>
            <p class="pkg-price">{price}</p>
            <p class="pkg-desc">{desc}</p>
            <ul class="pkg-features">
              {features.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>
            <a href="/website-designer-auckland/" class:list={['pkg-cta', highlight && 'pkg-cta-accent']}>Get Started -&gt;</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section hp-faq-section">
    <div class="container faq-layout" data-reveal>
      <div class="hp-motion-item hp-motion-soft" style="--motion-delay: 0ms;">
        <p class="faq-eyebrow">FAQs</p>
        <h2 class="faq-sidebar-title">Questions Auckland business owners ask before hiring a web designer.</h2>
        <p class="faq-sidebar-sub">If you do not see your question here, reach out and we will answer directly.</p>
        <a href="/website-designer-auckland/" class="hp-btn-dark" style="margin-top: 1.5rem; display: inline-flex;">Ask a Question</a>
      </div>
      <div class="hp-motion-faq hp-motion-soft" style="--motion-delay: 120ms;">
        <FAQAccordion items={faqs} title="" />
      </div>
    </div>
  </section>

  <section class="section hp-explore-section">
    <div class="container" data-reveal>
      <div class="hp-motion-heading" style="--motion-delay: 0ms;">
        <SectionHeader
          eyebrow="Explore More"
