      inLanguage: 'en-NZ'
    },
    {
      '@type': ['Organization', 'ProfessionalService'],
      '@id': 'https://www.kiwiwebdesign.co.nz/#organization',
      name: 'Kiwi Web Design',
      legalName: 'Ika Tech Limited',
      alternateName: 'Kiwi Web Design Auckland',
      url: 'https://www.kiwiwebdesign.co.nz/',
      telephone: '+64210396580',
      email: 'hi@kiwiwebdesign.co.nz',
      image: 'https://www.kiwiwebdesign.co.nz/logo-96.webp',
      priceRange: '$$',
