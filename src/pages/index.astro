---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import StatsRow from '../components/StatsRow.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import TestimonialGrid from '../components/TestimonialGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "name": "Auckland Web Design That Generates Leads | Kiwi Web Design",
      "description": "We build websites for Auckland small businesses that generate real enquiries. Strategy-first web design focused on leads, not just looks.",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "datePublished": "2025-04-09T22:43:08+00:00",
      "dateModified": "2026-03-05T21:19:05+00:00",
      "inLanguage": "en-NZ"
    },
    {
      "@type": "WebSite",
      "@id": "https://www.kiwiwebdesign.co.nz/#website",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "name": "Kiwi Web Design",
      "description": "Websites built to generate leads",
      "publisher": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" }
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/04/android-chrome-512x512-1.png",
        "width": 512,
        "height": 512
      },
      "sameAs": [
        "https://www.facebook.com/profile.php?id=61559560322941",
        "https://www.instagram.com/kiwi_web_design/",
        "https://www.linkedin.com/company/108270459/"
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "How much does it cost to generate leads online for a small Auckland business?", "acceptedAnswer": { "@type": "Answer", "text": "Starting from $1,290 for a lead-focused website with basic SEO." } },
        { "@type": "Question", "name": "Will my website actually generate enquiries?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every site we build is designed around conversion with clear calls to action." } },
        { "@type": "Question", "name": "How long does SEO take to bring leads?", "acceptedAnswer": { "@type": "Answer", "text": "You can expect early movement in 2 to 3 months, with stronger results building over 6-12 months." } }
      ]
    }
  ]
};

const services = [
  {
    icon: "🌐",
    title: "Website Design",
    desc: "Conversion-focused websites built for Auckland small businesses. Mobile-first, fast, and designed to turn visitors into enquiries — not just look good.",
    href: "/small-business-website-design-auckland/",
  },
  {
    icon: "📈",
    title: "SEO Auckland",
    desc: "Local SEO that targets the keywords your customers actually search. We build organic visibility that brings consistent, high-intent traffic to your site.",
    href: "/seo-auckland/",
  },
  {
    icon: "🎯",
    title: "Google Ads",
    desc: "PPC campaigns built around buyer intent. We set up, manage, and optimise Google Ads so you get more calls and enquiries — without wasting ad spend.",
    href: "/google-ads/",
  },
];

const whyUs = [
  {
    icon: "💬",
    title: "Free Consultation — In Person or Online",
    desc: "We meet you first, learn your goals, and only then recommend a path forward. No hard sell. Your consultation can happen in Grey Lynn, anywhere in Auckland, or over video call.",
  },
  {
    icon: "💰",
    title: "Websites from $1,290",
    desc: "We combine AI-assisted tools with local expertise to deliver premium results at 50–70% lower cost than typical Auckland web agencies. You know the price upfront.",
  },
  {
    icon: "⚡",
    title: "Live in 2–3 Weeks",
    desc: "Most projects launch in as little as two weeks. We move fast without cutting corners, so you can start getting enquiries sooner rather than waiting months.",
  },
  {
    icon: "📍",
    title: "Based in Grey Lynn, Auckland",
    desc: "Genuinely local — 147 Great North Road, Grey Lynn. We understand Auckland suburbs, local search intent, and what your customers expect.",
  },
];

const stats = [
  { number: "50+", label: "Projects Completed" },
  { number: "4.9★", label: "Average Google Rating" },
  { number: "98%", label: "Client Satisfaction" },
  { number: "2–3 wks", label: "Average Delivery" },
];

const packages = [
  {
    name: "Launch & Get Found",
    price: "From $1,290",
    desc: "For new businesses that need a professional presence and early visibility online.",
    features: [
      "5-page lead-focused website",
      "Mobile-first responsive design",
      "On-page local SEO",
      "Speed & Core Web Vitals optimisation",
      "Contact form + click-to-call",
      "Email & phone support",
    ],
    highlight: false,
    tag: "",
  },
  {
    name: "Lead Growth Engine",
    price: "From $2,690",
    desc: "A complete system combining a high-converting website, SEO, and Google Ads setup.",
    features: [
      "Conversion-optimised website",
      "Local SEO targeting buyer keywords",
      "Google Ads campaign setup",
      "Dedicated landing pages for ads",
      "Conversion tracking setup",
      "Ongoing optimisation recommendations",
    ],
    highlight: true,
    tag: "Most Popular",
  },
  {
    name: "Sales Accelerator",
    price: "From $3,890",
    desc: "Full-service growth through ongoing SEO, Google Ads management, and CRO.",
    features: [
      "Advanced conversion optimisation",
      "Ongoing SEO + Google Ads management",
      "Dedicated lead landing pages",
      "Monthly performance reporting",
      "Priority support",
    ],
    highlight: false,
    tag: "",
  },
];

const process = [
  { step: "1", title: "Free Consultation", desc: "We learn about your business, your goals, and who your customers are — before recommending anything." },
  { step: "2", title: "Strategy & Proposal", desc: "You receive a clear proposal: what we'll build, how it will generate leads, and exactly what it costs." },
  { step: "3", title: "Design & Build", desc: "We design and build your website, SEO strategy, or ad campaigns — typically in 2–3 weeks." },
  { step: "4", title: "Launch & Grow", desc: "Go live, start generating leads, and get ongoing support to keep improving results over time." },
];

const reviews = [
  {
    name: "Zane Barrett",
    company: "Barrett Access Scaffolding",
    text: "We recently worked with Kiwi Web Design to launch our new website, and we couldn't be happier. Professional, responsive, and they really took the time to understand our business. They even built the first scaffold cost calculator in NZ!",
  },
  {
    name: "Jack",
    company: "Show Me Shorts",
    text: "Kiwi Web Design were fantastic to work with. From the very beginning they understood what I needed and offered smart, practical solutions. Professional, friendly, and quick to respond.",
  },
  {
    name: "Steven Liu",
    company: "Client",
    text: "Outstanding experience with Charlie! The design is clean, modern, and user-friendly — exactly what I hoped for. Charlie's attention to detail and commitment to quality really stood out.",
  },
  {
    name: "Gina Dellabarca",
    company: "Client",
    text: "They provided a comprehensive and helpful website audit for us. Clear information. Great communication. Highly recommended.",
  },
];

const portfolio = [
  { src: "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/06/Auckland_Cleaner-e1750284778292.jpg",           alt: "Auckland cleaning company website", caption: "Top Line Services" },
  { src: "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/06/Auckland_Building_Inspector-e1750284793590.jpg", alt: "Auckland building inspector website", caption: "Inspector Guys" },
  { src: "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/07/Lavaranda-e1753415431519.jpg",                   alt: "Auckland restaurant website", caption: "La Veranda Restaurant" },
  { src: "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/07/Legal-e1753416217381.jpg",                       alt: "Auckland law firm website", caption: "FL Legal" },
  { src: "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/10/Mt-Albert-Business-Association-Website.jpg",     alt: "Mt Albert Business Association", caption: "Mt Albert Business Assoc." },
  { src: "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/07/Kiwiland-e1753410581810.jpg",                    alt: "Auckland construction company website", caption: "Kiwiland Construction" },
  { src: "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/07/Specialist-e1753415885359.jpg",                  alt: "Auckland medical specialist website", caption: "Melanoma NZ" },
  { src: "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2026/01/600-21B675F7-8EB5-45A5-99242870729DC26D.png",    alt: "TopRated.nz directory", caption: "TopRated.nz" },
];

const faqs = [
  { q: "How much does a small business website cost in Auckland?", a: "Our packages start from $1,290 for a 5-page lead-focused website. More complex projects with e-commerce, bookings, or custom features are priced accordingly. You'll always know the cost upfront — no surprises." },
  { q: "Will my website actually generate enquiries?", a: "A website alone doesn't guarantee leads. That's why we design around conversion: clear calls to action, trust signals, and buyer-intent structure. Combined with <a href=\"/seo-auckland/\">SEO</a> or <a href=\"/google-ads/\">Google Ads</a>, your site becomes a lead-generation system." },
  { q: "How long does SEO take to show results in Auckland?", a: "Most Auckland businesses see early movement in 2–3 months, with stronger results building over 6–12 months. We focus on local buyer keywords that matter, not vanity traffic." },
  { q: "Do you offer websites, SEO, and Google Ads together?", a: "Yes, and combining all three is our most effective approach. The website handles conversion, <a href=\"/seo-auckland/\">SEO builds long-term visibility</a>, and <a href=\"/google-ads/\">Google Ads drives immediate demand</a>." },
  { q: "How fast can you build a website?", a: "Most projects are live in 2–3 weeks. We're upfront if anything will take longer and keep you informed throughout the process." },
  { q: "Do you work with tradies and service businesses?", a: "Yes — regularly. Our <a href=\"/tradie-website-design-auckland/\">tradie website design</a> work covers plumbers, electricians, builders, cleaners, and other service businesses across Auckland. Our focus is making it easy for customers to find and contact you." },
  { q: "Can you migrate my existing website from Wix or Squarespace?", a: "Yes. Our <a href=\"/wordpress-website-rebuilds-auckland/\">WordPress website rebuild service</a> migrates and improves your site, preserving important content and significantly improving performance, SEO, and conversion." },
  { q: "Why choose Kiwi Web Design over other Auckland agencies?", a: "Free in-person consultations, transparent pricing, AI-assisted efficiency, and a genuine focus on leads rather than aesthetics. See our <a href=\"/website-design-process-in-auckland/\">design process</a> and <a href=\"/about-us/\">our story</a> — we deliver premium results at 50–70% less than traditional agencies." },
];
---

<Layout
  title="Auckland Web Design That Generates Leads | Kiwi Web Design"
  description="We build websites for Auckland small businesses that generate real enquiries. Strategy-first web design focused on leads, not just looks."
  canonicalURL="https://www.kiwiwebdesign.co.nz/"
  schema={schema}
>

  <!-- ── Hero ── -->
  <section class="hp-hero">
    <div class="container hp-hero-inner">
      <div class="hp-hero-text">
        <p class="hp-eyebrow">Web Design · SEO · Google Ads · Auckland, NZ</p>
        <h1 class="hp-headline">
          Websites. SEO. Google Ads.<br />
          <span class="hp-accent">Real leads for Auckland businesses.</span>
        </h1>
        <p class="hp-lead">Kiwi Web Design helps Auckland small businesses drive traffic, enquiries, and sales — not just build websites. Strategy-first, results-focused, locally based.</p>
        <div class="hp-ctas">
          <a href="/website-designer-auckland/" class="hp-btn-primary">Get a Free Quote</a>
          <a href="/small-business-website-design-auckland/" class="hp-btn-ghost">See Our Packages</a>
        </div>
      </div>
      <div class="hp-hero-visual">
        <img
          src="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/08/Auckland.jpg"
          alt="Auckland city skyline — Kiwi Web Design serves all of Auckland"
          width="640"
          height="420"
          loading="eager"
          class="hp-hero-img"
        />
        <div class="hp-trust-card">
          <div class="htc-stars">★★★★★</div>
          <p class="htc-text"><strong>4.9/5</strong> from 47 Google reviews</p>
          <p class="htc-sub">Trusted by 50+ Auckland businesses</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Trust bar ── -->
  <div class="trust-bar">
    <div class="container trust-bar-inner">
      <div class="tb-item">
        <span class="tb-value">4.9★</span>
        <span class="tb-label">Google Reviews</span>
      </div>
      <span class="tb-sep" aria-hidden="true"></span>
      <div class="tb-item">
        <span class="tb-value">50+</span>
        <span class="tb-label">Projects Delivered</span>
      </div>
      <span class="tb-sep" aria-hidden="true"></span>
      <div class="tb-item">
        <span class="tb-value">2–3 wks</span>
        <span class="tb-label">Average Delivery</span>
      </div>
      <span class="tb-sep" aria-hidden="true"></span>
      <div class="tb-item">
        <span class="tb-value">From $1,290</span>
        <span class="tb-label">Website Pricing</span>
      </div>
      <span class="tb-sep" aria-hidden="true"></span>
      <div class="tb-item">
        <span class="tb-value">Grey Lynn</span>
        <span class="tb-label">Auckland-based</span>
      </div>
    </div>
  </div>

  <!-- ── Core services ── -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="What We Do"
        title="Three services. One goal: more enquiries."
        subtitle="Web design, SEO, and Google Ads working together to bring your business a steady stream of qualified leads."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- ── Stats strip ── -->
  <StatsRow items={stats} dark={true} />

  <!-- ── Why choose us ── -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="Why Kiwi Web Design"
        title="The agency that puts your growth first."
        subtitle="We're not the biggest agency in Auckland — but we're the one that cares most about your results."
      />
      <ServiceGrid items={whyUs} cols={2} />
    </div>
  </section>

  <!-- ── Recent work ── -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="Our Work"
        title="Built for real Auckland businesses."
        subtitle="From tradies to restaurants to law firms — every site designed to generate leads."
        light={true}
      />
      <div class="portfolio-grid">
        {portfolio.map(({ src, alt, caption }) => (
          <figure class="portfolio-item">
            <img src={src} alt={alt} width="400" height="280" loading="lazy" class="portfolio-img" />
            <figcaption class="portfolio-caption">{caption}</figcaption>
          </figure>
        ))}
      </div>
      <div class="portfolio-cta-wrap">
        <a href="/website-designer-auckland/" class="hp-btn-primary">Start Your Project</a>
      </div>
    </div>
  </section>

  <!-- ── Testimonials ── -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Client Reviews"
        title="Don't take our word for it."
        subtitle="Here's what Auckland business owners say after working with us."
      />
      <TestimonialGrid items={reviews} cols={2} />
      <div class="reviews-trust">
        <img
          src="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/08/3-31594_google-5-stars-google-plus-reviews-logo-hd-e1757787389297.jpg"
          alt="Google 5 Star Reviews"
          width="160"
          height="60"
          loading="lazy"
        />
        <p>4.9 stars across 47 verified Google reviews</p>
      </div>
    </div>
  </section>

  <!-- ── Process ── -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="Simple process. Real results."
        subtitle="From your first conversation to a live, lead-generating website — here's how it works."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- ── Packages ── -->
  <section class="section" id="packages">
    <div class="container">
      <SectionHeader
        eyebrow="Pricing"
        title="Lead Generation Packages"
        subtitle="Choose based on how quickly you want to grow — every package is built around results."
      />
      <div class="packages-grid">
        {packages.map(({ name, price, desc, features, highlight, tag }) => (
          <div class:list={['pkg-card', highlight && 'pkg-highlight']}>
            {tag && <span class="pkg-tag">{tag}</span>}
            <h3 class="pkg-name">{name}</h3>
            <p class="pkg-price">{price}</p>
            <p class="pkg-desc">{desc}</p>
            <ul class="pkg-features">
              {features.map((f) => <li>{f}</li>)}
            </ul>
            <a href="/website-designer-auckland/" class:list={['pkg-cta', highlight && 'pkg-cta-accent']}>
              Get Started →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <div class="faq-layout">
        <div class="faq-sidebar">
          <p class="faq-eyebrow">FAQs</p>
          <h2 class="faq-sidebar-title">Common questions from Auckland business owners.</h2>
          <p class="faq-sidebar-sub">If you don't see your question here, reach out — we're happy to answer directly.</p>
          <a href="/website-designer-auckland/" class="hp-btn-dark" style="margin-top: 1.5rem; display: inline-block;">Ask a Question</a>
        </div>
        <div>
          <FAQAccordion items={faqs} title="" />
        </div>
      </div>
    </div>
  </section>

  <!-- ── Related services ── -->
  <section class="related-strip">
    <div class="container" style="max-width: 900px;">
      <p class="rps-label">Explore our services</p>
      <div class="rps-links">
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress Websites</a>
        <a href="/local-seo-for-auckland-small-businesses/" class="rps-link">Local SEO Auckland</a>
        <a href="/ecommerce-website-auckland/" class="rps-link">eCommerce Websites</a>
        <a href="/tradie-website-design-auckland/" class="rps-link">Tradie Websites</a>
        <a href="/wordpress-maintenance-auckland/" class="rps-link">WordPress Maintenance</a>
        <a href="/website-hosting-auckland/" class="rps-link">Website Hosting</a>
      </div>
    </div>
  </section>

  <!-- ── Final CTA ── -->
  <CTABanner
    variant="yellow"
    title="Ready to grow your Auckland business online?"
    subtitle="Free consultation — online or in person, Auckland wide. No commitment, no pressure."
    ctaPrimary={{ text: "Book a Free Consultation", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Our Packages", href: "/small-business-website-design-auckland/" }}
  />

</Layout>

<style>
  /* ── Hero ── */
  .hp-hero {
    background: var(--kwd-dark);
    padding: 5.5rem 0 4.5rem;
  }
  .hp-hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .hp-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-yellow);
    margin-bottom: 1.25rem;
  }
  .hp-headline {
    font-size: clamp(2.4rem, 5vw, 4.25rem);
    color: #fff;
    line-height: 1.08;
    margin-bottom: 1.25rem;
    font-family: var(--kwd-font-heading);
  }
  .hp-accent { color: var(--kwd-yellow); }
  .hp-lead {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.72);
    max-width: 540px;
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .hp-ctas { display: flex; flex-wrap: wrap; gap: 1rem; }

  .hp-btn-primary {
    display: inline-block;
    background: var(--kwd-yellow);
    color: var(--kwd-dark);
    padding: 0.875rem 2rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    transition: background 0.2s, transform 0.15s;
  }
  .hp-btn-primary:hover { background: var(--kwd-gold); transform: translateY(-1px); }

  .hp-btn-dark {
    display: inline-block;
    background: var(--kwd-dark);
    color: #fff;
    padding: 0.875rem 2rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    transition: background 0.2s, transform 0.15s;
  }
  .hp-btn-dark:hover { background: #3e3633; transform: translateY(-1px); }

  .hp-btn-ghost {
    display: inline-block;
    border: 2px solid rgba(255,255,255,0.3);
    color: rgba(255,255,255,0.85);
    padding: 0.875rem 2rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    transition: border-color 0.2s, color 0.2s;
  }
  .hp-btn-ghost:hover { border-color: var(--kwd-yellow); color: var(--kwd-yellow); }

  /* Hero visual */
  .hp-hero-visual { position: relative; }
  .hp-hero-img {
    width: 100%;
    height: auto;
    border-radius: 16px;
    display: block;
    object-fit: cover;
    box-shadow: 0 32px 64px rgba(0,0,0,0.45);
  }
  .hp-trust-card {
    position: absolute;
    bottom: -1.25rem;
    left: -1.25rem;
    background: #fff;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    min-width: 200px;
  }
  .htc-stars { color: #f5a523; font-size: 0.9rem; margin-bottom: 0.25rem; }
  .htc-text  { font-size: 0.85rem; font-weight: 600; color: var(--kwd-dark); margin: 0 0 0.15rem; }
  .htc-sub   { font-size: 0.75rem; color: var(--kwd-brown); margin: 0; }

  /* ── Trust bar ── */
  .trust-bar {
    background: #fff;
    border-bottom: 1px solid rgba(0,0,0,0.07);
    padding: 1.25rem 0;
  }
  .trust-bar-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  .tb-item { display: flex; flex-direction: column; align-items: center; gap: 0.1rem; }
  .tb-value { font-size: 1.05rem; font-weight: 700; color: var(--kwd-dark); font-family: var(--kwd-font-heading); }
  .tb-label { font-size: 0.7rem; color: var(--kwd-brown); text-transform: uppercase; letter-spacing: 0.07em; }
  .tb-sep   { width: 1px; height: 1.75rem; background: rgba(0,0,0,0.1); flex-shrink: 0; }

  /* ── Portfolio ── */
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .portfolio-item { margin: 0; overflow: hidden; border-radius: 10px; }
  .portfolio-img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
