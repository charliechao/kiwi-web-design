      description: 'Kiwi Web Design helps small businesses across Auckland build affordable, professional, and AI-optimised websites that convert visitors into customers.',
      thumbnailUrl: 'https://i.ytimg.com/vi/n9BFps8DyRY/maxresdefault.jpg',
      uploadDate: '2025-10-27T15:05:22-07:00',
      duration: 'PT3M15S',
      embedUrl: 'https://www.youtube.com/embed/n9BFps8DyRY',
      contentUrl: 'https://www.youtube.com/watch?v=n9BFps8DyRY',
      publisher: { '@id': 'https://www.kiwiwebdesign.co.nz/#organization' },
      isPartOf: { '@id': 'https://www.kiwiwebdesign.co.nz/' }
