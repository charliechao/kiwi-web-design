  <script>
    // Reviews carousel: one card per step, loops, auto-advances. Ported from /web-design-auckland-lp/.
    (() => {
      function initReviewClamp() {
        document.querySelectorAll<HTMLElement>('.lp-review-card').forEach((card) => {
          if (card.dataset.clampInit) return;
          const textEl = card.querySelector<HTMLElement>('.lp-review-text');
          const moreBtn = card.querySelector<HTMLButtonElement>('.lp-review-more');
          if (!textEl || !moreBtn) return;
          card.dataset.clampInit = '1';
          if (textEl.scrollHeight - textEl.clientHeight > 4) {
            moreBtn.hidden = false;
            moreBtn.addEventListener('click', () => {
              const expanded = card.classList.toggle('is-expanded');
              moreBtn.textContent = expanded ? 'Read less' : 'Read more';
            });
          }
        });
      }
      const fontsApi = (document as Document & { fonts?: FontFaceSet }).fonts;
      if (fontsApi?.ready) { fontsApi.ready.then(initReviewClamp); } else { initReviewClamp(); }

      const track = document.getElementById('lp-reviews-track');
      const prevBtn = document.getElementById('lp-rev-prev') as HTMLButtonElement | null;
      const nextBtn = document.getElementById('lp-rev-next') as HTMLButtonElement | null;
      if (!track || !prevBtn || !nextBtn) return;

      const stepBy = () => {
        const card = track.querySelector<HTMLElement>('.lp-review-card');
        return card ? card.getBoundingClientRect().width + 24 : track.clientWidth * 0.9;
      };
      const maxScroll = () => track.scrollWidth - track.clientWidth;
      const advance = (dir: 1 | -1) => {
        if (dir === 1 && track.scrollLeft >= maxScroll() - 2) {
          track.scrollTo({ left: 0, behavior: 'smooth' });
        } else if (dir === -1 && track.scrollLeft <= 2) {
          track.scrollTo({ left: maxScroll(), behavior: 'smooth' });
        } else {
          track.scrollBy({ left: dir * stepBy(), behavior: 'smooth' });
        }
      };

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let autoplayTimer: ReturnType<typeof setInterval> | null = null;
      const stopAutoplay = () => { if (autoplayTimer) { clearInterval(autoplayTimer); autoplayTimer = null; } };
      const startAutoplay = () => {
        if (prefersReducedMotion || autoplayTimer) return;
        autoplayTimer = setInterval(() => advance(1), 4500);
      };
      const restartAutoplay = () => { stopAutoplay(); startAutoplay(); };

      prevBtn.addEventListener('click', () => { advance(-1); restartAutoplay(); });
      nextBtn.addEventListener('click', () => { advance(1); restartAutoplay(); });
      track.addEventListener('mouseenter', stopAutoplay);
      track.addEventListener('mouseleave', startAutoplay);
      track.addEventListener('touchstart', stopAutoplay, { passive: true });
      track.addEventListener('touchend', () => { stopAutoplay(); setTimeout(startAutoplay, 3000); }, { passive: true });

      startAutoplay();
    })();
  </script>

