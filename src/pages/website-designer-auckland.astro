---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/website-designer-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/website-designer-auckland/",
      "name": "Contact Kiwi Web Design | Affordable Web Design Auckland",
      "description": "Have questions or ready to get started? Contact Kiwi Web Design for affordable web design in Auckland. Free in-person consults. Let's build your website together.",
      "datePublished": "2025-09-02T04:59:09+00:00",
      "dateModified": "2025-10-20T01:35:25+00:00",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/website-designer-auckland/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/website-designer-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Contact" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};
---

<Layout
  title="Contact Kiwi Web Design | Affordable Web Design Auckland"
  description="Have questions or ready to get started? Contact Kiwi Web Design for affordable web design in Auckland. Free in-person consults. Let's build your website together."
  canonicalURL="https://www.kiwiwebdesign.co.nz/website-designer-auckland/"
  schema={schema}
>

  <section class="section">
    <div class="container contact-grid">

      <!-- Left: contact details -->
      <div>
        <h1>Contact Us for Free Consultation</h1>
        <p>Have questions or ready to get started? We offer free in-person or online consultations across Auckland. Let's build your website together.</p>

        <ul class="contact-details">
          <li>
            <span class="detail-icon">✉</span>
            <a href="mailto:Hi@KiwiWebDesign.co.nz">Hi@KiwiWebDesign.co.nz</a>
          </li>
          <li>
            <span class="detail-icon">📍</span>
            <a
              href="https://www.google.com/maps/search/?api=1&query=147+Great+North+Road+Grey+Lynn+Auckland"
              target="_blank"
              rel="noopener noreferrer"
            >
              147 Great North Road, Grey Lynn, Auckland
            </a>
          </li>
          <li>
            <span class="detail-icon">📞</span>
            <a href="tel:+64210396580">Call / Text: 021 039 6580</a>
          </li>
          <li>
            <span class="detail-icon">📅</span>
            <a
              href="https://calendar.app.google/4ug4GCmLxd7K6uWb7"
              target="_blank"
              rel="noopener noreferrer"
            >
              Book an online or in-person appointment
            </a>
          </li>
        </ul>
      </div>

      <!-- Right: contact form -->
      <div class="form-wrap">
        <h3>Send us a message</h3>
        <!-- Note: wire this form to a form service (e.g. Cloudflare Worker, Formspree) -->
        <form class="contact-form" name="contact" method="POST">
          <label>
            Name <span class="req">*</span>
            <input type="text" name="name" required />
          </label>
          <label>
            Email <span class="req">*</span>
            <input type="email" name="email" required />
          </label>
          <label>
            Mobile <span class="req">*</span>
            <input type="tel" name="mobile" required />
          </label>
          <label>
            Message <span class="req">*</span>
            <textarea name="message" rows="5" required></textarea>
          </label>
          <button type="submit" class="btn-primary">Send Message</button>
        </form>
      </div>

    </div>
  </section>

</Layout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  h1 { margin-bottom: 1rem; }

  .contact-details {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .contact-details li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.95rem;
  }
  .detail-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 0.1rem; }
  .contact-details a { color: var(--kwd-dark); transition: color 0.2s; }
  .contact-details a:hover { color: var(--kwd-brown); text-decoration: underline; }

  .form-wrap {
    background: var(--kwd-cream);
    border-radius: 8px;
    padding: 2rem;
  }
  .form-wrap h3 { margin-bottom: 1.5rem; }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 600;
  }
  .req { color: #c0392b; }
  .contact-form input,
  .contact-form textarea {
    padding: 0.6rem 0.875rem;
    border: 1px solid rgba(0,0,0,0.15);
    border-radius: 4px;
    font-family: var(--kwd-font-body);
    font-size: 0.95rem;
    background: var(--kwd-white);
    transition: border-color 0.2s;
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--kwd-dark);
  }
  .contact-form textarea { resize: vertical; }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
