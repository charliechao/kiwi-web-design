---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import TestimonialGrid from '../components/TestimonialGrid.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/website-designer-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/website-designer-auckland/",
      "name": "Contact Kiwi Web Design | Affordable Web Design Auckland",
      "description": "Have questions or ready to get started? Contact Kiwi Web Design for affordable web design in Auckland. Free in-person consults. Let's build your website together.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/website-designer-auckland/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/website-designer-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Contact" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const reasons = [
  { icon: "💬", title: "Free Consultation", desc: "We talk first. No quotes before we understand your business, your customers, and your goals." },
  { icon: "📍", title: "Based in Grey Lynn", desc: "147 Great North Road. Easy to meet in person anywhere in Auckland, or jump on a video call." },
  { icon: "⚡", title: "Fast Turnaround", desc: "Most projects are live in 2–3 weeks. We move quickly and keep you informed the whole way." },
  { icon: "💰", title: "Transparent Pricing", desc: "You'll know the total cost before we start. No hidden extras, no surprise invoices." },
];

const reviews = [
  { name: "Zane Barrett", company: "Barrett Access Scaffolding", text: "Professional, responsive, and really took the time to understand our business. Couldn't be happier with the results." },
  { name: "Jack", company: "Show Me Shorts", text: "Smart, practical solutions. Professional, friendly and quick to respond whenever I had questions." },
  { name: "Steven Liu", company: "Client", text: "Outstanding experience. The design is clean, modern, and user-friendly — exactly what I was hoping for." },
  { name: "Gina Dellabarca", company: "Client", text: "Comprehensive and helpful website audit. Clear information. Great communication." },
];
---

<Layout
  title="Contact Kiwi Web Design | Affordable Web Design Auckland"
  description="Have questions or ready to get started? Contact Kiwi Web Design for affordable web design in Auckland. Free in-person consults. Let's build your website together."
  canonicalURL="https://www.kiwiwebdesign.co.nz/website-designer-auckland/"
  schema={schema}
>

  <!-- Hero with form -->
  <section class="contact-hero">
    <div class="container contact-layout">

      <!-- Left: info -->
      <div class="contact-info">
        <p class="contact-eyebrow">Get in Touch</p>
        <h1>Let's build something that generates leads.</h1>
        <p class="contact-lead">Whether you're ready to get started or just have questions — reach out. We'll always give you honest advice, even if that means pointing you somewhere else.</p>

        <ul class="contact-details">
          <li>
            <span class="cd-icon">✉</span>
            <div>
              <span class="cd-label">Email</span>
              <a href="mailto:Hi@KiwiWebDesign.co.nz">Hi@KiwiWebDesign.co.nz</a>
            </div>
          </li>
          <li>
            <span class="cd-icon">📞</span>
            <div>
              <span class="cd-label">Call or Text</span>
              <a href="tel:+64210396580">021 039 6580</a>
            </div>
          </li>
          <li>
            <span class="cd-icon">📍</span>
            <div>
              <span class="cd-label">Office</span>
              <a href="https://www.google.com/maps/search/?api=1&query=147+Great+North+Road+Grey+Lynn+Auckland" target="_blank" rel="noopener noreferrer">
                147 Great North Road, Grey Lynn, Auckland
              </a>
            </div>
          </li>
          <li>
            <span class="cd-icon">📅</span>
            <div>
              <span class="cd-label">Book a Time</span>
              <a href="https://calendar.app.google/4ug4GCmLxd7K6uWb7" target="_blank" rel="noopener noreferrer">
                Book an online or in-person appointment →
              </a>
            </div>
          </li>
        </ul>

        <div class="contact-reasons">
          {reasons.map(({ icon, title, desc }) => (
            <div class="cr-item">
              <span class="cr-icon">{icon}</span>
              <div>
                <strong class="cr-title">{title}</strong>
                <p class="cr-desc">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: form -->
      <div class="contact-form-wrap" id="contact">
        <h2 class="contact-form-title">Send us a message</h2>
        <p class="contact-form-sub">We reply within 1 business day. Fields marked * are required.</p>
        <form class="contact-form" name="contact" method="POST" action="/api/contact">
          <div class="form-row">
            <label class="form-label">
              Your Name <span class="req">*</span>
              <input type="text" name="name" placeholder="e.g. Sarah Johnson" required />
            </label>
          </div>
          <div class="form-row form-row-2">
            <label class="form-label">
              Email Address <span class="req">*</span>
              <input type="email" name="email" placeholder="you@yourbusiness.co.nz" required />
            </label>
            <label class="form-label">
              Phone / Mobile <span class="req">*</span>
              <input type="tel" name="mobile" placeholder="021 000 0000" required />
            </label>
          </div>
          <div class="form-row">
            <label class="form-label">
              Business Name
              <input type="text" name="business" placeholder="Your business name" />
            </label>
          </div>
          <div class="form-row">
            <label class="form-label">
              What are you looking for?
              <select name="service">
                <option value="">Select a service...</option>
                <option value="website">New Website</option>
                <option value="seo">SEO Services</option>
                <option value="google-ads">Google Ads</option>
                <option value="website-seo">Website + SEO</option>
                <option value="full-package">Full Growth Package</option>
                <option value="other">Other / Not Sure</option>
              </select>
            </label>
          </div>
          <div class="form-row">
            <label class="form-label">
              Message <span class="req">*</span>
              <textarea name="message" rows="4" placeholder="Tell us a bit about your business and what you're hoping to achieve..." required></textarea>
            </label>
          </div>
          <button type="submit" class="form-submit">Send Message →</button>
          <p class="form-privacy">We respect your privacy. Your details are never shared or sold.</p>
        </form>
      </div>

    </div>
  </section>

  <!-- Testimonials -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader eyebrow="Client Reviews" title="What Auckland businesses say about working with us." />
      <TestimonialGrid items={reviews} cols={2} />
    </div>
  </section>

  <!-- Final trust strip -->
  <section class="contact-final">
    <div class="container contact-final-inner">
      <div class="cf-stat">
        <span class="cf-num">4.9★</span>
        <span class="cf-label">Average Google Rating</span>
      </div>
      <div class="cf-stat">
        <span class="cf-num">50+</span>
        <span class="cf-label">Auckland Businesses Helped</span>
      </div>
      <div class="cf-stat">
        <span class="cf-num">Free</span>
        <span class="cf-label">Initial Consultation</span>
      </div>
      <div class="cf-stat">
        <span class="cf-num">Grey Lynn</span>
        <span class="cf-label">Auckland-based</span>
      </div>
    </div>
  </section>

</Layout>

<style>
  .contact-hero {
    background: var(--kwd-dark);
    padding: 4.5rem 0;
  }
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Info side */
  .contact-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-yellow);
    margin-bottom: 1rem;
  }
  .contact-info h1 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    color: #fff;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }
  .contact-lead {
    font-size: 1rem;
    color: rgba(255,255,255,0.68);
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 500px;
  }

  .contact-details {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .contact-details li {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }
  .cd-icon {
    font-size: 1.15rem;
    width: 2.25rem;
    height: 2.25rem;
    background: rgba(255,255,255,0.08);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .cd-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--kwd-yellow);
    margin-bottom: 0.15rem;
  }
  .contact-details a {
    color: rgba(255,255,255,0.8);
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .contact-details a:hover { color: var(--kwd-yellow); }

  .contact-reasons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .cr-item {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }
  .cr-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    width: 2.25rem;
    text-align: center;
  }
  .cr-title { display: block; font-size: 0.9rem; font-weight: 700; color: #fff; margin-bottom: 0.15rem; }
  .cr-desc  { font-size: 0.82rem; color: rgba(255,255,255,0.55); margin: 0; line-height: 1.5; }

  /* Form side */
  .contact-form-wrap {
    background: #fff;
    border-radius: 20px;
    padding: 2.5rem;
    box-shadow: 0 24px 64px rgba(0,0,0,0.3);
  }
  .contact-form-title {
    font-size: 1.5rem;
    color: var(--kwd-dark);
    margin-bottom: 0.35rem;
  }
  .contact-form-sub {
    font-size: 0.82rem;
    color: var(--kwd-brown);
    margin-bottom: 2rem;
  }

  .contact-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .form-row {}
  .form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--kwd-dark);
  }
  .req { color: #d83b3b; }
  .form-label input,
  .form-label select,
  .form-label textarea {
    padding: 0.75rem 1rem;
    border: 1.5px solid rgba(0,0,0,0.12);
    border-radius: 8px;
    font-size: 0.9rem;
    font-family: var(--kwd-font-body);
    color: var(--kwd-dark);
    transition: border-color 0.2s;
    background: #fff;
  }
  .form-label input:focus,
  .form-label select:focus,
  .form-label textarea:focus {
    outline: none;
    border-color: var(--kwd-dark);
  }
  .form-label textarea { resize: vertical; min-height: 100px; }

  .form-submit {
    background: var(--kwd-dark);
    color: #fff;
    padding: 0.9rem 2rem;
    border: none;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    cursor: pointer;
    transition: background 0.2s;
    font-family: var(--kwd-font-body);
  }
  .form-submit:hover { background: #3e3633; }

  .form-privacy {
    font-size: 0.75rem;
    color: var(--kwd-brown);
    text-align: center;
    margin: 0;
    opacity: 0.75;
  }

  /* Final strip */
  .contact-final {
    background: var(--kwd-cream);
    padding: 2rem 0;
    border-top: 1px solid rgba(0,0,0,0.06);
  }
  .contact-final-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }
  .cf-stat { display: flex; flex-direction: column; gap: 0.2rem; }
  .cf-num  { font-family: var(--kwd-font-heading); font-size: 1.75rem; color: var(--kwd-dark); }
  .cf-label { font-size: 0.75rem; color: var(--kwd-brown); text-transform: uppercase; letter-spacing: 0.07em; }

  @media (max-width: 960px) {
    .contact-layout { grid-template-columns: 1fr; gap: 2.5rem; }
    .contact-final-inner { grid-template-columns: repeat(2, 1fr); }
    .form-row-2 { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .contact-final-inner { grid-template-columns: 1fr; }
    .contact-form-wrap { padding: 1.75rem; }
  }
</style>
