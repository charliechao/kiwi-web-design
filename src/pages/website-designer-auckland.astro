---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import TestimonialGrid from '../components/TestimonialGrid.astro';
import Icon from '../components/Icon.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["WebPage", "ContactPage"],
      "@id": "https://www.kiwiwebdesign.co.nz/website-designer-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/website-designer-auckland/",
      "name": "Website Designer Auckland | Free Consultation | Kiwi Web Design",
      "description": "Book a free consultation with Kiwi Web Design — Auckland website designers based in Grey Lynn. Web design, SEO, and Google Ads for small businesses across Auckland and NZ.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/website-designer-auckland/#breadcrumb" },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".contact-eyebrow", ".contact-info h1", ".contact-lead"]
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/website-designer-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://www.kiwiwebdesign.co.nz/website-designer-auckland/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Auckland Website Consultation",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "City", "name": "Auckland" },
        { "@type": "Country", "name": "New Zealand" }
      ],
      "priceRange": "$$",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "bestRating": "5",
        "ratingCount": "50"
      },
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.kiwiwebdesign.co.nz/favicon.png",
        "width": 512,
        "height": 512
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Web Design and Digital Marketing Services Auckland",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Website Design Auckland" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "SEO Auckland" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Google Ads Auckland" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "AI SEO & GEO Auckland" } }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How quickly does Kiwi Web Design respond to enquiries?",
          "acceptedAnswer": { "@type": "Answer", "text": "We respond to all enquiries within 1 business day. For urgent projects, call or text 021 039 6580 directly." }
        },
        {
          "@type": "Question",
          "name": "Is the initial consultation with Kiwi Web Design really free?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. The initial consultation is completely free with no obligation. We talk through your business, goals, and options before any quote is given." }
        },
        {
          "@type": "Question",
          "name": "Does Kiwi Web Design work with businesses outside Auckland?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. While based in Grey Lynn, Auckland, we work with businesses across New Zealand via video call. We meet in person with Auckland clients when useful." }
        },
        {
          "@type": "Question",
          "name": "How long does a typical website project take?",
          "acceptedAnswer": { "@type": "Answer", "text": "Most small business websites go live in 2–6 weeks from project start. eCommerce and custom builds take 8–12 weeks depending on complexity." }
        },
        {
          "@type": "Question",
          "name": "What should I prepare before my first conversation with Kiwi Web Design?",
          "acceptedAnswer": { "@type": "Answer", "text": "Nothing formal. Think about what your business does, who your ideal customer is, and any websites you admire. We guide the rest in the consultation." }
        }
      ]
    }
  ]
};

const reasons = [
  { icon: "MessageCircle", title: "Free Consultation", desc: "We talk first. No quotes before we understand your business, your customers, and your goals." },
  { icon: "MapPin", title: "Based in Grey Lynn", desc: "147 Great North Road. Easy to meet in person anywhere in Auckland, or jump on a video call." },
  { icon: "Zap", title: "Fast Turnaround", desc: "Most projects are live in 2–3 weeks. We move quickly and keep you informed the whole way." },
  { icon: "BadgeDollarSign", title: "Transparent Pricing", desc: "You'll know the total cost before we start. No hidden extras, no surprise invoices." },
];

const reviews = [
  { name: "Zane Barrett", company: "Barrett Access Scaffolding", text: "Professional, responsive, and really took the time to understand our business. Couldn't be happier with the results." },
  { name: "Jack", company: "Show Me Shorts", text: "Smart, practical solutions. Professional, friendly and quick to respond whenever I had questions." },
  { name: "Steven Liu", company: "Client", text: "Outstanding experience. The design is clean, modern, and user-friendly — exactly what I was hoping for." },
  { name: "Gina Dellabarca", company: "Client", text: "Comprehensive and helpful website audit. Clear information. Great communication." },
];
---

<Layout
  title="Website Designer Auckland | Free Consultation | Kiwi Web Design"
  description="Book a free consultation with Kiwi Web Design — Auckland website designers based in Grey Lynn. Web design, SEO, and Google Ads for small businesses. Reply within 1 business day."
  canonicalURL="https://www.kiwiwebdesign.co.nz/website-designer-auckland/"
  schema={schema}
  alternateUrl="https://www.kiwiwebdesign.co.nz/zh/website-designer-auckland/"
>

  <!-- Hero with form -->
  <section class="contact-hero">
    <div class="container contact-layout">

      <!-- Left: info -->
      <div class="contact-info">
        <p class="contact-eyebrow">Get in Touch</p>
        <h1>Let's build something that generates leads.</h1>
        <p class="contact-lead">Whether you're ready to get started or just have questions — reach out. We'll always give you honest advice about what your business needs, even if that means pointing you somewhere else. Not sure what you need? See our <a href="/solutions-auckland-kiwi-web-design/" class="cl-link">full services overview</a> or our <a href="/website-design-process-in-auckland/" class="cl-link">design process</a>.</p>

        <ul class="contact-details">
          <li>
            <span class="cd-icon"><Icon name="Mail" size={18} /></span>
            <div>
              <span class="cd-label">Email</span>
              <a href="mailto:Hi@KiwiWebDesign.co.nz">Hi@KiwiWebDesign.co.nz</a>
            </div>
          </li>
          <li>
            <span class="cd-icon"><Icon name="Phone" size={18} /></span>
            <div>
              <span class="cd-label">Call or Text</span>
              <a href="tel:+64210396580">021 039 6580</a>
            </div>
          </li>
          <li>
            <span class="cd-icon"><Icon name="MapPin" size={18} /></span>
            <div>
              <span class="cd-label">Office</span>
              <a href="https://www.google.com/maps/search/?api=1&query=147+Great+North+Road+Grey+Lynn+Auckland" target="_blank" rel="noopener noreferrer">
                147 Great North Road, Grey Lynn, Auckland
              </a>
            </div>
          </li>
        </ul>

        <div class="contact-reasons">
          {reasons.map(({ icon, title, desc }) => (
            <div class="cr-item">
              <span class="cr-icon"><Icon name={icon} size={20} /></span>
              <div>
                <strong class="cr-title">{title}</strong>
                <p class="cr-desc">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: form -->
      <div class="contact-form-wrap" id="contact">
        <h2 class="contact-form-title">Send us a message</h2>
        <p class="contact-form-sub">We reply within 1 business day. Fields marked * are required.</p>
        <form class="contact-form" id="contact-form" name="contact" method="POST" action="https://api.web3forms.com/submit">
          <input type="hidden" name="access_key" value="e0a725e4-f764-4536-826c-df981c8bdf3b" />
          <input type="hidden" name="subject" value="New enquiry from KWD contact form" />
          <input type="hidden" name="from_name" value="Kiwi Web Design Website" />
          <input type="hidden" name="submitted_at" id="contact-submitted-at" value="" />
          <input type="checkbox" name="botcheck" class="form-botcheck" tabindex="-1" autocomplete="off" />
          <div class="form-row">
            <label class="form-label">
              Your Name <span class="req">*</span>
              <input type="text" name="name" placeholder="e.g. Sarah Johnson" required />
            </label>
          </div>
          <div class="form-row form-row-2">
            <label class="form-label">
              Email Address <span class="req">*</span>
              <input type="email" name="email" placeholder="you@yourbusiness.co.nz" required />
            </label>
            <label class="form-label">
              Phone / Mobile
              <input type="tel" name="mobile" placeholder="021 000 0000" />
            </label>
          </div>
          <div class="form-row">
            <label class="form-label">
              Business Name
              <input type="text" name="business" placeholder="Your business name" />
            </label>
          </div>
          <div class="form-row">
            <label class="form-label">
              What are you looking for?
              <select name="service">
                <option value="">Select a service...</option>
                <option value="website">New Website</option>
                <option value="seo">SEO Services</option>
                <option value="google-ads">Google Ads</option>
                <option value="website-seo">Website + SEO</option>
                <option value="full-package">Full Growth Package</option>
                <option value="other">Other / Not Sure</option>
              </select>
            </label>
          </div>
          <div class="form-row">
            <label class="form-label">
              Message <span class="req">*</span>
              <textarea name="message" rows="4" placeholder="Tell us a bit about your business and what you're hoping to achieve..." required></textarea>
            </label>
          </div>
          <button type="submit" class="form-submit" id="contact-submit">Send Message →</button>
          <p id="contact-status" aria-live="polite" style="display:none" class="form-status"></p>
          <p class="form-privacy">We respect your privacy. Your details are never shared or sold.</p>
        </form>
      </div>

    </div>
  </section>

  <!-- Industries we serve -->
  <section class="related-strip">
    <div class="container">
      <p class="rps-label">Industries we serve</p>
      <div class="rps-links">
        <a href="/tradie-website-design-auckland/" class="rps-link">Tradies</a>
        <a href="/how-kiwi-web-design-helps-auckland-beauty-industry/" class="rps-link">Beauty &amp; Wellness</a>
        <a href="/how-kiwi-web-design-helps-auckland-restaurants/" class="rps-link">Restaurants &amp; Cafés</a>
        <a href="/how-kiwi-web-design-helps-auckland-healthcare/" class="rps-link">Healthcare</a>
        <a href="/how-kiwi-web-design-helps-auckand-lawyers/" class="rps-link">Lawyers &amp; Professional Services</a>
        <a href="/industries-we-serve-in-auckland/" class="rps-link">All Industries →</a>
      </div>
    </div>
  </section>

  <!-- Areas we serve -->
  <section class="related-strip">
    <div class="container">
      <p class="rps-label">Areas we serve</p>
      <div class="rps-links">
        <a href="/central-auckland-web-design/" class="rps-link">Central Auckland</a>
        <a href="/north-shore-website-design/" class="rps-link">North Shore</a>
        <a href="/west-auckland-web-design/" class="rps-link">West Auckland</a>
        <a href="/east-auckland-web-design/" class="rps-link">East Auckland</a>
        <a href="/south-auckland-web-design/" class="rps-link">South Auckland</a>
      </div>
    </div>
  </section>

  <!-- Popular starting points -->
  <section class="related-strip">
    <div class="container">
      <p class="rps-label">Popular starting points</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design Packages</a>
        <a href="/seo-auckland/" class="rps-link">SEO Services</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
        <a href="/wordpress-maintenance-auckland/" class="rps-link">WordPress Maintenance</a>
        <a href="/ecommerce-website-auckland/" class="rps-link">eCommerce Websites</a>
        <a href="/faq/" class="rps-link">FAQ</a>
      </div>
    </div>
  </section>

  <!-- FAQ section -->
  <section class="contact-faq">
    <div class="container">
      <p class="rps-label">Common questions before getting in touch</p>
      <div class="faq-list">
        <details class="faq-item">
          <summary class="faq-q">How quickly do you respond to enquiries?</summary>
          <p class="faq-a">We reply within 1 business day. For urgent matters, call or text <a href="tel:+64210396580">021 039 6580</a> directly.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-q">Is the initial consultation really free?</summary>
          <p class="faq-a">Yes — no obligation, no quote pressure. We talk through your business and goals first. If we're a good fit, great. If not, we'll tell you honestly.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-q">Do you work with businesses outside Auckland?</summary>
          <p class="faq-a">Yes. We're based in Grey Lynn but work with businesses across New Zealand via video call. Auckland clients can always meet in person at our Great North Road office.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-q">How long does a website project take?</summary>
          <p class="faq-a">Most small business websites are live in 2–6 weeks from project start. eCommerce and custom builds take 8–12 weeks depending on scope and complexity.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-q">What should I prepare before our first conversation?</summary>
          <p class="faq-a">Nothing formal. Think about what your business does, who your best customers are, and any websites you like. We guide the rest in the consultation.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader eyebrow="Client Reviews" title="What Auckland businesses say about working with us." />
      <TestimonialGrid items={reviews} cols={2} />
    </div>
  </section>

  <!-- Final trust strip -->
  <section class="contact-final">
    <div class="container contact-final-inner">
      <div class="cf-stat">
        <span class="cf-num">4.9★</span>
        <span class="cf-label">Average Google Rating</span>
      </div>
      <div class="cf-stat">
        <span class="cf-num">50+</span>
        <span class="cf-label">Auckland Businesses Helped</span>
      </div>
      <div class="cf-stat">
        <span class="cf-num">Free</span>
        <span class="cf-label">Initial Consultation</span>
      </div>
      <div class="cf-stat">
        <span class="cf-num">Grey Lynn</span>
        <span class="cf-label">Auckland-based</span>
      </div>
    </div>
  </section>

  <script>
    (function () {
      const form = document.getElementById('contact-form') as HTMLFormElement | null;
      const btn = document.getElementById('contact-submit') as HTMLButtonElement | null;
      const status = document.getElementById('contact-status') as HTMLElement | null;
      const submittedAt = document.getElementById('contact-submitted-at') as HTMLInputElement | null;
      if (!form || !btn || !status) return;

      const minSubmitSeconds = 3;
      if (submittedAt) submittedAt.value = String(Date.now());

      function setStatus(msg: string, isError: boolean) {
        status!.textContent = msg;
        status!.style.display = 'block';
        status!.className = 'form-status ' + (isError ? 'form-status--error' : 'form-status--success');
      }

      function countUrls(value: string) {
        return (value.match(/(?:https?:\/\/|www\.)/gi) || []).length;
      }

      function hasSuspiciousPattern(value: string) {
        return /(.)\1{7,}/.test(value);
      }

      function validateSubmission() {
        const formData = new FormData(form!);
        const name = String(formData.get('name') || '').trim();
        const message = String(formData.get('message') || '').trim();
        const startedAt = Number(formData.get('submitted_at') || 0);
        const botcheck = formData.get('botcheck');
        if (botcheck) return 'Submission blocked. Please refresh the page and try again.';
        if (!startedAt || ((Date.now() - startedAt) / 1000) < minSubmitSeconds) {
          return 'Please wait a few seconds before sending your message.';
        }
        if (name.length < 2 || !/[a-z]/i.test(name)) return 'Please enter your name.';
        if (message.length < 10) return 'Please add a bit more detail so we can help properly.';
        if (countUrls(message) > 1 || hasSuspiciousPattern(message)) {
          return 'Please remove suspicious content and try again.';
        }
        return '';
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const validationError = validateSubmission();
        if (validationError) {
          setStatus(validationError, true);
          return;
        }
        btn.disabled = true;
        btn.textContent = 'Sending…';
        status.style.display = 'none';
        try {
          const res  = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify(Object.fromEntries(new FormData(form))),
          });
          const data = await res.json();
          if (data.success) {
            setStatus("Message sent! We'll be in touch within 1 business day.", false);
            form.reset();
            if (submittedAt) submittedAt.value = String(Date.now());
          } else {
            setStatus(data.message || 'Something went wrong. Please try again.', true);
          }
        } catch {
          setStatus('Network error — please check your connection and try again.', true);
        } finally {
          btn.disabled = false;
          btn.textContent = 'Send Message →';
        }
      });
    })();
  </script>
  <script is:inline src="https://web3forms.com/client/script.js" async defer></script>

</Layout>

<style>
  .contact-hero {
    background: var(--kwd-dark);
    padding: 4.5rem 0;
  }
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Info side */
  .contact-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-yellow);
    margin-bottom: 1rem;
  }
  .contact-info h1 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    color: #fff;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }
  .contact-lead {
    font-size: 1rem;
    color: rgba(255,255,255,0.68);
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 500px;
  }

  .contact-details {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .contact-details li {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }
  .cd-icon {
    width: 2.25rem;
    height: 2.25rem;
    background: rgba(255,255,255,0.08);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--kwd-yellow);
  }
  .cd-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--kwd-yellow);
    margin-bottom: 0.15rem;
  }
  .contact-details a {
    color: rgba(255,255,255,0.8);
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .contact-details a:hover { color: var(--kwd-yellow); }

  .contact-reasons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .cr-item {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }
  .cr-icon {
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    background: rgba(255,255,255,0.08);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--kwd-yellow);
  }
  .cr-title { display: block; font-size: 0.9rem; font-weight: 700; color: #fff; margin-bottom: 0.15rem; }
  .cr-desc  { font-size: 0.82rem; color: rgba(255,255,255,0.55); margin: 0; line-height: 1.5; }

  /* Form side */
  .contact-form-wrap {
    background: #fff;
    border-radius: 20px;
    padding: 2.5rem;
    box-shadow: 0 24px 64px rgba(0,0,0,0.3);
  }
  .contact-form-title {
    font-size: 1.5rem;
    color: var(--kwd-dark);
    margin-bottom: 0.35rem;
  }
  .contact-form-sub {
    font-size: 0.82rem;
    color: var(--kwd-brown);
    margin-bottom: 2rem;
  }

  .contact-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .form-row {}
  .form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--kwd-dark);
  }
  .req { color: #d83b3b; }
  .form-label input,
  .form-label select,
  .form-label textarea {
    padding: 0.75rem 1rem;
    border: 1.5px solid rgba(0,0,0,0.12);
    border-radius: 8px;
    font-size: 0.9rem;
    font-family: var(--kwd-font-body);
    color: var(--kwd-dark);
    transition: border-color 0.2s;
    background: #fff;
  }
  .form-label input:focus,
  .form-label select:focus,
  .form-label textarea:focus {
    outline: none;
    border-color: var(--kwd-dark);
  }
  .form-label textarea { resize: vertical; min-height: 100px; }
  .form-botcheck { display: none !important; }

  .form-submit {
    background: var(--kwd-dark);
    color: #fff;
    padding: 0.9rem 2rem;
    border: none;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    cursor: pointer;
    transition: background 0.2s;
    font-family: var(--kwd-font-body);
  }
  .form-submit:hover { background: #3e3633; }

  .form-privacy {
    font-size: 0.75rem;
    color: var(--kwd-brown);
    text-align: center;
    margin: 0;
    opacity: 0.75;
  }
  .form-status {
    font-size: 0.88rem;
    font-weight: 600;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    text-align: center;
    margin: 0.5rem 0 0;
  }
  .form-status--success {
    background: #d1fae5;
    color: #065f46;
    border: 1.5px solid #6ee7b7;
  }
  .form-status--error {
    background: #fee2e2;
    color: #991b1b;
    border: 1.5px solid #fca5a5;
