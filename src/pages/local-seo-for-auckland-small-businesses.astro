---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import StatsRow from '../components/StatsRow.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/local-seo-for-auckland-small-businesses/",
      "url": "https://www.kiwiwebdesign.co.nz/local-seo-for-auckland-small-businesses/",
      "name": "Local SEO for Auckland Small Businesses | Google Maps & 3-Pack",
      "description": "Auckland local SEO specialists. Dominate Google Maps, the 3-Pack, and local organic results. Google Business Profile, citations, reviews, and suburb landing pages. Free audit.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/local-seo-for-auckland-small-businesses/#breadcrumb" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": [".local-snippet", "h1"] }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/local-seo-for-auckland-small-businesses/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Local SEO Auckland", "item": "https://www.kiwiwebdesign.co.nz/local-seo-for-auckland-small-businesses/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "Place", "name": "Auckland" },
        { "@type": "Place", "name": "New Zealand" }
      ],
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "ratingCount": "50", "bestRating": "5" },
      "logo": { "@type": "ImageObject", "url": "https://www.kiwiwebdesign.co.nz/favicon.png", "width": 512, "height": 512 }
    },
    {
      "@type": "Service",
      "@id": "https://www.kiwiwebdesign.co.nz/local-seo-for-auckland-small-businesses/#service",
      "name": "Local SEO Auckland",
      "serviceType": "Local Search Engine Optimisation",
      "category": "Digital Marketing",
      "provider": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "areaServed": [
        { "@type": "Place", "name": "Auckland" },
        { "@type": "Place", "name": "New Zealand" }
      ],
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "500",
        "highPrice": "2000",
        "priceCurrency": "NZD",
        "priceSpecification": { "@type": "PriceSpecification", "valueAddedTaxIncluded": false, "unitCode": "MON" }
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "What is local SEO and why does my Auckland business need it?", "acceptedAnswer": { "@type": "Answer", "text": "Local SEO is the process of optimising your online presence to appear in location-based searches — like 'plumber Auckland' or 'cafe near me'. If your business serves customers in specific Auckland areas, local SEO is often the highest-ROI digital investment you can make." } },
        { "@type": "Question", "name": "How long does local SEO take to work in Auckland?", "acceptedAnswer": { "@type": "Answer", "text": "Most Auckland businesses see improvements in map pack visibility within 4–8 weeks for less competitive niches. Highly competitive industries like trades, legal, or dental may take 3–6 months to see significant movement. Results then compound over time." } },
        { "@type": "Question", "name": "What's the difference between local SEO and general SEO?", "acceptedAnswer": { "@type": "Answer", "text": "Local SEO focuses on appearing for searches with geographic intent ('near me', suburb names, city names). It heavily weights your Google Business Profile, local citations, and reviews. General SEO covers national or topical visibility without a geographic filter — many businesses benefit from both." } },
        { "@type": "Question", "name": "Do I need a physical address to do local SEO in Auckland?", "acceptedAnswer": { "@type": "Answer", "text": "Not necessarily. Service-area businesses (like plumbers or cleaners) can do local SEO without a public address by configuring a service area in Google Business Profile. However, businesses with a physical location generally have an easier time ranking in the map pack." } },
        { "@type": "Question", "name": "How important are Google reviews for local SEO?", "acceptedAnswer": { "@type": "Answer", "text": "Very important. Google uses review quantity, quality, and recency as ranking signals for map pack results. Beyond rankings, reviews also directly influence whether customers choose you. We help you build a sustainable, authentic review acquisition process." } },
        { "@type": "Question", "name": "Can you help with Google Business Profile suspension or reinstatement?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. If your Google Business Profile has been suspended, we can help diagnose the reason and submit a reinstatement request with the right supporting documentation. This is a common issue and usually resolvable with the right approach." } }
      ]
    }
  ]
};

const localStats = [
  { number: "46%", label: "of Google searches have local intent" },
  { number: "78%", label: "of local mobile searches lead to a purchase within 24 hrs" },
  { number: "70%", label: "of clicks go to the top 3 Google Maps results" },
  { number: "500%", label: "growth in 'near me' searches over 5 years" },
];

const localServices = [
  {
    icon: "📍",
    title: "Google Business Profile",
    desc: "Your GBP is the single most important local SEO asset. We optimise every element — categories, services, photos, posts, and reviews — to maximise your map pack visibility.",
    items: ["Complete profile setup & optimisation", "Service area configuration", "Photo strategy", "Weekly posts & Q&A management"],
  },
  {
    icon: "🗺️",
    title: "Map Pack Rankings",
    desc: "The 3-Pack at the top of Google Maps results captures 70% of local clicks. We build the signals needed to earn and hold those positions.",
    items: ["Local ranking factor optimisation", "Proximity signal building", "Review acquisition strategy", "Competitor displacement"],
  },
  {
    icon: "📋",
    title: "Local Citations",
    desc: "Consistent NAP (Name, Address, Phone) across directories builds trust and authority. We build and fix citations across NZ-relevant directories.",
    items: ["NZ directory submissions", "Citation consistency audit & fix", "Industry-specific directories", "Ongoing citation monitoring"],
  },
  {
    icon: "⭐",
    title: "Review Strategy",
    desc: "Online reviews influence both rankings and buyer decisions. We help you build a systematic process for collecting and managing reviews across Google, Facebook, and Yelp.",
    items: ["Review request workflows", "Response management", "Review monitoring", "Reputation protection"],
  },
  {
    icon: "🏙️",
    title: "Local Content & Pages",
    desc: "Location-specific landing pages that rank for suburb-level searches. We create pages targeting the specific Auckland areas your customers come from.",
    items: ["Auckland suburb landing pages", "Local keyword optimisation", "Hyperlocal content", "Internal linking strategy"],
  },
  {
    icon: "🔗",
    title: "Local Link Building",
    desc: "Links from local Auckland businesses, associations, and media build geographic authority that map pack rankings depend on.",
    items: ["Local business partnerships", "Chamber & association listings", "NZ news & media mentions", "Community sponsorship"],
  },
];

const process = [
  { step: "1", title: "Local SEO Audit", desc: "We assess your current local visibility: GBP status, citation consistency, reviews, and local ranking positions." },
  { step: "2", title: "Keyword & Competitor Research", desc: "We find the local search terms your customers use and analyse how your top competitors are ranking." },
  { step: "3", title: "On-Site & Off-Site Optimisation", desc: "We fix your GBP, build citations, create local content, and earn local links — all systematically." },
  { step: "4", title: "Review & Reporting", desc: "Monthly reports tracking your map pack positions, organic rankings, and the enquiries generated." },
];

const faqs = [
  { q: "What is local SEO and why does my Auckland business need it?", a: "Local SEO is the process of optimising your online presence to appear in location-based searches — like 'plumber Auckland' or 'café near me'. If your business serves customers in specific Auckland areas, local SEO is often the highest-ROI digital investment you can make." },
  { q: "How long does local SEO take to work in Auckland?", a: "Most Auckland businesses see improvements in map pack visibility within 4–8 weeks for less competitive niches. Highly competitive industries like trades, legal, or dental may take 3–6 months to see significant movement. Results then compound over time." },
  { q: "What's the difference between local SEO and general SEO?", a: "Local SEO focuses on appearing for searches with geographic intent ('near me', suburb names, city names). It heavily weights your Google Business Profile, local citations, and reviews. Our broader <a href=\"/affordable-seo-auckland/\">SEO services Auckland</a> covers national or topical visibility without a geographic filter — many businesses benefit from both." },
  { q: "Do I need a physical address to do local SEO in Auckland?", a: "Not necessarily. Service-area businesses (like plumbers or cleaners) can do local SEO without a public address by configuring a service area in Google Business Profile. However, businesses with a physical location generally have an easier time ranking in the map pack." },
  { q: "How important are Google reviews for local SEO?", a: "Very important. Google uses review quantity, quality, and recency as ranking signals for map pack results. Beyond rankings, reviews also directly influence whether customers choose you. We help you build a sustainable, authentic review acquisition process." },
  { q: "Can you help with Google Business Profile suspension or reinstatement?", a: "Yes. If your GBP has been suspended, we can help diagnose the reason and submit a reinstatement request with the right supporting documentation. This is a common issue and usually resolvable with the right approach. For a full walkthrough of setup and optimisation, see our <a href=\"/google-business-profile-guide-for-auckland-businesses/\">Google Business Profile guide for Auckland businesses</a>." },
];
---

<Layout
  title="Local SEO for Auckland Small Businesses"
  description="Auckland's local SEO specialists. Dominate local search — Google Maps, the 3-Pack, and organic results. Free local SEO audit for Auckland businesses."
  canonicalURL="https://www.kiwiwebdesign.co.nz/local-seo-for-auckland-small-businesses/"
  schema={schema}
  alternateUrl="https://www.kiwiwebdesign.co.nz/zh/local-seo-for-auckland-small-businesses/"
>

  <PageHero
    eyebrow="Local SEO Auckland"
    title="Dominate local search. Be found first."
    subtitle="46% of all Google searches have local intent. We make sure Auckland customers searching for your services find your business first — in Google Maps, the 3-Pack, and organic results."
    ctaPrimary={{ text: "Get a Free Local SEO Audit", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "Our SEO Services", href: "/affordable-seo-auckland/" }}
    imgSrc="/local-seo/auckland-local-seo-hero.webp"
    imgAlt="Auckland small business owner reviewing local SEO map rankings on a laptop"
  />

  <!-- Local search stats -->
  <StatsRow items={localStats} accent={true} />

  <!-- AI citability snippet -->
  <div class="local-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> provides local SEO services for Auckland small businesses — Google Business Profile optimisation, map pack rankings, citation building, review strategy, and suburb-specific landing pages. Results typically visible within 4–8 weeks. Based in Grey Lynn, Auckland — 4.9★ Google rating from 50+ clients.</p>
    </div>
  </div>

  <!-- Visual overview -->
  <section class="local-visual-band">
    <div class="container local-visual-grid">
      <figure class="local-feature-figure">
        <img
          src="/local-seo/local-seo-map-pack-workflow.webp"
          alt="Local SEO workflow showing map pack, reviews, citations, suburb pages, and enquiry tracking"
          loading="lazy"
          width="1536"
          height="864"
        />
      </figure>
      <div class="local-feature-copy">
        <p class="local-eyebrow">Local Visibility System</p>
        <h2>Turn Google Maps visibility into calls, bookings, and quote requests.</h2>
        <p>Local SEO works best when your Google Business Profile, suburb pages, reviews, citations, and tracking all support the same commercial goal. We build that system around how Auckland customers actually search.</p>
        <div class="local-proof-list" aria-label="Local SEO focus areas">
          <span>Map pack visibility</span>
          <span>Review trust signals</span>
          <span>Suburb landing pages</span>
          <span>Enquiry tracking</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Why local SEO matters -->
  <section class="section">
    <div class="container">
      <div class="local-why">
        <div class="local-why-text">
          <p class="local-eyebrow">Why It Matters</p>
          <h2>Auckland customers search local — are you showing up?</h2>
          <p>When someone in <a href="/central-auckland-web-design/">Ponsonby</a>, Remuera, or <a href="/west-auckland-web-design/">Henderson</a> searches for your services, Google surfaces the most locally relevant results first. Businesses that appear in the Google Maps 3-Pack capture the majority of clicks — and the majority of enquiries.</p>
          <p>If your competitors are showing up and you're not, you're invisible to a significant portion of your potential customers. Local SEO — combined with a well-built <a href="/small-business-website-design-auckland/">small business website</a> — is how you fix that.</p>
        </div>
        <div class="local-why-card-wrap">
          <div class="local-why-card">
            <span class="lwc-icon">🗺️</span>
            <h3>Google Maps 3-Pack</h3>
            <p>The top 3 map results appear above all organic listings. Appearing here puts your business in front of customers before they even scroll.</p>
          </div>
          <div class="local-why-card">
            <span class="lwc-icon">📱</span>
            <h3>Mobile Local Searches</h3>
            <p>78% of local mobile searches result in a purchase within 24 hours. Being visible at the moment of intent is everything.</p>
          </div>
          <div class="local-why-card">
            <span class="lwc-icon">⭐</span>
            <h3>Reviews Drive Decisions</h3>
            <p>Customers compare reviews before calling. A strong review profile builds trust that converts views into enquiries.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="Our Local SEO Services"
        title="Everything needed to dominate Auckland local search."
        subtitle="A comprehensive local SEO approach targeting map pack, organic, and directory visibility."
      />
      <ServiceGrid items={localServices} cols={3} />
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader eyebrow="Our Process" title="How we improve your local visibility." light={true} />
      <ProcessSteps items={process} dark={true} />
    </div>
  </section>

  <!-- Auckland suburbs -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Coverage"
        title="We serve businesses across all of Auckland."
        subtitle="From Central Auckland to the North Shore, East Auckland, West Auckland, and South Auckland — wherever your customers are."
      />
      <figure class="local-coverage-figure">
        <img
          src="/local-seo/auckland-suburb-coverage.webp"
          alt="Auckland suburb coverage map for local SEO campaigns"
          loading="eager"
          width="1536"
          height="864"
        />
      </figure>
      <div class="local-suburbs">
        <a href="/central-auckland-web-design/" class="local-suburb-tag local-suburb-link">Central Auckland</a>
        <a href="/north-shore-website-design/" class="local-suburb-tag local-suburb-link">North Shore</a>
        <a href="/west-auckland-web-design/" class="local-suburb-tag local-suburb-link">West Auckland</a>
        <a href="/east-auckland-web-design/" class="local-suburb-tag local-suburb-link">East Auckland</a>
        <a href="/south-auckland-web-design/" class="local-suburb-tag local-suburb-link">South Auckland</a>
        {["Ponsonby", "Grey Lynn", "Remuera", "Mt Eden", "Henderson", "Pakuranga", "Manukau"].map((area) => (
          <span class="local-suburb-tag">{area}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion items={faqs} title="Local SEO Questions Answered" subtitle="Common questions from Auckland business owners about local search." />
    </div>
  </section>

  <!-- Areas we serve -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Areas we serve</p>
      <div class="rps-links">
        <a href="/central-auckland-web-design/" class="rps-link">Central Auckland</a>
        <a href="/north-shore-website-design/" class="rps-link">North Shore</a>
        <a href="/west-auckland-web-design/" class="rps-link">West Auckland</a>
        <a href="/east-auckland-web-design/" class="rps-link">East Auckland</a>
        <a href="/south-auckland-web-design/" class="rps-link">South Auckland</a>
      </div>
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/affordable-seo-auckland/" class="rps-link">SEO Services Auckland</a>
        <a href="/google-business-profile-guide-for-auckland-businesses/" class="rps-link">Google Business Profile Guide</a>
        <a href="/google-ads/" class="rps-link">Google Ads Auckland</a>
        <a href="/analytics-reporting-for-auckland-small-business-websites/" class="rps-link">Analytics &amp; Reporting</a>
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design Auckland</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to show up first in Auckland local search?"
    subtitle="Get a free local SEO audit — we'll show you exactly where you stand and what to do next."
    ctaPrimary={{ text: "Get a Free Local SEO Audit", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "All SEO Services", href: "/affordable-seo-auckland/" }}
  />

</Layout>

<style>
  .local-snippet { background: #fff8e1; border-left: 4px solid var(--kwd-yellow); padding: 1rem 0; }
  .local-snippet p { margin: 0; font-size: 0.95rem; line-height: 1.65; color: var(--kwd-dark); }

  .local-visual-band {
    background: linear-gradient(180deg, #fff 0%, #f2f1e5 100%);
    padding: 4.5rem 0;
  }
  .local-visual-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: 3rem;
    align-items: center;
  }
  .local-feature-figure,
  .local-coverage-figure {
    margin: 0;
    position: relative;
  }
  .local-feature-figure::after,
  .local-coverage-figure::after {
    content: "";
    position: absolute;
    inset: auto 10% -18px;
    height: 34px;
    border-radius: 999px;
    background: rgba(44, 41, 39, 0.18);
    filter: blur(22px);
    z-index: 0;
  }
  .local-feature-figure img,
  .local-coverage-figure img {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: auto;
    border-radius: 18px;
    object-fit: cover;
    border: 1px solid rgba(44, 41, 39, 0.12);
    box-shadow: 0 28px 70px rgba(44, 41, 39, 0.16);
  }
  .local-feature-copy {
    background: rgba(255,255,255,0.86);
    border: 1px solid rgba(44, 41, 39, 0.08);
    border-radius: 18px;
    padding: 2rem;
    box-shadow: 0 18px 48px rgba(44, 41, 39, 0.08);
  }
  .local-feature-copy h2 {
    font-size: clamp(1.55rem, 2.7vw, 2.25rem);
    margin: 0 0 1rem;
    color: var(--kwd-dark);
  }
  .local-feature-copy p:not(.local-eyebrow) {
    margin: 0;
    color: var(--kwd-brown);
    line-height: 1.7;
    font-size: 0.95rem;
  }
  .local-proof-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
    margin-top: 1.4rem;
  }
  .local-proof-list span {
    background: var(--kwd-cream);
    border: 1px solid rgba(44, 41, 39, 0.08);
    border-radius: 999px;
    padding: 0.55rem 0.85rem;
    color: var(--kwd-dark);
    font-size: 0.78rem;
    font-weight: 700;
    text-align: center;
  }

  .local-why {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .local-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-brown);
    margin-bottom: 0.75rem;
  }
  .local-why-text h2 { font-size: clamp(1.6rem, 3vw, 2.25rem); margin-bottom: 1rem; }
  .local-why-text p { font-size: 0.95rem; color: var(--kwd-brown); line-height: 1.7; }

  .local-why-card-wrap { display: flex; flex-direction: column; gap: 1rem; }
  .local-why-card {
    background: var(--kwd-cream);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .lwc-icon { font-size: 1.5rem; }
  .local-why-card h3 { font-family: var(--kwd-font-body); font-size: 1rem; font-weight: 700; color: var(--kwd-dark); margin: 0; }
  .local-why-card p { font-size: 0.875rem; color: var(--kwd-brown); margin: 0; line-height: 1.6; }

  .local-coverage-figure {
    max-width: 980px;
    margin: 0 auto 2rem;
  }

  .local-suburbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  .local-suburb-tag {
    display: inline-block;
    background: var(--kwd-cream);
    color: var(--kwd-dark);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.45rem 1rem;
    border-radius: 100px;
    border: 1px solid rgba(0,0,0,0.08);
  }

  .local-suburb-link { text-decoration: none; color: var(--kwd-dark); }
  .local-suburb-link:hover { background: var(--kwd-dark); color: #fff; border-color: var(--kwd-dark); }
  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }

  @media (max-width: 860px) {
    .local-visual-grid { grid-template-columns: 1fr; gap: 2rem; }
    .local-why { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  @media (max-width: 580px) {
    .local-visual-band { padding: 3rem 0; }
    .local-feature-copy { padding: 1.35rem; }
    .local-proof-list { grid-template-columns: 1fr; }
    .local-feature-figure img,
    .local-coverage-figure img { border-radius: 12px; }
  }
</style>

<!-- Vanta.js BIRDS background for hero -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/vanta@0.5.24/dist/vanta.birds.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    VANTA.BIRDS({
      el: '.hero-section',
      mouseControls: true,
      touchControls: true,
      gyroControls: false,
      minHeight: 200,
      minWidth: 200,
      scale: 1.0,
      scaleMobile: 0.75,
      backgroundColor: 0x2c2927,
      color1: 0xf3d97a,
      color2: 0xfbe8a6,
      birdSize: 1.2,
      wingSpan: 25,
      speedLimit: 4,
      separation: 60,
      alignment: 50,
