---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';

const stats = [
  { fig: "3 weeks", label: "Zero to fully live booking website" },
  { fig: "24/7", label: "Online booking active around the clock" },
  { fig: "6", label: "Treatment pages with booking links" },
];

const deliverables = [
  "Trafft online booking system",
  "6 dedicated treatment service pages",
  "Automated email & SMS reminders",
  "Service descriptions with durations and pricing",
  "Google Business Profile setup",
  "Mobile-first responsive design",
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/beauty-touch-case-study/",
      "url": "https://www.kiwiwebdesign.co.nz/beauty-touch-case-study/",
      "name": "Beauty Touch Auckland, Website Case Study | Kiwi Web Design",
      "description": "How Kiwi Web Design built a launch-ready booking website for Beauty Touch Auckland, online booking, 6 treatment pages, and automated reminders, live in 3 weeks.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/beauty-touch-case-study/#breadcrumb" }
    },
    {
      "@type": "CreativeWork",
      "@id": "https://www.kiwiwebdesign.co.nz/beauty-touch-case-study/#case-study",
      "name": "Case Study: Beauty Touch Auckland",
      "description": "How Kiwi Web Design helped Beauty Touch Auckland go from no online booking to a fully operational website in 3 weeks.",
      "url": "https://www.kiwiwebdesign.co.nz/beauty-touch-case-study/",
      "creator": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "about": { "@type": "LocalBusiness", "name": "Beauty Touch Auckland", "address": { "@type": "PostalAddress", "addressLocality": "Auckland", "addressCountry": "NZ" } },
      "genre": "Case Study",
      "keywords": "beauty salon website design Auckland, online booking, Trafft"
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/beauty-touch-case-study/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Beauty Touch Auckland" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz"
    }
  ]
};
---

<Layout
  title="Beauty Touch Auckland, Website Case Study | Kiwi Web Design"
  description="How Kiwi Web Design built a launch-ready booking website for Beauty Touch Auckland, online booking, 6 treatment pages, and automated reminders, live in 3 weeks."
  canonicalURL="https://www.kiwiwebdesign.co.nz/beauty-touch-case-study/"
  schema={schema}
>

  <!-- Hero -->
  <section class="cs-hero">
    <div class="container">
      <div class="cs-hero-inner no-img">
        <div class="cs-hero-text">
          <div class="cs-tags">
            <span class="cs-tag">Case Study</span>
            <span class="cs-industry">Beauty & Wellness</span>
          </div>
          <h1>Beauty Touch Auckland, Booked Out in 3 Weeks</h1>
          <p>From zero online presence to a fully operational booking website in 21 days. Online booking, six dedicated treatment pages, and automated appointment reminders that work around the clock.</p>
        </div>
      </div>
    </div>
    <div class="cs-stat-strip">
      <div class="container cs-stat-grid">
        {stats.map(s => (
          <div class="cs-stat-item">
            <span class="cs-stat-fig">{s.fig}</span>
            <span class="cs-stat-lbl">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <div class="cs-overview">
        <div class="cs-client-card">
          <div class="cs-client-row">
            <span class="cs-client-label">Client</span>
            <span class="cs-client-value">Beauty Touch Auckland</span>
          </div>
          <div class="cs-client-row">
            <span class="cs-client-label">Industry</span>
            <span class="cs-client-value">Beauty & Wellness</span>
          </div>
          <div class="cs-client-row">
            <span class="cs-client-label">Location</span>
            <span class="cs-client-value">Auckland, New Zealand</span>
          </div>
          <div class="cs-client-row">
            <span class="cs-client-label">Project Type</span>
            <span class="cs-client-value">New Website + Booking Integration</span>
          </div>
          <div class="cs-client-row">
            <span class="cs-client-label">Timeline</span>
            <span class="cs-client-value">3 weeks</span>
          </div>
        </div>
        <div class="cs-overview-body">
          <p class="cs-sub-eyebrow">Project Overview</p>
          <h2>A premium studio needed a website that matched their treatments.</h2>
          <p>Beauty Touch Auckland is a specialist beauty and wellness studio offering advanced skin treatments, lash and brow design, and relaxation therapies. Owner-operated and premium-positioned, they needed a website that matched the quality of their treatments and let clients book without picking up the phone.</p>
          <p>The goal was clear: take them from zero online booking capability to a fully functional website that works 24 hours a day, without adding admin overhead for the owner.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Challenge -->
  <section class="section">
    <div class="container cs-content-narrow">
      <p class="cs-sub-eyebrow">The Challenge</p>
      <h2 class="cs-section-h2">Bookings through DMs and phone calls, with no online showcase.</h2>
      <p class="cs-section-p">All bookings were coming through Instagram DMs and phone calls, a time-consuming process that missed clients after business hours. There was no way to showcase treatments properly, no service-by-service pricing, and no online booking capability.</p>
      <p class="cs-section-p">The existing online presence didn't reflect the premium quality of the studio. Potential clients couldn't explore what Beauty Touch offered before booking, and without a clear service menu and pricing, many simply moved on to a competitor with a better-structured website.</p>
    </div>
  </section>

  <!-- Solution -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container cs-content-narrow">
      <p class="cs-sub-eyebrow">What We Built</p>
      <h2 class="cs-section-h2">A booking-ready website live in three weeks.</h2>
      <p class="cs-section-p">We built a WordPress website with Trafft online booking integrated on each service page. Clients can book a specific treatment, choose a time slot, and receive an automated confirmation, no back-and-forth required. Six dedicated treatment pages were built with full descriptions, durations, and pricing.</p>
      <p class="cs-section-p">Automated reminders go out 24 hours before each appointment, reducing no-shows without any manual work from the owner.</p>
      <div class="cs-deliverables">
        {deliverables.map(d => <span class="cs-chip">{d}</span>)}
      </div>
    </div>
  </section>

  <!-- Results -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <p class="cs-sub-eyebrow cs-sub-eyebrow-light">The Results</p>
      <h2 class="cs-section-h2 cs-section-h2-light">From phone-only to 24/7 bookings in three weeks.</h2>
      <p class="cs-section-p cs-section-p-light">The website launched on time and immediately started taking bookings outside business hours, the first automated confirmations were sent within 48 hours of going live.</p>
      <div class="cs-results-grid">
        {stats.map(s => (
          <div class="cs-result-card">
            <div class="cs-result-fig">{s.fig}</div>
            <div class="cs-result-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design</a>
        <a href="/booking-appointment-websites-with-wordpress/" class="rps-link">Booking Websites</a>
        <a href="/how-kiwi-web-design-helps-auckland-beauty-industry/" class="rps-link">Beauty Industry</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress</a>
        <a href="/testimonials-reviews/" class="rps-link">Case Studies</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to start taking bookings online?"
    subtitle="Free consultation, we'll show you exactly how online booking would work for your business."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "See More Case Studies", href: "/testimonials-reviews/" }}
  />

</Layout>

<style>
  .cs-hero { background: var(--kwd-dark); padding: 5rem 0 0; }
  .cs-hero-inner { display: grid; grid-template-columns: 55% 45%; gap: 3rem; align-items: center; padding-bottom: 3rem; }
  .cs-hero-inner.no-img { grid-template-columns: 1fr; max-width: 760px; }
  .cs-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
  .cs-tag { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 0.3rem 0.85rem; border-radius: 999px; background: var(--kwd-yellow); color: var(--kwd-dark); }
  .cs-industry { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; padding: 0.3rem 0.85rem; border-radius: 999px; background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.75); }
  .cs-hero-text h1 { font-family: var(--kwd-font-heading); font-size: clamp(2rem, 4vw, 3rem); color: #fff; line-height: 1.15; margin-bottom: 1rem; }
  .cs-hero-text p { font-size: 1rem; color: rgba(255,255,255,0.7); line-height: 1.7; }
  .cs-hero-img img { width: 100%; height: 400px; object-fit: cover; border-radius: 12px; display: block; box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
  .cs-stat-strip { border-top: 1px solid rgba(255,255,255,0.1); }
  .cs-stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); }
  .cs-stat-item { padding: 1.5rem 2rem; border-right: 1px solid rgba(255,255,255,0.1); display: flex; flex-direction: column; gap: 0.25rem; }
  .cs-stat-item:last-child { border-right: none; }
  .cs-stat-fig { font-family: var(--kwd-font-heading); font-size: 2.25rem; color: var(--kwd-yellow); line-height: 1; }
  .cs-stat-lbl { font-size: 0.8rem; color: rgba(255,255,255,0.55); line-height: 1.4; }
  .cs-overview { display: grid; grid-template-columns: 260px 1fr; gap: 3.5rem; align-items: start; }
  .cs-client-card { background: #fff; border: 1.5px solid rgba(0,0,0,0.07); border-radius: 14px; padding: 1.75rem; }
  .cs-client-row { margin-bottom: 1rem; }
  .cs-client-row:last-child { margin-bottom: 0; }
  .cs-client-label { display: block; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.2rem; }
  .cs-client-value { font-size: 0.9rem; color: var(--kwd-dark); font-weight: 600; line-height: 1.4; }
  .cs-sub-eyebrow { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--kwd-brown); margin-bottom: 0.75rem; }
  .cs-sub-eyebrow-light { color: var(--kwd-yellow); }
  .cs-overview-body h2 { font-family: var(--kwd-font-heading); font-size: clamp(1.5rem, 2.5vw, 2rem); color: var(--kwd-dark); line-height: 1.2; margin-bottom: 0.75rem; }
  .cs-overview-body p { font-size: 0.9375rem; color: var(--kwd-brown); line-height: 1.75; margin-bottom: 0.75rem; }
  .cs-section-h2 { font-family: var(--kwd-font-heading); font-size: clamp(1.5rem, 2.5vw, 2rem); color: var(--kwd-dark); line-height: 1.2; margin-bottom: 0.75rem; }
  .cs-section-h2-light { color: #fff; }
  .cs-section-p { font-size: 0.9375rem; color: var(--kwd-brown); line-height: 1.75; margin-bottom: 0.75rem; }
  .cs-section-p-light { color: rgba(255,255,255,0.7); }
  .cs-content-narrow { max-width: 760px; }
  .cs-deliverables { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.5rem; }
  .cs-chip { font-size: 0.8rem; font-weight: 600; padding: 0.4rem 1rem; border-radius: 999px; background: var(--kwd-dark); color: #fff; }
  .cs-results-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-top: 2.5rem; }
  .cs-result-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 2rem 1.5rem; text-align: center; }
  .cs-result-fig { font-family: var(--kwd-font-heading); font-size: 2.75rem; color: var(--kwd-yellow); line-height: 1; margin-bottom: 0.5rem; }
  .cs-result-label { font-size: 0.875rem; color: rgba(255,255,255,0.65); line-height: 1.5; }
  .cs-screenshot-wrap { margin-top: 2rem; }
  .cs-screenshot-wrap img { width: 100%; border-radius: 12px; border: 1.5px solid rgba(0,0,0,0.07); display: block; box-shadow: 0 8px 32px rgba(0,0,0,0.1); }
  .cs-screenshot-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 2rem; }
  .cs-screenshot-grid img { width: 100%; border-radius: 10px; border: 1.5px solid rgba(0,0,0,0.07); display: block; }
  .cs-testimonial-wrap { max-width: 760px; margin: 0 auto; text-align: center; }
  .cs-testimonial-wrap blockquote { font-family: var(--kwd-font-heading); font-size: clamp(1.2rem, 2.5vw, 1.625rem); color: var(--kwd-dark); line-height: 1.4; font-style: italic; margin: 0 0 1.5rem; }
  .cs-testimonial-author { font-size: 0.875rem; font-weight: 600; color: var(--kwd-brown); }
  @media (max-width: 900px) {
    .cs-hero-inner { grid-template-columns: 1fr; }
    .cs-hero-img { display: none; }
    .cs-overview { grid-template-columns: 1fr; }
    .cs-screenshot-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .cs-stat-grid { grid-template-columns: repeat(2, 1fr); }
    .cs-stat-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .cs-stat-item:last-child { border-bottom: none; }
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
