---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import Icon from '../components/Icon.astro';
import maintenanceImage from '../assets/services/wordpress-website-maintenance-kiwi-web-design-auckland.jpg';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/wordpress-maintenance-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/wordpress-maintenance-auckland/",
      "name": "WordPress Maintenance Auckland | Managed WordPress Care Plans",
      "description": "Managed WordPress maintenance plans for Auckland businesses, updates, security, daily backups, and support. From $99/month + GST. No lock-in contracts.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/wordpress-maintenance-auckland/#breadcrumb" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": [".maint-snippet", "h1"] }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/wordpress-maintenance-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "WordPress Maintenance Auckland", "item": "https://www.kiwiwebdesign.co.nz/wordpress-maintenance-auckland/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "Place", "name": "Auckland" },
        { "@type": "Place", "name": "New Zealand" }
      ],
      "logo": { "@type": "ImageObject", "url": "https://www.kiwiwebdesign.co.nz/favicon.png", "width": 512, "height": 512 }
    },
    {
      "@type": "Service",
      "@id": "https://www.kiwiwebdesign.co.nz/wordpress-maintenance-auckland/#service",
      "name": "WordPress Maintenance Auckland",
      "serviceType": "WordPress Maintenance",
      "category": "Web Services",
      "provider": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "areaServed": [
        { "@type": "Place", "name": "Auckland" },
        { "@type": "Place", "name": "New Zealand" }
      ],
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "99",
        "highPrice": "349",
        "priceCurrency": "NZD",
        "priceSpecification": { "@type": "PriceSpecification", "valueAddedTaxIncluded": false, "unitCode": "MON" }
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Do I need a maintenance plan if I have a new website?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, a new site is actually the ideal time to start. Updates are released constantly for WordPress core, plugins, and themes. Without regular maintenance, security vulnerabilities accumulate quickly. The first 6–12 months are when most sites become vulnerable if left unattended." } },
        { "@type": "Question", "name": "What happens if my site gets hacked while I'm on a plan?", "acceptedAnswer": { "@type": "Answer", "text": "Under Standard and Premium plans, malware removal is covered. We investigate, clean the infection, harden the site, and restore from a backup if necessary, at no extra charge beyond your monthly plan fee." } },
        { "@type": "Question", "name": "Can you maintain a WordPress site you didn't build?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We can take over maintenance of any WordPress site, built by us or anyone else. We start with an audit to understand the current state of the site, plugins, and any issues. If your site needs more than maintenance, we also offer WordPress website rebuilds to bring it up to standard." } },
        { "@type": "Question", "name": "Is there a lock-in contract?", "acceptedAnswer": { "@type": "Answer", "text": "No. All plans run month-to-month. You can cancel with 30 days notice. We don't believe in trapping clients, we'd rather earn your continued business." } },
        { "@type": "Question", "name": "What counts as a 'content change'?", "acceptedAnswer": { "@type": "Answer", "text": "Text updates, image swaps, adding or removing pages, menu changes, price updates, adding blog posts, anything that doesn't require custom development. Major new features or redesigns are quoted separately." } }
      ]
    }
  ]
};

const risks = [
  { icon: "🦠", title: "90% of hacked WordPress sites had outdated plugins", desc: "Outdated plugins are the number one attack vector for WordPress. A single unpatched plugin can compromise your entire site, customer data, contact forms, everything." },
  { icon: "📉", title: "Slow sites lose customers and rankings", desc: "A 1-second delay reduces conversions by 7%. Old WordPress installs accumulate bloat that slows load times. Regular maintenance keeps things running fast." },
  { icon: "💔", title: "Broken sites happen without warning", desc: "A plugin update conflict can take your site offline in seconds. Without backups, that means rebuilding from scratch. With daily backups, it means a 5-minute restore." },
  { icon: "⚠️", title: "Google flags insecure sites", desc: "Expired SSLs, outdated PHP, and security vulnerabilities can trigger browser warnings, 'This site may be unsafe', that kill your traffic and conversions overnight." },
];

const maintenancePlans = [
  {
    name: "Basic",
    price: "$99/mo",
    note: "+ GST",
    desc: "Core maintenance for sites that just need to stay secure and up to date.",
    items: [
      "Monthly WordPress core updates",
      "Monthly plugin & theme updates",
      "Daily backups (14-day retention)",
      "SSL monitoring",
      "Uptime monitoring",
      "Monthly status report",
    ],
    highlight: false,
    href: "/website-designer-auckland/",
  },
  {
    name: "Standard",
    price: "$199/mo",
    note: "+ GST",
    desc: "Full maintenance plus hosting and 2 hours of content changes every month.",
    items: [
      "Everything in Basic",
      "Managed WordPress hosting",
      "2 hours content changes/mo",
      "Security scanning & firewall",
      "Daily backups (30-day retention)",
      "Priority support response",
      "Google Analytics summary",
    ],
    highlight: true,
    tag: "Most Popular",
    href: "/website-designer-auckland/",
  },
  {
    name: "Premium",
    price: "$349/mo",
    note: "+ GST",
    desc: "For businesses that need more hands-on support, regular content updates, and SEO reporting.",
    items: [
      "Everything in Standard",
      "4 hours content changes/mo",
      "Monthly SEO health check",
      "Performance optimisation",
      "Staging site for testing",
      "Same-day support response",
      "Quarterly strategy review",
    ],
    highlight: false,
    href: "/website-designer-auckland/",
  },
];

const services = [
  {
    icon: "🔄",
    title: "Core & Plugin Updates",
    desc: "We apply WordPress core, plugin, and theme updates monthly, testing on a staging environment first to catch any conflicts before they affect your live site.",
    items: ["WordPress core updates", "Plugin updates (all)", "Theme updates", "Pre-update backups"],
  },
  {
    icon: "💾",
    title: "Daily Backups",
    desc: "Automated daily backups stored offsite. If anything goes wrong, a bad update, a hack, accidental deletion, we can restore your site to any point in the retention window.",
    items: ["Daily automated backups", "Offsite storage", "30-day retention (Standard+)", "One-click restore"],
  },
  {
    icon: "🔒",
    title: "Security Monitoring",
    desc: "Continuous malware scanning, login protection, firewall rules, and SSL certificate management. If a threat is detected, we respond immediately.",
    items: ["Malware scanning", "Firewall configuration", "Login protection", "SSL certificate management"],
  },
  {
    icon: "⚡",
    title: "Performance Maintenance",
    desc: "Database cleaning, cache configuration, image optimisation, and PHP version management to keep your site loading fast month after month.",
    items: ["Database optimisation", "Cache management", "Image compression", "PHP version management"],
  },
  {
    icon: "📊",
    title: "Monthly Reporting",
    desc: "A simple monthly report showing uptime, security scan results, updates applied, and Google Analytics highlights, so you always know what's happening.",
    items: ["Uptime report", "Security scan summary", "Updates log", "Traffic overview"],
  },
  {
    icon: "🛎️",
    title: "Priority Support",
    desc: "Got something wrong or need a quick fix? As a maintenance client you get priority support, typically responded to within a few hours on business days.",
    items: ["Priority email support", "Same/next business day response", "Issue diagnosis", "Emergency fix included"],
  },
];

const faqs = [
  { q: "Do I need a maintenance plan if I have a new website?", a: "Yes, actually a new site is the ideal time to start. Whether we built your <a href=\"/wordpress-website-design-auckland/\">WordPress website</a> or someone else did, updates are released constantly for WordPress core, plugins, and themes. Without regular maintenance, security vulnerabilities accumulate quickly. The first 6–12 months are when most sites become vulnerable if left unattended." },
  { q: "What happens if my site gets hacked while I'm on a plan?", a: "Under our Standard and Premium plans, malware removal is covered. We'll investigate, clean the infection, harden the site, and restore from a backup if necessary, at no extra charge beyond your plan." },
  { q: "Can you maintain a WordPress site you didn't build?", a: "Yes. We can take over maintenance of any WordPress site, built by us or anyone else. We'll start with an audit to understand the current state of the site, plugins, and any issues. If your site needs more than maintenance, we also offer <a href=\"/wordpress-website-rebuilds-auckland/\">WordPress website rebuilds</a> to bring it up to standard." },
  { q: "Is there a lock-in contract?", a: "No. All plans run month-to-month. You can cancel with 30 days notice. We don't believe in trapping clients, we'd rather earn your continued business." },
  { q: "What's the difference between the Standard plan and the Monthly Subscription?", a: "They're essentially the same thing, the Standard plan is our Monthly Subscription product. It includes managed hosting, security, updates, daily backups, 2 hours of content changes, and priority support for $199/month + GST." },
  { q: "What counts as a 'content change'?", a: "Text updates, image swaps, adding or removing pages, menu changes, price updates, adding blog posts, anything that doesn't require custom development. Major new features or redesigns are quoted separately." },
];
---

<Layout
  title="WordPress Maintenance Auckland | Managed WordPress Care Plans"
  description="Keep your website fast, secure, and up to date with Kiwi Web Design's WordPress maintenance services. We offer affordable monthly plans."
  canonicalURL="https://www.kiwiwebdesign.co.nz/wordpress-maintenance-auckland/"
  schema={schema}
>

  <PageHero
    eyebrow="WordPress Maintenance Auckland"
    title="Your WordPress site needs regular care. We do it for you."
    subtitle="Managed WordPress maintenance plans for Auckland businesses, updates, security, backups, and support handled monthly so you never have to think about it."
    badgeText="From $99/month + GST"
    ctaPrimary={{ text: "Get a Care Plan", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Plans", href: "#plans" }}
    imgSrc={maintenanceImage.src}
    imgAlt="Managed WordPress maintenance dashboard for Auckland small business websites"
    imgTitle="WordPress maintenance Auckland care plan"
  />

  <!-- AI citability snippet -->
  <div class="maint-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> offers managed WordPress maintenance plans for Auckland businesses from <strong>$99/month + GST</strong>. Plans include monthly core and plugin updates, daily backups, security monitoring, uptime monitoring, and monthly reporting. No lock-in, cancel anytime with 30 days notice. 5★ Google rating.</p>
    </div>
  </div>

  <!-- Risk section -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="The Risk of Neglect"
        title="What happens to unmanaged WordPress sites."
        subtitle="It's not a question of if, it's a question of when. These are the real costs of skipping maintenance."
      />
      <div class="maint-risks">
        {risks.map(({ icon, title, desc }) => (
          <div class="maint-risk">
            <span class="maint-risk-icon"><Icon name={icon} size={24} /></span>
            <div>
              <strong class="maint-risk-title">{title}</strong>
              <p class="maint-risk-desc">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Plans -->
  <section class="section" id="plans">
    <div class="container">
      <SectionHeader
        eyebrow="Care Plans"
        title="Simple, flat-fee monthly plans."
        subtitle="No lock-in contracts. Cancel anytime with 30 days notice."
      />
      <div class="maint-plans">
        {maintenancePlans.map((plan) => (
          <div class:list={['maint-plan', plan.highlight && 'maint-plan--featured']}>
            {plan.tag && <span class="maint-plan-tag">{plan.tag}</span>}
            <p class="maint-plan-name">{plan.name}</p>
            <div class="maint-plan-price-wrap">
              <span class="maint-plan-price">{plan.price}</span>
              <span class="maint-plan-note">{plan.note}</span>
            </div>
            <p class="maint-plan-desc">{plan.desc}</p>
            <ul class="maint-plan-list">
              {plan.items.map((item) => <li>{item}</li>)}
            </ul>
            <a href={plan.href} class:list={['maint-plan-btn', plan.highlight && 'maint-plan-btn--featured']}>
              Get Started
            </a>
          </div>
        ))}
      </div>
      <p class="maint-plans-note">All plans exclude GST. No lock-in, cancel anytime with 30 days notice. <a href="/website-designer-auckland/">Questions? Get in touch →</a></p>
    </div>
  </section>

  <!-- Services breakdown -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="What's Included"
        title="Every service. Explained."
        subtitle="We don't hide anything in the fine print. Here's exactly what we do each month."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Maintenance Questions Answered"
        subtitle="Common questions from Auckland business owners about WordPress maintenance."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/website-hosting-auckland/" class="rps-link">Website Hosting</a>
        <a href="/wordpress-website-rebuilds-auckland/" class="rps-link">WordPress Rebuilds</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress Web Design</a>
        <a href="/website-training-and-handover/" class="rps-link">Training & Handover</a>
        <a href="/wordpress-seo-optimisation/" class="rps-link">WordPress SEO</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Stop worrying about your WordPress site."
    subtitle="Get a care plan today, we'll audit your site and have it under management within 48 hours."
    ctaPrimary={{ text: "Get a Care Plan", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Monthly Subscription", href: "/monthly-subscription/" }}
  />

</Layout>

<style>
  .maint-snippet { background: #fff8e1; border-left: 4px solid var(--kwd-yellow); padding: 1rem 0; }
  .maint-snippet p { margin: 0; font-size: 0.95rem; line-height: 1.65; color: var(--kwd-dark); }

  .maint-risks {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .maint-risk {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 14px;
    padding: 1.5rem;
  }
  .maint-risk-icon { flex-shrink: 0; width: 2.25rem; text-align: center; }
  .maint-risk-title { display: block; font-size: 0.9rem; font-weight: 700; color: var(--kwd-dark); margin-bottom: 0.35rem; }
  .maint-risk-desc { font-size: 0.83rem; color: var(--kwd-brown); line-height: 1.6; margin: 0; }

  /* Plans */
  .maint-plans {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
    margin-top: 2.5rem;
  }
  .maint-plan {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.08);
    border-radius: 18px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .maint-plan--featured {
    background: var(--kwd-dark);
    border-color: var(--kwd-dark);
  }
  .maint-plan-tag {
    display: inline-block;
    background: var(--kwd-yellow);
    color: var(--kwd-dark);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 1rem;
    align-self: flex-start;
  }
  .maint-plan-name {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--kwd-brown);
    margin: 0 0 0.5rem;
  }
  .maint-plan--featured .maint-plan-name { color: rgba(255,255,255,0.5); }
  .maint-plan-price-wrap { display: flex; align-items: baseline; gap: 0.4rem; margin-bottom: 0.75rem; }
  .maint-plan-price {
    font-family: var(--kwd-font-heading);
    font-size: 2.25rem;
    color: var(--kwd-dark);
    line-height: 1;
  }
  .maint-plan--featured .maint-plan-price { color: var(--kwd-yellow); }
  .maint-plan-note { font-size: 0.8rem; color: var(--kwd-brown); }
  .maint-plan--featured .maint-plan-note { color: rgba(255,255,255,0.45); }
  .maint-plan-desc { font-size: 0.85rem; color: var(--kwd-brown); line-height: 1.6; margin: 0 0 1.25rem; }
  .maint-plan--featured .maint-plan-desc { color: rgba(255,255,255,0.6); }
  .maint-plan-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .maint-plan-list li {
    font-size: 0.84rem;
    color: var(--kwd-dark);
    padding-left: 1.3rem;
    position: relative;
    line-height: 1.5;
  }
  .maint-plan-list li::before { content: "✓"; position: absolute; left: 0; color: var(--kwd-brown); font-weight: 700; }
  .maint-plan--featured .maint-plan-list li { color: rgba(255,255,255,0.8); }
  .maint-plan--featured .maint-plan-list li::before { color: var(--kwd-yellow); }
  .maint-plan-btn {
    display: block;
    text-align: center;
    padding: 0.875rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--kwd-cream);
    color: var(--kwd-dark);
    transition: background 0.2s;
  }
  .maint-plan-btn:hover { background: #e8e7da; }
  .maint-plan-btn--featured { background: var(--kwd-yellow); }
  .maint-plan-btn--featured:hover { background: var(--kwd-gold); }
  .maint-plans-note {
    text-align: center;
    font-size: 0.82rem;
    color: var(--kwd-brown);
    margin-top: 1.5rem;
  }
  .maint-plans-note a { color: var(--kwd-dark); font-weight: 600; }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }

  @media (max-width: 960px) {
    .maint-plans { grid-template-columns: 1fr; max-width: 480px; margin-inline: auto; }
    .maint-risks { grid-template-columns: 1fr; }
  }
</style>
