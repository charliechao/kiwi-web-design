---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import heroImg from '../assets/general/pexels-photo-67112-67112.jpg';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/domain-management-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/domain-management-auckland/",
      "name": "Domain Management Auckland | DNS, Renewals & Transfers",
      "description": "Domain management Auckland, we handle renewals, DNS configuration, transfers, and ownership so your website and email stay connected without stress.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/domain-management-auckland/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/domain-management-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Domain Management Auckland" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const services = [
  {
    icon: "🔄",
    title: "Domain Renewals",
    desc: "We monitor your domain expiry dates and handle renewals before they lapse, so you never lose your domain name through a forgotten invoice.",
    items: ["Expiry monitoring", "Automatic renewal setup", "Renewal reminders", "Multi-year registration"],
  },
  {
    icon: "⚙️",
    title: "DNS Configuration",
    desc: "DNS records point your domain to the right place, your website, email, Google tools, and third-party services. We configure and manage them correctly.",
    items: ["A & CNAME records", "MX records for email", "TXT records (SPF, DKIM)", "Subdomain setup"],
  },
  {
    icon: "↔️",
    title: "Domain Transfers",
    desc: "Moving your domain to a new registrar or taking ownership from a previous provider. We handle the transfer process start to finish with minimal downtime.",
    items: ["Registrar transfers", "Auth code management", "WHOIS update", "Ownership transfer"],
  },
  {
    icon: "🏠",
    title: "Domain Registration",
    desc: "Need a new domain? We research availability, recommend the best option (.co.nz, .nz, .com), and register it under your name, you always own it.",
    items: [".co.nz & .nz registration", ".com & .net registration", "Availability research", "Ownership in your name"],
  },
  {
    icon: "🔒",
    title: "Domain Security",
    desc: "Domain lock prevents unauthorised transfers. WHOIS privacy protects your personal contact details. Both are simple but often overlooked.",
    items: ["Domain lock enabled", "WHOIS privacy", "Transfer authorisation", "Hijack prevention"],
  },
  {
    icon: "📧",
    title: "Email DNS Setup",
    desc: "Your domain's DNS needs to be correctly configured for email to work reliably. We set up MX, SPF, DKIM, and DMARC records to ensure deliverability.",
    items: ["MX record configuration", "SPF setup", "DKIM configuration", "DMARC policy"],
  },
];

const faqs = [
  { q: "What happens if I forget to renew my domain?", a: "Your website goes offline and your email stops working. After the grace period (usually 30 days), the domain enters redemption, expensive to recover, and then becomes available for anyone to register. If a competitor or domain squatter registers your domain name, getting it back can be very costly. This is why active monitoring matters." },
  { q: "Who should own my domain?", a: "You should, always. Your domain is a business asset. It should be registered in your name or your company's name, not your web designer's name. We register all domains under client ownership and never hold them on your behalf in a way that creates dependency." },
  { q: "Can you take over management of a domain I already have?", a: "Yes. If your domain is currently with a registrar you have access to, we can manage the DNS and renewals. If you need to transfer it, we handle that process too. We just need the login credentials or auth code from your current provider." },
  { q: "What's the difference between a domain and hosting?", a: "Your domain is your address (e.g. yourbusiness.co.nz). Hosting is where your website files live. They're separate things managed separately. DNS records in your domain settings are what connect the domain to your hosting. Getting this wrong is one of the most common causes of email and website outages." },
  { q: "How long does a domain transfer take?", a: ".co.nz transfers are fast, usually completed within a few hours. International .com transfers take up to 5 days due to registrar processes. We'll keep you updated throughout." },
];
---

<Layout
  title="Domain Management Auckland | DNS, Renewals & Transfers"
  description="Domain management Auckland, we handle renewals, DNS configuration, transfers, and ownership so your website and email stay connected without stress."
  canonicalURL="https://www.kiwiwebdesign.co.nz/domain-management-auckland/"
  schema={schema}
>

  <PageHero
    eyebrow="Domain Management"
    title="Your domain sorted, renewals, DNS, and transfers handled."
    subtitle="Domain management for Auckland small businesses. We keep your domain renewed, your DNS configured correctly, and your website and email pointing where they should."
    imgSrc={heroImg.src}
    imgAlt="Domain management for Auckland small businesses"
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View All Services", href: "/small-business-website-design-auckland/" }}
  />

  <!-- Services -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="What We Handle"
        title="Everything your domain needs to work properly."
        subtitle="Most domain problems come from neglected renewals or incorrect DNS. We handle both."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- Why it matters -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <SectionHeader
        eyebrow="Why It Matters"
        title="A forgotten renewal can take down your entire business."
        align="left"
      />
      <div class="domain-body">
        <p>Your domain name is the foundation of your online presence. Everything else, your <a href="/small-business-website-design-auckland/">website</a>, your email, your Google Business Profile, your brand, depends on it staying active and correctly configured.</p>
        <p>The most common domain problems we see: expired domains that took the website and email down together; incorrect DNS records from a poorly configured setup that made email unreliable; and domains registered in a previous web designer's name with no easy way to take ownership back.</p>
        <p>We manage your domain as part of your overall website setup, keeping track of renewal dates, maintaining correct DNS records as services change, and ensuring you always own and control your domain outright. This is typically bundled with our <a href="/website-hosting-auckland/">website hosting</a> and <a href="/wordpress-maintenance-auckland/">WordPress maintenance</a> plans for a fully managed setup.</p>
        <ul class="domain-checklist">
          <li>All domains registered and owned by you</li>
          <li>Renewal monitoring and proactive reminders</li>
          <li>DNS updated as your services change</li>
          <li>Can manage existing domains you already own</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Domain Questions Answered"
        subtitle="Common questions from Auckland business owners about domain management."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/website-hosting-auckland/" class="rps-link">Website Hosting</a>
        <a href="/wordpress-maintenance-auckland/" class="rps-link">WordPress Maintenance</a>
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress</a>
        <a href="/website-training-and-handover/" class="rps-link">Training</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Not sure who controls your domain?"
    subtitle="Free consultation, we'll check your domain situation and make sure everything's in order."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View All Services", href: "/small-business-website-design-auckland/" }}
  />

</Layout>

<style>
  .domain-body p {
    font-size: 0.9375rem;
    color: var(--kwd-brown);
    line-height: 1.75;
    margin-bottom: 0.9rem;
  }
  .domain-checklist {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .domain-checklist li {
    font-size: 0.9rem;
    color: var(--kwd-dark);
    font-weight: 600;
    padding-left: 1.5rem;
    position: relative;
  }
  .domain-checklist li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--kwd-brown);
    font-weight: 700;
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
