---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import heroImg from '../assets/general/pexels-photo-7218525-7218525-scaled-e1758396597668.jpg';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/wordpress-website-rebuilds-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/wordpress-website-rebuilds-auckland/",
      "name": "WordPress Website Rebuilds Auckland | Kiwi Web Design",
      "description": "Is it time to rebuild your WordPress site? Kiwi Web Design helps Auckland businesses rebuild fast, modern websites that generate enquiries. Free audit included.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/wordpress-website-rebuilds-auckland/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/wordpress-website-rebuilds-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "WordPress Website Rebuilds Auckland" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const signs = [
  { icon: "🐌", title: "Your site loads slowly", desc: "If your site takes more than 3 seconds to load on mobile, you're losing visitors before they even see your business. Slow sites rank lower and convert worse." },
  { icon: "📱", title: "It doesn't work on mobile", desc: "Over 60% of web traffic is mobile. A site that forces visitors to pinch-zoom or scroll sideways is losing you enquiries every day." },
  { icon: "🔒", title: "You can't update it yourself", desc: "If changing a phone number or adding a new service requires calling a developer, you're paying for something that should be simple." },
  { icon: "📉", title: "It's not generating enquiries", desc: "A website that looks good but doesn't get enquiries has a conversion problem — weak CTAs, poor structure, or missing trust signals. That's fixable." },
];

const included = [
  {
    icon: "🎨",
    title: "Fresh Design",
    desc: "A new design built for your current brand, industry, and goals — not a template swap. Mobile-first and built to convert visitors into enquiries.",
    items: ["Custom layout", "Mobile-first design", "Brand-matched styling", "CTA optimisation"],
  },
  {
    icon: "⚡",
    title: "Performance Rebuild",
    desc: "Clean code, optimised images, fast hosting, and proper caching — so your new site loads in under 2 seconds and scores well on Core Web Vitals.",
    items: ["Core Web Vitals optimised", "Image optimisation", "Clean plugin setup", "Fast managed hosting"],
  },
  {
    icon: "🔍",
    title: "SEO Foundation",
    desc: "301 redirects from old URLs, proper page structure, schema markup, and Search Console setup — so your existing rankings transfer and new ones build.",
    items: ["301 redirect mapping", "Page title & meta setup", "Schema markup", "Search Console submission"],
  },
  {
    icon: "🔒",
    title: "Security Setup",
    desc: "SSL certificate, firewall, login protection, and daily backups configured from day one — so your new site is protected before it even goes live.",
    items: ["SSL certificate", "Firewall & WAF", "Login hardening", "Daily backups"],
  },
  {
    icon: "📝",
    title: "Content Migration",
    desc: "All your existing pages, images, and content moved across to the new build — organised cleanly and with any outdated content updated or removed.",
    items: ["Page content transfer", "Image migration", "URL structure review", "Navigation rebuild"],
  },
  {
    icon: "🎓",
    title: "Training & Handover",
    desc: "A structured handover session so you can manage your new site yourself — and every login credential documented and handed to you.",
    items: ["WordPress training", "Content editing walkthrough", "Credentials handover", "Follow-up support"],
  },
];

const rebuildProcess = [
  { step: "1", title: "Free Audit", desc: "We review your existing site and identify exactly what's holding it back — speed, SEO, conversion, security. No obligation." },
  { step: "2", title: "Scope & Quote", desc: "We scope the rebuild based on your pages, requirements, and goals. A fixed-price quote with no surprises." },
  { step: "3", title: "Build on Staging", desc: "The new site is built on a private staging URL so you can review it fully before anything goes live." },
  { step: "4", title: "Review & Refine", desc: "Two structured rounds of feedback to refine the design and content until everything is right." },
  { step: "5", title: "Launch", desc: "We migrate the new site live, set up all redirects, and submit to Google Search Console. Your old site URL stays intact." },
  { step: "6", title: "Training & Support", desc: "A handover session covering how to manage your new site, plus 30 days of post-launch support." },
];

const faqs = [
  { q: "How long does a WordPress rebuild take?", a: "Most small business site rebuilds take 2–3 weeks from project start to launch. Larger sites with more pages or custom functionality may take 3–5 weeks. We'll give you a specific timeline at the scoping stage." },
  { q: "Will I lose my Google rankings if I rebuild?", a: "Not if it's done correctly. We map all your existing URLs, set up 301 redirects for any that change, and submit the new sitemap to Google Search Console. In most cases, rankings are maintained or improve — because the new site is better structured and faster. We also pair rebuilds with <a href=\"/wordpress-seo-optimisation/\">WordPress SEO optimisation</a> to maximise ranking gains." },
  { q: "Do I have to use WordPress?", a: "No — we build on WordPress as our default because it's what most clients already have and it's easy to manage. But if there's a reason to use a different platform, we can discuss alternatives." },
  { q: "Can you rebuild a site that was built by someone else?", a: "Yes. We can rebuild any WordPress site regardless of who originally built it. We start with a full audit so we understand what's there and what's worth keeping." },
  { q: "What happens to my existing hosting and domain?", a: "Your domain stays in your name and continues pointing to your existing site throughout the build. On launch day, we update the DNS to point to the new site. Hosting can be moved to our <a href=\"/website-hosting-auckland/\">managed NZ hosting</a> or stay where it is — we'll advise based on performance." },
];
---

<Layout
  title="WordPress Website Rebuilds Auckland | Kiwi Web Design"
  description="Is it time to rebuild your WordPress site? Kiwi Web Design helps Auckland businesses rebuild fast, modern websites that generate enquiries. Free audit included."
  canonicalURL="https://www.kiwiwebdesign.co.nz/wordpress-website-rebuilds-auckland/"
  schema={schema}
>

  <PageHero
    eyebrow="WordPress Rebuilds"
    title="Your site is holding your business back. Let's fix that."
    subtitle="WordPress website rebuilds for Auckland businesses — faster load times, better mobile experience, and a design built to convert visitors into enquiries."
    imgSrc={heroImg.src}
    imgAlt="WordPress website rebuild for Auckland small business"
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View Web Design", href: "/small-business-website-design-auckland/" }}
  />

  <!-- Signs you need a rebuild -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="Signs It's Time"
        title="When a refresh isn't enough."
        subtitle="Some problems are symptoms of a deeper issue — a site that was built wrong or is too old to fix efficiently."
      />
      <div class="rebuild-signs">
        {signs.map(({ icon, title, desc }) => (
          <div class="rebuild-sign">
            <span class="rebuild-sign-icon">{icon}</span>
            <div>
              <strong class="rebuild-sign-title">{title}</strong>
              <p class="rebuild-sign-desc">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's included -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="What's Included"
        title="Every rebuild. Not just a new coat of paint."
        subtitle="A rebuild with Kiwi Web Design covers everything — design, performance, SEO, security, content, and training."
      />
      <ServiceGrid items={included} cols={3} />
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="Our Process"
        title="From audit to launch — simple and transparent."
        subtitle="Six clear steps. You know what's happening at every stage."
      />
      <ProcessSteps items={rebuildProcess} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Rebuild Questions Answered"
        subtitle="Common questions from Auckland business owners considering a WordPress rebuild."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress Web Design</a>
        <a href="/wordpress-maintenance-auckland/" class="rps-link">WordPress Maintenance</a>
        <a href="/website-hosting-auckland/" class="rps-link">Website Hosting</a>
        <a href="/wordpress-seo-optimisation/" class="rps-link">WordPress SEO</a>
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design Packages</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Free site audit — no obligation."
    subtitle="We'll review your current site and tell you exactly what's holding it back. Takes 24 hours."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View Web Design Packages", href: "/small-business-website-design-auckland/" }}
  />

</Layout>

<style>
  .rebuild-signs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .rebuild-sign {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 14px;
    padding: 1.5rem;
  }
  .rebuild-sign-icon { font-size: 1.75rem; flex-shrink: 0; width: 2.25rem; text-align: center; }
  .rebuild-sign-title { display: block; font-size: 0.9rem; font-weight: 700; color: var(--kwd-dark); margin-bottom: 0.35rem; }
  .rebuild-sign-desc { font-size: 0.83rem; color: var(--kwd-brown); line-height: 1.6; margin: 0; }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }

  @media (max-width: 700px) {
    .rebuild-signs { grid-template-columns: 1fr; }
  }
</style>
