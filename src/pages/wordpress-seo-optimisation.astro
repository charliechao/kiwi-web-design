---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/wordpress-seo-optimisation/",
      "url": "https://www.kiwiwebdesign.co.nz/wordpress-seo-optimisation/",
      "name": "WordPress SEO Optimisation Auckland | Rank Higher on Google",
      "description": "Expert WordPress SEO and schema optimisation in Auckland to help your website rank higher on Google and AI search.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/wordpress-seo-optimisation/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/wordpress-seo-optimisation/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "WordPress SEO Optimisation" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const services = [
  {
    icon: "⚙️",
    title: "Technical SEO",
    desc: "The behind-the-scenes work that Google requires before it will rank your site. We fix crawl errors, site speed, mobile issues, and structured data.",
    items: ["Core Web Vitals optimisation", "XML sitemap & robots.txt", "Crawl error resolution", "Canonical tags & redirects"],
  },
  {
    icon: "🏷️",
    title: "On-Page Optimisation",
    desc: "Every page optimised with the right keywords, heading structure, meta tags, and internal linking to signal relevance to Google.",
    items: ["Title tag & meta description", "H1–H3 heading structure", "Keyword placement", "Internal linking strategy"],
  },
  {
    icon: "🔗",
    title: "Schema Markup",
    desc: "Structured data (JSON-LD) that tells Google exactly what your site is about — and helps you appear in rich results, AI Overviews, and featured snippets.",
    items: ["Organisation schema", "LocalBusiness schema", "Service & Product schema", "FAQ & How-To schema"],
  },
  {
    icon: "📄",
    title: "Content Optimisation",
    desc: "Existing content audited and rewritten for target keywords and search intent — without sacrificing readability or brand voice.",
    items: ["Content gap analysis", "Keyword-to-page mapping", "Title & copy rewrites", "Word count & depth analysis"],
  },
  {
    icon: "⚡",
    title: "WordPress Speed Optimisation",
    desc: "Page speed is a Google ranking factor and a conversion factor. We optimise your WordPress install for Core Web Vitals performance.",
    items: ["Image compression & WebP", "Plugin audit & cleanup", "Caching setup", "Database optimisation"],
  },
  {
    icon: "🤖",
    title: "AI Search Optimisation",
    desc: "AI Overviews, ChatGPT search, and Perplexity are changing how people find businesses. We structure your content to be cited by AI systems.",
    items: ["AI-citability content structure", "llms.txt setup", "Conversational keyword targeting", "Entity-based SEO"],
  },
];

const auditItems = [
  "Technical SEO health check (crawlability, indexability, speed)",
  "Keyword ranking audit (where you rank now and for what)",
  "On-page SEO audit (titles, headings, content, internal links)",
  "Schema markup review (what's present, what's missing)",
  "Competitor gap analysis (what they rank for that you don't)",
  "Google Search Console setup & error review",
  "Core Web Vitals assessment",
  "Prioritised action list with estimated impact",
];

const process = [
  { step: "1", title: "SEO Audit", desc: "We audit your current WordPress site — technical health, keyword positions, on-page factors, schema, and competitor gaps. You get a prioritised report." },
  { step: "2", title: "Strategy & Roadmap", desc: "We map out which fixes and optimisations will have the biggest impact for your specific business and competitive landscape." },
  { step: "3", title: "Implementation", desc: "We implement all on-site changes — technical fixes, schema markup, title tags, heading structure, speed optimisation, and content updates." },
  { step: "4", title: "Monitor & Report", desc: "We track keyword rankings, organic traffic, and Search Console data. Monthly reports show progress and next-step recommendations." },
];

const faqs = [
  { q: "What is WordPress SEO optimisation?", a: "It's the process of configuring your <a href=\"/wordpress-website-design-auckland/\">WordPress site</a> so that Google can correctly crawl, understand, and rank your content. This includes technical fixes (speed, crawlability), on-page optimisation (titles, headings, keywords), schema markup, and content improvements — all working together as part of a broader <a href=\"/affordable-seo-auckland/\">SEO strategy</a>." },
  { q: "Is SEO different for WordPress compared to other platforms?", a: "WordPress has specific SEO advantages (flexibility, full control over code and content) and specific pitfalls (plugin bloat, speed issues, duplicate content from categories/tags). We know the WordPress SEO landscape well and address both." },
  { q: "What is schema markup and why does it matter?", a: "Schema markup is structured data (in JSON-LD format) that tells Google exactly what your page, business, products, and reviews are. It enables rich results (star ratings, FAQ dropdowns, price displays) in search results and helps AI systems like Google's AI Overviews and ChatGPT cite your content correctly." },
  { q: "How long does WordPress SEO take to show results?", a: "Technical fixes and schema can show results in 2–4 weeks. Keyword ranking improvements typically take 3–6 months for most industries. Highly competitive niches may take 6–12 months. We give you an honest timeline based on your specific situation." },
  { q: "Do you use the Yoast SEO plugin?", a: "We typically use Yoast SEO or Rank Math — both are excellent and serve different use cases. We configure whichever plugin is right for your site (or install it fresh if you don't have one) as part of the optimisation work." },
  { q: "Can you optimise an existing WordPress site or only new ones?", a: "Both. We frequently do SEO optimisation on existing sites — auditing what's there, fixing what's broken, and improving what's underperforming. We also build SEO in as a foundation for every new <a href=\"/wordpress-website-design-auckland/\">WordPress site we create</a>. For location-based businesses, this WordPress SEO work pairs naturally with our <a href=\"/local-seo-for-auckland-small-businesses/\">local SEO services</a>." },
];
---

<Layout
  title="WordPress SEO Optimisation Auckland | Rank Higher on Google"
  description="Expert WordPress SEO and schema optimisation in Auckland to help your website rank higher on Google and AI search."
  canonicalURL="https://www.kiwiwebdesign.co.nz/wordpress-seo-optimisation/"
  schema={schema}
>

  <PageHero
    eyebrow="WordPress SEO Optimisation Auckland"
    title="Get your WordPress site ranking on Google — and AI search."
    subtitle="Technical SEO, schema markup, on-page optimisation, and speed improvements for WordPress sites. We fix what Google and AI systems need to rank and cite your content."
    ctaPrimary={{ text: "Get an SEO Audit", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "Full SEO Services", href: "/affordable-seo-auckland/" }}
  />

  <!-- Services -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="WordPress SEO Services"
        title="Everything Google needs to rank your WordPress site."
        subtitle="We cover every layer of WordPress SEO — from technical foundations to AI search visibility."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- What an audit includes -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <div class="wpco-audit-wrap">
        <div class="wpco-audit-text">
          <p class="wpco-eyebrow">Free Audit</p>
          <h2>Start with a WordPress SEO audit.</h2>
          <p>Before we recommend any changes, we audit your existing site. You get a clear picture of where you stand — and a prioritised list of what to fix first for the biggest impact.</p>
          <a href="/website-designer-auckland/" class="wpco-audit-btn">Book a Free SEO Audit →</a>
        </div>
        <ul class="wpco-audit-list">
          {auditItems.map((item) => (
            <li>
              <span class="wpco-check">✓</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="Audit, strategy, implement, report."
        subtitle="A clear four-step process for improving your WordPress SEO."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="WordPress SEO Questions Answered"
        subtitle="Common questions from Auckland businesses about improving their WordPress site's rankings."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/affordable-seo-auckland/" class="rps-link">SEO Services Auckland</a>
        <a href="/local-seo-for-auckland-small-businesses/" class="rps-link">Local SEO Auckland</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress Web Design</a>
        <a href="/analytics-reporting-for-auckland-small-business-websites/" class="rps-link">Analytics & Reporting</a>
        <a href="/wordpress-maintenance-auckland/" class="rps-link">WordPress Maintenance</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to rank higher on Google?"
    subtitle="Get a free WordPress SEO audit — we'll show you exactly what's holding your site back."
    ctaPrimary={{ text: "Get a Free SEO Audit", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See All SEO Services", href: "/affordable-seo-auckland/" }}
  />

</Layout>

<style>
  .wpco-audit-wrap {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: start;
  }
  .wpco-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-yellow);
    margin-bottom: 0.75rem;
  }
  .wpco-audit-text h2 { font-size: clamp(1.5rem, 2.5vw, 2rem); color: #fff; margin-bottom: 0.75rem; }
  .wpco-audit-text p { font-size: 0.9rem; color: rgba(255,255,255,0.65); line-height: 1.7; margin-bottom: 1.5rem; }
  .wpco-audit-btn {
    display: inline-block;
    background: var(--kwd-yellow);
    color: var(--kwd-dark);
    padding: 0.875rem 2rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    transition: background 0.2s;
  }
  .wpco-audit-btn:hover { background: var(--kwd-gold); }
  .wpco-audit-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 1.75rem;
  }
  .wpco-audit-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.8);
    line-height: 1.5;
  }
  .wpco-check { color: var(--kwd-yellow); font-weight: 700; flex-shrink: 0; margin-top: 1px; }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }

  @media (max-width: 860px) {
    .wpco-audit-wrap { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>

<!-- Vanta.js FOG background for hero -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/vanta@0.5.24/dist/vanta.fog.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    VANTA.FOG({
      el: '.hero-section',
      mouseControls: true,
      touchControls: true,
      gyroControls: false,
      minHeight: 200,
      minWidth: 200,
      scale: 1.0,
      scaleMobile: 0.75,
      highlightColor: 0xf3d97a,
      midtoneColor: 0x534a45,
      lowlightColor: 0x2c2927,
      baseColor: 0x2c2927,
      blurFactor: 0.6,
      speed: 1.5,
      zoom: 0.8,
    });
  });
</script>
