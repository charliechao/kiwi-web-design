---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTABanner from '../components/CTABanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/solutions-auckland-kiwi-web-design/",
      "url": "https://www.kiwiwebdesign.co.nz/solutions-auckland-kiwi-web-design/",
      "name": "Solutions Auckland – Kiwi Web Design",
      "description": "Affordable web design, eCommerce, SEO, hosting & maintenance for Auckland small businesses. Local, fast, and friendly.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/solutions-auckland-kiwi-web-design/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/solutions-auckland-kiwi-web-design/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Solutions Auckland" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const solutions = [
  {
    icon: "🌐",
    category: "Web Design",
    title: "WordPress Websites That Generate Leads",
    desc: "Custom WordPress websites for Auckland small businesses — designed around your customers, your goals, and your budget. From 5-page starter sites to complex eCommerce stores.",
    features: ["Custom WordPress design", "Mobile-first, fast-loading", "Lead generation focus", "From $1,290 + GST"],
    links: [
      { label: "Small Business Web Design", href: "/small-business-website-design-auckland/" },
      { label: "Tradie Websites", href: "/tradie-website-design-auckland/" },
      { label: "WordPress Design", href: "/wordpress-website-design-auckland/" },
    ],
  },
  {
    icon: "🛒",
    category: "eCommerce",
    title: "Online Stores Built to Sell",
    desc: "WooCommerce and Shopify stores with NZ payment gateways, shipping rules, and GST configured from day one. Your store is ready to sell on launch day.",
    features: ["WooCommerce & Shopify", "NZ payment gateways", "NZ shipping & GST setup", "From $3,990 + GST"],
    links: [
      { label: "eCommerce Overview", href: "/ecommerce-website-auckland/" },
      { label: "WooCommerce Design", href: "/woocommerce-website-design-auckland/" },
      { label: "Shopify Design", href: "/shopify-website-design-auckland/" },
    ],
  },
  {
    icon: "🔍",
    category: "SEO",
    title: "Search Engine Optimisation Auckland",
    desc: "Local SEO, technical SEO, content strategy, and link building to help Auckland businesses rank on Google and be found by AI search engines.",
    features: ["Local SEO & Google Maps", "Technical SEO", "WordPress SEO", "Ongoing monthly management"],
    links: [
      { label: "SEO Auckland", href: "/seo-auckland/" },
      { label: "Local SEO", href: "/local-seo-for-auckland-small-businesses/" },
      { label: "WordPress SEO", href: "/wordpress-seo-optimisation/" },
    ],
  },
  {
    icon: "📣",
    category: "Google Ads",
    title: "Google Ads Management",
    desc: "Targeted Google Ads campaigns for Auckland small businesses — set up, managed, and optimised to generate real leads, not just clicks.",
    features: ["Search & Local Service Ads", "Conversion tracking setup", "Monthly management", "From $399/mo + ad spend"],
    links: [
      { label: "Google Ads Auckland", href: "/google-ads/" },
    ],
  },
  {
    icon: "🌐",
    category: "Hosting",
    title: "Managed NZ Website Hosting",
    desc: "Fast, NZ-based WordPress hosting with daily backups, SSL, security, and support from a local team — not an overseas helpdesk.",
    features: ["NZ-based servers", "Daily backups", "SSL & security", "From $49/mo + GST"],
    links: [
      { label: "Website Hosting Auckland", href: "/website-hosting-auckland/" },
    ],
  },
  {
    icon: "🔧",
    category: "Maintenance",
    title: "WordPress Maintenance & Care",
    desc: "Monthly maintenance plans that keep your WordPress site secure, fast, and up to date — including updates, backups, security monitoring, and content changes.",
    features: ["Monthly WP updates", "Security monitoring", "Daily backups", "From $99/mo + GST"],
    links: [
      { label: "WordPress Maintenance", href: "/wordpress-maintenance-auckland/" },
      { label: "Monthly Subscription", href: "/monthly-subscription/" },
    ],
  },
];

const bundles = [
  {
    name: "Website + Hosting",
    desc: "Get your site built and hosted under one roof. No coordinating between a developer and a separate host.",
    href: "/website-designer-auckland/",
  },
  {
    name: "Website + SEO",
    desc: "Build your site and start ranking at the same time. SEO foundations baked into the build, with ongoing optimisation.",
    href: "/website-designer-auckland/",
  },
  {
    name: "Website + Google Ads",
    desc: "Launch your site and start generating leads immediately with targeted Google Ads while SEO builds over time.",
    href: "/website-designer-auckland/",
  },
  {
    name: "Full Growth Package",
    desc: "Website, SEO, Google Ads, hosting, and maintenance — everything your business needs to grow online, managed in one place.",
    href: "/website-designer-auckland/",
  },
];
---

<Layout
  title="Solutions Auckland | Web Design, SEO, Google Ads & More"
  description="Affordable web design, eCommerce, SEO, hosting & maintenance for Auckland small businesses. Local, fast, and friendly."
  canonicalURL="https://www.kiwiwebdesign.co.nz/solutions-auckland-kiwi-web-design/"
  schema={schema}
>

  <!-- Hero -->
  <section class="sol-hero">
    <div class="container sol-hero-inner">
      <p class="sol-eyebrow">Our Solutions</p>
      <h1>Everything an Auckland small business needs online — in one place.</h1>
      <p class="sol-hero-sub">From your first website to an ongoing growth strategy — web design, eCommerce, SEO, Google Ads, hosting, and maintenance. Local team, transparent pricing, real results.</p>
      <div class="sol-hero-actions">
        <a href="/website-designer-auckland/" class="sol-btn-primary">Book a Free Consult</a>
        <a href="#solutions" class="sol-btn-secondary">Browse Solutions ↓</a>
      </div>
    </div>
  </section>

  <!-- Solutions -->
  <section class="section" id="solutions">
    <div class="container">
      <SectionHeader
        eyebrow="Services"
        title="Every solution we offer. Explained."
        subtitle="Click through to each service area for detailed information, pricing, and FAQs."
      />
      <div class="sol-grid">
        {solutions.map(({ icon, category, title, desc, features, links }) => (
          <div class="sol-card">
            <div class="sol-card-top">
              <span class="sol-icon">{icon}</span>
              <span class="sol-category">{category}</span>
            </div>
            <h3 class="sol-title">{title}</h3>
            <p class="sol-desc">{desc}</p>
            <ul class="sol-features">
              {features.map((f) => <li>{f}</li>)}
            </ul>
            <div class="sol-links">
              {links.map(({ label, href }) => (
                <a href={href} class="sol-link">{label} →</a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bundles -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="Popular Combinations"
        title="Solutions that work better together."
        light={true}
        subtitle="Most Auckland businesses benefit from combining services. Here are our most popular bundles."
      />
      <div class="sol-bundles">
        {bundles.map(({ name, desc, href }) => (
          <a href={href} class="sol-bundle">
            <strong class="sol-bundle-name">{name}</strong>
            <p class="sol-bundle-desc">{desc}</p>
            <span class="sol-bundle-link">Get a quote →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why KWD -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container sol-why-wrap">
      <div class="sol-why-text">
        <p class="sol-why-eyebrow">Why Kiwi Web Design</p>
        <h2>One team. Every solution. Auckland-based.</h2>
        <p>Managing a website, <a href="/seo-auckland/">SEO agency</a>, hosting provider, and <a href="/google-ads/">Google Ads manager</a> separately is time-consuming and expensive. Briefing multiple people means things fall through the cracks.</p>
        <p>We offer every digital service an Auckland <a href="/small-business-website-design-auckland/">small business</a> needs — under one roof, at honest pricing, managed by a local team who knows your business. Whether you need a new <a href="/ecommerce-website-auckland/">eCommerce store</a> or just a professional starter site, find out <a href="/about-us/">about us</a> before you get in touch.</p>
      </div>
      <div class="sol-why-stats">
        <div class="sol-why-stat"><span class="sws-num">50+</span><span class="sws-label">Auckland businesses helped</span></div>
        <div class="sol-why-stat"><span class="sws-num">4.9★</span><span class="sws-label">Average Google rating</span></div>
        <div class="sol-why-stat"><span class="sws-num">Grey Lynn</span><span class="sws-label">Auckland-based, in-person consults</span></div>
        <div class="sol-why-stat"><span class="sws-num">Free</span><span class="sws-label">Initial consultation — always</span></div>
      </div>
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design</a>
        <a href="/seo-auckland/" class="rps-link">SEO</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
        <a href="/ecommerce-website-auckland/" class="rps-link">eCommerce</a>
        <a href="/website-designer-auckland/" class="rps-link">Contact</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Not sure which solution is right for you?"
    subtitle="Book a free consultation — we'll assess your business and recommend the highest-impact starting point."
    ctaPrimary={{ text: "Book a Free Consult", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Industries We Serve", href: "/industries-we-serve-in-auckland/" }}
  />

</Layout>

<style>
  .sol-hero {
    background: var(--kwd-dark);
    padding: 5rem 0;
    text-align: center;
  }
  .sol-hero-inner { max-width: 740px; margin-inline: auto; }
  .sol-eyebrow {
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--kwd-yellow); margin-bottom: 1rem;
  }
  .sol-hero h1 { font-size: clamp(2rem, 4.5vw, 3.5rem); color: #fff; line-height: 1.1; margin-bottom: 1.25rem; }
  .sol-hero-sub { font-size: 1rem; color: rgba(255,255,255,0.65); line-height: 1.7; margin-bottom: 2.5rem; }
  .sol-hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .sol-btn-primary {
    display: inline-block; background: var(--kwd-yellow); color: var(--kwd-dark);
    padding: 0.875rem 2rem; border-radius: 8px; font-weight: 700; font-size: 0.875rem;
    text-transform: uppercase; letter-spacing: 0.07em; transition: background 0.2s;
  }
  .sol-btn-primary:hover { background: var(--kwd-gold); }
  .sol-btn-secondary {
    display: inline-block; color: rgba(255,255,255,0.65); padding: 0.875rem 1.5rem;
    font-size: 0.875rem; font-weight: 600; transition: color 0.2s;
  }
  .sol-btn-secondary:hover { color: #fff; }

  /* Solutions grid */
  .sol-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .sol-card {
    background: var(--kwd-cream);
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 18px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .sol-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .sol-card-top { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.25rem; }
  .sol-icon { font-size: 1.75rem; }
  .sol-category {
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--kwd-brown); background: rgba(0,0,0,0.06); padding: 0.2rem 0.6rem; border-radius: 100px;
  }
  .sol-title { font-family: var(--kwd-font-body); font-size: 1rem; font-weight: 700; color: var(--kwd-dark); margin: 0; }
  .sol-desc { font-size: 0.84rem; color: var(--kwd-brown); line-height: 1.6; margin: 0; flex: 1; }
  .sol-features {
    list-style: none; padding: 0; margin: 0.25rem 0 0; display: flex; flex-direction: column; gap: 0.35rem;
  }
  .sol-features li {
    font-size: 0.8rem; color: var(--kwd-dark); padding-left: 1.1rem; position: relative;
  }
  .sol-features li::before { content: "✓"; position: absolute; left: 0; color: var(--kwd-brown); font-weight: 700; }
  .sol-links { display: flex; flex-direction: column; gap: 0.3rem; margin-top: 0.5rem; border-top: 1px solid rgba(0,0,0,0.07); padding-top: 0.75rem; }
  .sol-link { font-size: 0.82rem; font-weight: 700; color: var(--kwd-dark); transition: opacity 0.2s; }
  .sol-link:hover { opacity: 0.65; }

  /* Bundles */
  .sol-bundles {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .sol-bundle {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 14px;
    padding: 1.5rem;
    transition: background 0.2s;
  }
  .sol-bundle:hover { background: rgba(255,255,255,0.1); }
  .sol-bundle-name { font-size: 0.95rem; font-weight: 700; color: #fff; }
  .sol-bundle-desc { font-size: 0.84rem; color: rgba(255,255,255,0.6); line-height: 1.55; margin: 0; }
  .sol-bundle-link { font-size: 0.82rem; font-weight: 700; color: var(--kwd-yellow); margin-top: 0.25rem; }

  /* Why KWD */
  .sol-why-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .sol-why-eyebrow { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--kwd-brown); margin-bottom: 0.75rem; }
  .sol-why-text h2 { font-size: clamp(1.5rem, 2.5vw, 2rem); margin-bottom: 1rem; }
  .sol-why-text p { font-size: 0.95rem; color: var(--kwd-brown); line-height: 1.7; margin-bottom: 0.75rem; }
  .sol-why-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .sol-why-stat {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 14px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-align: center;
  }
  .sws-num { font-family: var(--kwd-font-heading); font-size: 1.75rem; color: var(--kwd-dark); line-height: 1; }
  .sws-label { font-size: 0.78rem; color: var(--kwd-brown); line-height: 1.4; }

  @media (max-width: 960px) {
    .sol-grid { grid-template-columns: repeat(2, 1fr); }
    .sol-bundles { grid-template-columns: 1fr; }
    .sol-why-wrap { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  @media (max-width: 580px) {
    .sol-grid { grid-template-columns: 1fr; }
    .sol-why-stats { grid-template-columns: 1fr; }
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
