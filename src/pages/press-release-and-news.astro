---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTABanner from '../components/CTABanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/press-release-and-news/",
      "url": "https://www.kiwiwebdesign.co.nz/press-release-and-news/",
      "name": "Press Releases & News | Kiwi Web Design Auckland",
      "description": "Latest press releases and news from Kiwi Web Design — Auckland's small business web design specialists.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/press-release-and-news/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/press-release-and-news/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Press Releases & News" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const releases = [
  {
    date: "2025-10-15",
    dateDisplay: "15 October 2025",
    title: "Kiwi Web Design Launches New Website Packages for Auckland Small Businesses",
    summary: "Kiwi Web Design has released a new range of fixed-price website packages specifically designed for Auckland sole traders and small business owners. The packages include full WordPress builds, SEO setup, and 30-day post-launch support — with most sites going live within 2–3 weeks.",
    source: "PRLog",
    sourceUrl: "https://www.prlog.org/",
    category: "Company News",
  },
  {
    date: "2025-09-01",
    dateDisplay: "1 September 2025",
    title: "Auckland Web Design Agency Kiwi Web Design Marks 100+ Local Business Clients",
    summary: "Kiwi Web Design has reached a milestone of over 100 Auckland-based small business clients. The agency, founded by Charlie Chao, specialises in affordable websites for trades, professional services, and retail businesses that prioritise lead generation over aesthetic-only design.",
    source: "PRLog",
    sourceUrl: "https://www.prlog.org/",
    category: "Milestone",
  },
  {
    date: "2025-07-20",
    dateDisplay: "20 July 2025",
    title: "Kiwi Web Design Expands SEO Services for Auckland Small Business Market",
    summary: "Following strong demand from existing website clients, Kiwi Web Design has expanded its local SEO service offering to include Google Business Profile optimisation, citation building, and monthly rank tracking. The expanded service targets Auckland businesses seeking to rank in local map results.",
    source: "PRLog",
    sourceUrl: "https://www.prlog.org/",
    category: "Service Update",
  },
];

const categoryColours: Record<string, string> = {
  "Company News": "#2c2927",
  "Milestone": "#4a7c59",
  "Service Update": "#2c5f8a",
};
---

<Layout
  title="Press Releases & News | Kiwi Web Design Auckland"
  description="Latest press releases and news from Kiwi Web Design — Auckland's small business web design specialists."
  canonicalURL="https://www.kiwiwebdesign.co.nz/press-release-and-news/"
  schema={schema}
>

  <!-- Page header -->
  <section class="news-hero section">
    <div class="container" style="max-width: 860px;">
      <p class="news-eyebrow">Press & News</p>
      <h1 class="news-title">Press Releases &amp; News</h1>
      <p class="news-subtitle">The latest updates, milestones, and announcements from Kiwi Web Design — Auckland's small business web design specialists.</p>
    </div>
  </section>

  <!-- News listing -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <SectionHeader
        eyebrow="Latest Releases"
        title="News from Kiwi Web Design"
        align="left"
      />

      <div class="releases-list">
        {releases.map(item => (
          <article class="release-card">
            <div class="release-meta">
              <span
                class="release-category"
                style={`background: ${categoryColours[item.category] ?? '#2c2927'};`}
              >{item.category}</span>
              <time class="release-date" datetime={item.date}>{item.dateDisplay}</time>
            </div>
            <h2 class="release-title">{item.title}</h2>
            <p class="release-summary">{item.summary}</p>
            <div class="release-source">
              <span class="release-source-label">Published via</span>
              <a href={item.sourceUrl} target="_blank" rel="noopener noreferrer" class="release-source-link">{item.source}</a>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>

  <!-- Media contact callout -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <div class="media-contact">
        <div class="media-contact-text">
          <h2 class="media-contact-heading">Media enquiries</h2>
          <p class="media-contact-body">For press enquiries, interview requests, or media assets, contact us directly. We're happy to provide commentary on web design trends, small business digital marketing, and the Auckland SME market.</p>
        </div>
        <div class="media-contact-detail">
          <p class="media-detail-label">Contact</p>
          <p class="media-detail-value">Charlie Chao</p>
          <p class="media-detail-value">Kiwi Web Design, Auckland, New Zealand</p>
          <a href="/work-with-us/" class="btn-media">Get in Touch</a>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Need a website for your Auckland business?"
    subtitle="Free consultation — fixed-price quote within 24 hours. Most sites live within 2–3 weeks."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View Web Design Services", href: "/small-business-website-design-auckland/" }}
  />

</Layout>

<style>
  .news-hero {
    border-bottom: 1px solid rgba(0,0,0,0.07);
  }
  .news-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-brown);
    margin-bottom: 0.75rem;
  }
  .news-title {
    font-family: var(--kwd-font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--kwd-dark);
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }
  .news-subtitle {
    font-size: 1rem;
    color: var(--kwd-brown);
    line-height: 1.7;
    max-width: 640px;
  }

  .releases-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .release-card {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 12px;
    padding: 1.75rem 2rem;
    transition: box-shadow 0.2s;
  }
  .release-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
  }

  .release-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }
  .release-category {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
  }
  .release-date {
    font-size: 0.82rem;
    color: var(--kwd-brown);
    font-weight: 500;
  }

  .release-title {
    font-family: var(--kwd-font-heading);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    color: var(--kwd-dark);
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }
  .release-summary {
    font-size: 0.9rem;
    color: var(--kwd-brown);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .release-source {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
  }
  .release-source-label {
    color: var(--kwd-brown);
  }
  .release-source-link {
    color: var(--kwd-dark);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .release-source-link:hover {
    color: var(--kwd-brown);
  }

  /* Media contact */
  .media-contact {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: start;
    background: var(--kwd-cream);
    border-left: 4px solid var(--kwd-yellow);
    border-radius: 0 12px 12px 0;
    padding: 2rem 2.5rem;
  }
  .media-contact-heading {
    font-family: var(--kwd-font-heading);
    font-size: 1.4rem;
    color: var(--kwd-dark);
    margin-bottom: 0.6rem;
  }
  .media-contact-body {
    font-size: 0.9rem;
    color: var(--kwd-brown);
    line-height: 1.75;
  }
  .media-detail-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--kwd-brown);
    margin-bottom: 0.35rem;
  }
  .media-detail-value {
    font-size: 0.9rem;
    color: var(--kwd-dark);
    font-weight: 600;
    line-height: 1.5;
  }
  .btn-media {
    display: inline-block;
    margin-top: 1rem;
    background: var(--kwd-dark);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.6rem 1.25rem;
    border-radius: 6px;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .btn-media:hover { opacity: 0.85; }

  @media (max-width: 640px) {
    .media-contact {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 1.5rem;
    }
    .release-card { padding: 1.25rem 1.25rem; }
  }
</style>
