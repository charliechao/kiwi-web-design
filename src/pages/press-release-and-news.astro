---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTABanner from '../components/CTABanner.astro';
import PageVisual from '../components/PageVisual.astro';
import pressImage from '../assets/services/kiwi-web-design-press-and-news-auckland.jpg';

const releases = [
  {
    date: '2026-05-15',
    dateDisplay: '15 May 2026',
    title: 'Kiwi Web Design Ranked First in New 2026 Guide to SEO Agencies in Auckland',
    summary: "A company-supplied release published by InfoNews covers Kiwi Web Design's 2026 Auckland SEO agency guide and links to the agency's SEO service page.",
    source: 'InfoNews',
    sourceUrl: 'https://www.infonews.co.nz/news.cfm?id=129007',
    category: 'Published Coverage',
  },
  {
    date: '2026-01-05',
    dateDisplay: '5 January 2026',
    title: 'Top Web Design Agencies in Auckland Reviewed for 2026',
    summary: 'An Ika Tech Limited, trading as Kiwi Web Design, release published by openPR introduces the updated Auckland web design agency comparison guide.',
    source: 'openPR',
    sourceUrl: 'https://www.openpr.com/news/4335211/top-web-design-agencies-in-auckland-reviewed-for-2026',
    category: 'Published Release',
  },
  {
    date: '2025-12-04',
    dateDisplay: '4 December 2025',
    title: 'Kiwi Web Design Helps Auckland Builder Kiwiland Construction Launch a New Website',
    summary: 'This openPR project release names Ika Tech Limited, Kiwi Web Design, Kiwiland Construction, Steven Liu, Charlie Chao, and the live client website.',
    source: 'openPR',
    sourceUrl: 'https://www.openpr.com/news/4299557/kiwi-web-design-helps-auckland-builder-kiwiland-construction',
    category: 'Client Project',
  },
];

const profiles = [
  {
    name: 'LinkedIn',
    description: 'Official Kiwi Web Design company profile with the Auckland location, company information, and published updates.',
    url: 'https://nz.linkedin.com/company/kiwi-web-design',
  },
  {
    name: 'Sortlist',
    description: "Claimed Auckland agency profile listing Kiwi Web Design's address and Kiwiland Construction portfolio work.",
    url: 'https://www.sortlist.com/agency/kiwi-web-design',
  },
  {
    name: 'DesignRush',
    description: 'Agency profile with portfolio information and client reviews sourced from public review platforms.',
    url: 'https://www.designrush.com/agency/profile/kiwi-web-design',
  },
  {
    name: 'Techreviewer',
    description: 'Public company profile listing Kiwi Web Design in Auckland with contact details and named clients.',
    url: 'https://techreviewer.co/companies/kiwi-web-design',
  },
  {
    name: 'Trustindex',
    description: 'Public review profile containing attributable reviews from Kiwi Web Design clients.',
    url: 'https://www.trustindex.io/reviews/kiwiwebdesign.co.nz',
  },
  {
    name: 'openPR publisher archive',
    description: 'Publisher archive for releases submitted by Ika Tech Limited, trading as Kiwi Web Design.',
    url: 'https://www.openpr.com/news/archive/277321/Ika-Tech-Limited-T-A-Kiwi-Web-Design.html',
  },
];

const externalItems = [
  ...releases.map(item => ({ name: item.title, url: item.sourceUrl })),
  ...profiles,
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['WebPage', 'CollectionPage'],
      '@id': 'https://www.kiwiwebdesign.co.nz/press-release-and-news/',
      url: 'https://www.kiwiwebdesign.co.nz/press-release-and-news/',
      name: 'Press, Coverage & Public Profiles | Kiwi Web Design Auckland',
      description: 'Verified external coverage, published releases, public agency profiles, and review sources for Kiwi Web Design in Auckland.',
      dateModified: '2026-07-10',
      inLanguage: 'en-NZ',
      isPartOf: { '@id': 'https://www.kiwiwebdesign.co.nz/#website' },
      about: { '@id': 'https://www.kiwiwebdesign.co.nz/#organization' },
      mainEntity: {
        '@type': 'ItemList',
        itemListElement: externalItems.map((item, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: item.name,
          url: item.url,
        })),
      },
      breadcrumb: { '@id': 'https://www.kiwiwebdesign.co.nz/press-release-and-news/#breadcrumb' },
    },
    {
      '@type': 'BreadcrumbList',
      '@id': 'https://www.kiwiwebdesign.co.nz/press-release-and-news/#breadcrumb',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.kiwiwebdesign.co.nz/' },
        { '@type': 'ListItem', position: 2, name: 'Press & Public Profiles' },
      ],
    },
    {
      '@type': 'Organization',
      '@id': 'https://www.kiwiwebdesign.co.nz/#organization',
      name: 'Kiwi Web Design',
      legalName: 'Ika Tech Limited',
      url: 'https://www.kiwiwebdesign.co.nz/',
      identifier: {
        '@type': 'PropertyValue',
        propertyID: 'NZBN',
        value: '9429052816840',
      },
    },
  ],
};

const categoryColours: Record<string, string> = {
  'Published Coverage': '#2c5f8a',
  'Published Release': '#2c2927',
  'Client Project': '#4a7c59',
};
---

<Layout
  title="Press, Coverage & Public Profiles | Kiwi Web Design Auckland"
  description="Verified external coverage, published releases, public agency profiles, and review sources for Kiwi Web Design in Auckland."
  canonicalURL="https://www.kiwiwebdesign.co.nz/press-release-and-news/"
  schema={schema}
>
  <section class="news-hero section">
    <div class="container news-inner">
      <p class="news-eyebrow">External Evidence</p>
      <h1 class="news-title">Press, coverage and public profiles</h1>
      <p class="news-subtitle">A transparent record of external pages that identify Kiwi Web Design, Ika Tech Limited, Charlie Chao, or our published client work.</p>
    </div>
  </section>

  <PageVisual
    imgSrc={pressImage.src}
    imgAlt="Kiwi Web Design press and public profile source register"
    imgTitle="Kiwi Web Design external coverage and public profiles"
    eyebrow="Source Register"
    title="Evidence should be easy to trace."
    caption="Every item below links directly to the external publication, directory, or review profile where it appears."
  />

  <section class="section releases-section">
    <div class="container news-inner">
      <SectionHeader eyebrow="Published Externally" title="Coverage and releases" align="left" />
      <p class="section-intro">These are externally hosted pages, but the releases were supplied by Kiwi Web Design or Ika Tech Limited. They are listed as corroborating publication records, not independent editorial endorsements.</p>

      <div class="releases-list">
        {releases.map(item => (
          <article class="release-card">
            <div class="release-meta">
              <span class="release-category" style={`background: ${categoryColours[item.category] ?? '#2c2927'};`}>{item.category}</span>
              <time class="release-date" datetime={item.date}>{item.dateDisplay}</time>
            </div>
            <h2 class="release-title">{item.title}</h2>
            <p class="release-summary">{item.summary}</p>
            <a href={item.sourceUrl} target="_blank" rel="noopener noreferrer" class="release-source-link">Read on {item.source}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section profile-section">
    <div class="container news-inner">
      <SectionHeader eyebrow="Entity Corroboration" title="Verified public profiles" align="left" />
      <p class="section-intro">These profiles provide external confirmation of the business name, Auckland location, services, client work, or attributable reviews. Directory ratings and descriptions are controlled by their respective platforms.</p>

      <div class="profile-list">
        {profiles.map(profile => (
          <article class="profile-row">
            <h3>{profile.name}</h3>
            <p>{profile.description}</p>
            <a href={profile.url} target="_blank" rel="noopener noreferrer">Open profile</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container news-inner">
      <div class="media-contact">
        <div>
          <h2>Media enquiries</h2>
          <p>For press enquiries, interview requests, source checks, or media assets, contact Charlie directly. Commentary is available on Auckland web design, local SEO, AI search, and small-business lead generation.</p>
        </div>
        <div class="media-contact-detail">
          <p class="media-detail-label">Contact</p>
          <p class="media-detail-value">Charlie Chao</p>
          <p class="media-detail-value">Kiwi Web Design, Auckland</p>
          <a href="mailto:hi@kiwiwebdesign.co.nz" class="btn-media">Email Charlie</a>
        </div>
      </div>
    </div>
  </section>

  <section class="related-strip">
    <div class="container news-inner">
      <p class="rps-label">Related</p>
      <div class="rps-links">
        <a href="/about-us/" class="rps-link">About Us</a>
        <a href="/legal-information/" class="rps-link">Legal Information</a>
        <a href="/testimonials-reviews/" class="rps-link">Client Reviews</a>
        <a href="/kiwiland-construction-website/" class="rps-link">Kiwiland Case Study</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Planning your next stage of growth?"
    subtitle="Talk directly with Charlie about website design, SEO, AI search visibility, and paid advertising for your business."
    ctaPrimary={{ text: 'Work With Us', href: '/work-with-us/' }}
    ctaSecondary={{ text: 'View Web Design Services', href: '/' }}
  />
</Layout>

<style>
  .news-inner { max-width: 860px; }
  .news-hero { border-bottom: 1px solid rgba(0,0,0,0.07); }
  .news-eyebrow,
  .rps-label,
  .media-detail-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--kwd-brown);
  }
  .news-eyebrow { margin-bottom: 0.75rem; }
  .news-title {
    max-width: 720px;
    font-family: var(--kwd-font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--kwd-dark);
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }
  .news-subtitle,
  .section-intro {
    max-width: 70ch;
    font-size: 0.95rem;
    color: var(--kwd-brown);
    line-height: 1.75;
  }
  .section-intro { margin-top: 0.75rem; }
  .releases-section { background: var(--kwd-cream); }
  .releases-list { display: grid; gap: 1rem; margin-top: 2rem; }
  .release-card {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 8px;
    padding: 1.75rem 2rem;
  }
  .release-meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.85rem; }
  .release-category {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #fff;
    padding: 0.25rem 0.65rem;
    border-radius: 4px;
  }
  .release-date { font-size: 0.82rem; color: var(--kwd-brown); font-weight: 500; }
  .release-title {
    font-family: var(--kwd-font-heading);
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    color: var(--kwd-dark);
    line-height: 1.3;
    margin-bottom: 0.65rem;
  }
  .release-summary { font-size: 0.9rem; color: var(--kwd-brown); line-height: 1.75; margin-bottom: 0.9rem; }
  .release-source-link,
  .profile-row a {
    color: var(--kwd-dark);
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .profile-list { margin-top: 2rem; border-top: 1px solid rgba(0,0,0,0.1); }
  .profile-row {
    display: grid;
    grid-template-columns: minmax(130px, 0.35fr) 1fr auto;
    gap: 1.5rem;
    align-items: center;
    padding: 1.2rem 0;
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
  .profile-row h3 { font-size: 1rem; color: var(--kwd-dark); margin: 0; }
  .profile-row p { font-size: 0.86rem; line-height: 1.65; color: var(--kwd-brown); margin: 0; }
  .profile-row a { white-space: nowrap; }
  .media-contact {
    display: grid;
    grid-template-columns: 1fr minmax(190px, auto);
    gap: 3rem;
    background: var(--kwd-cream);
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 8px;
    padding: 2rem 2.5rem;
  }
  .media-contact h2 { font-family: var(--kwd-font-heading); font-size: 1.4rem; color: var(--kwd-dark); margin-bottom: 0.6rem; }
  .media-contact p { font-size: 0.9rem; color: var(--kwd-brown); line-height: 1.7; }
  .media-detail-label { margin-bottom: 0.35rem; }
  .media-detail-value { color: var(--kwd-dark) !important; font-weight: 600; }
  .btn-media {
    display: inline-block;
    margin-top: 1rem;
    background: var(--kwd-dark);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.6rem 1.15rem;
    border-radius: 6px;
    text-decoration: none;
  }
  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link {
    font-size: 0.82rem;
    font-weight: 600;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.1);
    color: var(--kwd-dark);
    text-decoration: none;
  }
  .rps-link:hover { background: #e8e7db; }
  @media (max-width: 700px) {
    .release-card { padding: 1.25rem; }
    .profile-row { grid-template-columns: 1fr; gap: 0.45rem; }
    .profile-row a { margin-top: 0.2rem; }
    .media-contact { grid-template-columns: 1fr; gap: 1.5rem; padding: 1.5rem; }
  }
</style>
