---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import heroImg from '../assets/general/shopping-cart-for-eCommerce-1.jpg';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/shopify-website-design-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/shopify-website-design-auckland/",
      "name": "Shopify Website Design Auckland | High-Converting Shopify Stores",
      "description": "Kiwi Web Design builds beautiful, high-converting Shopify websites for Auckland businesses. NZ payments, shipping, and AfterPay configured. From $3,890 + GST.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/shopify-website-design-auckland/#breadcrumb" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": [".shopify-snippet", "h1"] }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/shopify-website-design-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Shopify Website Design Auckland", "item": "https://www.kiwiwebdesign.co.nz/shopify-website-design-auckland/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "Place", "name": "Auckland" },
        { "@type": "Place", "name": "New Zealand" }
      ],
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "ratingCount": "50", "bestRating": "5" },
      "logo": { "@type": "ImageObject", "url": "https://www.kiwiwebdesign.co.nz/favicon.png", "width": 512, "height": 512 }
    },
    {
      "@type": "Service",
      "@id": "https://www.kiwiwebdesign.co.nz/shopify-website-design-auckland/#service",
      "name": "Shopify Website Design Auckland",
      "serviceType": "Shopify Website Design",
      "category": "eCommerce",
      "provider": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "areaServed": [
        { "@type": "Place", "name": "Auckland" },
        { "@type": "Place", "name": "New Zealand" }
      ],
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "3890",
        "highPrice": "8000",
        "priceCurrency": "NZD",
        "priceSpecification": { "@type": "PriceSpecification", "valueAddedTaxIncluded": false }
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Is Shopify available in New Zealand?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Shopify is fully available in NZ and Shopify Payments now works for NZ merchants, accepting NZD credit and debit cards. You can also add AfterPay, Laybuy, and PayPal as additional gateways." } },
        { "@type": "Question", "name": "How much does Shopify cost per month?", "acceptedAnswer": { "@type": "Answer", "text": "Shopify plans start at $49 USD/month (Basic), $132 (Shopify), and $399 (Advanced). This is on top of our design fee and any app subscriptions. For businesses on tight margins or lower volume, WooCommerce may be more cost-effective — we advise honestly." } },
        { "@type": "Question", "name": "Can you migrate my existing store to Shopify?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We handle migrations from WooCommerce, Wix, Squarespace Commerce, and other platforms. Products, customers, and order history can typically be migrated. URL redirects are set up to preserve eCommerce SEO." } },
        { "@type": "Question", "name": "What theme do you use?", "acceptedAnswer": { "@type": "Answer", "text": "We primarily work with high-performance themes like Dawn (Shopify's own), Prestige, or Impulse depending on your brand and product type. We don't use cheap third-party themes with bloated code." } },
        { "@type": "Question", "name": "Can Shopify handle large product catalogues?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Shopify scales extremely well for large catalogues. If you have thousands of SKUs or complex variant structures, Shopify is often a better choice than WooCommerce due to its more reliable inventory management." } },
        { "@type": "Question", "name": "What's the difference between a Shopify build and a Shopify template?", "acceptedAnswer": { "@type": "Answer", "text": "A Shopify template (from their Theme Store) is what everyone gets by default. We customise the theme to match your brand — your fonts, colours, homepage layout, product page structure — so your store looks and functions differently from competitors using the same theme." } }
      ]
    }
  ]
};

const services = [
  {
    icon: "🎨",
    title: "Custom Shopify Theme",
    desc: "We customise a high-performance Shopify theme to match your brand — your colours, fonts, imagery, and product layout — not a generic out-of-the-box look.",
    items: ["Theme customisation", "Brand-matched design", "Mobile-first layout", "Fast-loading storefront"],
  },
  {
    icon: "🛍️",
    title: "Product Setup & Optimisation",
    desc: "We set up your product catalogue with variants, collections, smart filters, and SEO-optimised product descriptions.",
    items: ["Collections & tags", "Product variants", "Metafields", "SEO product titles & descriptions"],
  },
  {
    icon: "💳",
    title: "Shopify Payments & NZ Setup",
    desc: "Shopify Payments now works in NZ — we activate it along with AfterPay, Laybuy, and any other gateways relevant to your audience.",
    items: ["Shopify Payments (NZD)", "AfterPay / Laybuy", "PayPal Express", "Manual payment options"],
  },
  {
    icon: "📦",
    title: "Shipping & Fulfilment",
    desc: "NZ shipping profiles, rural delivery surcharges, free shipping thresholds, and courier integrations to match how you fulfil orders.",
    items: ["NZ shipping profiles", "Rural delivery rules", "Click & collect", "Courier app integrations"],
  },
  {
    icon: "📈",
    title: "Conversion Rate Optimisation",
    desc: "We design product pages, collection pages, and the checkout flow to convert browsers into buyers — every layout decision is tested and intentional.",
    items: ["Trust badges & social proof", "Cart abandonment recovery", "Upsell & cross-sell", "CRO-focused layouts"],
  },
  {
    icon: "🔗",
    title: "App Integrations & Automation",
    desc: "Connect your Shopify store to Klaviyo, Mailchimp, Xero, loyalty apps, review platforms, and more through the Shopify App Store.",
    items: ["Klaviyo email flows", "Xero accounting sync", "Loyalty & rewards", "Review apps (Okendo, Yotpo)"],
  },
];

const shopifyStrengths = [
  { icon: "⚡", title: "Easiest to manage day-to-day", desc: "Adding products, processing orders, and running discounts is intuitive. No technical knowledge needed." },
  { icon: "📱", title: "Excellent mobile app", desc: "Manage your entire store from your phone — view orders, update products, process refunds on the go." },
  { icon: "🌐", title: "Multi-channel selling", desc: "Sell on Instagram, Facebook, TikTok Shop, Google Shopping, and Amazon from one dashboard." },
  { icon: "🔒", title: "Hosted & maintained by Shopify", desc: "No server management, no updates to worry about. Shopify handles platform security and uptime." },
];

const process = [
  { step: "1", title: "Discovery & Strategy", desc: "We understand your products, brand, and target customer. We recommend the right theme and plan the store structure together." },
  { step: "2", title: "Design & Customise", desc: "We customise your chosen theme — homepage, collection pages, product pages, and cart — to match your brand and optimise for conversion." },
  { step: "3", title: "Products, Payments & Shipping", desc: "We populate your catalogue, configure Shopify Payments and BNPL options, set up NZ shipping profiles, and test the full checkout flow." },
  { step: "4", title: "Launch & Train", desc: "We connect your domain, set up Analytics, and walk you through the Shopify admin so you can manage everything confidently from day one." },
];

const faqs = [
  { q: "Is Shopify available in New Zealand?", a: "Yes. Shopify is fully available in NZ and Shopify Payments (their built-in payment gateway) now works for NZ merchants, accepting NZD credit and debit cards. You can also add AfterPay, Laybuy, and PayPal as additional gateways. See our <a href=\"/ecommerce-website-auckland/\">eCommerce overview</a> to compare all platform options." },
  { q: "How much does Shopify cost per month?", a: "Shopify plans start at $49 USD/month (Basic), $132 (Shopify), and $399 (Advanced). This is on top of our design fee and any app subscriptions. For businesses on tight margins or lower volume, <a href=\"/woocommerce-website-design-auckland/\">WooCommerce</a> may be more cost-effective — we'll advise honestly." },
  { q: "Can you migrate my existing store to Shopify?", a: "Yes. We handle migrations from WooCommerce, Wix, Squarespace Commerce, and other platforms. Products, customers, and order history can typically be migrated. URL redirects are set up to preserve <a href=\"/seo-for-ecommerce/\">eCommerce SEO</a>." },
  { q: "What theme do you use?", a: "We primarily work with high-performance themes like Dawn (Shopify's own), Prestige, or Impulse depending on your brand and product type. We don't use cheap third-party themes with bloated code." },
  { q: "Can Shopify handle large product catalogues?", a: "Yes. Shopify scales extremely well for large catalogues. If you have thousands of SKUs or complex variant structures, Shopify is often a better choice than WooCommerce due to its more reliable inventory management. Pair it with <a href=\"/google-ads/\">Google Ads</a> to drive immediate traffic on launch." },
  { q: "What's the difference between a Shopify build and a Shopify template?", a: "A Shopify template (from their Theme Store) is what everyone gets by default. We customise the theme to match your brand — your fonts, colours, homepage layout, product page structure — so your store looks and functions differently from competitors using the same theme." },
];
---

<Layout
  title="Shopify Website Design Auckland | High-Converting Shopify Stores"
  description="Kiwi Web Design builds beautiful, high-converting Shopify websites for Auckland businesses. Local team, fast turnaround."
  canonicalURL="https://www.kiwiwebdesign.co.nz/shopify-website-design-auckland/"
  schema={schema}
>

  <PageHero
    eyebrow="Shopify Website Design Auckland"
    title="Shopify stores designed to convert — not just to look good."
    subtitle="Custom Shopify design for Auckland businesses. We customise high-performance themes, configure NZ payments, set up shipping, and train you to manage it all yourself."
    badgeText="From $3,890 + GST"
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "Compare Platforms", href: "/ecommerce-website-auckland/" }}
    imgSrc={heroImg.src}
    imgAlt="Shopify website design Auckland"
  />

  <!-- AI citability snippet -->
  <div class="shopify-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> builds custom Shopify stores for Auckland and NZ businesses from <strong>$3,890 + GST</strong>. Every build includes NZ payment setup (Shopify Payments, AfterPay, Laybuy), NZ shipping profiles, and full training. Delivered in 2–4 weeks. 4.9★ Google rating from 50+ clients.</p>
    </div>
  </div>

  <!-- Why Shopify -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="Why Shopify"
        title="Where Shopify genuinely excels."
        subtitle="Shopify isn't the right choice for everyone — but when it is, it's excellent. Here's what it does best."
      />
      <div class="shopify-strengths">
        {shopifyStrengths.map(({ icon, title, desc }) => (
          <div class="shopify-strength">
            <span class="ss-icon">{icon}</span>
            <h3 class="ss-title">{title}</h3>
            <p class="ss-desc">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="What We Build"
        title="Complete Shopify store setup."
        subtitle="From theme customisation to checkout — every element built for your brand and your customers."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- Shopify vs WooCommerce -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="Honest Comparison"
        title="Shopify or WooCommerce — which is right for you?"
        light={true}
        subtitle="We build both. Here's our honest take on which suits which type of business."
      />
      <div class="shopify-compare-grid">
        <div class="shopify-compare-col shopify-compare-col--shopify">
          <h3>Choose Shopify if...</h3>
          <ul>
            <li>You want the easiest day-to-day management</li>
            <li>You're selling primarily on social / multi-channel</li>
            <li>You have a large, fast-growing product catalogue</li>
            <li>You want a mobile app to manage orders on the go</li>
            <li>You don't need deep content / blogging capability</li>
          </ul>
        </div>
        <div class="shopify-compare-col shopify-compare-col--woo">
          <h3>Choose WooCommerce if...</h3>
          <ul>
            <li>You want zero monthly platform fees</li>
            <li>You need content marketing alongside your store</li>
            <li>You want complete design and technical control</li>
            <li>You need NZ-specific payment gateways (POLi, etc.)</li>
            <li>You're integrating with NZ-specific tools (Xero, etc.)</li>
          </ul>
        </div>
      </div>
      <p class="shopify-compare-note">Still unsure? <a href="/website-designer-auckland/">Book a free consultation</a> — we'll recommend the right option for your specific situation.</p>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="From brief to launch in 2–4 weeks."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Shopify Questions Answered"
        subtitle="Common questions from Auckland businesses about Shopify."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/ecommerce-website-auckland/" class="rps-link">eCommerce Hub</a>
        <a href="/woocommerce-website-design-auckland/" class="rps-link">WooCommerce</a>
        <a href="/seo-for-ecommerce/" class="rps-link">eCommerce SEO</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to launch your Shopify store?"
    subtitle="Free consultation — we'll recommend the right platform and give you a fixed quote."
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See WooCommerce Instead", href: "/woocommerce-website-design-auckland/" }}
  />

</Layout>

<style>
  .shopify-snippet { background: #fff8e1; border-left: 4px solid var(--kwd-yellow); padding: 1rem 0; }
  .shopify-snippet p { margin: 0; font-size: 0.95rem; line-height: 1.65; color: var(--kwd-dark); }

  .shopify-strengths {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .shopify-strength {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 14px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ss-icon { font-size: 1.75rem; }
  .ss-title { font-family: var(--kwd-font-body); font-size: 0.95rem; font-weight: 700; color: var(--kwd-dark); margin: 0; }
  .ss-desc { font-size: 0.83rem; color: var(--kwd-brown); line-height: 1.6; margin: 0; }

  .shopify-compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .shopify-compare-col {
    border-radius: 16px;
    padding: 2rem;
    border: 1px solid rgba(255,255,255,0.12);
  }
  .shopify-compare-col--shopify { background: rgba(255,255,255,0.06); }
  .shopify-compare-col--woo { background: rgba(251,232,166,0.08); border-color: rgba(251,232,166,0.2); }
  .shopify-compare-col h3 {
    font-family: var(--kwd-font-body);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 1rem;
  }
  .shopify-compare-col--woo h3 { color: var(--kwd-yellow); }
  .shopify-compare-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .shopify-compare-col li {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.72);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }
  .shopify-compare-col li::before { content: "✓"; position: absolute; left: 0; color: var(--kwd-yellow); font-weight: 700; }
  .shopify-compare-note {
    text-align: center;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.5);
    margin-top: 2rem;
  }
  .shopify-compare-note a { color: var(--kwd-yellow); font-weight: 600; }

  @media (max-width: 900px) {
    .shopify-strengths { grid-template-columns: repeat(2, 1fr); }
    .shopify-compare-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 580px) {
    .shopify-strengths { grid-template-columns: 1fr; }
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
