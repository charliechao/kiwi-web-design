    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }
  .criteria-label {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.4);
    font-weight: 600;
    text-transform: uppercase;
