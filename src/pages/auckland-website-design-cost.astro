const faqs = [
  {
    q: "How much does a small business website cost in Auckland?",
    a: "Most small business websites in Auckland cost between NZD $1,500 and $4,000. The final price depends on the number of pages, whether you need custom design, and how much content needs to be created."
  },
  {
    q: "How much does an ecommerce website cost?",
