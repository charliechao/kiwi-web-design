---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';

const stats = [
  { fig: "3x", label: "More booking enquiries" },
  { fig: "92%", label: "Mobile-ready score" },
  { fig: "6x", label: "Organic traffic increase" },
];

const deliverables = [
  "Service pages per inspection type",
  "Inspection booking enquiry form",
  "Trust signal section (credentials, reviews)",
  "Mobile-first responsive build",
  "Google Business Profile update",
  "LocalBusiness schema markup",
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/inspector-guys-building-inspections-website/",
      "url": "https://www.kiwiwebdesign.co.nz/inspector-guys-building-inspections-website/",
      "name": "Inspector Guys Building Inspections — Website Case Study | Kiwi Web Design",
      "description": "How Kiwi Web Design rebuilt Inspector Guys' website to generate 3x more booking enquiries with clearer service pages, trust signals, and a mobile-first design.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/inspector-guys-building-inspections-website/#breadcrumb" }
    },
    {
      "@type": "CreativeWork",
      "@id": "https://www.kiwiwebdesign.co.nz/inspector-guys-building-inspections-website/#case-study",
      "name": "Case Study: Inspector Guys Building Inspections",
      "description": "How Kiwi Web Design helped Inspector Guys triple booking enquiries with a rebuilt website focused on trust, service clarity, and mobile usability.",
      "url": "https://www.kiwiwebdesign.co.nz/inspector-guys-building-inspections-website/",
      "creator": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "about": { "@type": "LocalBusiness", "name": "Inspector Guys Building Inspections", "address": { "@type": "PostalAddress", "addressLocality": "Auckland", "addressCountry": "NZ" } },
      "genre": "Case Study",
      "keywords": "building inspection website Auckland, home inspector website design, pre-purchase inspection"
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/inspector-guys-building-inspections-website/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Inspector Guys Building Inspections" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz"
    }
  ]
};
---

<Layout
  title="Inspector Guys Building Inspections — Website Case Study | Kiwi Web Design"
  description="How Kiwi Web Design rebuilt Inspector Guys' website to generate 3x more booking enquiries with clearer service pages, trust signals, and a mobile-first design."
  canonicalURL="https://www.kiwiwebdesign.co.nz/inspector-guys-building-inspections-website/"
  schema={schema}
>

  <!-- Hero -->
  <section class="cs-hero">
    <div class="container">
      <div class="cs-hero-inner">
        <div class="cs-hero-text">
          <div class="cs-tags">
            <span class="cs-tag">Case Study</span>
            <span class="cs-industry">Building Inspections</span>
          </div>
          <h1>Inspector Guys — 3x More Booking Enquiries</h1>
          <p>A trusted Auckland building inspector with a website that wasn't communicating that trust. We rebuilt it around pre-purchase buyer anxiety — bookings tripled and organic traffic increased sixfold.</p>
        </div>
        <div class="cs-hero-img">
          <img
            src="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/06/Auckland_Building_Inspector-e1750284793590.jpg"
            alt="Inspector Guys Building Inspections website by Kiwi Web Design Auckland"
            width="700"
            height="500"
            loading="eager"
          />
        </div>
      </div>
    </div>
    <div class="cs-stat-strip">
      <div class="container cs-stat-grid">
        {stats.map(s => (
          <div class="cs-stat-item">
            <span class="cs-stat-fig">{s.fig}</span>
            <span class="cs-stat-lbl">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <div class="cs-overview">
        <div class="cs-client-card">
          <div class="cs-client-row">
            <span class="cs-client-label">Client</span>
            <span class="cs-client-value">Inspector Guys</span>
          </div>
          <div class="cs-client-row">
            <span class="cs-client-label">Industry</span>
            <span class="cs-client-value">Building Inspections</span>
          </div>
          <div class="cs-client-row">
            <span class="cs-client-label">Location</span>
            <span class="cs-client-value">Auckland, New Zealand</span>
          </div>
          <div class="cs-client-row">
            <span class="cs-client-label">Project Type</span>
            <span class="cs-client-value">Website Rebuild + Lead Gen</span>
          </div>
          <div class="cs-client-row">
            <span class="cs-client-label">Results</span>
            <span class="cs-client-value">3x booking enquiries</span>
          </div>
        </div>
        <div class="cs-overview-body">
          <p class="cs-sub-eyebrow">Project Overview</p>
          <h2>An Auckland building inspector trusted by buyers — with a website that didn't show it.</h2>
          <p>Inspector Guys is an Auckland-based building and home inspection service led by Andy, specialising in pre-purchase reports, roof and moisture assessments, and practical advice for Kiwis making property decisions. The business had strong word-of-mouth and a growing client base.</p>
          <p>The previous site had helpful information — but it felt dated, didn't guide visitors clearly toward booking, and didn't present the credentials and experience that property buyers want to see before trusting someone with a five- or six-figure purchase decision.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Challenge -->
  <section class="section">
    <div class="container cs-content-narrow">
      <p class="cs-sub-eyebrow">The Challenge</p>
      <h2 class="cs-section-h2">Pre-purchase buyers need to trust you before they book — the old site didn't build that trust.</h2>
      <p class="cs-section-p">Someone booking a building inspection is about to spend $400–700 to protect themselves on a property purchase worth hundreds of thousands. They research inspectors carefully. They look for qualifications, insurance, sample reports, and real reviews. If your website doesn't communicate those signals clearly, they move on to someone whose website does.</p>
      <p class="cs-section-p">The old Inspector Guys site had the credibility — it just wasn't visible. Services were described generically, credentials were buried, and the mobile experience was inconsistent. The booking process was a basic contact form with no structure — no service type, no property address, no urgency indicator.</p>
    </div>
  </section>

  <!-- Solution -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container cs-content-narrow">
      <p class="cs-sub-eyebrow">What We Built</p>
      <h2 class="cs-section-h2">A trust-first website built for property buyers under pressure.</h2>
      <p class="cs-section-p">We structured the site around the buyer's journey: what types of inspection are available, what's included in each, how quickly reports are delivered, and what credentials Andy holds. Each service page ends with a structured booking enquiry form — property address, inspection type, and preferred timeframe — so enquiries arrive with the information needed to respond and schedule immediately.</p>
      <p class="cs-section-p">A dedicated trust section displays qualifications, insurance details, and real Google reviews with schema markup. The mobile score went from inconsistent to 92%. LocalBusiness and ProfessionalService schema markup was added to improve local search visibility.</p>
      <div class="cs-deliverables">
        {deliverables.map(d => <span class="cs-chip">{d}</span>)}
      </div>
    </div>
  </section>

  <!-- Screenshot -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <div class="cs-screenshot-wrap">
        <img
          src="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/06/Auckland_Building_Inspector-e1750284793590.jpg"
          alt="Inspector Guys Building Inspections website design by Kiwi Web Design"
          width="1200"
          height="700"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Results -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <p class="cs-sub-eyebrow cs-sub-eyebrow-light">The Results</p>
      <h2 class="cs-section-h2 cs-section-h2-light">Booking enquiries tripled — from a clearer, faster website.</h2>
      <p class="cs-section-p cs-section-p-light">The rebuilt site immediately improved conversion from visitor to enquiry. Organic traffic increased sixfold as the service pages began ranking for pre-purchase inspection searches across Auckland suburbs. The structured booking form reduced back-and-forth — Andy could respond to enquiries with a quote and availability without needing a follow-up call to get basic details.</p>
      <div class="cs-results-grid">
        {stats.map(s => (
          <div class="cs-result-card">
            <div class="cs-result-fig">{s.fig}</div>
            <div class="cs-result-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="section">
    <div class="container">
      <div class="cs-testimonial-wrap">
        <blockquote>"The new site feels professional and is much easier for customers to use. Calls and enquiries are simpler than ever — great job team."</blockquote>
        <p class="cs-testimonial-author">— Andy, Inspector Guys Auckland</p>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Need a website that converts property buyers into bookings?"
    subtitle="Free consultation — we'll show you exactly what's stopping your current site from working harder."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "See More Case Studies", href: "/testimonials-reviews/" }}
  />

</Layout>

<style>
  .cs-hero { background: var(--kwd-dark); padding: 5rem 0 0; }
  .cs-hero-inner { display: grid; grid-template-columns: 55% 45%; gap: 3rem; align-items: center; padding-bottom: 3rem; }
  .cs-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
  .cs-tag { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 0.3rem 0.85rem; border-radius: 999px; background: var(--kwd-yellow); color: var(--kwd-dark); }
  .cs-industry { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; padding: 0.3rem 0.85rem; border-radius: 999px; background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.75); }
  .cs-hero-text h1 { font-family: var(--kwd-font-heading); font-size: clamp(2rem, 4vw, 3rem); color: #fff; line-height: 1.15; margin-bottom: 1rem; }
  .cs-hero-text p { font-size: 1rem; color: rgba(255,255,255,0.7); line-height: 1.7; }
  .cs-hero-img img { width: 100%; height: 400px; object-fit: cover; border-radius: 12px; display: block; box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
  .cs-stat-strip { border-top: 1px solid rgba(255,255,255,0.1); }
  .cs-stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); }
  .cs-stat-item { padding: 1.5rem 2rem; border-right: 1px solid rgba(255,255,255,0.1); display: flex; flex-direction: column; gap: 0.25rem; }
  .cs-stat-item:last-child { border-right: none; }
  .cs-stat-fig { font-family: var(--kwd-font-heading); font-size: 2.25rem; color: var(--kwd-yellow); line-height: 1; }
  .cs-stat-lbl { font-size: 0.8rem; color: rgba(255,255,255,0.55); line-height: 1.4; }
  .cs-overview { display: grid; grid-template-columns: 260px 1fr; gap: 3.5rem; align-items: start; }
  .cs-client-card { background: #fff; border: 1.5px solid rgba(0,0,0,0.07); border-radius: 14px; padding: 1.75rem; }
  .cs-client-row { margin-bottom: 1rem; }
  .cs-client-row:last-child { margin-bottom: 0; }
  .cs-client-label { display: block; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.2rem; }
  .cs-client-value { font-size: 0.9rem; color: var(--kwd-dark); font-weight: 600; line-height: 1.4; }
  .cs-sub-eyebrow { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--kwd-brown); margin-bottom: 0.75rem; }
  .cs-sub-eyebrow-light { color: var(--kwd-yellow); }
  .cs-overview-body h2 { font-family: var(--kwd-font-heading); font-size: clamp(1.5rem, 2.5vw, 2rem); color: var(--kwd-dark); line-height: 1.2; margin-bottom: 0.75rem; }
  .cs-overview-body p { font-size: 0.9375rem; color: var(--kwd-brown); line-height: 1.75; margin-bottom: 0.75rem; }
  .cs-section-h2 { font-family: var(--kwd-font-heading); font-size: clamp(1.5rem, 2.5vw, 2rem); color: var(--kwd-dark); line-height: 1.2; margin-bottom: 0.75rem; }
  .cs-section-h2-light { color: #fff; }
  .cs-section-p { font-size: 0.9375rem; color: var(--kwd-brown); line-height: 1.75; margin-bottom: 0.75rem; }
  .cs-section-p-light { color: rgba(255,255,255,0.7); }
  .cs-content-narrow { max-width: 760px; }
  .cs-deliverables { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.5rem; }
  .cs-chip { font-size: 0.8rem; font-weight: 600; padding: 0.4rem 1rem; border-radius: 999px; background: var(--kwd-dark); color: #fff; }
  .cs-results-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-top: 2.5rem; }
  .cs-result-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 2rem 1.5rem; text-align: center; }
  .cs-result-fig { font-family: var(--kwd-font-heading); font-size: 2.75rem; color: var(--kwd-yellow); line-height: 1; margin-bottom: 0.5rem; }
  .cs-result-label { font-size: 0.875rem; color: rgba(255,255,255,0.65); line-height: 1.5; }
  .cs-screenshot-wrap { margin-top: 2rem; }
  .cs-screenshot-wrap img { width: 100%; border-radius: 12px; border: 1.5px solid rgba(0,0,0,0.07); display: block; box-shadow: 0 8px 32px rgba(0,0,0,0.1); }
  .cs-testimonial-wrap { max-width: 760px; margin: 0 auto; text-align: center; }
  .cs-testimonial-wrap blockquote { font-family: var(--kwd-font-heading); font-size: clamp(1.2rem, 2.5vw, 1.625rem); color: var(--kwd-dark); line-height: 1.4; font-style: italic; margin: 0 0 1.5rem; }
  .cs-testimonial-author { font-size: 0.875rem; font-weight: 600; color: var(--kwd-brown); }
  @media (max-width: 900px) {
    .cs-hero-inner { grid-template-columns: 1fr; }
    .cs-hero-img { display: none; }
    .cs-overview { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .cs-stat-grid { grid-template-columns: repeat(2, 1fr); }
    .cs-stat-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .cs-stat-item:last-child { border-bottom: none; }
  }
</style>
