---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/email-setup-business-email-hosting/",
      "url": "https://www.kiwiwebdesign.co.nz/email-setup-business-email-hosting/",
      "name": "Business Email Setup & Hosting Auckland | Microsoft 365 & Google Workspace",
      "description": "Professional business email setup for Auckland businesses. We configure Microsoft 365 or Google Workspace, DNS records, and all devices — done right the first time.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/email-setup-business-email-hosting/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/email-setup-business-email-hosting/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Business Email Setup & Hosting" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const services = [
  {
    icon: "💼",
    title: "Microsoft 365 Setup",
    desc: "Microsoft 365 Business configured end to end — accounts, domain verification, DNS records, and Outlook on every device. Includes Word, Excel, and Teams.",
    items: ["Account creation", "Domain verification", "DNS record configuration", "Outlook on all devices"],
  },
  {
    icon: "🔵",
    title: "Google Workspace Setup",
    desc: "Google Workspace configured — Gmail with your domain, Drive, Calendar, and Meet. We handle domain verification and DNS so everything works from day one.",
    items: ["Gmail with custom domain", "Drive & Calendar", "DNS configuration", "Multi-device setup"],
  },
  {
    icon: "⚙️",
    title: "DNS Configuration",
    desc: "Email DNS is easy to get wrong. We configure MX, SPF, DKIM, and DMARC records correctly — which means your emails land in the inbox, not the spam folder.",
    items: ["MX records", "SPF configuration", "DKIM setup", "DMARC policy"],
  },
  {
    icon: "📱",
    title: "Device Setup",
    desc: "We configure email on your phone, tablet, and desktop — iOS, Android, Windows, or Mac. You won't need to figure out server settings or app configurations.",
    items: ["Phone setup (iOS & Android)", "Desktop client setup", "Tablet configuration", "Sync verification"],
  },
  {
    icon: "↔️",
    title: "Email Migration",
    desc: "Moving from an old email system or shared hosting email to Microsoft 365 or Google Workspace? We migrate your existing emails across so nothing is lost.",
    items: ["Full mailbox migration", "Contact import", "Calendar migration", "Zero downtime transfer"],
  },
  {
    icon: "👥",
    title: "Team Email Setup",
    desc: "Multiple team members, shared mailboxes, group addresses like info@ or sales@ — we configure your email structure to suit how your business actually works.",
    items: ["Multiple user accounts", "Shared mailboxes", "Group/alias addresses", "Admin access setup"],
  },
];

const faqs = [
  { q: "What's wrong with using Gmail or a free email account?", a: "A gmail.com or yahoo.com address looks unprofessional — especially in B2B and trade environments where clients are choosing between providers. A professional email address (you@yourbusiness.co.nz) builds credibility and trust. It also gives you more control: if a team member leaves, you own the account, not them." },
  { q: "Microsoft 365 or Google Workspace — which should I choose?", a: "Both are excellent. Microsoft 365 suits businesses that already use Office apps (Word, Excel, PowerPoint) heavily or work in environments where Word documents are the standard. Google Workspace suits businesses that prefer browser-based tools, use Chrome, and want seamless integration with Google Analytics, Search Console, and Ads. We can advise based on how you work." },
  { q: "Why do my emails sometimes go to spam?", a: "Usually because your domain's DNS isn't correctly configured — specifically SPF, DKIM, or DMARC records are missing or wrong. These records tell receiving mail servers that your email is legitimate. We fix this as part of any email setup." },
  { q: "Can you migrate my existing emails from my old system?", a: "Yes. We migrate full mailbox contents — emails, contacts, calendar events — from most providers. The migration is done in a way that keeps your existing email accessible throughout the process." },
  { q: "Can you set up email if you didn't build my website?", a: "Yes. Email setup is independent of who built your website. We just need access to your domain's DNS settings to configure the required records. This is usually done through your domain registrar's control panel." },
];
---

<Layout
  title="Business Email Setup & Hosting Auckland | Microsoft 365 & Google Workspace"
  description="Professional business email setup for Auckland businesses. We configure Microsoft 365 or Google Workspace, DNS records, and all devices — done right the first time."
  canonicalURL="https://www.kiwiwebdesign.co.nz/email-setup-business-email-hosting/"
  schema={schema}
>

  <PageHero
    eyebrow="Business Email Setup"
    title="Professional email on your own domain — set up properly."
    subtitle="Microsoft 365 and Google Workspace setup for Auckland businesses. We configure everything — accounts, DNS, devices — so your business email works reliably from day one."
    imgSrc="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/11/email-setup-business-email-hosting-auckland.png"
    imgAlt="Business email setup and hosting for Auckland small businesses"
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View All Services", href: "/small-business-website-design-auckland/" }}
  />

  <!-- Services -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="What We Set Up"
        title="Everything from accounts to devices — handled."
        subtitle="A complete business email setup means more than just creating an account. Here's what we configure."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- Why it matters -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <SectionHeader
        eyebrow="Why It Matters"
        title="Your email address is your first impression."
        align="left"
      />
      <div class="email-body">
        <p>Using a Gmail, Hotmail, or ISP email address for your business immediately signals that you're not fully established. A professional email address — name@yourbusiness.co.nz — builds credibility from the first contact and keeps all your business communications under your control.</p>
        <p>Beyond the address itself, incorrect DNS configuration causes deliverability problems: emails land in spam folders, Microsoft and Google block outbound messages, or email simply doesn't arrive. We configure SPF, DKIM, and DMARC records correctly so your emails reach their destination.</p>
        <p>We handle the setup from start to finish — choosing the right platform, creating accounts, configuring DNS, and getting everything working on your phone and desktop. You won't need to touch a server settings page.</p>
        <ul class="email-checklist">
          <li>Works for sole traders through to multi-person teams</li>
          <li>Microsoft 365 or Google Workspace — your choice</li>
          <li>Configured on all your devices</li>
          <li>Can bundle with website build or domain management</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Business Email Questions"
        subtitle="Common questions from Auckland business owners about professional email setup."
      />
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready for a professional email address?"
    subtitle="Free consultation — we'll recommend the right platform and handle the whole setup for you."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View All Services", href: "/small-business-website-design-auckland/" }}
  />

</Layout>

<style>
  .email-body p {
    font-size: 0.9375rem;
    color: var(--kwd-brown);
    line-height: 1.75;
    margin-bottom: 0.9rem;
  }
  .email-checklist {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .email-checklist li {
    font-size: 0.9rem;
    color: var(--kwd-dark);
    font-weight: 600;
    padding-left: 1.5rem;
    position: relative;
  }
  .email-checklist li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--kwd-brown);
    font-weight: 700;
  }
</style>
