---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import StatsRow from '../components/StatsRow.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import TestimonialGrid from '../components/TestimonialGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import heroImg from '../assets/general/pexels-photo-4348404-4348404-scaled-1.jpg';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/wordpress-website-design-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/wordpress-website-design-auckland/",
      "name": "WordPress Website Design Auckland | Fast, Modern WordPress Sites",
      "description": "Kiwi Web Design builds fast, modern, and affordable WordPress websites for Auckland small businesses. From $1,290 + GST. Delivered in 2–3 weeks. You own it outright.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/wordpress-website-design-auckland/#breadcrumb" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": [".wp-snippet", "h1"] }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/wordpress-website-design-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "WordPress Website Design Auckland", "item": "https://www.kiwiwebdesign.co.nz/wordpress-website-design-auckland/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "Place", "name": "Auckland" },
        { "@type": "Place", "name": "New Zealand" }
      ],
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "ratingCount": "50", "bestRating": "5" },
      "logo": { "@type": "ImageObject", "url": "https://www.kiwiwebdesign.co.nz/favicon.png", "width": 512, "height": 512 }
    },
    {
      "@type": "Service",
      "@id": "https://www.kiwiwebdesign.co.nz/wordpress-website-design-auckland/#service",
      "name": "WordPress Website Design Auckland",
      "serviceType": "WordPress Website Design",
      "category": "Web Design",
      "provider": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "areaServed": [
        { "@type": "Place", "name": "Auckland" },
        { "@type": "Place", "name": "New Zealand" }
      ],
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "1290",
        "highPrice": "3890",
        "priceCurrency": "NZD",
        "priceSpecification": { "@type": "PriceSpecification", "valueAddedTaxIncluded": false }
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Why WordPress instead of Wix or Squarespace?", "acceptedAnswer": { "@type": "Answer", "text": "WordPress gives you complete ownership and control. You can move hosts, change agencies, and fully export your data. Wix and Squarespace are proprietary platforms, if they change pricing or shut down, you lose everything. WordPress also has far superior SEO capabilities and can grow into complex functionality (online bookings, eCommerce via WooCommerce, memberships) as your business scales." } },
        { "@type": "Question", "name": "Is WordPress hard to use?", "acceptedAnswer": { "@type": "Answer", "text": "Modern WordPress (with the block editor) is very easy to update. We include a structured handover session so you can update text, images, and add simple pages without any technical knowledge. For anything more complex, we are available to help." } },
        { "@type": "Question", "name": "Do I need to worry about WordPress security?", "acceptedAnswer": { "@type": "Answer", "text": "WordPress security is manageable with the right setup, and we handle all of it for you. We configure security plugins, limit login attempts, keep everything updated, and recommend our WordPress maintenance plan to keep things secure ongoing. The vast majority of WordPress hacks target outdated, unmanaged sites." } },
        { "@type": "Question", "name": "What theme do you build on?", "acceptedAnswer": { "@type": "Answer", "text": "We primarily build on lightweight, performance-focused foundations like GeneratePress or a custom theme. We avoid heavy page-builder themes (like Divi or Elementor) that slow down load times and create technical debt. Performance and maintainability are our priorities." } },
        { "@type": "Question", "name": "Can you migrate my existing website to WordPress?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We handle full WordPress website rebuilds and migrations from Wix, Squarespace, Weebly, or older WordPress installations. We preserve your content, redirects, and SEO during the process." } },
        { "@type": "Question", "name": "What does a WordPress website cost in Auckland?", "acceptedAnswer": { "@type": "Answer", "text": "WordPress packages start from $1,290 + GST. Growth packages run $2,690–$3,500, and eCommerce sites start from $3,890. We give you a fixed quote upfront, no surprises." } }
      ]
    }
  ]
};

const wpStats = [
  { number: "43%", label: "of all websites worldwide run on WordPress" },
  { number: "2–3 wks", label: "typical build and delivery time" },
  { number: "100%", label: "client ownership, your site, your data" },
  { number: "From $1,290", label: "WordPress website packages" },
];

const wpAdvantages = [
  {
    icon: "🧩",
    title: "You Own It Completely",
    desc: "Unlike Wix or Squarespace, WordPress gives you full ownership of your website and data. You can move hosts, change agencies, or manage it yourself, no lock-in.",
    items: ["Portable to any host", "Full data export", "No platform fees", "Works with any developer"],
  },
  {
    icon: "⚡",
    title: "Fast & SEO-Optimised",
    desc: "We build WordPress sites with performance in mind, caching, image compression, minimal plugins, and proper heading structure for better Google rankings.",
    items: ["Sub-2 second load times", "Google Core Web Vitals", "SEO plugin setup (Yoast)", "Schema markup"],
  },
  {
    icon: "✏️",
    title: "Easy to Update Yourself",
    desc: "WordPress's block editor (Gutenberg) means updating your own content is as simple as editing a Google Doc. No developer needed for text and image changes.",
    items: ["Visual block editor", "No coding required", "Add pages & posts yourself", "Included training session"],
  },
  {
    icon: "🔌",
    title: "Powerful Plugin Ecosystem",
    desc: "55,000+ plugins extend WordPress's functionality. Bookings, e-commerce, memberships, forms, live chat, almost anything your business needs already exists.",
    items: ["Booking systems", "WooCommerce eCommerce", "Membership / gating", "CRM integrations"],
  },
  {
    icon: "📱",
    title: "Fully Mobile Responsive",
    desc: "Every WordPress site we build is tested across devices. Mobile-first design ensures your site looks and performs perfectly on phones, tablets, and desktops.",
    items: ["Mobile-first layouts", "Touch-friendly navigation", "Fast mobile load", "Cross-device tested"],
  },
  {
    icon: "🔒",
    title: "Secure by Default",
    desc: "We implement WordPress security best practices from day one, hardened configuration, security plugins, SSL, and regular update schedules.",
    items: ["SSL certificate", "Login protection", "Security plugin setup", "Regular updates schedule"],
  },
];

const wpServices = [
  {
    icon: "🎨",
    title: "Custom WordPress Design",
    desc: "Brand-matched custom themes, not off-the-shelf templates. Your site looks unique and reflects your business.",
    items: ["Custom theme development", "Brand integration", "UX/UI strategy", "Mobile-first build"],
  },
  {
    icon: "🛒",
    title: "WooCommerce Stores",
    desc: "Full eCommerce setup on WordPress. Product management, payment gateways, shipping rules, and order notifications.",
    items: ["Product catalogue setup", "Payment gateway integration", "Shipping configuration", "Inventory management"],
  },
  {
    icon: "📋",
    title: "WordPress Rebuilds",
    desc: "Old, slow, or hacked WordPress site? We rebuild it from scratch on modern foundations while preserving your content and SEO.",
    items: ["Content migration", "SEO preservation", "Speed optimisation", "Security hardening"],
  },
  {
    icon: "🔧",
    title: "WordPress Maintenance",
    desc: "Ongoing updates, security monitoring, backups, and support so your site stays fast and secure after launch.",
    items: ["Monthly updates", "Daily backups", "Security monitoring", "Priority support"],
    href: "/wordpress-maintenance-auckland/",
  },
];

const process = [
  { step: "1", title: "Discover & Plan", desc: "We talk through your goals, customers, and content needs. Then we plan the site structure and propose a design direction." },
  { step: "2", title: "Design & Approve", desc: "We design your homepage and key pages in a staging environment. You review and request changes before we build everything out." },
  { step: "3", title: "Build & Test", desc: "We build the full site, set up plugins, configure forms, test on all devices, and optimise for speed." },
  { step: "4", title: "Launch & Train", desc: "We go live, set up Analytics and Search Console, and train you on updating your own content." },
];

const faqs = [
  { q: "Why WordPress instead of Wix or Squarespace?", a: "WordPress gives you complete ownership and control. You can move hosts, change agencies, and fully export your data. Wix and Squarespace are proprietary platforms, if they change pricing or shut down, you lose everything. WordPress also has far superior SEO capabilities and can grow into complex functionality (<a href=\"/booking-appointment-websites-with-wordpress/\">online bookings</a>, <a href=\"/woocommerce-website-design-auckland/\">eCommerce via WooCommerce</a>, <a href=\"/membership-subscription-websites-with-wordpress-auckland/\">memberships</a>) as your business scales." },
  { q: "Is WordPress hard to use?", a: "Modern WordPress (with the block editor) is very easy to update. We include a <a href=\"/website-training-and-handover/\">structured handover session</a> so you can update text, images, and add simple pages without any technical knowledge. For anything more complex, we're available to help." },
  { q: "Do I need to worry about WordPress security?", a: "WordPress security is manageable with the right setup, and we handle all of it for you. We configure security plugins, limit login attempts, keep everything updated, and recommend our <a href=\"/wordpress-maintenance-auckland/\">WordPress maintenance plan</a> to keep things secure ongoing. The vast majority of WordPress hacks target outdated, unmanaged sites." },
  { q: "What theme do you build on?", a: "We primarily build on lightweight, performance-focused foundations like GeneratePress or a custom theme. We avoid heavy page-builder themes (like Divi or Elementor) that slow down load times and create technical debt. Performance and maintainability are our priorities." },
  { q: "Can you migrate my existing website to WordPress?", a: "Yes. We handle full <a href=\"/wordpress-website-rebuilds-auckland/\">WordPress website rebuilds and migrations</a> from Wix, Squarespace, Weebly, or older WordPress installations. We preserve your content, redirects, and SEO during the process." },
  { q: "What does a WordPress website cost in Auckland?", a: "Our <a href=\"/small-business-website-design-auckland/\">WordPress packages start from $1,290 + GST</a>. Growth packages run $2,690–$3,500, and eCommerce sites start from $3,890. We give you a fixed quote upfront, no surprises." },
];

const reviews = [
  { name: "Zane Barrett", company: "Barrett Access Scaffolding", text: "Charlie built our new WordPress site in under 3 weeks. It looks great, runs fast, and I can update it myself now. Best investment we've made online." },
  { name: "Jack", company: "Show Me Shorts", text: "The WordPress site they built for us is clean, fast, and easy to manage. Charlie explained everything at handover and we've had no issues." },
  { name: "Steven Liu", company: "Client", text: "Outstanding experience. The design is clean, modern, and user-friendly, exactly what I was hoping for." },
];
---

<Layout
  title="WordPress Website Design Auckland | Fast, Modern WordPress Sites"
  description="Kiwi Web Design builds fast, modern, and affordable WordPress sites small businesses can easily manage in Auckland."
  canonicalURL="https://www.kiwiwebdesign.co.nz/wordpress-website-design-auckland/"
  schema={schema}
>

  <PageHero
    eyebrow="WordPress Website Design Auckland"
    title="WordPress websites built for performance and growth."
    subtitle="Fast, modern, and fully managed WordPress sites for Auckland small businesses. You own it completely, no lock-in, no platform fees."
    badgeText="From $1,290 + GST"
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Our Process", href: "#process" }}
    imgSrc={heroImg.src}
    imgAlt="WordPress website design Auckland"
  />

  <!-- Stats -->
  <StatsRow items={wpStats} />

  <!-- AI citability snippet -->
  <div class="wp-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> builds WordPress websites for Auckland small businesses from <strong>$1,290 + GST</strong>. Every site includes custom theme design, SEO setup, mobile-first build, and a training handover. Delivered in 2–3 weeks. You own the site outright, no lock-in, no monthly platform fees. 4.9★ Google rating from 50+ Auckland clients.</p>
    </div>
  </div>

  <!-- Why WordPress -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="Why WordPress"
        title="The world's most trusted website platform, for good reason."
        subtitle="43% of all websites run on WordPress. Here's why it's the right choice for your Auckland business."
      />
      <ServiceGrid items={wpAdvantages} cols={3} />
    </div>
  </section>

  <!-- WordPress vs alternatives -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="Platform Comparison"
        title="WordPress vs the alternatives."
        light={true}
        subtitle="Why we recommend WordPress over Wix, Squarespace, and other website builders."
      />
      <div class="wp-compare">
        <div class="wp-compare-table">
          <div class="wp-ct-header">
            <div class="wp-ct-col wp-ct-feature">Feature</div>
            <div class="wp-ct-col wp-ct-good">WordPress</div>
            <div class="wp-ct-col wp-ct-bad">Wix / Squarespace</div>
          </div>
          {[
            ["You own your website", true, false],
            ["Can move to any host", true, false],
            ["No monthly platform fees", true, false],
            ["SEO flexibility", true, "Limited"],
            ["eCommerce (WooCommerce)", true, "Basic only"],
            ["Plugin ecosystem (55,000+)", true, false],
            ["Developer community", true, "Small"],
            ["Scales to enterprise", true, false],
          ].map(([feature, wp, alt]) => (
            <div class="wp-ct-row">
              <div class="wp-ct-col wp-ct-feature">{feature}</div>
              <div class="wp-ct-col wp-ct-good">
                {wp === true ? <span class="wp-tick">✓</span> : <span class="wp-partial">{wp}</span>}
              </div>
              <div class="wp-ct-col wp-ct-bad">
                {alt === false ? <span class="wp-cross">✗</span> : <span class="wp-partial">{alt}</span>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Our WordPress Services"
        title="Everything from builds to ongoing maintenance."
        subtitle="Whether you need a new site, a rebuild, or ongoing care, we cover the full WordPress lifecycle."
      />
      <ServiceGrid items={wpServices} cols={2} />
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);" id="process">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="From brief to live in 2–3 weeks."
        subtitle="A clear, four-step process so you always know what's happening next."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section">
    <div class="container">
      <SectionHeader eyebrow="Client Reviews" title="What Auckland businesses say about our WordPress work." />
      <TestimonialGrid items={reviews} cols={3} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="WordPress Questions Answered"
        subtitle="Common questions from Auckland businesses about building on WordPress."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">WordPress services</p>
      <div class="rps-links">
        <a href="/wordpress-maintenance-auckland/" class="rps-link">WordPress Maintenance</a>
        <a href="/wordpress-website-rebuilds-auckland/" class="rps-link">WordPress Rebuilds</a>
        <a href="/woocommerce-website-design-auckland/" class="rps-link">WooCommerce Design</a>
        <a href="/wordpress-seo-optimisation/" class="rps-link">WordPress SEO</a>
        <a href="/wordpress-plugins-for-small-businesses-in-auckland/" class="rps-link">Plugins Guide</a>
        <a href="/wordpress-themes-for-auckland-small-businesses/" class="rps-link">Themes Guide</a>
        <a href="/wordpress-ai-tools-integration-auckland/" class="rps-link">AI Tools Integration</a>
        <a href="/booking-appointment-websites-with-wordpress/" class="rps-link">Booking &amp; Appointments</a>
        <a href="/landing-pages-funnels-on-wordpress/" class="rps-link">Landing Pages &amp; Funnels</a>
        <a href="/membership-subscription-websites-with-wordpress-auckland/" class="rps-link">Membership Websites</a>
      </div>
    </div>
  </section>

  <!-- Case studies -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Client case studies</p>
      <div class="rps-links">
        <a href="/beauty-touch-case-study/" class="rps-link">Beauty Touch Auckland, live in 3 weeks</a>
        <a href="/case-study-scaffolding/" class="rps-link">Barrett Access Scaffolding, +125% quote requests</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to get a fast, modern WordPress site?"
    subtitle="Free consultation, we'll plan your site structure, recommend the right package, and give you a fixed quote."
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "View Pricing", href: "/small-business-website-design-auckland/#packages" }}
  />

</Layout>

<style>
  .wp-snippet { background: #fff8e1; border-left: 4px solid var(--kwd-yellow); padding: 1rem 0; }
  .wp-snippet p { margin: 0; font-size: 0.95rem; line-height: 1.65; color: var(--kwd-dark); }

  /* Comparison table */
  .wp-compare {
    margin-top: 2.5rem;
    overflow-x: auto;
  }
  .wp-compare-table {
    min-width: 600px;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .wp-ct-header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    background: rgba(255,255,255,0.08);
    padding: 0.875rem 1.25rem;
    gap: 1rem;
  }
  .wp-ct-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    padding: 0.75rem 1.25rem;
    gap: 1rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .wp-ct-row:hover { background: rgba(255,255,255,0.03); }
  .wp-ct-col {
    font-size: 0.875rem;
    display: flex;
    align-items: center;
  }
  .wp-ct-feature { color: rgba(255,255,255,0.8); }
  .wp-ct-good {
    color: var(--kwd-yellow);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .wp-ct-bad {
    color: rgba(255,255,255,0.4);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .wp-tick { font-size: 1.1rem; color: var(--kwd-yellow); }
  .wp-cross { font-size: 1.1rem; color: rgba(255,255,255,0.25); }
  .wp-partial { font-size: 0.82rem; color: rgba(255,255,255,0.45); }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }

  @media (max-width: 700px) {
    .wp-compare-table { min-width: 500px; }
  }
</style>
