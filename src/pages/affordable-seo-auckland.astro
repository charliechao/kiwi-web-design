---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import TestimonialGrid from '../components/TestimonialGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { Image } from 'astro:assets';
import aboutImg from '../assets/general/about.jpg';
import about3Img from '../assets/general/about3.jpg';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/affordable-seo-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/affordable-seo-auckland/",
      "name": "Affordable SEO Auckland | SEO Services from $500/mo | Kiwi Web Design",
      "description": "Affordable SEO Auckland for small businesses. Local SEO, Google Business Profile, technical fixes and content from $500/month. No lock-in. Based in Grey Lynn, Auckland.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/affordable-seo-auckland/#breadcrumb" },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".seo-snippet", ".seo-statbar-inner"]
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/affordable-seo-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Affordable SEO Auckland", "item": "https://www.kiwiwebdesign.co.nz/affordable-seo-auckland/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "City", "name": "Auckland" },
        { "@type": "Country", "name": "New Zealand" }
      ],
      "priceRange": "$$",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "bestRating": "5",
        "ratingCount": "50"
      },
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.kiwiwebdesign.co.nz/favicon.png",
        "width": 512,
        "height": 512
      }
    },
    {
      "@type": "Service",
      "@id": "https://www.kiwiwebdesign.co.nz/affordable-seo-auckland/#service",
      "name": "Affordable SEO Auckland",
      "serviceType": "SEO Agency Services",
      "category": "Digital Marketing",
      "description": "Affordable SEO Auckland services for small businesses. Local SEO, Google Business Profile optimisation, on-page SEO, technical SEO, content, and monthly reporting from $500/month with no lock-in contracts.",
      "provider": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "areaServed": [
        { "@type": "City", "name": "Auckland" },
        { "@type": "Country", "name": "New Zealand" }
      ],
      "url": "https://www.kiwiwebdesign.co.nz/affordable-seo-auckland/",
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "500",
        "highPrice": "2500",
        "priceCurrency": "NZD",
        "priceSpecification": { "@type": "PriceSpecification", "price": "500", "priceCurrency": "NZD", "unitCode": "MON" }
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What does affordable SEO actually mean in Auckland?",
          "acceptedAnswer": { "@type": "Answer", "text": "Affordable SEO in Auckland means getting the work that actually moves rankings — local SEO, Google Business Profile, on-page optimisation, technical fixes, and reporting — without the big-agency overhead of account managers, pitch decks, and bloated retainers. At Kiwi Web Design, affordable SEO starts from $500/month with no lock-in contracts." }
        },
        {
          "@type": "Question",
          "name": "How much should a small business pay for SEO in Auckland?",
          "acceptedAnswer": { "@type": "Answer", "text": "Most small Auckland businesses spend $500–$1,500/month on SEO to get meaningful results. Less than $500/month typically means the work is too light to move rankings in competitive niches. More than $2,000/month is usually justified for high-competition industries like legal, finance, or medical. Every engagement starts with a free audit so we can quote based on your actual situation." }
        },
        {
          "@type": "Question",
          "name": "Can I get real SEO results on a $500/month budget in Auckland?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes — in less competitive niches and suburban markets, $500/month is enough to establish strong Google visibility. We focus that budget on the highest-impact activities: Google Business Profile optimisation, local citations, and on-page fixes for your top 5 pages. As results build, many clients scale up to Growth SEO at $1,000/month." }
        },
        {
          "@type": "Question",
          "name": "What's the difference between cheap SEO and affordable SEO?",
          "acceptedAnswer": { "@type": "Answer", "text": "Cheap SEO uses shortcuts — spam links, keyword stuffing, and overseas content farms — that can get your site penalised. Affordable SEO delivers the same legitimate work as expensive agencies (local citations, GBP optimisation, technical fixes, real content) at a lower cost because there's no big-agency overhead. Kiwi Web Design keeps overheads low by working directly with clients — no account managers, no middlemen." }
        },
        {
          "@type": "Question",
          "name": "How long before affordable SEO starts showing results in Auckland?",
          "acceptedAnswer": { "@type": "Answer", "text": "Most Auckland businesses see early movement within 2–3 months, with meaningful results over 6–12 months. SEO compounds over time — the work done in month one builds on itself. Starting with Google Business Profile optimisation often shows quicker wins (4–8 weeks) in local search results." }
        },
        {
          "@type": "Question",
          "name": "Do I need SEO if I'm already running Google Ads?",
          "acceptedAnswer": { "@type": "Answer", "text": "They serve different purposes. Google Ads stops the moment you stop paying. Affordable SEO in Auckland builds organic visibility that earns free clicks over time. Most growing businesses benefit from both — Ads for immediate leads while SEO builds long-term visibility." }
        },
        {
          "@type": "Question",
          "name": "Do you work with businesses outside Auckland?",
          "acceptedAnswer": { "@type": "Answer", "text": "Kiwi Web Design is Auckland-based but works with businesses across New Zealand. Our local SEO expertise is strongest for Auckland, but our technical and content SEO applies everywhere in NZ." }
        }
      ]
    }
  ]
};

const seoServices = [
  {
    icon: "📍",
    title: "Local SEO Auckland",
    desc: "Dominate Google Maps and the local 3-Pack. We optimise your Google Business Profile, build local citations, and target the geo-specific keywords your customers are actually searching.",
    items: ["Google Business Profile optimisation", "Local citations & directory listings", "Map pack ranking", "Geo-targeted keyword strategy"],
  },
  {
    icon: "⚙️",
    title: "Technical SEO",
    desc: "A fast, well-structured site that Google can crawl and index properly. We find and fix the technical issues that hold small business sites back from ranking.",
    items: ["Site speed optimisation", "Core Web Vitals improvements", "Schema markup", "Mobile responsiveness"],
  },
  {
    icon: "✍️",
    title: "Content & On-Page SEO",
    desc: "Keyword research and page-level optimisation that connects your content to buyer intent — written for real customers, structured for Google.",
    items: ["Keyword research", "SEO content creation", "Meta tag optimisation", "Internal linking structure"],
  },
  {
    icon: "🔗",
    title: "Link Building",
    desc: "Quality backlinks from relevant NZ sources that build your site's authority sustainably — no shortcuts, no purchased links, no spam.",
    items: ["NZ-relevant directory listings", "Local business partnerships", "Content-based link earning", "Authority building"],
  },
  {
    icon: "📊",
    title: "Analytics & Reporting",
    desc: "Clear monthly reports showing what's moving — rankings, organic traffic, and enquiries. Plain English. No vanity metrics. Tied to actual leads.",
    items: ["Google Analytics 4 setup", "Search Console monitoring", "Monthly rank tracking", "Lead attribution"],
  },
  {
    icon: "🛒",
    title: "eCommerce SEO",
    desc: "Product and category page optimisation for WooCommerce and Shopify stores that drives organic traffic that converts into sales.",
    items: ["Product page optimisation", "Category structure", "Schema for products", "Shopping visibility"],
  },
];

const process = [
  { step: "1", title: "Free SEO Audit", desc: "We review your current rankings, site health, keyword gaps, and competitor landscape — no cost, no obligation, no sales pressure." },
  { step: "2", title: "Custom Strategy", desc: "A tailored plan focused on the keywords that will bring qualified leads. We recommend the right package for your budget and competition level." },
  { step: "3", title: "Implementation", desc: "Technical fixes, content, local signals, and link building — executed systematically each month against a clear priority list." },
  { step: "4", title: "Monthly Reporting", desc: "Readable reports showing where rankings are moving, what we did, and what's next. You always know what you're paying for." },
];

const reviews = [
  { name: "Zane Barrett", company: "Barrett Access Scaffolding", text: "Charlie really took the time to understand our business and built a site that actually ranks. We're getting enquiries we never would have found without SEO." },
  { name: "Jack", company: "Show Me Shorts", text: "The SEO work was thorough and professional. They explained everything clearly and I can see real improvements in our Google rankings." },
];

const caseStudies = [
  {
    name: "Barrett Access Scaffolding",
    summary: "For Barrett Access Scaffolding, we paired sector landing pages with clearer local intent, Google Business Profile updates, and enquiry routing that matched residential, commercial, and industrial searches.",
    takeaway: "The SEO lesson: better local landing pages and better-fit enquiry paths usually lift lead quality before you even start chasing harder keywords.",
    href: "/case-study-scaffolding/",
    cta: "Read the Barrett case study",
  },
  {
    name: "Beauty Touch Auckland",
    summary: "For Beauty Touch Auckland, we launched service pages, booking-ready structure, and Google Business Profile support so the business could show up more credibly for branded and treatment-led local searches.",
    takeaway: "The SEO lesson: many Auckland small businesses need cleaner service-page structure and stronger local trust signals before advanced SEO campaigns make sense.",
    href: "/beauty-touch-case-study/",
    cta: "Read the Beauty Touch case study",
  },
];

const faqs = [
  { q: "What does affordable SEO actually mean in Auckland?", a: "Affordable SEO in Auckland means getting the work that actually moves rankings — local SEO, Google Business Profile, on-page optimisation, technical fixes, and reporting — without big-agency overhead. At Kiwi Web Design, affordable SEO starts from <strong>$500/month</strong> with no lock-in contracts." },
  { q: "How much should a small business pay for SEO in Auckland?", a: "Most small Auckland businesses spend $500–$1,500/month to see meaningful results. Less than $500/month is usually too light to move rankings in competitive niches. More than $2,000/month is typically for high-competition industries like legal, finance, or medical. Every engagement starts with a free audit so we can quote based on your actual competition." },
  { q: "Can I get real SEO results on a $500/month budget?", a: "Yes — in less competitive niches and suburban markets, $500/month is enough to establish strong Google visibility. We focus that budget on the highest-impact work: Google Business Profile optimisation, local citations, and on-page fixes for your top 5 pages." },
  { q: "What's the difference between cheap SEO and affordable SEO?", a: "Cheap SEO uses shortcuts — spam links, keyword stuffing, offshore content farms — that can get your site penalised. Affordable SEO delivers the same legitimate work as expensive agencies at lower cost because there's no big-agency overhead. We keep overheads low by working directly with clients — no account managers, no middlemen." },
  { q: "What does an Auckland SEO agency actually do?", a: "A good Auckland SEO agency handles the work that improves both visibility and conversion: keyword targeting, Google Business Profile optimisation, on-page improvements, technical fixes, content strategy, internal linking, and reporting tied to real enquiries." },
  { q: "How long before affordable SEO shows results in Auckland?", a: "Most Auckland businesses see early movement in 2–3 months, with meaningful results over 6–12 months. SEO compounds over time. Google Business Profile optimisation often shows quicker wins (4–8 weeks) in local search." },
  { q: "Do I need SEO if I'm already running Google Ads?", a: "<a href=\"/google-ads/\">Google Ads</a> stops the moment you stop paying. Affordable SEO in Auckland builds organic visibility that earns free clicks over time. Most businesses benefit from both — Ads for immediate leads, SEO for long-term growth." },
];
---

<Layout
  title="Affordable SEO Auckland | SEO Services from $500/mo | Kiwi Web Design"
  description="Affordable SEO Auckland for small businesses. Local SEO, Google Business Profile, technical fixes and content from $500/month. No lock-in. Free audit. Based in Grey Lynn."
  canonicalURL="https://www.kiwiwebdesign.co.nz/affordable-seo-auckland/"
  schema={schema}
  alternateUrl="https://www.kiwiwebdesign.co.nz/zh/seo-auckland/"
>

  <PageHero
    eyebrow="Affordable SEO Auckland"
    title="Auckland SEO that small businesses can actually afford."
    subtitle="Big-agency SEO retainers can run $2,000–$5,000/month. Kiwi Web Design delivers the same results for Auckland small businesses from $500/month — no lock-in, direct contact with Charlie, and reporting tied to real enquiries not vanity metrics."
    badgeText="Free SEO audit — no obligation"
    ctaPrimary={{ text: "Get a Free SEO Audit", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "View Pricing", href: "#pricing" }}
    centered={true}
  />

  <!-- AI citability snippet -->
  <div class="seo-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> provides affordable SEO Auckland small businesses can sustain: local SEO, Google Business Profile optimisation, technical SEO, content strategy, and plain-English reporting from <strong>$500/month</strong> with no lock-in contracts. Based in Grey Lynn, Auckland. 4.9/5 Google rating. Free SEO audit available.</p>
    </div>
  </div>

  <!-- Stat bar -->
  <div class="seo-statbar">
    <div class="container seo-statbar-inner">
      <div class="ssb-item"><span class="ssb-num">From $500/mo</span><span class="ssb-lbl">Affordable SEO packages</span></div>
      <span class="ssb-sep" aria-hidden="true"></span>
      <div class="ssb-item"><span class="ssb-num">No lock-in</span><span class="ssb-lbl">Month-to-month contracts</span></div>
      <span class="ssb-sep" aria-hidden="true"></span>
      <div class="ssb-item"><span class="ssb-num">4.9/5</span><span class="ssb-lbl">Google rating</span></div>
      <span class="ssb-sep" aria-hidden="true"></span>
      <div class="ssb-item"><span class="ssb-num">Grey Lynn</span><span class="ssb-lbl">Auckland-based SEO team</span></div>
    </div>
  </div>

  <!-- Why affordable SEO matters -->
  <section class="section seo-why-section">
    <div class="container" style="max-width: 860px;">
      <SectionHeader
        eyebrow="Affordable vs Cheap SEO"
        title="Why does affordable SEO cost less — without the risk?"
        subtitle="There's a big difference between cheap SEO and genuinely affordable SEO. Here's how to tell them apart."
      />
      <div class="seo-why-grid">
        <div class="seo-why-card seo-why-bad">
          <p class="seo-why-label">❌ Cheap SEO</p>
          <ul>
            <li>Automated link schemes and spam directories</li>
            <li>Keyword stuffing and thin AI content</li>
            <li>Offshore "SEO packages" with no local knowledge</li>
            <li>No reporting or vague vanity-metric dashboards</li>
            <li>Risks a Google penalty that can kill your rankings</li>
          </ul>
        </div>
        <div class="seo-why-card seo-why-good">
          <p class="seo-why-label">✅ Affordable SEO at Kiwi Web Design</p>
          <ul>
            <li>Same legitimate work as big agencies — GBP, on-page, technical, content</li>
            <li>Lower cost because there's no account-manager layer or office overhead</li>
            <li>Local Auckland knowledge across suburb intent and service-area searches</li>
            <li>Monthly reports tied to actual enquiries, not screenshots of rank changes</li>
            <li>No lock-in — stay because the work is moving, not because you have to</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Our SEO Services"
        title="Everything an Auckland SEO campaign needs to rank and convert."
        subtitle="From technical fixes to content and local signals — a complete affordable SEO offer for small businesses that want better visibility and better enquiries."
      />
      <ServiceGrid items={seoServices} cols={3} />
    </div>
  </section>

  <!-- Results strip (dark) -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader eyebrow="SEO Signals" title="The kind of affordable SEO work that moves Auckland campaigns forward." light={true} />
      <div class="seo-results">
        <div class="seo-result">
          <span class="sr-num">GBP</span>
          <span class="sr-label">Google Business Profile optimisation</span>
          <span class="sr-industry">Local visibility foundation</span>
        </div>
        <div class="seo-result">
          <span class="sr-num">On-page</span>
          <span class="sr-label">Service-page targeting and internal links</span>
          <span class="sr-industry">Clearer keyword intent</span>
        </div>
        <div class="seo-result">
          <span class="sr-num">Tech SEO</span>
          <span class="sr-label">Crawl, speed, schema, and indexing fixes</span>
          <span class="sr-industry">Cleaner site quality signals</span>
        </div>
        <div class="seo-result">
          <span class="sr-num">3-6 mo</span>
          <span class="sr-label">Typical time to see meaningful movement</span>
          <span class="sr-industry">Most Auckland SEO campaigns</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Case studies -->
  <section class="section seo-proof-section">
    <div class="container">
      <SectionHeader
        eyebrow="SEO Case Studies"
        title="What affordable SEO work looks like on real Auckland projects."
        subtitle="Grounded examples from live client work — not made-up ranking wins or cherry-picked screenshots."
      />
      <div class="seo-case-grid">
        {caseStudies.map(({ name, summary, takeaway, href, cta }) => (
          <article class="seo-case-card">
            <p class="seo-case-name">{name}</p>
            <p class="seo-case-summary">{summary}</p>
            <p class="seo-case-takeaway">{takeaway}</p>
            <a href={href} class="seo-case-link">{cta} -&gt;</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="A clear process from free audit to real results."
        subtitle="We start every SEO engagement with a free audit — so we know exactly what to fix, what to build, and what budget it actually needs."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- About split -->
  <section class="section seo-about-section">
    <div class="container">
      <div class="seo-about-split">
        <div class="seo-about-img-wrap">
          <Image src={aboutImg} alt="SEO specialist reviewing keyword strategy for an affordable SEO campaign for an Auckland small business" width={560} height={700} class="seo-about-img" />
        </div>
        <div class="seo-about-content">
          <p class="seo-about-eyebrow">Why Choose Kiwi Web Design</p>
          <h2>Why is our SEO more affordable than most Auckland agencies?</h2>
          <p>Most Auckland small businesses don't need a big-agency process with layers of account managers and monthly pitch decks. They need focused, affordable SEO that understands local search intent, fixes the website alongside the keywords, and stays accountable to leads.</p>
          <p>We keep costs low by staying lean — you work directly with Charlie, not a junior who passes messages up the chain. That means faster decisions, no miscommunication, and none of the overhead that inflates agency retainers.</p>
          <ul class="seo-about-list">
            <li>Direct strategy with Charlie Chao — no offshore handoff</li>
            <li>SEO, website fixes, and landing-page improvements under one roof</li>
            <li>Local Auckland knowledge: GBP, suburb intent, service-area searches</li>
            <li>Plain-English reporting tied to enquiries, not just ranking screenshots</li>
            <li>No lock-in contracts — stay because the work is moving</li>
          </ul>
          <a href="/website-designer-auckland/" class="seo-about-btn">Book a Free SEO Audit →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section" id="pricing">
    <div class="container">
      <SectionHeader
        eyebrow="Pricing"
        title="Affordable SEO Pricing for Auckland Businesses"
        subtitle="Transparent, fixed monthly fees. No lock-in contracts. Every engagement starts with a free audit."
      />
      <div class="seo-pkg-grid">
        <div class="seo-pkg">
          <h3>Starter SEO</h3>
          <p class="seo-price">From $500<span class="seo-period">/mo</span></p>
          <p class="seo-pkg-desc">Ideal for small businesses in less competitive niches wanting to establish Google visibility without a big commitment.</p>
          <ul class="seo-pkg-list">
            <li>Google Business Profile optimisation</li>
            <li>On-page SEO for up to 5 pages</li>
            <li>Local citation building</li>
            <li>Monthly reporting</li>
          </ul>
          <a href="/website-designer-auckland/" class="seo-pkg-btn">Get Started</a>
        </div>
        <div class="seo-pkg seo-pkg-highlight">
          <span class="seo-pkg-tag">Most Popular</span>
          <h3>Growth SEO</h3>
          <p class="seo-price">From $1,000<span class="seo-period">/mo</span></p>
          <p class="seo-pkg-desc">For competitive Auckland markets wanting consistent, compounding lead flow from organic search.</p>
          <ul class="seo-pkg-list">
            <li>Full technical SEO audit & fixes</li>
            <li>On-page optimisation across all pages</li>
            <li>Local SEO + Google Business Profile</li>
            <li>Content creation (2 pages/month)</li>
            <li>Link building</li>
            <li>Monthly performance reports</li>
          </ul>
          <a href="/website-designer-auckland/" class="seo-pkg-btn seo-pkg-btn-accent">Get Started</a>
        </div>
        <div class="seo-pkg">
          <h3>Authority SEO</h3>
          <p class="seo-price">From $2,500<span class="seo-period">/mo</span></p>
          <p class="seo-pkg-desc">For highly competitive niches — legal, finance, healthcare — where dominating search in your category is the goal.</p>
          <ul class="seo-pkg-list">
            <li>Everything in Growth SEO</li>
            <li>Content strategy & pillar pages</li>
            <li>Advanced link building</li>
            <li>Competitor gap analysis</li>
            <li>Conversion rate optimisation</li>
            <li>Weekly reporting</li>
          </ul>
          <a href="/website-designer-auckland/" class="seo-pkg-btn">Get Started</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader eyebrow="Client Reviews" title="What our SEO clients say." />
      <TestimonialGrid items={reviews} cols={2} />
    </div>
  </section>

  <!-- Team card -->
  <div class="container seo-team-card-wrap">
    <div class="seo-team-card">
      <div class="seo-team-stats">
        <p class="seo-team-eyebrow">The team behind your SEO</p>
        <h2>Data-driven. Auckland-focused. Accountable.</h2>
        <div class="seo-team-nums">
          <div class="stn-item">
            <span class="stn-num">50+</span>
            <span class="stn-lbl">NZ client projects</span>
          </div>
          <div class="stn-item">
            <span class="stn-num">4.9★</span>
            <span class="stn-lbl">Google rating</span>
          </div>
          <div class="stn-item">
            <span class="stn-num">3-6 mo</span>
            <span class="stn-lbl">Typical time to movement</span>
          </div>
        </div>
        <a href="/website-designer-auckland/" class="seo-team-btn">Start with a Free Audit →</a>
      </div>
      <div class="seo-team-img-wrap">
        <Image src={about3Img} alt="Kiwi Web Design team analysing affordable SEO data for Auckland clients" width={800} height={540} class="seo-team-img" />
      </div>
    </div>
  </div>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion items={faqs} title="Affordable SEO Auckland — Questions Answered" subtitle="Common questions from Auckland small business owners about affordable SEO options." />
    </div>
  </section>

  <!-- Areas we serve -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Areas we serve</p>
      <div class="rps-links">
        <a href="/central-auckland-web-design/" class="rps-link">Central Auckland</a>
