---
import Layout from '../layouts/Layout.astro';
import nsVideo from '../assets/general/ns.mp4';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/north-shore-website-design/",
      "url": "https://www.kiwiwebdesign.co.nz/north-shore-website-design/",
      "name": "North Shore Website Design | Web Design Takapuna, Albany, Devonport",
      "description": "Affordable WordPress web design for North Shore businesses. Serving Takapuna, Albany, Milford, and Devonport. Professional websites built to generate enquiries.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/north-shore-website-design/#breadcrumb" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": [".loc-snippet", ".loc-hero-text"] }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/north-shore-website-design/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "North Shore Web Design", "item": "https://www.kiwiwebdesign.co.nz/north-shore-website-design/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "Place", "name": "Takapuna, Auckland" },
        { "@type": "Place", "name": "Albany, Auckland" },
        { "@type": "Place", "name": "Devonport, Auckland" },
        { "@type": "Place", "name": "Milford, Auckland" },
        { "@type": "Place", "name": "Browns Bay, Auckland" },
        { "@type": "Place", "name": "Glenfield, Auckland" },
        { "@type": "Place", "name": "North Shore, Auckland" }
      ],
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -36.7867,
        "longitude": 174.7406
      },
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "ratingCount": "50", "bestRating": "5" },
      "logo": { "@type": "ImageObject", "url": "https://www.kiwiwebdesign.co.nz/favicon.png", "width": 512, "height": 512 }
    },
    {
      "@type": "Service",
      "@id": "https://www.kiwiwebdesign.co.nz/north-shore-website-design/#service",
      "name": "Web Design, North Shore Auckland",
      "serviceType": "Website Design",
      "provider": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "areaServed": { "@type": "Place", "name": "North Shore, Auckland" },
      "offers": { "@type": "Offer", "price": "1290", "priceCurrency": "NZD", "priceSpecification": { "@type": "PriceSpecification", "price": "1290", "priceCurrency": "NZD", "valueAddedTaxIncluded": false } }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Do you work with businesses across the whole North Shore?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We work with businesses from Devonport and Takapuna through to Albany, Browns Bay, and the Hibiscus Coast. Everything is handled remotely, we don't need to meet in person, though we're happy to for North Shore clients who prefer it." } },
        { "@type": "Question", "name": "North Shore businesses compete with CBD firms, can you match that quality?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We build the same quality of website for North Shore clients that a CBD agency would charge three times more for. Our advantage is lower overheads and direct work with Charlie, no account managers or junior designers." } },
        { "@type": "Question", "name": "Can you help us rank in local North Shore searches?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Local SEO for North Shore requires suburb-specific content, a well-maintained Google Business Profile, and consistent citations in NZ directories. We handle all of this as part of our SEO service, targeting suburbs like Takapuna, Albany, and Devonport specifically." } },
        { "@type": "Question", "name": "How long does a North Shore website project take?", "acceptedAnswer": { "@type": "Answer", "text": "Most projects launch within 2–4 weeks from brief approval. Simple brochure sites for North Shore businesses can be live in under two weeks. We agree on a timeline upfront and stick to it." } },
        { "@type": "Question", "name": "What does a North Shore website cost?", "acceptedAnswer": { "@type": "Answer", "text": "A professional small business website starts from $1,290 + GST. eCommerce, booking systems, and multi-page builds are quoted by scope. All quotes are fixed price, no surprises." } }
      ]
    }
  ]
};

const services = [
  {
    icon: "🏛️",
    title: "Professional Service Websites",
    desc: "Consultants, financial advisers, lawyers, and accountants on the North Shore compete with CBD-based firms for the same clients. Your website needs to match their polish, without the agency price tag.",
    items: ["Clean, authoritative design", "Service/practice area pages", "Client consultation booking", "Trust signals and credentials"],
  },
  {
    icon: "⚕️",
    title: "Healthcare & Allied Health",
    desc: "North Shore has one of Auckland's highest concentrations of healthcare providers. Practitioner profiles, online appointment booking, and patient information pages that help you attract new patients.",
    items: ["Practitioner profile pages", "Online appointment booking", "Patient FAQ and information", "Local healthcare SEO"],
  },
  {
    icon: "🏪",
    title: "Local Business & Retail",
    desc: "Takapuna and Albany retail precincts are competitive. Whether you're a boutique, a café on The Strand, or a service business in Glenfield, we build sites that attract local customers searching online.",
    items: ["Google Business Profile setup", "Product/service showcase", "Location and hours", "Google Maps integration"],
  },
  {
    icon: "🔍",
    title: "Local SEO, North Shore",
    desc: "Ranking for 'accountant Takapuna' or 'physio Albany' takes targeted local SEO, suburb-specific content, Google Business Profile optimisation, and consistent citations across directories.",
    items: ["Suburb-targeted content", "Google Business Profile", "Citation building", "Schema markup"],
  },
  {
    icon: "🎯",
    title: "Google Ads, North Shore",
    desc: "For North Shore businesses where organic SEO takes time, Google Ads generates immediate enquiries. We manage campaigns for professional services, healthcare, and trades across the Shore.",
    items: ["North Shore keyword targeting", "Service area campaigns", "Landing pages per service", "Conversion tracking"],
  },
  {
    icon: "📱",
    title: "Mobile-First Design",
    desc: "North Shore residents search on their phones while commuting, between meetings, and at the weekend. Every site we build is designed mobile-first, fast, clean, and easy to navigate on any device.",
    items: ["Mobile-first responsive design", "Core Web Vitals optimised", "Touch-friendly navigation", "Fast load times"],
  },
];

const areas = [
  { name: "Takapuna", note: "Retail, hospitality, healthcare, and professional services on Auckland's North Shore hub." },
  { name: "Albany", note: "Business park and retail precinct, high demand for professional service and trade websites." },
  { name: "Devonport", note: "Boutique retail, hospitality, and independent businesses with a distinct local character." },
  { name: "Milford", note: "Professional services, medical centres, and family-oriented businesses." },
  { name: "Browns Bay", note: "Growing suburban centre with retail, trades, and service businesses." },
  { name: "Glenfield", note: "Trade and industrial businesses, professional services, and local retail." },
  { name: "Orewa & Hibiscus Coast", note: "Northern corridor businesses serving a growing residential population." },
];

const faqs = [
  { q: "Do you work with businesses across the whole North Shore?", a: "Yes. We work with businesses from Devonport and Takapuna through to Albany, Browns Bay, and the Hibiscus Coast. Everything is handled remotely, we don't need to meet in person, though we're happy to for North Shore clients who prefer it." },
  { q: "North Shore businesses compete with CBD firms, can you match that quality?", a: "Yes. We build the same quality of website for North Shore clients that a CBD agency would charge three times more for. Our advantage is lower overheads and direct work with Charlie, no account managers or junior designers." },
  { q: "Can you help us rank in local North Shore searches?", a: "Yes. Local SEO for North Shore requires suburb-specific content, a well-maintained Google Business Profile, and consistent citations in NZ directories. We handle all of this as part of our SEO service, targeting suburbs like Takapuna, Albany, and Devonport specifically." },
  { q: "How long does a North Shore website project take?", a: "Most projects launch within 2–4 weeks from brief approval. Simple brochure sites for North Shore businesses can be live in under two weeks. We agree on a timeline upfront and stick to it." },
  { q: "What does a North Shore website cost?", a: "Our pricing is the same regardless of location. A professional small business website starts from $990 + GST. eCommerce, booking systems, and multi-page builds are quoted by scope. See our packages page for details." },
];
---

<Layout
  title="North Shore Website Design | Web Design Takapuna, Albany, Devonport"
  description="Affordable WordPress web design for North Shore businesses. Serving Takapuna, Albany, Milford, and Devonport. Professional websites built to generate enquiries."
  canonicalURL="https://www.kiwiwebdesign.co.nz/north-shore-website-design/"
  schema={schema}
>

  <!-- Hero -->
  <section class="loc-hero">
    <video class="loc-hero-video" autoplay muted loop playsinline preload="auto">
      <source src={nsVideo} type="video/mp4" />
    </video>
    <div class="loc-hero-overlay" aria-hidden="true"></div>
    <div class="container">
      <div class="loc-hero-inner">
        <div class="loc-hero-text">
          <p class="loc-hero-eyebrow">North Shore Web Design</p>
          <h1>North Shore businesses deserve a website that competes with the CBD.</h1>
          <p class="loc-hero-sub">Professional WordPress websites for Takapuna, Albany, Devonport, Milford, and across the North Shore. Designed to look established, rank locally, and turn searches into enquiries.</p>
          <div class="loc-hero-btns">
            <a href="/website-designer-auckland/" class="loc-btn-primary">Get a Free Quote</a>
            <a href="/small-business-website-design-auckland/" class="loc-btn-outline">View Packages</a>
          </div>
        </div>
        <div class="loc-hero-card">
          <p class="lhc-label">Serving North Shore</p>
          <ul class="lhc-areas">
            <li>Takapuna</li>
            <li>Albany</li>
            <li>Devonport</li>
            <li>Milford</li>
            <li>Browns Bay</li>
            <li>Glenfield</li>
            <li>Orewa & Hibiscus Coast</li>
          </ul>
          <p class="lhc-note">All projects handled remotely. In-person consultations available for North Shore clients.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AI citability snippet -->
  <div class="loc-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> builds professional websites for North Shore businesses, Takapuna, Albany, Devonport, Milford, Browns Bay, and Glenfield, from <strong>$1,290 + GST</strong>. Delivered in 2–4 weeks with local SEO included. Based in Grey Lynn, Auckland, 4.9★ Google rating from 50+ clients.</p>
    </div>
  </div>

  <!-- North Shore context -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="The North Shore Market"
        title="North Shore clients expect a professional online presence."
        subtitle="The North Shore has one of Auckland's highest concentrations of professional service businesses. Your clients are comparing you against your competitors before they call."
      />
      <div class="loc-context">
        <div class="loc-context-text">
          <p>The North Shore, Takapuna, Albany, Devonport, and surrounds, is home to a disproportionate number of accountants, financial advisers, consultants, healthcare providers, and professional services firms. These are discerning clients who Google everything before making a decision.</p>
          <p>That means your website isn't just a brochure, it's your first filter. A poorly designed site signals to a North Shore professional that your firm might not be up to the job. A clean, well-structured site with clear credentials and an easy enquiry path signals the opposite. See our <a href="/small-business-website-design-auckland/">web design packages</a> for pricing and what's included.</p>
          <p>We've built websites for North Shore businesses across financial services, healthcare, legal, and hospitality. Pairing your new site with <a href="/local-seo-for-auckland-small-businesses/">local SEO</a> and a well-optimised Google Business Profile is how North Shore businesses consistently appear at the top of suburb-specific searches. For faster results, our broader <a href="/affordable-seo-auckland/">SEO services in Auckland</a> can help you compete across the whole city.</p>
        </div>
        <div class="loc-areas-grid">
          {areas.map(({ name, note }) => (
            <div class="loc-area-card">
              <strong class="lac-name">{name}</strong>
              <p class="lac-note">{note}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Services"
        title="Everything a North Shore business needs online."
        subtitle="From professional service websites to local SEO and Google Ads campaigns targeting your specific North Shore suburb."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="North Shore Web Design Questions"
        subtitle="What North Shore businesses ask about working with Kiwi Web Design."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design</a>
        <a href="/local-seo-for-auckland-small-businesses/" class="rps-link">Local SEO</a>
        <a href="/central-auckland-web-design/" class="rps-link">Central Auckland</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to build a website your North Shore clients will trust?"
    subtitle="Free consultation, we'll review your current site or brief and give you a fixed quote."
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Our Process", href: "/our-process/" }}
  />

</Layout>

<style>
  .loc-hero {
    position: relative;
    overflow: hidden;
    background: var(--kwd-dark);
    color: #fff;
    padding: 4rem 0 3.5rem;
  }
  .loc-hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .loc-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(44,41,39,0.82) 0%, rgba(44,41,39,0.55) 100%);
    z-index: 1;
  }
  .loc-hero .container {
    position: relative;
    z-index: 2;
  }
  .loc-hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: start;
  }
  .loc-hero-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-yellow);
    margin: 0 0 1rem;
  }
  .loc-hero-text h1 {
    font-family: var(--kwd-font-heading);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    line-height: 1.18;
    margin: 0 0 1.1rem;
    color: #fff;
  }
  .loc-hero-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.65;
    max-width: 540px;
    margin: 0 0 2rem;
  }
  .loc-hero-btns { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .loc-btn-primary {
    background: var(--kwd-yellow);
    color: var(--kwd-dark);
    padding: 0.75rem 1.75rem;
    border-radius: 6px;
    font-weight: 700;
    text-decoration: none;
    font-size: 0.95rem;
  }
  .loc-btn-outline {
    border: 2px solid rgba(255,255,255,0.35);
    color: rgba(255,255,255,0.85);
    padding: 0.75rem 1.75rem;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    font-size: 0.95rem;
  }
  .loc-hero-card {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 16px;
    padding: 1.75rem;
    min-width: 220px;
    flex-shrink: 0;
  }
  .lhc-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--kwd-yellow);
    margin: 0 0 0.875rem;
  }
  .lhc-areas {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .lhc-areas li {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.82);
    padding-left: 1.1rem;
    position: relative;
  }
  .lhc-areas li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--kwd-yellow);
    font-size: 0.72rem;
    top: 0.15rem;
  }
  .lhc-note { font-size: 0.72rem; color: rgba(255,255,255,0.35); margin: 0; line-height: 1.55; }

  /* Context section */
  .loc-context {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-top: 2.5rem;
    align-items: start;
  }
  .loc-context-text p {
    font-size: 0.9rem;
    color: var(--kwd-brown);
    line-height: 1.75;
    margin-bottom: 0.875rem;
  }
  .loc-areas-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .loc-area-card {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 10px;
    padding: 0.875rem 1.125rem;
  }
  .lac-name { font-size: 0.875rem; font-weight: 700; color: var(--kwd-dark); display: block; margin-bottom: 0.2rem; }
  .lac-note { font-size: 0.78rem; color: var(--kwd-brown); margin: 0; line-height: 1.5; }

  .loc-snippet { background: #fff8e1; border-left: 4px solid var(--kwd-yellow); padding: 1rem 0; }
  .loc-snippet p { margin: 0; font-size: 0.95rem; line-height: 1.65; color: var(--kwd-dark); }
  @media (max-width: 900px) {
    .loc-hero-inner { grid-template-columns: 1fr; }
    .loc-hero-card { display: none; }
    .loc-context { grid-template-columns: 1fr; }
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
