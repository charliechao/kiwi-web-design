---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/how-kiwi-web-design-helps-auckland-healthcare/",
      "url": "https://www.kiwiwebdesign.co.nz/how-kiwi-web-design-helps-auckland-healthcare/",
      "name": "Web Design for Auckland Healthcare & Medical Practices | Kiwi Web Design",
      "description": "WordPress websites for Auckland medical centres, specialists, and allied health providers. Practitioner profiles, appointment booking, and patient-centred design.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/how-kiwi-web-design-helps-auckland-healthcare/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/how-kiwi-web-design-helps-auckland-healthcare/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Industries", "item": "https://www.kiwiwebdesign.co.nz/industries-we-serve-in-auckland/" },
        { "@type": "ListItem", "position": 3, "name": "Healthcare" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz"
    }
  ]
};

const painPoints = [
  {
    icon: "📞",
    title: "Appointment booking is still 100% by phone",
    desc: "Your receptionist fields the same calls all day: 'Can I see Dr Smith on Tuesday?' or 'What's your ACC process?'. Online appointment booking and a well-structured FAQ page reduce call volume significantly — freeing up front desk time for patients who actually need it.",
  },
  {
    icon: "👥",
    title: "Patients can't find the right practitioner",
    desc: "A patient referred to your clinic for physiotherapy, or choosing a GP for their family, wants to understand who they'll be seeing. Individual practitioner profiles with qualifications, areas of focus, and a brief bio build confidence before the first appointment.",
  },
  {
    icon: "🌐",
    title: "New patients can't find you at all",
    desc: "People relocating to a new Auckland suburb, or looking for a specialist within their insurance network, search Google before asking a GP for a referral. If your Google Business Profile is sparse and your website isn't optimised for local search, you're invisible.",
  },
  {
    icon: "📋",
    title: "Patient information is scattered and outdated",
    desc: "Downloadable intake forms, ACC information, after-hours instructions, and referral processes are often buried in PDFs or on pages that haven't been updated since 2019. Patients form their first impression of your practice from your website — outdated information is a red flag.",
  },
];

const solutions = [
  {
    icon: "👨‍⚕️",
    title: "Practitioner Profile Pages",
    desc: "Individual pages for each doctor, specialist, or allied health practitioner — photo, qualifications, areas of focus, languages spoken, and a human bio. Patients book with confidence when they know who they're seeing.",
    items: ["Professional headshot", "Qualifications & registration", "Specialty / treatment focus", "Languages spoken"],
  },
  {
    icon: "📅",
    title: "Online Appointment Booking",
    desc: "Self-service booking for patient appointments — with practitioner selection, appointment type, and confirmation by email. Reduces phone volume and lets patients book at 11pm if needed.",
    items: ["Simply Schedule or Trafft", "Practitioner selection", "Appointment type (new/returning)", "Automated confirmation + reminder"],
  },
  {
    icon: "📄",
    title: "Patient Information Hub",
    desc: "A clear, well-organised patient information section: new patient registration, ACC forms, after-hours options, referral process, fees, and frequently asked questions. Saves your front desk answering the same questions repeatedly.",
    items: ["Downloadable intake forms", "ACC process overview", "Fees & insurance information", "After-hours instructions"],
  },
  {
    icon: "♿",
    title: "Accessible, Inclusive Design",
    desc: "Healthcare websites serve a broad population — including older patients, those with low digital literacy, and people with visual impairments. We design for clarity, readability, and accessibility standards (WCAG AA).",
    items: ["High contrast text", "Large, readable typography", "WCAG AA compliance", "Screen reader friendly"],
  },
  {
    icon: "🔍",
    title: "Local Healthcare SEO",
    desc: "Patients searching 'physio near me' or 'GP accepting new patients East Auckland' rely on Google to find a provider. We optimise your site and Google Business Profile so you show up when patients are looking.",
    items: ["MedicalOrganization schema", "Google Business Profile setup", "Suburb-specific page content", "Health condition keyword targeting"],
  },
  {
    icon: "🔒",
    title: "Privacy & Compliance",
    desc: "Healthcare websites handle sensitive information. We ensure secure contact forms, a compliant privacy policy, no unsecured patient data capture, and appropriate disclaimers for health content.",
    items: ["SSL security", "Privacy Act compliant policy", "Secure form handling", "Health content disclaimers"],
  },
];

const process = [
  { step: "1", title: "Discovery & Stakeholder Brief", desc: "We meet with your practice manager or principal to understand your patient profile, service mix, practitioner roster, and what patients currently find confusing or missing on your current site." },
  { step: "2", title: "Structure & Content Planning", desc: "We map your site architecture: practitioner pages, services/specialties, patient info sections, and booking flow. We identify what content you need to provide and what we can draft." },
  { step: "3", title: "Build & Accessibility Review", desc: "We build your site with healthcare-appropriate design — clean, clinical confidence. We run an accessibility check and test the patient information sections thoroughly." },
  { step: "4", title: "Launch & Staff Training", desc: "We launch and train your front desk or practice manager on updating the site — adding new practitioners, updating fees, uploading forms — so you're never dependent on us for routine changes." },
];

const faqs = [
  { q: "Can patients book appointments directly through the website?", a: "Yes. We integrate <a href=\"/booking-appointment-websites-with-wordpress/\">online appointment booking</a> plugins (Simply Schedule Appointments or Trafft) that allow patients to select a practitioner, appointment type, and time. New patient vs returning patient options can be handled separately. All bookings generate confirmation emails and reminders automatically." },
  { q: "Can you build a website for a multi-practitioner clinic?", a: "Yes. Multi-practitioner healthcare sites are a common build for us. Each practitioner has an individual profile page, and the <a href=\"/booking-appointment-websites-with-wordpress/\">booking system</a> routes to the correct calendar. We can accommodate GPs, specialists, and allied health practitioners on the same site." },
  { q: "Do you handle patient data securely?", a: "We do not build systems that store clinical patient data — that's the role of your practice management software. What we do ensure is that all contact forms use SSL, we don't embed unsecured data capture, and your privacy policy accurately reflects how you handle patient information under the NZ Privacy Act. All sites are built on <a href=\"/small-business-website-design-auckland/\">WordPress</a> for ease of updates." },
  { q: "Can you add a downloadable patient intake form to our website?", a: "Yes. We can add downloadable PDF forms, and also online intake forms where patients fill out details before their appointment. For the latter, responses go to your designated email or practice management system — not stored on the website. Our <a href=\"/local-seo-for-auckland-small-businesses/\">local SEO</a> add-on can also help new patients find your practice." },
  { q: "How much does a healthcare website cost?", a: "A single-practitioner healthcare website starts from $1,490 + GST. View our <a href=\"/small-business-website-design-auckland/\">web design packages</a> for baseline pricing. A multi-practitioner clinic with individual profiles, <a href=\"/booking-appointment-websites-with-wordpress/\">online booking</a>, and patient information hub typically runs $2,490–$3,500 + GST depending on practitioner count and scope. We quote by scope, not by hourly rate." },
];
---

<Layout
  title="Web Design for Auckland Healthcare & Medical Practices | Kiwi Web Design"
  description="WordPress websites for Auckland medical centres, specialists, and allied health providers. Practitioner profiles, appointment booking, and patient-centred design."
  canonicalURL="https://www.kiwiwebdesign.co.nz/how-kiwi-web-design-helps-auckland-healthcare/"
  schema={schema}
>

  <PageHero
    eyebrow="Web Design for Healthcare"
    title="A website that patients trust before they walk through your door."
    subtitle="WordPress websites for Auckland GPs, specialists, and allied health practices. Practitioner profiles, online appointment booking, accessible design, and patient information that actually helps people find you."
    ctaPrimary={{ text: "Get a Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See What's Included", href: "#solutions" }}
  />

  <!-- Pain points -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="The Challenge"
        title="Healthcare websites need to work harder than most."
        subtitle="Patients look for very specific signals before booking with a practice. Most healthcare websites fail to provide them."
      />
      <div class="ind-pain-grid">
        {painPoints.map(({ icon, title, desc }) => (
          <div class="ind-pain-card">
            <span class="ipc-icon">{icon}</span>
            <h3 class="ipc-title">{title}</h3>
            <p class="ipc-desc">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Solutions -->
  <section class="section" id="solutions">
    <div class="container">
      <SectionHeader
        eyebrow="What We Build"
        title="Everything a modern Auckland healthcare practice needs online."
        subtitle="From practitioner profiles to patient information hubs — built for clarity, trust, and accessibility."
      />
      <ServiceGrid items={solutions} cols={3} />
    </div>
  </section>

  <!-- Trust callout -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <div class="ind-callout">
        <div class="ind-callout-text">
          <p class="ind-callout-eyebrow">Why It Matters</p>
          <h2>Patients research their healthcare providers more carefully than almost any other purchase.</h2>
          <p>Choosing a GP, a physio, or a specialist is a high-trust decision. Patients read reviews, look up practitioner credentials, and check that the practice accepts new patients — all before they call.</p>
          <p>A healthcare website needs to answer those questions clearly: who are your practitioners, what do they specialise in, are you accepting new patients, and how do I book? Every missing answer is a potential patient who calls a competitor instead.</p>
        </div>
        <div class="ind-callout-stats">
          <div class="ind-stat"><span class="is-fig">77%</span><span class="is-label">of patients use online search before choosing a healthcare provider</span></div>
          <div class="ind-stat"><span class="is-fig">60%</span><span class="is-label">of patients prefer to book appointments online if given the option</span></div>
          <div class="ind-stat"><span class="is-fig">30%</span><span class="is-label">reduction in front desk call volume when a patient FAQ page is well-maintained</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="How We Work"
        title="A process designed around busy healthcare practices."
        subtitle="We work around your schedule — minimal time required from clinical staff."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Healthcare Website Questions Answered"
        subtitle="What Auckland medical practices ask before starting a project with us."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design</a>
        <a href="/booking-appointment-websites-with-wordpress/" class="rps-link">Booking Websites</a>
        <a href="/local-seo-for-auckland-small-businesses/" class="rps-link">Local SEO</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress</a>
        <a href="/seo-auckland/" class="rps-link">SEO</a>
        <a href="/melanoma-specialists-website/" class="rps-link">Case Study: Melanoma NZ ↗</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to modernise your practice's online presence?"
    subtitle="Free consultation — we'll review your current site and identify the highest-impact improvements."
    ctaPrimary={{ text: "Get a Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See All Industries", href: "/industries-we-serve-in-auckland/" }}
  />

</Layout>

<style>
  .ind-pain-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .ind-pain-card {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 14px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ipc-icon { font-size: 1.75rem; }
  .ipc-title { font-family: var(--kwd-font-body); font-size: 0.95rem; font-weight: 700; color: var(--kwd-dark); margin: 0; }
  .ipc-desc { font-size: 0.875rem; color: var(--kwd-brown); line-height: 1.65; margin: 0; }

  .ind-callout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .ind-callout-eyebrow { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--kwd-yellow); margin-bottom: 0.75rem; }
  .ind-callout-text h2 { font-size: clamp(1.4rem, 2.5vw, 1.875rem); color: #fff; margin-bottom: 0.75rem; line-height: 1.25; }
  .ind-callout-text p { font-size: 0.9rem; color: rgba(255,255,255,0.65); line-height: 1.7; margin-bottom: 0.75rem; }
  .ind-callout-stats { display: flex; flex-direction: column; gap: 1rem; }
  .ind-stat {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .is-fig { font-family: var(--kwd-font-heading); font-size: 1.75rem; color: var(--kwd-yellow); flex-shrink: 0; min-width: 72px; line-height: 1; }
  .is-label { font-size: 0.85rem; color: rgba(255,255,255,0.65); line-height: 1.5; }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
  @media (max-width: 900px) {
    .ind-callout { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  @media (max-width: 640px) {
    .ind-pain-grid { grid-template-columns: 1fr; }
  }
</style>
