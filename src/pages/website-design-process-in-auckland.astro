---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/website-design-process-in-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/website-design-process-in-auckland/",
      "name": "Website Design Process Auckland | How We Build Sites | Kiwi Web Design",
      "description": "Our 6-step web design process for Auckland businesses: discover, plan, design, build, launch, and support. Simple, transparent, and fast — most sites launch in 2–3 weeks.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/website-design-process-in-auckland/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/website-design-process-in-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Website Design Process Auckland" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const steps = [
  {
    step: "1",
    title: "Discovery Call",
    desc: "A free 30-minute conversation to understand your business, goals, and what you need from your website. We ask the right questions so nothing gets missed.",
  },
  {
    step: "2",
    title: "Scope & Quote",
    desc: "We document exactly what we're building — pages, features, integrations — and give you a fixed-price quote. No hourly billing, no scope creep surprises.",
  },
  {
    step: "3",
    title: "Design",
    desc: "A custom design built in your brand's colours, fonts, and style. We present it for your feedback before any development begins — changes are easiest at this stage.",
  },
  {
    step: "4",
    title: "Build",
    desc: "Development on a private staging URL so you can see the real site before it goes live. We build for speed, mobile, and SEO from the start.",
  },
  {
    step: "5",
    title: "Review & Launch",
    desc: "Two structured rounds of feedback, then a full pre-launch checklist. On launch day, we go live, set up Search Console, and verify everything is working correctly.",
  },
  {
    step: "6",
    title: "Training & Support",
    desc: "A handover session covering how to manage your site, followed by 30 days of post-launch support. You leave knowing how to make updates yourself.",
  },
];

const principles = [
  { label: "Fixed pricing", body: "You get a written quote before we start. We don't charge by the hour or add extras later. The price we quote is the price you pay." },
  { label: "Your content, your ownership", body: "Everything we build is yours — the domain, the hosting account, the code. We don't use proprietary platforms that lock you in." },
  { label: "Built for results", body: "Every design decision — layout, CTAs, page structure — is made with conversions in mind. A site that looks good but doesn't generate enquiries hasn't done its job." },
  { label: "Fast turnaround", body: "Most small business sites launch within 2–3 weeks of project start. We don't let builds drag on — we keep momentum." },
];

const faqs = [
  { q: "How long does the whole process take?", a: "Most small business sites launch in 2–3 weeks once content is ready. Larger sites or eCommerce builds may take 3–5 weeks depending on scope. We'll give you a specific timeline at the quoting stage so you can plan accordingly. See our <a href=\"/small-business-website-design-auckland/\">web design packages</a> for what's included at each price point." },
  { q: "What do you need from me to get started?", a: "Your logo, brand preferences (colours, fonts, examples you like), the list of pages you need, and any existing content or photos. If you don't have professional photos, we can use high-quality stock imagery. If your content isn't fully ready, we can work around your timeline." },
  { q: "Can I request changes during the build?", a: "Yes. We include structured feedback rounds at design stage and again during staging — two rounds of revisions at each stage. Changes are always easier before development starts, which is why we get design sign-off first." },
  { q: "What happens after launch?", a: "You get 30 days of post-launch support at no extra charge — for bug fixes, content tweaks, or questions about managing the site. After that, ongoing support is available through our maintenance plans. Learn <a href=\"/about-us/\">more about our team</a> and how we work." },
  { q: "Will I be able to update the site myself?", a: "Yes. We build on <a href=\"/wordpress-website-design-auckland/\">WordPress</a> with a straightforward editing setup. At handover we show you how to update text, add images, publish blog posts, and manage your enquiry forms. Most clients can handle day-to-day updates confidently within the first session." },
  { q: "Do you work with clients outside Auckland?", a: "Yes. While most of our clients are Auckland-based, we work with businesses throughout New Zealand. Discovery calls and reviews happen over video call — the process is the same regardless of location." },
];
---

<Layout
  title="Website Design Process Auckland | How We Build Sites | Kiwi Web Design"
  description="Our 6-step web design process for Auckland businesses: discover, plan, design, build, launch, and support. Simple, transparent, and fast — most sites launch in 2–3 weeks."
  canonicalURL="https://www.kiwiwebdesign.co.nz/website-design-process-in-auckland/"
  schema={schema}
>

  <PageHero
    eyebrow="Our Process"
    title="Simple. Transparent. Fast."
    subtitle="Six clear steps from first call to launch day. Most Auckland small business sites go live within 2–3 weeks — with no hidden costs and no surprises."
    imgSrc="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/10/web-design-process-kiwi-web-design-auckland.jpg"
    imgAlt="Web design process at Kiwi Web Design Auckland"
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View Web Design", href: "/small-business-website-design-auckland/" }}
  />

  <!-- Steps -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="Six steps from conversation to launch."
        subtitle="Every project follows the same clear process — you always know what's happening next."
      />
      <div style="margin-top: 2.5rem;">
        <ProcessSteps items={steps} />
      </div>
    </div>
  </section>

  <!-- Principles -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <SectionHeader
        eyebrow="How We Work"
        title="What makes our process different."
        align="left"
      />
      <div class="principles-list">
        {principles.map(({ label, body }) => (
          <div class="principle">
            <strong class="principle-label">{label}</strong>
            <p class="principle-body">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline callout -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <div class="timeline-grid">
        <div class="timeline-item">
          <span class="timeline-num">Day 1</span>
          <span class="timeline-label">Discovery call & scoping</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-num">Days 2–5</span>
          <span class="timeline-label">Design presented for review</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-num">Days 6–14</span>
          <span class="timeline-label">Build on staging, content loaded</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-num">Days 15–18</span>
          <span class="timeline-label">Review rounds & refinement</span>
        </div>
        <div class="timeline-item">
          <span class="timeline-num">Day 21</span>
          <span class="timeline-label">Launch day</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Process Questions Answered"
        subtitle="Common questions from Auckland business owners about how the build works."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design Packages</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress</a>
        <a href="/about-us/" class="rps-link">About Us</a>
        <a href="/seo-auckland/" class="rps-link">SEO Services</a>
        <a href="/website-training-and-handover/" class="rps-link">Training &amp; Handover</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to start? It begins with a free call."
    subtitle="Book a 30-minute discovery call and we'll scope your project, answer your questions, and give you a fixed-price quote."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View Packages", href: "/small-business-website-design-auckland/" }}
  />

</Layout>

<style>
  .principles-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .principle {
    padding: 1.25rem 1.5rem;
    background: var(--kwd-cream);
    border-left: 4px solid var(--kwd-yellow);
    border-radius: 0 10px 10px 0;
  }
  .principle-label {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    color: var(--kwd-dark);
    margin-bottom: 0.35rem;
  }
  .principle-body {
    font-size: 0.9rem;
    color: var(--kwd-brown);
    line-height: 1.7;
    margin: 0;
  }
  .timeline-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
  }
  .timeline-item {
    padding: 1.75rem 1.25rem;
    border-right: 1px solid rgba(255,255,255,0.1);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .timeline-item:last-child { border-right: none; }
  .timeline-num {
    font-family: var(--kwd-font-heading);
    font-size: 1.2rem;
    color: var(--kwd-yellow);
    line-height: 1;
  }
  .timeline-label {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.45;
  }
  @media (max-width: 860px) {
    .timeline-grid { grid-template-columns: repeat(2, 1fr); }
    .timeline-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .timeline-item:last-child { border-bottom: none; }
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
