---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/how-kiwi-web-design-helps-auckand-lawyers/",
      "url": "https://www.kiwiwebdesign.co.nz/how-kiwi-web-design-helps-auckand-lawyers/",
      "name": "Web Design for Auckland Lawyers & Law Firms | Kiwi Web Design",
      "description": "Website design for Auckland solicitors and law firms. Professionally built WordPress sites with practice area pages, consultation booking, and Google Ads landing pages.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/how-kiwi-web-design-helps-auckand-lawyers/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/how-kiwi-web-design-helps-auckand-lawyers/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Industries", "item": "https://www.kiwiwebdesign.co.nz/industries-we-serve-in-auckland/" },
        { "@type": "ListItem", "position": 3, "name": "Law Firms" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz"
    }
  ]
};

const painPoints = [
  {
    icon: "⚖️",
    title: "Your site looks like a free template from 2015",
    desc: "Potential clients are Googling you before they call. A generic, cluttered website signals that your firm isn't established — even if you've been practising for 20 years. First impressions in law are everything.",
  },
  {
    icon: "📞",
    title: "You're still fielding enquiries the slow way",
    desc: "Phone tag with prospective clients who want a 'quick question' answered costs you hours every week. A website with a proper enquiry form — matter type, brief description, urgency — filters time-wasters before they reach you.",
  },
  {
    icon: "🔍",
    title: "You're invisible for the searches that matter",
    desc: "Someone searching 'commercial lawyer Auckland' or 'employment lawyer North Shore' will call whoever appears first. If that's not you, it's a competitor. Legal is one of the highest-value categories in Google Ads — and it's unforgiving to those without a presence.",
  },
  {
    icon: "🏛️",
    title: "Your practice areas aren't clearly communicated",
    desc: "A homepage that says 'full service law firm' tells a client nothing. Dedicated practice area pages — each written for that specific type of client and their specific anxiety — convert far better than a generic capabilities list.",
  },
];

const solutions = [
  {
    icon: "🏛️",
    title: "Practice Area Pages",
    desc: "Dedicated pages for each area of law you practise — written for the person searching, not for other lawyers. Each page addresses the client's specific situation and drives them toward a consultation.",
    items: ["Family law, property, commercial, employment", "Written in plain English (not legalese)", "FAQ sections per practice area", "Optimised for specific search terms"],
  },
  {
    icon: "📋",
    title: "Consultation Enquiry Forms",
    desc: "Structured intake forms that capture matter type, a brief description, and preferred contact time — so you and your secretary know exactly what's coming before you pick up the phone.",
    items: ["Matter type dropdown", "Brief description field", "Urgency indicator", "Email + phone to your practice"],
  },
  {
    icon: "👤",
    title: "Solicitor Profile Pages",
    desc: "Individual pages for each solicitor — photo, credentials, areas of practice, admitted year, and a personal statement. Clients choose lawyers they trust; trust starts with a face and a background.",
    items: ["Professional headshots (brief on specs)", "Credentials and admissions", "Practice areas per solicitor", "Direct contact option"],
  },
  {
    icon: "📣",
    title: "Google Ads Landing Pages",
    desc: "High-stakes legal searches convert best on focused landing pages — not homepages. We build dedicated pages for each campaign: 'car accident claim Auckland', 'property dispute lawyer', and so on.",
    items: ["Ad-to-page message match", "Single clear CTA (consultation)", "Trust signals above the fold", "Google Ads conversion tracking"],
  },
  {
    icon: "🔍",
    title: "Legal SEO Foundations",
    desc: "Local SEO for your practice areas and geographic areas. Schema markup (LegalService, Attorney) so Google understands exactly what you offer and where you serve.",
    items: ["LegalService schema markup", "Google Business Profile optimisation", "Location + practice area pages", "Citation building"],
  },
  {
    icon: "🔒",
    title: "Trust & Compliance",
    desc: "A law firm website needs to reinforce trust at every point. We include all the elements that establish credibility: accreditations, society memberships, secure forms, and a professional privacy policy.",
    items: ["NZLS accreditation display", "Secure contact forms (SSL)", "Privacy policy (GDPR/NZ Privacy Act)", "Professional colour and typography"],
  },
];

const process = [
  { step: "1", title: "Discovery Call", desc: "We learn your practice areas, ideal client profile, and what differentiates your firm. We discuss tone — some firms are formal and established, others are approachable and modern." },
  { step: "2", title: "Structure & Copy", desc: "We plan your practice area pages, solicitor profiles, and enquiry form structure. Copywriting is available as an add-on — plain-English legal copy that speaks to clients, not peers." },
  { step: "3", title: "Design & Build", desc: "We build in WordPress with a professional, trustworthy aesthetic — dark navy or charcoal tones, clean typography, structured layouts that communicate authority." },
  { step: "4", title: "Launch & Ads Setup", desc: "Site goes live with full SEO foundations. If Google Ads are part of the scope, we set up campaigns and landing pages simultaneously." },
];

const faqs = [
  { q: "Do you have experience building websites for law firms specifically?", a: "Yes. Legal websites have specific requirements: practice area page structure, solicitor profiles, intake forms, and trust signals that matter to people making high-stakes decisions. We've built sites for Auckland solicitors across family law, commercial, property, and employment practice areas. See our <a href=\"/small-business-website-design-auckland/\">web design packages</a> for scope and pricing." },
  { q: "Can you write the copy for our practice area pages?", a: "Yes. We offer copywriting as an add-on. Legal copy needs to be written for the person in the situation — not for other lawyers. We write in plain English that addresses the client's concern, explains your approach, and ends with a clear call to action. <a href=\"/seo-auckland/\">SEO keyword research</a> is included." },
  { q: "We have multiple solicitors — can each have their own page?", a: "Yes. Solicitor profile pages are standard for multi-partner firms. Each page includes a professional photo, admitted year, practice areas, credentials, and a brief personal statement. We can also route enquiries to the appropriate solicitor based on the matter type selected. Combined with <a href=\"/local-seo-for-auckland-small-businesses/\">local SEO</a>, each solicitor can also rank for their own practice area searches." },
  { q: "Do you handle Google Ads for law firms?", a: "Yes. Legal is one of the most competitive — and most rewarding — categories in <a href=\"/google-ads/\">Google Ads</a>. We manage campaigns for Auckland law firms including keyword strategy, ad copy, and dedicated landing pages per practice area. We charge a management fee separate from the build." },
  { q: "How much does a law firm website cost?", a: "A professional <a href=\"/small-business-website-design-auckland/\">law firm website</a> (5–8 pages, solicitor profiles, intake form, <a href=\"/seo-auckland/\">SEO</a> foundations) starts from $1,990 + GST. Larger multi-solicitor firms with extensive practice area pages are quoted by scope. We give you a fixed price before starting." },
];
---

<Layout
  title="Web Design for Auckland Lawyers & Law Firms | Kiwi Web Design"
  description="Website design for Auckland solicitors and law firms. Professionally built WordPress sites with practice area pages, consultation booking, and Google Ads landing pages."
  canonicalURL="https://www.kiwiwebdesign.co.nz/how-kiwi-web-design-helps-auckand-lawyers/"
  schema={schema}
>

  <PageHero
    eyebrow="Web Design for Law Firms"
    title="Your website should win clients before you've spoken a word."
    subtitle="Auckland solicitors and law firms rely on first impressions. We build WordPress websites that communicate authority, structure practice area content for search, and convert enquiries into consultations."
    ctaPrimary={{ text: "Get a Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See What's Included", href: "#solutions" }}
  />

  <!-- Why legal websites are different -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="The Challenge"
        title="Legal clients judge before they call."
        subtitle="People searching for a lawyer are often in a stressful situation. Their first interaction with your firm is your website — and they're deciding whether to trust you within seconds."
      />
      <div class="ind-pain-grid">
        {painPoints.map(({ icon, title, desc }) => (
          <div class="ind-pain-card">
            <span class="ipc-icon">{icon}</span>
            <h3 class="ipc-title">{title}</h3>
            <p class="ipc-desc">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Solutions -->
  <section class="section" id="solutions">
    <div class="container">
      <SectionHeader
        eyebrow="What We Build"
        title="Every element of a high-converting law firm website."
        subtitle="From practice area pages to Google Ads landing pages — built to turn searches into consultations."
      />
      <ServiceGrid items={solutions} cols={3} />
    </div>
  </section>

  <!-- Authority callout -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <div class="ind-callout">
        <div class="ind-callout-text">
          <p class="ind-callout-eyebrow">Why It Matters</p>
          <h2>Legal clients don't shop by price — they shop by trust.</h2>
          <p>A prospective client searching for an employment lawyer after being dismissed, or a property buyer needing conveyancing advice, is not comparing hourly rates on your homepage. They're looking for signals that you're competent, established, and will handle their matter properly.</p>
          <p>Your website needs to communicate that within the first five seconds. That means a clean, authoritative design, clear practice area pages written for the person in their situation, and visible trust signals — credentials, accreditations, and real solicitor profiles.</p>
        </div>
        <div class="ind-callout-stats">
          <div class="ind-stat"><span class="is-fig">73%</span><span class="is-label">of people research a lawyer online before making first contact</span></div>
          <div class="ind-stat"><span class="is-fig">4×</span><span class="is-label">higher conversion rate from practice-specific landing pages vs homepage</span></div>
          <div class="ind-stat"><span class="is-fig">#1</span><span class="is-label">Legal is among the highest-value Google Ads categories in New Zealand</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="How We Work"
        title="From brief to live site in 2–3 weeks."
        subtitle="We understand that busy solicitors don't have hours to spend on website meetings."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Law Firm Website Questions Answered"
        subtitle="What Auckland solicitors ask before starting a project with us."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design</a>
        <a href="/local-seo-for-auckland-small-businesses/" class="rps-link">Local SEO</a>
        <a href="/seo-auckland/" class="rps-link">SEO Services</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to build a site your clients will trust?"
    subtitle="Free consultation — we'll review your current site and tell you exactly what needs to change."
    ctaPrimary={{ text: "Get a Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See All Industries", href: "/industries-we-serve-in-auckland/" }}
  />

</Layout>

<style>
  .ind-pain-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .ind-pain-card {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 14px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ipc-icon { font-size: 1.75rem; }
  .ipc-title { font-family: var(--kwd-font-body); font-size: 0.95rem; font-weight: 700; color: var(--kwd-dark); margin: 0; }
  .ipc-desc { font-size: 0.875rem; color: var(--kwd-brown); line-height: 1.65; margin: 0; }

  .ind-callout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .ind-callout-eyebrow { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--kwd-yellow); margin-bottom: 0.75rem; }
  .ind-callout-text h2 { font-size: clamp(1.4rem, 2.5vw, 1.875rem); color: #fff; margin-bottom: 0.75rem; line-height: 1.25; }
  .ind-callout-text p { font-size: 0.9rem; color: rgba(255,255,255,0.65); line-height: 1.7; margin-bottom: 0.75rem; }
  .ind-callout-stats { display: flex; flex-direction: column; gap: 1rem; }
  .ind-stat {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .is-fig { font-family: var(--kwd-font-heading); font-size: 1.75rem; color: var(--kwd-yellow); flex-shrink: 0; min-width: 72px; line-height: 1; }
  .is-label { font-size: 0.85rem; color: rgba(255,255,255,0.65); line-height: 1.5; }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
  @media (max-width: 900px) {
    .ind-callout { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  @media (max-width: 640px) {
    .ind-pain-grid { grid-template-columns: 1fr; }
  }
</style>
