---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post: CollectionEntry<'blog'>) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props { post: CollectionEntry<'blog'>; }
const { post } = Astro.props;
const { Content } = await render(post);

const { title, description, pubDate, image } = post.data;

const canonicalURL = `https://www.kiwiwebdesign.co.nz/affordable-web-design-auckland/${post.slug}/`;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-NZ', { day: 'numeric', month: 'long', year: 'numeric' });
}

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": title,
      "description": description,
      "datePublished": pubDate.toISOString(),
      "image": image || "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/04/android-chrome-512x512-1.png",
      "author": {
        "@type": "Person",
        "name": "Charlie Chao",
        "url": "https://www.kiwiwebdesign.co.nz/about-us/"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Kiwi Web Design",
        "url": "https://www.kiwiwebdesign.co.nz/",
        "logo": {
          "@type": "ImageObject",
          "url": "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/04/android-chrome-512x512-1.png"
        }
      },
      "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalURL }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.kiwiwebdesign.co.nz/affordable-web-design-auckland/" },
        { "@type": "ListItem", "position": 3, "name": title }
      ]
    }
  ]
};
---

<Layout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  schema={schema}
>

  <!-- Reading progress bar -->
  <div class="progress-bar" id="progress-bar" aria-hidden="true"></div>

  <!-- Hero -->
  <header class="post-hero">
    {image && (
      <div class="post-hero-bg" style={`background-image: url('${image}')`} aria-hidden="true"></div>
    )}
    <div class="post-hero-overlay" aria-hidden="true"></div>
    <div class="post-hero-inner container">
      <nav class="post-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/affordable-web-design-auckland/">Blog</a>
      </nav>
      <div class="post-meta">
        <time datetime={pubDate.toISOString()} class="post-date">{formatDate(pubDate)}</time>
        <span class="post-author">by Charlie Chao</span>
      </div>
      <h1 class="post-title">{title}</h1>
      <p class="post-desc">{description}</p>
    </div>
    <div class="post-hero-rule" aria-hidden="true"></div>
  </header>

  <!-- Article body -->
  <article class="post-body">
    <div class="post-container">
      <div class="post-content prose">
        <Content />
      </div>

      <!-- CTA -->
      <aside class="post-cta">
        <div class="post-cta-label">Ready to act on this?</div>
        <h2 class="post-cta-title">Close the gap before your competitors do.</h2>
        <p class="post-cta-sub">Get a free consultation with Kiwi Web Design — we'll review your current presence and show you exactly what's holding you back.</p>
        <a href="/website-designer-auckland/" class="post-cta-btn">Book a Free Consultation →</a>
      </aside>

      <!-- Back -->
      <div class="post-back">
        <a href="/affordable-web-design-auckland/">← Back to all articles</a>
      </div>
    </div>
  </article>

</Layout>

<style>
  /* ── Progress bar ── */
  .progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0%;
    background: var(--kwd-gold);
    z-index: 200;
    transition: width 0.1s linear;
  }

  /* ── Hero ── */
  .post-hero {
    position: relative;
    background: var(--kwd-dark);
    padding: 7rem 0 5rem;
    overflow: hidden;
  }
  .post-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.12;
    filter: grayscale(60%);
    transform: scale(1.04);
  }
  .post-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(44,41,39,0.6) 0%, rgba(44,41,39,0.95) 70%);
  }
  .post-hero-rule {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--kwd-gold) 0%, var(--kwd-yellow) 50%, transparent 100%);
  }
  .post-hero-inner {
    position: relative;
    z-index: 2;
    max-width: 860px;
    animation: heroIn 0.7s ease both;
  }
  @keyframes heroIn {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .post-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.4);
    margin-bottom: 1.75rem;
  }
  .post-breadcrumb a {
    color: rgba(255,255,255,0.4);
    transition: color 0.2s;
  }
  .post-breadcrumb a:hover { color: var(--kwd-yellow); }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }
  .post-date {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--kwd-gold);
  }
  .post-author {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.04em;
  }

  .post-title {
    font-family: var(--kwd-font-heading);
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: #fff;
    line-height: 1.1;
    margin: 0 0 1.25rem;
    max-width: 820px;
  }
  .post-desc {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.65;
    max-width: 640px;
    margin: 0;
  }

  /* ── Article body ── */
  .post-body {
    background: #fff;
    padding: 4rem 0 5rem;
  }
  .post-container {
    max-width: 740px;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  /* ── Prose ── */
  .prose {
    font-size: 1.05rem;
    line-height: 1.85;
    color: #2c2927;
  }

  /* Hide the H1 that duplicates the hero title */
  .prose :global(h1:first-child) {
    display: none;
  }

  /* Hide the duplicate hero image at top of content */
  .prose :global(p:first-of-type img) {
    display: none;
  }
  .prose :global(p:first-of-type:has(img)) {
    display: none;
  }

  .prose :global(h2) {
    font-family: var(--kwd-font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--kwd-dark);
    margin: 3rem 0 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 2px solid var(--kwd-gold);
    line-height: 1.2;
  }
  .prose :global(h3) {
    font-family: var(--kwd-font-heading);
    font-size: clamp(1.15rem, 2.5vw, 1.45rem);
    color: var(--kwd-dark);
    margin: 2.25rem 0 0.6rem;
  }
  .prose :global(h4) {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--kwd-brown);
    margin: 2rem 0 0.5rem;
  }
  .prose :global(p) {
    margin: 0 0 1.4rem;
  }
  .prose :global(a) {
    color: var(--kwd-dark);
    text-decoration: underline;
    text-decoration-color: var(--kwd-gold);
    text-underline-offset: 3px;
    font-weight: 600;
    transition: text-decoration-color 0.2s;
  }
  .prose :global(a:hover) {
    text-decoration-color: var(--kwd-dark);
  }
  .prose :global(strong) {
    font-weight: 700;
    color: var(--kwd-dark);
  }

  /* Bullet lists */
  .prose :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .prose :global(ul li) {
    padding-left: 1.5rem;
    position: relative;
    line-height: 1.65;
  }
  .prose :global(ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 8px;
    height: 8px;
    background: var(--kwd-gold);
    border-radius: 2px;
    transform: rotate(45deg);
  }
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.5rem;
  }
  .prose :global(ol li) {
    margin-bottom: 0.5rem;
    line-height: 1.65;
  }

  /* Blockquote as pull-quote band */
  .prose :global(blockquote) {
    margin: 2.5rem -2rem;
    padding: 2rem 2rem;
    background: var(--kwd-dark);
    border: none;
    border-radius: 0;
    position: relative;
    overflow: hidden;
  }
  .prose :global(blockquote::before) {
    content: '\201C';
    position: absolute;
    top: -0.5rem;
    left: 1.5rem;
    font-family: var(--kwd-font-heading);
    font-size: 6rem;
    color: var(--kwd-gold);
    opacity: 0.25;
    line-height: 1;
  }
  .prose :global(blockquote p) {
    font-family: var(--kwd-font-heading);
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
    color: #fff;
    line-height: 1.4;
    margin: 0;
    font-style: italic;
    position: relative;
    z-index: 1;
  }

  /* Images */
  .prose :global(img) {
    width: 100%;
    height: auto;
    border-radius: 4px;
    margin: 2rem 0;
    display: block;
  }

  /* Tables */
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9rem;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 8px;
    overflow: hidden;
  }
  .prose :global(th) {
    background: var(--kwd-dark);
    color: var(--kwd-yellow);
    text-align: left;
    padding: 0.75rem 1rem;
    font-weight: 700;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }
  .prose :global(td) {
    padding: 0.7rem 1rem;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    color: var(--kwd-dark);
  }
  .prose :global(tr:nth-child(even) td) {
    background: var(--kwd-cream);
  }

  /* Horizontal rule */
  .prose :global(hr) {
    border: none;
    border-top: 1px solid rgba(0,0,0,0.08);
    margin: 2.5rem 0;
  }

  /* ── CTA block ── */
  .post-cta {
    margin-top: 4rem;
    background: var(--kwd-dark);
    border-radius: 16px;
    padding: 3rem;
    position: relative;
    overflow: hidden;
  }
  .post-cta::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--kwd-gold), var(--kwd-yellow));
  }
  .post-cta-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-gold);
    margin-bottom: 0.75rem;
  }
  .post-cta-title {
    font-family: var(--kwd-font-heading);
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: #fff;
    margin: 0 0 0.875rem;
    line-height: 1.15;
  }
  .post-cta-sub {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.65);
    margin: 0 0 2rem;
    max-width: 480px;
    line-height: 1.6;
  }
  .post-cta-btn {
    display: inline-block;
    background: var(--kwd-yellow);
    color: var(--kwd-dark);
    padding: 0.85rem 2rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }
  .post-cta-btn:hover {
    background: var(--kwd-gold);
    transform: translateY(-1px);
  }

  /* ── Back link ── */
  .post-back {
    margin-top: 2.5rem;
    padding-top: 1.75rem;
    border-top: 1px solid rgba(0,0,0,0.07);
  }
  .post-back a {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--kwd-brown);
    text-decoration: none;
    transition: color 0.2s;
  }
  .post-back a:hover { color: var(--kwd-dark); }

  @media (max-width: 640px) {
    .post-hero { padding: 5.5rem 0 3.5rem; }
    .prose :global(blockquote) { margin: 2rem -1.5rem; }
    .post-cta { padding: 2rem 1.5rem; }
  }
</style>

<script>
  // Reading progress bar
  const bar = document.getElementById('progress-bar') as HTMLElement;
  if (bar) {
    const update = () => {
      const total = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width = total > 0 ? `${(window.scrollY / total) * 100}%` : '0%';
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>
