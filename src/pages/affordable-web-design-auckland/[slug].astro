---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post: CollectionEntry<'blog'>) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props { post: CollectionEntry<'blog'>; }
const { post } = Astro.props;
const { Content } = await render(post);

const { title, description, pubDate, image } = post.data;

const canonicalURL = `https://www.kiwiwebdesign.co.nz/affordable-web-design-auckland/${post.slug}/`;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-NZ', { day: 'numeric', month: 'long', year: 'numeric' });
}

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": title,
      "description": description,
      "datePublished": pubDate.toISOString(),
      "image": image || "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/04/android-chrome-512x512-1.png",
      "author": {
        "@type": "Person",
        "name": "Charlie Chao",
        "url": "https://www.kiwiwebdesign.co.nz/about-us/"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Kiwi Web Design",
        "url": "https://www.kiwiwebdesign.co.nz/",
        "logo": {
          "@type": "ImageObject",
          "url": "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/04/android-chrome-512x512-1.png"
        }
      },
      "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalURL }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.kiwiwebdesign.co.nz/affordable-web-design-auckland/" },
        { "@type": "ListItem", "position": 3, "name": title }
      ]
    }
  ]
};
---

<Layout
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  schema={schema}
>

  <!-- Post hero -->
  {image && (
    <div class="post-hero">
      <img src={image} alt={title} width="1200" height="630" loading="eager" class="hero-img" />
    </div>
  )}

  <article class="section">
    <div class="container post-container">

      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/affordable-web-design-auckland/">Blog</a>
        <span aria-hidden="true">›</span>
        <span>{title}</span>
      </nav>

      <!-- Post header -->
      <header class="post-header">
        <time class="post-date" datetime={pubDate.toISOString()}>
          {formatDate(pubDate)}
        </time>
        <h1>{title}</h1>
        <p class="post-desc">{description}</p>
      </header>

      <!-- Post content -->
      <div class="post-content prose">
        <Content />
      </div>

      <!-- CTA -->
      <div class="post-cta">
        <h2>Ready to grow your Auckland business online?</h2>
        <p>Get a free consultation with Kiwi Web Design — we'll show you exactly what's holding your website back.</p>
        <a href="/website-designer-auckland/" class="btn-primary">Book a Free Consultation</a>
      </div>

      <!-- Back to blog -->
      <div class="back-link">
        <a href="/affordable-web-design-auckland/">← Back to all articles</a>
      </div>

    </div>
  </article>

</Layout>

<style>
  .post-hero {
    width: 100%;
    max-height: 480px;
    overflow: hidden;
  }
  .hero-img {
    width: 100%;
    height: 480px;
    object-fit: cover;
    display: block;
  }

  .post-container {
    max-width: 820px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--kwd-brown);
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--kwd-brown); }
  .breadcrumb a:hover { color: var(--kwd-dark); }

  .post-header { margin-bottom: 2.5rem; }
  .post-date {
    display: block;
    font-size: 0.8rem;
    color: var(--kwd-brown);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }
  .post-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 1rem;
    line-height: 1.15;
  }
  .post-desc {
    font-size: 1.1rem;
    color: var(--kwd-brown);
    margin: 0;
    line-height: 1.6;
  }

  /* Prose styles for rendered Markdown */
  .prose {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--kwd-dark);
  }
  .prose :global(h2) {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    margin: 2.5rem 0 0.75rem;
    border-left: 4px solid var(--kwd-yellow);
    padding-left: 0.875rem;
  }
  .prose :global(h3) {
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    margin: 2rem 0 0.5rem;
  }
  .prose :global(h4) {
    font-size: 1.05rem;
    margin: 1.5rem 0 0.4rem;
  }
  .prose :global(p) {
    margin: 0 0 1.25rem;
  }
  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
  }
  .prose :global(li) {
    margin-bottom: 0.4rem;
  }
  .prose :global(a) {
    color: var(--kwd-dark);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose :global(a:hover) { color: var(--kwd-brown); }
  .prose :global(strong) { font-weight: 700; }
  .prose :global(img) {
    width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5rem 0;
  }
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }
  .prose :global(th) {
    background: var(--kwd-dark);
    color: var(--kwd-white);
    text-align: left;
    padding: 10px 14px;
    font-weight: 600;
  }
  .prose :global(td) {
    padding: 9px 14px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  .prose :global(tr:nth-child(even) td) {
    background: var(--kwd-cream);
  }
  .prose :global(blockquote) {
    border-left: 4px solid var(--kwd-yellow);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: var(--kwd-cream);
    border-radius: 0 6px 6px 0;
    font-style: italic;
  }

  /* Post CTA */
  .post-cta {
    background: var(--kwd-dark);
    color: var(--kwd-white);
    border-radius: 10px;
    padding: 2.5rem;
    margin-top: 3rem;
    text-align: center;
  }
  .post-cta h2 {
    color: var(--kwd-white);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    margin-bottom: 0.75rem;
  }
  .post-cta p {
    color: rgba(255,255,255,0.75);
    margin-bottom: 1.5rem;
  }

  .back-link {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(0,0,0,0.08);
  }
  .back-link a {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--kwd-brown);
  }
  .back-link a:hover { color: var(--kwd-dark); }
</style>
