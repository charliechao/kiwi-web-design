---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog');
const posts = allPosts.sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Blog",
      "@id": "https://www.kiwiwebdesign.co.nz/affordable-web-design-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/affordable-web-design-auckland/",
      "name": "Free Resources to Help Kiwi Small Businesses",
      "description": "Web design, SEO, and online marketing guides for Auckland small businesses.",
      "inLanguage": "en-NZ",
      "publisher": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/affordable-web-design-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Blog" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

function formatDate(date: Date) {
  return date.toLocaleDateString('en-NZ', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<Layout
  title="Free web design resources for small businesses in Auckland"
  description="Web design, SEO, and online marketing guides for Auckland small businesses. Free resources from Kiwi Web Design."
  canonicalURL="https://www.kiwiwebdesign.co.nz/affordable-web-design-auckland/"
  schema={schema}
>

  <section class="blog-hero section-dark">
    <div class="container">
      <p class="eyebrow">NZ Small Business Know-How</p>
      <h1>Free Resources to Help Kiwi Small Businesses</h1>
      <p class="hero-desc">Web design, SEO, and online marketing guides — written for Auckland business owners.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="posts-grid">
        {posts.map((post: CollectionEntry<'blog'>) => (
          <article class="post-card">
            {post.data.image && (
              <a href={`/affordable-web-design-auckland/${post.slug}/`} tabindex="-1" aria-hidden="true">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  width="600"
                  height="340"
                  loading="lazy"
                  class="post-img"
                />
              </a>
            )}
            <div class="post-body">
              <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
              <h2 class="post-title">
                <a href={`/affordable-web-design-auckland/${post.slug}/`}>{post.data.title}</a>
              </h2>
              <p class="post-desc">{post.data.description}</p>
              <a href={`/affordable-web-design-auckland/${post.slug}/`} class="read-more">Read More →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .blog-hero { padding: 5rem 0; }
  .blog-hero h1 { color: var(--kwd-white); margin-bottom: 1rem; }
  .eyebrow {
    color: var(--kwd-yellow);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.75rem;
  }
  .hero-desc {
    color: rgba(255,255,255,0.75);
    font-size: 1.05rem;
    max-width: 560px;
    margin: 0;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .post-card {
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s;
    background: var(--kwd-white);
  }
  .post-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.09); }
  .post-img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }
  .post-body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .post-date {
    font-size: 0.78rem;
    color: var(--kwd-brown);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .post-title {
    font-size: 1rem;
    font-family: var(--kwd-font-heading);
    margin: 0;
    line-height: 1.3;
    flex: 1;
  }
  .post-title a { color: var(--kwd-dark); }
  .post-title a:hover { color: var(--kwd-brown); }
  .post-desc {
    font-size: 0.875rem;
    color: var(--kwd-brown);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .read-more {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--kwd-dark);
    margin-top: 0.5rem;
    transition: color 0.2s;
  }
  .read-more:hover { color: var(--kwd-brown); }

  @media (max-width: 900px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
