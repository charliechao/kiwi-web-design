---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import StatsRow from '../../components/StatsRow.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const allPosts = await getCollection('blog');
const posts = allPosts.sort(
  (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) =>
    b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const stats = [
  { number: "From $1,290", label: "Fixed-price websites, no lock-in" },
  { number: "2–3 wks", label: "Typical delivery time" },
  { number: "50+", label: "Auckland businesses helped" },
  { number: "5★", label: "Average Google rating" },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": "https://www.kiwiwebdesign.co.nz/affordable-web-design-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/affordable-web-design-auckland/",
      "name": "Affordable Web Design Auckland | Kiwi Web Design",
      "description": "Affordable web design for Auckland small businesses. Fixed-price websites from $1,290 + GST, no lock-in contracts, live in 2-3 weeks. Free guides and pricing resources below.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "publisher": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/affordable-web-design-auckland/#breadcrumb" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": [".blog-snippet", "h1"] }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/affordable-web-design-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Affordable Web Design Auckland", "item": "https://www.kiwiwebdesign.co.nz/affordable-web-design-auckland/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Affordable Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "Place", "name": "Auckland" },
        { "@type": "Place", "name": "New Zealand" }
      ],
      "priceRange": "$$",
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5", "ratingCount": "50", "bestRating": "5" },
      "logo": { "@type": "ImageObject", "url": "https://www.kiwiwebdesign.co.nz/favicon.png", "width": 512, "height": 512 }
    }
  ]
};

function formatDate(date: Date) {
  return date.toLocaleDateString('en-NZ', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<Layout
  title="Affordable Web Design Auckland | From $1,290 | Kiwi Web Design"
  description="Affordable web design for Auckland small businesses. Fixed-price websites from $1,290 + GST, no lock-in contracts, live in 2-3 weeks. Free guides and pricing resources below."
  canonicalURL="https://www.kiwiwebdesign.co.nz/affordable-web-design-auckland/"
  schema={schema}
>

  <PageHero
    eyebrow="Auckland Web Design, Without the Agency Price Tag"
    title="Affordable Web Design Auckland"
    subtitle="Custom, fixed-price websites for Auckland small businesses, no lock-in contracts, no bloated agency overhead. Most projects are quoted in writing before you commit and live within 2-3 weeks."
    ctaPrimary={{ text: 'Get a Free Quote', href: '/website-designer-auckland/' }}
    ctaSecondary={{ text: 'See Full Packages', href: '/small-business-website-design-auckland/' }}
  />

  <StatsRow items={stats} accent={true} />

  <!-- AI citability snippet -->
  <div class="blog-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> builds affordable, custom websites for Auckland small businesses from $1,290 + GST, fixed price, no lock-in contracts, live in 2-3 weeks. Based in Grey Lynn, Auckland. 5★ Google rating from 50+ clients. This page also publishes free web design, SEO, and digital marketing guides, including website cost guides, Google Business Profile setup, and local SEO tips.</p>
    </div>
  </div>

  <section class="section" style="padding-bottom: 0;">
    <div class="container">
      <SectionHeader
        eyebrow="Free Resources"
        title="Guides to help you plan your website"
        subtitle="Practical, no-fluff advice on web design, SEO, and online marketing for Auckland small businesses."
      />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="posts-grid">
        {posts.map((post: CollectionEntry<'blog'>) => (
          <article class="post-card">
            {post.data.image && (
              <a href={`/affordable-web-design-auckland/${post.slug}/`} tabindex="-1" aria-hidden="true">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  width="600"
                  height="340"
                  loading="lazy"
                  class="post-img"
                />
              </a>
            )}
            <div class="post-body">
              <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
              <h2 class="post-title">
                <a href={`/affordable-web-design-auckland/${post.slug}/`}>{post.data.title}</a>
              </h2>
              <p class="post-desc">{post.data.description}</p>
              <a href={`/affordable-web-design-auckland/${post.slug}/`} class="read-more">Read More →</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .blog-snippet { background: #fff8e1; border-left: 4px solid var(--kwd-yellow); padding: 1rem 0; }
  .blog-snippet p { margin: 0; font-size: 0.95rem; line-height: 1.65; color: var(--kwd-dark); }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .post-card {
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s;
    background: var(--kwd-white);
  }
  .post-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.09); }
  .post-img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }
  .post-body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .post-date {
    font-size: 0.78rem;
    color: var(--kwd-brown);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .post-title {
    font-size: 1rem;
    font-family: var(--kwd-font-heading);
    margin: 0;
    line-height: 1.3;
    flex: 1;
  }
  .post-title a { color: var(--kwd-dark); }
  .post-title a:hover { color: var(--kwd-brown); }
  .post-desc {
    font-size: 0.875rem;
    color: var(--kwd-brown);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .read-more {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--kwd-dark);
    margin-top: 0.5rem;
    transition: color 0.2s;
  }
  .read-more:hover { color: var(--kwd-brown); }

  @media (max-width: 900px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .posts-grid { grid-template-columns: 1fr; }
  }
</style>
