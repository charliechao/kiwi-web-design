---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import heroImg from '../assets/general/about.jpg';
import Icon from '../components/Icon.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/website-branding/",
      "url": "https://www.kiwiwebdesign.co.nz/website-branding/",
      "name": "Website Branding Auckland | Brand Identity for Small Businesses",
      "description": "Brand first, website second. Website branding for small businesses in Auckland — logo, colours, fonts, and messaging that make your site feel consistent and professional.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/website-branding/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/website-branding/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Website Branding" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const services = [
  {
    icon: "🔷",
    title: "Logo Design",
    desc: "A professional logo that works across digital and print — your website, business cards, uniforms, vehicle wraps, and social profiles. Supplied in all formats.",
    items: ["Primary logo + variations", "PNG, SVG, PDF files", "Light & dark versions", "Icon/favicon version"],
  },
  {
    icon: "🎨",
    title: "Colour Palette",
    desc: "A defined colour system — primary, secondary, and accent colours — with HEX, RGB, and CMYK values so every touchpoint looks consistent.",
    items: ["Primary & secondary colours", "HEX / RGB / CMYK codes", "Accessibility contrast check", "Usage guidance"],
  },
  {
    icon: "✍️",
    title: "Typography System",
    desc: "Paired font choices — a heading font and a body font — that reflect your brand personality and are optimised for web performance.",
    items: ["Heading & body font pair", "Scale & sizing guide", "Web font setup (Google Fonts)", "Print font alternatives"],
  },
  {
    icon: "📣",
    title: "Brand Voice & Messaging",
    desc: "Your tagline, value proposition, and core messaging framework — so everyone in your business communicates consistently.",
    items: ["Tagline / strapline", "Elevator pitch", "Key messages by audience", "Tone of voice guide"],
  },
  {
    icon: "📋",
    title: "Brand Style Guide",
    desc: "A single reference document covering your logo usage rules, colour palette, typography, imagery style, and tone of voice.",
    items: ["Logo usage rules (do/don't)", "Colour & font guide", "Imagery & photography style", "Social media templates"],
  },
  {
    icon: "🌐",
    title: "Brand Implementation",
    desc: "We apply your new brand consistently across your WordPress site — colours, fonts, button styles, and imagery — so the site and the brand are perfectly aligned.",
    items: ["WordPress theme branding", "CSS variables setup", "Component styling", "Favicon & OG image"],
  },
];

const whyBrandFirst = [
  { icon: "🔄", title: "Rebrand without rebuild", desc: "A well-documented brand system means you can update your site's look in minutes — not weeks — because everything is defined and consistent." },
  { icon: "✅", title: "Consistency builds trust", desc: "When your site, cards, social, and signage all match, customers perceive you as more established and professional — even if you're a one-person operation." },
  { icon: "🎯", title: "Design decisions get easier", desc: "With a defined colour and typography system, every future design decision is faster because the rules are already set." },
  { icon: "📸", title: "Photography looks intentional", desc: "A brand guide defines the style of photography that fits your brand — so stock photos and your own images all feel cohesive." },
];

const process = [
  { step: "1", title: "Discovery & Moodboard", desc: "We start with a brand questionnaire and a visual moodboard session — presenting 2–3 direction options with example logos, colours, and fonts." },
  { step: "2", title: "Logo Concepts", desc: "We design 2–3 logo concepts based on your chosen direction. You select one and we refine it through up to 2 rounds of revisions." },
  { step: "3", title: "Full Brand System", desc: "We develop the colour palette, typography pair, brand voice guide, and style guide around your approved logo." },
  { step: "4", title: "Delivery & Implementation", desc: "We deliver all files (PNG, SVG, PDF) with a brand style guide — and if you're building a site with us, we apply the brand immediately." },
];

const faqs = [
  { q: "Do I need branding before building a website?", a: "Ideally, yes. A website built without a defined brand can feel inconsistent and is harder to maintain. That said, we often do them together — designing the brand and applying it to the <a href=\"/small-business-website-design-auckland/\">website build</a> as a single engagement. This is usually the most efficient approach." },
  { q: "What if I already have a logo but nothing else?", a: "We work from your existing logo and build out the full brand system around it — colour palette, typography, messaging, and style guide. We'll assess whether the logo itself holds up at web sizes or needs refining." },
  { q: "What file formats will I receive?", a: "You receive your logo in PNG (transparent background), SVG (vector, scalable), and PDF formats. This covers digital, web, and print use cases. We also supply a web-optimised favicon and an OG (Open Graph) image for social sharing." },
  { q: "Can you redesign my existing brand?", a: "Yes. We do full rebrands and brand refreshes. A rebrand retains your business name and builds a new visual identity from scratch. A refresh updates your existing logo and colour palette while preserving recognisability." },
  { q: "How much does branding cost?", a: "Our starter branding package (logo + colour palette + typography) starts from $690 + GST. A full brand system (logo + style guide + messaging) runs $1,200–$1,800 + GST. When combined with a <a href=\"/wordpress-website-design-auckland/\">WordPress website build</a>, we offer bundled pricing. For content to match your new brand, see our <a href=\"/website-copywriting-auckland/\">website copywriting service</a>." },
];
---

<Layout
  title="Website Branding Auckland | Brand Identity for Small Businesses"
  description="Brand first, website second. Website branding for small businesses in Auckland — logo, colours, fonts, and messaging that make your site feel consistent and professional."
  canonicalURL="https://www.kiwiwebdesign.co.nz/website-branding/"
  schema={schema}
>

  <PageHero
    eyebrow="Website Branding Auckland"
    title="Brand first. Website second. Always."
    subtitle="A website works best when your brand is clear. Logo, colours, fonts, and messaging — defined, documented, and applied consistently across every touchpoint."
    badgeText="From $690 + GST"
    ctaPrimary={{ text: "Get a Branding Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See What's Included", href: "#services" }}
    imgSrc={heroImg.src}
    imgAlt="Website branding Auckland small business"
  />

  <!-- Why brand first -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="Why It Matters"
        title="Your brand is the foundation your website is built on."
        subtitle="Kiwi small businesses often grow fast and the brand falls behind. This service helps you catch up — and stay consistent."
      />
      <div class="brand-why-grid">
        {whyBrandFirst.map(({ icon, title, desc }) => (
          <div class="brand-why-card">
            <span class="bwc-icon"><Icon name={icon} size={24} /></span>
            <h3 class="bwc-title">{title}</h3>
            <p class="bwc-desc">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" id="services">
    <div class="container">
      <SectionHeader
        eyebrow="Branding Services"
        title="Everything in a complete brand system."
        subtitle="From your first logo to a full brand guide — we cover every element of consistent brand identity."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- Brand vs no-brand -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="With vs Without"
        title="What a defined brand does for your website."
        light={true}
      />
      <div class="brand-compare">
        <div class="brand-compare-col brand-compare-col--without">
          <p class="bcc-label">Without a brand system</p>
          <ul>
            <li>Inconsistent colours across pages</li>
            <li>Multiple fonts that clash</li>
            <li>Generic stock photos that don't fit</li>
            <li>Hard to brief any designer or developer</li>
            <li>Looks different on social vs the website</li>
            <li>Every update takes longer without clear rules</li>
          </ul>
        </div>
        <div class="brand-compare-col brand-compare-col--with">
          <p class="bcc-label bcc-label--good">With a brand system</p>
          <ul>
            <li>Every page feels intentionally designed</li>
            <li>One font pair — consistent across everything</li>
            <li>Photography style guide makes every image fit</li>
            <li>Any designer can pick up and apply your brand</li>
            <li>Website, social, and print all look cohesive</li>
            <li>Fast design decisions — the rules are already set</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="From discovery to delivery in 1–2 weeks."
        subtitle="A focused, collaborative process for clear branding outcomes."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Branding Questions Answered"
        subtitle="Common questions from Auckland small business owners about brand identity."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design Packages</a>
        <a href="/website-copywriting-auckland/" class="rps-link">Web Copywriting</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress</a>
        <a href="/website-design-process-in-auckland/" class="rps-link">Design Process</a>
        <a href="/website-designer-auckland/" class="rps-link">Contact</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to build a brand that matches your ambition?"
    subtitle="Get a fixed quote for your branding project — logo, style guide, and messaging included."
    ctaPrimary={{ text: "Get a Branding Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "Bundle With a Website", href: "/small-business-website-design-auckland/" }}
  />

</Layout>

<style>
  .brand-why-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .brand-why-card { background: #fff; border: 1.5px solid rgba(0,0,0,0.07); border-radius: 14px; padding: 1.75rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .bwc-icon { }
  .bwc-title { font-family: var(--kwd-font-body); font-size: 0.95rem; font-weight: 700; color: var(--kwd-dark); margin: 0; }
  .bwc-desc { font-size: 0.83rem; color: var(--kwd-brown); line-height: 1.6; margin: 0; }

  .brand-compare { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 2.5rem; }
  .brand-compare-col { border-radius: 16px; padding: 2rem; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.04); }
  .brand-compare-col--with { background: rgba(251,232,166,0.07); border-color: rgba(251,232,166,0.2); }
  .bcc-label { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.35); margin-bottom: 1.25rem; }
  .bcc-label--good { color: var(--kwd-yellow); }
  .brand-compare-col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .brand-compare-col li { font-size: 0.875rem; line-height: 1.5; padding-left: 1.4rem; position: relative; }
  .brand-compare-col--without li { color: rgba(255,255,255,0.5); }
  .brand-compare-col--without li::before { content: "✗"; position: absolute; left: 0; color: rgba(255,255,255,0.25); font-weight: 700; }
  .brand-compare-col--with li { color: rgba(255,255,255,0.82); }
  .brand-compare-col--with li::before { content: "✓"; position: absolute; left: 0; color: var(--kwd-yellow); font-weight: 700; }

  @media (max-width: 900px) {
    .brand-why-grid { grid-template-columns: repeat(2, 1fr); }
    .brand-compare { grid-template-columns: 1fr; }
  }
  @media (max-width: 580px) { .brand-why-grid { grid-template-columns: 1fr; } }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
