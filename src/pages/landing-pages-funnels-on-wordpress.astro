---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/landing-pages-funnels-on-wordpress/",
      "url": "https://www.kiwiwebdesign.co.nz/landing-pages-funnels-on-wordpress/",
      "name": "Landing Pages & Funnels on WordPress",
      "description": "High-converting WordPress landing pages with optimised forms, CTAs, and tracking. Affordable lead-gen for Auckland businesses by Kiwi Web Design.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/landing-pages-funnels-on-wordpress/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/landing-pages-funnels-on-wordpress/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Landing Pages & Funnels" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const services = [
  {
    icon: "🎯",
    title: "Google Ads Landing Pages",
    desc: "Dedicated landing pages matched to specific ad campaigns — same keywords, same message, same offer. Conversion-optimised and tracking-ready.",
    items: ["Ad-to-page message match", "Conversion tracking setup", "A/B variant support", "Quality Score optimisation"],
  },
  {
    icon: "📋",
    title: "Lead Capture Pages",
    desc: "Single-purpose pages designed to capture name, email, and phone in exchange for a free quote, consultation, download, or offer.",
    items: ["Distraction-free layout", "Multi-step form option", "Email integration", "Thank-you page with next step"],
  },
  {
    icon: "💰",
    title: "Sales & Offer Pages",
    desc: "Long-form sales pages for services, courses, or products — designed with proven conversion frameworks and psychological triggers.",
    items: ["Problem–solution structure", "Social proof sections", "Objection handling copy", "Multiple CTA placements"],
  },
  {
    icon: "🔄",
    title: "Email Opt-In Funnels",
    desc: "Lead magnet landing pages connected to your email marketing platform — Mailchimp, Klaviyo, ActiveCampaign — with automated welcome sequences.",
    items: ["Lead magnet delivery", "Email platform integration", "Welcome sequence setup", "List segmentation"],
  },
  {
    icon: "📊",
    title: "Conversion Tracking",
    desc: "GA4 goal setup, Google Ads conversion events, Facebook Pixel, and heatmap tools so you know exactly what's working on every page.",
    items: ["GA4 conversion events", "Google Ads tracking", "Facebook Pixel", "Hotjar / heatmaps"],
  },
  {
    icon: "🧪",
    title: "A/B Testing Setup",
    desc: "We set up simple A/B tests for headlines, CTAs, and form layouts — so you can improve conversion rates over time with real data.",
    items: ["Headline variant testing", "CTA button testing", "Form length testing", "Analytics reporting"],
  },
];

const anatomy = [
  { icon: "🏷️", label: "Headline", desc: "One clear, benefit-led headline that matches the ad or link that brought the visitor here." },
  { icon: "📝", label: "Subheadline", desc: "A supporting sentence that reinforces the headline and gives context." },
  { icon: "⭐", label: "Social proof", desc: "Reviews, logos, or numbers that establish trust before the ask." },
  { icon: "✓", label: "Benefits list", desc: "3–5 bullet points focused on outcomes, not features." },
  { icon: "📋", label: "Form / CTA", desc: "A short form or prominent button — the single conversion action on the page." },
  { icon: "🔒", label: "Trust signals", desc: "Privacy assurance, 'no spam' promise, or guarantee to remove form friction." },
];

const process = [
  { step: "1", title: "Goal & Audience", desc: "We define the single conversion goal (quote request, call, download) and the specific audience segment the page is for." },
  { step: "2", title: "Copy & Structure", desc: "We write the headline, benefits, social proof, and CTA copy — and map the page structure before any design begins." },
  { step: "3", title: "Design & Build", desc: "We design and build the page in WordPress, optimised for mobile, with tracking codes and form integrations installed." },
  { step: "4", title: "Test & Launch", desc: "We QA on all devices, test form submissions, verify tracking, and launch. We hand over with a brief on how to read the analytics." },
];

const faqs = [
  { q: "What's the difference between a landing page and a website page?", a: "A regular website page has navigation, links to other pages, and serves multiple purposes. A landing page removes all distractions — no nav, no footer links — and focuses a visitor on one single action. This focus is what makes landing pages convert 3–5× better than standard pages for paid traffic." },
  { q: "Do I need a separate landing page for each Google Ad campaign?", a: "Yes — for best results. A dedicated landing page that matches your ad's keyword and message will get a higher Quality Score (reducing your cost per click) and convert at a higher rate. We build landing pages as standalone pages within your WordPress site." },
  { q: "Can I update the landing page myself after it's built?", a: "Yes. Landing pages are built in WordPress and can be edited like any other page. We set them up with flexible layouts so you can update copy, images, and offers without breaking the design." },
  { q: "What forms do you use?", a: "We typically use Gravity Forms or WPForms — both support multi-step forms, conditional logic, email notifications, and integrations with CRMs and email platforms. Gravity Forms is our preference for complex funnels." },
  { q: "Do landing pages work without paid ads?", a: "Yes. Landing pages can be used for any focused traffic source — email campaigns, social posts, partnerships, or organic SEO. They're particularly effective for any campaign where you want to control the visitor's path and measure conversions precisely." },
  { q: "How much do landing pages cost?", a: "A single conversion-optimised landing page starts from $390 + GST (design, copy structure, tracking setup). Multi-page funnels (opt-in → thank you → upsell) start from $790 + GST. We give you a fixed quote before we start." },
];
---

<Layout
  title="Landing Pages & Funnels on WordPress | High-Converting Lead Gen Auckland"
  description="High-converting WordPress landing pages with optimised forms, CTAs, and tracking. Affordable lead-gen for Auckland businesses by Kiwi Web Design."
  canonicalURL="https://www.kiwiwebdesign.co.nz/landing-pages-funnels-on-wordpress/"
  schema={schema}
>

  <PageHero
    eyebrow="Landing Pages & Funnels"
    title="Landing pages that turn ad clicks into leads."
    subtitle="Conversion-optimised WordPress landing pages for Google Ads, email campaigns, and lead generation — built with proven frameworks, tracking-ready, and mobile-first."
    badgeText="From $390 + GST"
    ctaPrimary={{ text: "Get a Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See What's Included", href: "#services" }}
  />

  <!-- Anatomy of a landing page -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="Anatomy of a Landing Page"
        title="Every element has a job to do."
        subtitle="A high-converting landing page isn't designed by feel — it follows a proven structure."
      />
      <div class="lp-anatomy">
        {anatomy.map(({ icon, label, desc }) => (
          <div class="lp-anat-item">
            <div class="lp-anat-icon-wrap">
              <span class="lp-anat-icon">{icon}</span>
            </div>
            <div>
              <strong class="lp-anat-label">{label}</strong>
              <p class="lp-anat-desc">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" id="services">
    <div class="container">
      <SectionHeader
        eyebrow="Landing Page Services"
        title="Every type of landing page and funnel."
        subtitle="From Google Ads click catchers to full lead-gen funnels."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- Why dedicated pages -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <div class="lp-why-wrap">
        <div>
          <p class="lp-why-eyebrow">Why It Matters</p>
          <h2>Sending ad traffic to your homepage is costing you leads.</h2>
          <p>Your homepage has to do too many things for too many people. A visitor from a Google Ad for 'emergency plumber Auckland' lands on your homepage and has to find what they need — most won't bother.</p>
          <p>A dedicated landing page for that same campaign tells that visitor exactly what they searched for, shows them why you're the best choice, and gives them one action to take. Conversion rates are typically 3–5× higher.</p>
        </div>
        <div class="lp-why-numbers">
          <div class="lp-why-num"><span class="lwn-fig">3–5×</span><span class="lwn-label">higher conversion rate with a dedicated landing page vs homepage</span></div>
          <div class="lp-why-num"><span class="lwn-fig">↓ CPC</span><span class="lwn-label">Google Ads Quality Score improves when ad and page message match</span></div>
          <div class="lp-why-num"><span class="lwn-fig">100%</span><span class="lwn-label">of conversions are trackable with proper GA4 goal setup</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="From goal to go-live in 3–5 days."
        subtitle="A fast, focused build process for landing pages."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Landing Page Questions Answered"
        subtitle="Common questions from Auckland businesses about landing pages and funnels."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
        <a href="/seo-auckland/" class="rps-link">SEO Auckland</a>
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design</a>
        <a href="/website-copywriting-auckland/" class="rps-link">Copywriting</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to turn more ad clicks into customers?"
    subtitle="Get a fixed quote for your landing page — we'll have it live in 3–5 days."
    ctaPrimary={{ text: "Get a Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Google Ads Management", href: "/google-ads/" }}
  />

</Layout>

<style>
  .lp-anatomy {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 2.5rem;
  }
  .lp-anat-item {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 12px;
    padding: 1.25rem;
  }
  .lp-anat-icon-wrap {
    width: 2.25rem;
    height: 2.25rem;
    background: var(--kwd-cream);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 1rem;
  }
  .lp-anat-label { display: block; font-size: 0.875rem; font-weight: 700; color: var(--kwd-dark); margin-bottom: 0.2rem; }
  .lp-anat-desc { font-size: 0.82rem; color: var(--kwd-brown); line-height: 1.5; margin: 0; }

  .lp-why-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .lp-why-eyebrow { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--kwd-yellow); margin-bottom: 0.75rem; }
  .lp-why-wrap h2 { font-size: clamp(1.5rem, 2.5vw, 2rem); color: #fff; margin-bottom: 0.75rem; }
  .lp-why-wrap p { font-size: 0.9rem; color: rgba(255,255,255,0.65); line-height: 1.7; margin-bottom: 0.75rem; }
  .lp-why-numbers { display: flex; flex-direction: column; gap: 1rem; }
  .lp-why-num {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .lwn-fig { font-family: var(--kwd-font-heading); font-size: 1.75rem; color: var(--kwd-yellow); flex-shrink: 0; min-width: 80px; line-height: 1; }
  .lwn-label { font-size: 0.85rem; color: rgba(255,255,255,0.65); line-height: 1.5; }

  @media (max-width: 900px) {
    .lp-anatomy { grid-template-columns: repeat(2, 1fr); }
    .lp-why-wrap { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  @media (max-width: 580px) { .lp-anatomy { grid-template-columns: 1fr; } }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
