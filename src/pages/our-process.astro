---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import Icon from '../components/Icon.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/our-process/",
      "url": "https://www.kiwiwebdesign.co.nz/our-process/",
      "name": "Our Process | How Kiwi Web Design Builds Your Website",
      "description": "See how Kiwi Web Design builds your website in three clear steps: discovery call, WordPress build, and launch. A simple process for Auckland and NZ businesses",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/our-process/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/our-process/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Our Process" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/04/android-chrome-512x512-1.png"
      }
    }
  ]
};

const phases = [
  {
    num: "01",
    label: "Week 1",
    title: "Discovery & Strategy",
    subtitle: "We learn your business before we touch a pixel.",
    color: "var(--kwd-yellow)",
    we: [
      "Free 30-minute consultation (phone or in-person Auckland)",
      "Review your current site and competitors",
      "Define your target customer and their search intent",
      "Agree on pages, sitemap, and URL structure",
      "Confirm your goals, timeline, and fixed-price quote",
    ],
    you: [
      "Tell us about your business and your best customers",
      "Share any sites you like or dislike (for visual reference)",
      "Provide your logo and brand colours (if you have them)",
      "Review and approve the sitemap before build begins",
    ],
    outcome: "Approved sitemap + fixed quote. You know exactly what you're getting and what it costs.",
  },
  {
    num: "02",
    label: "Weeks 2–3",
    title: "Design & Build",
    subtitle: "Your site is built in WordPress, fast, properly, with SEO from day one.",
    color: "var(--kwd-yellow)",
    we: [
      "Build your site in WordPress with Astra/GeneratePress theme",
      "Write or structure your page copy (if copywriting is included)",
      "Integrate your contact form, Google Maps, and Analytics",
      "Configure on-page SEO: titles, metas, headings, schema",
      "Set up speed optimisation, caching, and image compression",
      "Implement your branding, colours, fonts, logo",
    ],
    you: [
      "Provide content, images, and any specific copy you want used",
      "Answer questions as they come up (usually just a few)",
      "We handle everything technical, no input needed from you",
    ],
    outcome: "A fully built WordPress site ready for your review, on a staging URL.",
  },
  {
    num: "03",
    label: "Week 3–4",
    title: "Review & Launch",
    subtitle: "One round of feedback, then live. No surprise delays.",
    color: "var(--kwd-yellow)",
    we: [
      "Send you a staging link to review every page",
      "Apply your feedback (one full round of revisions included)",
      "Final QA: mobile, tablet, desktop across Chrome and Safari",
      "Test all forms, links, and conversion tracking",
      "Migrate to your hosting and connect your domain",
      "Submit sitemap to Google Search Console",
    ],
    you: [
      "Review the staging site and send us your consolidated feedback",
      "Approve the final version before we go live",
      "Confirm your domain registrar login (we handle the DNS)",
    ],
    outcome: "Your site is live, indexed by Google, and you're ready to start getting enquiries.",
  },
];

const commitments = [
  { icon: "📅", title: "Fixed timeline", desc: "Most sites launch within 2–4 weeks of brief approval. We set a launch date and stick to it." },
  { icon: "💰", title: "Fixed price", desc: "You get a fixed quote before we start. No hourly billing, no scope creep surprises." },
  { icon: "📞", title: "Direct communication", desc: "You deal with Charlie directly, no account managers, no offshore teams, no ticketing system." },
  { icon: "🎓", title: "Handover & training", desc: "At launch we give you a walkthrough of your site and a short video so you can make updates yourself." },
];

const faqs = [
  { q: "How long does a website project take?", a: "Most projects launch within 2–4 weeks from the date we receive your brief approval and content. Simple brochure sites can be live in 7–10 days. More complex builds with eCommerce or custom functionality take 3–5 weeks. We agree on a timeline upfront and stick to it. See our <a href=\"/small-business-website-design-auckland/\">web design packages</a> for a full breakdown of what's included in each tier." },
  { q: "What do I need to provide for you to get started?", a: "For the discovery call: nothing. We just need to talk. For the build to start: your logo (if you have one), any brand colours, photos you want used, and your key messaging. If you don't have these, we can help, we offer copywriting and branding as add-ons." },
  { q: "Can I make changes after the site is launched?", a: "Yes. WordPress is easy to update, text, images, and new pages can all be managed without a developer. We give you a handover walkthrough and a short screen-recording at launch. For ongoing updates or maintenance, ask about our <a href=\"/wordpress-maintenance-auckland/\">monthly maintenance plan</a>. You can also read more about how we work on the <a href=\"/website-design-process-in-auckland/\">design process page</a> or <a href=\"/about-us/\">about us</a>." },
  { q: "Do you work with clients outside Auckland?", a: "Yes. We work with businesses across New Zealand. The discovery call is over phone or Zoom, we don't need to meet in person unless you're local and prefer it." },
  { q: "What happens if I need more revisions than one round?", a: "One full round of revisions is included in every project. Additional revision rounds are available at our standard hourly rate ($95/hr + GST). In practice, most projects are resolved in one round when the brief is clear, which is why we spend time on discovery." },
  { q: "Is there a contract?", a: "Yes. We use a simple project agreement that covers scope, timeline, payment schedule, and ownership of files. You own the site and all content from day one. We ask for a 50% deposit to start and the balance on launch day." },
];
---

<Layout
  title="Our Process | How Kiwi Web Design Builds Your Website"
  description="See how Kiwi Web Design builds your website in three clear steps: discovery call, WordPress build, and launch. A simple process for Auckland and NZ businesses"
  canonicalURL="https://www.kiwiwebdesign.co.nz/our-process/"
  schema={schema}
>

  <!-- Hero -->
  <section class="proc-hero">
    <div class="container">
      <p class="proc-hero-eyebrow">How We Work</p>
      <h1>From first call to live site<br />in 2–4 weeks.</h1>
      <p class="proc-hero-sub">A clear, three-step process for Auckland small businesses. You'll know what's happening, when it's happening, and what you need to do at each stage.</p>
      <div class="proc-hero-btns">
        <a href="/website-designer-auckland/" class="proc-btn-primary">Start the Conversation</a>
        <a href="#step-01" class="proc-btn-outline">See the Steps ↓</a>
      </div>

      <!-- Phase overview strip -->
      <div class="proc-overview">
        <div class="proc-ov-item">
          <span class="proc-ov-num">01</span>
          <span class="proc-ov-label">Discovery & Strategy</span>
          <span class="proc-ov-time">Week 1</span>
        </div>
        <div class="proc-ov-divider">→</div>
        <div class="proc-ov-item">
          <span class="proc-ov-num">02</span>
          <span class="proc-ov-label">Design & Build</span>
          <span class="proc-ov-time">Weeks 2–3</span>
        </div>
        <div class="proc-ov-divider">→</div>
        <div class="proc-ov-item">
          <span class="proc-ov-num">03</span>
          <span class="proc-ov-label">Review & Launch</span>
          <span class="proc-ov-time">Week 3–4</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Detailed Steps Timeline -->
  <section class="section proc-steps-section">
    <div class="container">
      {phases.map((phase, idx) => (
        <div class="proc-step" id={`step-0${idx + 1}`}>

          <!-- Step header -->
          <div class="proc-step-header">
            <div class="proc-step-num-wrap">
              <span class="proc-step-num">{phase.num}</span>
            </div>
            <div class="proc-step-meta">
              <span class="proc-step-time">{phase.label}</span>
              <h2 class="proc-step-title">{phase.title}</h2>
              <p class="proc-step-subtitle">{phase.subtitle}</p>
            </div>
          </div>

          <!-- Step content grid -->
          <div class="proc-step-body">
            <div class="proc-col proc-col--we">
              <p class="proc-col-label">What we do</p>
              <ul class="proc-col-list">
                {phase.we.map(item => <li>{item}</li>)}
              </ul>
            </div>
            <div class="proc-col proc-col--you">
              <p class="proc-col-label">What you need to do</p>
              <ul class="proc-col-list">
                {phase.you.map(item => <li>{item}</li>)}
              </ul>
            </div>
          </div>

          <!-- Outcome badge -->
          <div class="proc-outcome">
            <span class="proc-outcome-icon">✓</span>
            <p class="proc-outcome-text"><strong>Outcome:</strong> {phase.outcome}</p>
          </div>

          {/* Connector line between steps */}
          {idx < phases.length - 1 && (
            <div class="proc-connector">
              <span class="proc-connector-line"></span>
              <span class="proc-connector-arrow">↓</span>
            </div>
          )}

        </div>
      ))}
    </div>
  </section>

  <!-- What to expect section -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="Our Commitments"
        title="What you can always expect from us."
        subtitle="Every project at Kiwi Web Design runs the same way, transparent, on time, and direct."
      />
      <div class="proc-commitments">
        {commitments.map(({ icon, title, desc }) => (
          <div class="proc-commit-card">
            <span class="pcc-icon"><Icon name={icon} size={24} /></span>
            <h3 class="pcc-title">{title}</h3>
            <p class="pcc-desc">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline visual -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="Project Timeline"
        title="What a typical project looks like."
        light={true}
        subtitle="From first contact to live site, here's the full picture."
      />
      <div class="proc-timeline">
        <div class="proc-tl-item">
          <div class="proc-tl-day">Day 1</div>
          <div class="proc-tl-dot"></div>
          <div class="proc-tl-content">
            <strong>Free consultation</strong>
            <p>30-minute call to understand your business and goals.</p>
          </div>
        </div>
        <div class="proc-tl-item">
          <div class="proc-tl-day">Day 2–3</div>
          <div class="proc-tl-dot"></div>
          <div class="proc-tl-content">
            <strong>Quote & sitemap</strong>
            <p>Fixed price quote and agreed page structure delivered within 24 hours.</p>
          </div>
        </div>
        <div class="proc-tl-item">
          <div class="proc-tl-day">Day 4–5</div>
          <div class="proc-tl-dot"></div>
          <div class="proc-tl-content">
            <strong>Deposit & kickoff</strong>
            <p>50% deposit confirms the project. Build begins immediately.</p>
          </div>
        </div>
        <div class="proc-tl-item">
          <div class="proc-tl-day">Days 6–18</div>
          <div class="proc-tl-dot proc-tl-dot--active"></div>
          <div class="proc-tl-content">
            <strong>Design & build</strong>
            <p>We build your site on a staging URL. You don't need to do anything.</p>
          </div>
        </div>
        <div class="proc-tl-item">
          <div class="proc-tl-day">Day 19–21</div>
          <div class="proc-tl-dot"></div>
          <div class="proc-tl-content">
            <strong>Staging review</strong>
            <p>You receive the staging link and send consolidated feedback.</p>
          </div>
        </div>
        <div class="proc-tl-item">
          <div class="proc-tl-day">Day 22–25</div>
          <div class="proc-tl-dot"></div>
          <div class="proc-tl-content">
            <strong>Revisions applied</strong>
            <p>We apply your feedback and prepare for final sign-off.</p>
          </div>
        </div>
        <div class="proc-tl-item">
          <div class="proc-tl-day">Day 26–28</div>
          <div class="proc-tl-dot proc-tl-dot--launch"></div>
          <div class="proc-tl-content">
            <strong>🚀 Live launch</strong>
            <p>Balance invoice paid, DNS connected, site live. Google Search Console submitted.</p>
          </div>
        </div>
      </div>
      <p class="proc-timeline-note">Timeline assumes prompt content supply and feedback. Delays in content or approvals will shift the launch date accordingly.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Process Questions Answered"
        subtitle="What Auckland business owners ask before starting a project with us."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design Packages</a>
        <a href="/website-design-process-in-auckland/" class="rps-link">Design Process</a>
        <a href="/about-us/" class="rps-link">About Us</a>
        <a href="/website-designer-auckland/" class="rps-link">Contact</a>
        <a href="/faq/" class="rps-link">FAQ</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to start the conversation?"
    subtitle="Free 30-minute consultation, no obligation, no hard sell. Just an honest chat about what you need."
    ctaPrimary={{ text: "Book Free Consultation", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "View Packages", href: "/small-business-website-design-auckland/" }}
  />

</Layout>

<style>
  /* ── Hero ── */
  .proc-hero {
    background: var(--kwd-dark);
    color: #fff;
    padding: 4.5rem 0 3rem;
    text-align: center;
  }
  .proc-hero-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-yellow);
    margin: 0 0 1rem;
  }
  .proc-hero h1 {
    font-family: var(--kwd-font-heading);
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.15;
    margin: 0 0 1.25rem;
    color: #fff;
  }
  .proc-hero-sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.72);
    line-height: 1.7;
    max-width: 580px;
    margin: 0 auto 2rem;
  }
  .proc-hero-btns {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }
  .proc-btn-primary {
    background: var(--kwd-yellow);
    color: var(--kwd-dark);
    padding: 0.8rem 1.875rem;
    border-radius: 6px;
    font-weight: 700;
    text-decoration: none;
    font-size: 0.95rem;
  }
  .proc-btn-outline {
    border: 2px solid rgba(255,255,255,0.35);
    color: rgba(255,255,255,0.85);
    padding: 0.8rem 1.875rem;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    font-size: 0.95rem;
  }

  /* ── Overview strip ── */
  .proc-overview {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 1.5rem 2rem;
    max-width: 680px;
    margin: 0 auto;
  }
  .proc-ov-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    text-align: center;
    flex: 1;
  }
  .proc-ov-num {
    font-family: var(--kwd-font-heading);
    font-size: 1.75rem;
    color: var(--kwd-yellow);
    line-height: 1;
  }
  .proc-ov-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: #fff;
  }
  .proc-ov-time {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.45);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .proc-ov-divider {
    font-size: 1.25rem;
    color: rgba(255,255,255,0.2);
    flex-shrink: 0;
  }

  /* ── Steps ── */
  .proc-steps-section { background: #fff; }

  .proc-step {
    max-width: 860px;
    margin: 0 auto;
  }

  .proc-step-header {
    display: flex;
    align-items: flex-start;
    gap: 1.75rem;
    margin-bottom: 1.75rem;
  }
  .proc-step-num-wrap {
    width: 72px;
    height: 72px;
    background: var(--kwd-dark);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .proc-step-num {
    font-family: var(--kwd-font-heading);
    font-size: 1.6rem;
    color: var(--kwd-yellow);
    line-height: 1;
  }
  .proc-step-meta { flex: 1; }
  .proc-step-time {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--kwd-yellow);
    background: var(--kwd-dark);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    margin-bottom: 0.5rem;
  }
  .proc-step-title {
    font-family: var(--kwd-font-heading);
    font-size: clamp(1.4rem, 2.5vw, 1.875rem);
    color: var(--kwd-dark);
    margin: 0 0 0.4rem;
    line-height: 1.2;
  }
  .proc-step-subtitle {
    font-size: 0.95rem;
    color: var(--kwd-brown);
    margin: 0;
    line-height: 1.6;
  }

  .proc-step-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-left: calc(72px + 1.75rem);
    margin-bottom: 1.25rem;
  }
  .proc-col {
    background: var(--kwd-cream);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .proc-col--we { border-top: 3px solid var(--kwd-dark); }
  .proc-col--you { border-top: 3px solid rgba(0,0,0,0.15); }
  .proc-col-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--kwd-brown);
    margin: 0 0 0.875rem;
  }
  .proc-col--we .proc-col-label { color: var(--kwd-dark); }
  .proc-col-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .proc-col-list li {
    font-size: 0.875rem;
    color: var(--kwd-dark);
    line-height: 1.55;
    padding-left: 1.25rem;
    position: relative;
  }
  .proc-col--we .proc-col-list li::before { content: "✓"; position: absolute; left: 0; color: var(--kwd-dark); font-weight: 700; font-size: 0.75rem; top: 0.1rem; }
  .proc-col--you .proc-col-list li::before { content: "→"; position: absolute; left: 0; color: var(--kwd-brown); font-weight: 700; font-size: 0.75rem; top: 0.1rem; }

  .proc-outcome {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-left: calc(72px + 1.75rem);
    background: rgba(251,232,166,0.25);
    border: 1.5px solid rgba(251,232,166,0.6);
    border-radius: 10px;
    padding: 0.875rem 1.25rem;
  }
  .proc-outcome-icon {
    width: 24px;
    height: 24px;
    background: var(--kwd-dark);
    color: var(--kwd-yellow);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
    line-height: 24px;
    text-align: center;
  }
  .proc-outcome-text {
    font-size: 0.875rem;
    color: var(--kwd-dark);
    line-height: 1.55;
    margin: 0;
  }

  .proc-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 2rem 0;
    gap: 0;
  }
  .proc-connector-line {
    width: 2px;
    height: 2.5rem;
    background: linear-gradient(to bottom, rgba(0,0,0,0.12), rgba(0,0,0,0.06));
    display: block;
  }
  .proc-connector-arrow {
    font-size: 1.25rem;
    color: rgba(0,0,0,0.2);
    line-height: 1;
  }

  /* ── Commitments ── */
  .proc-commitments {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .proc-commit-card {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 14px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .pcc-icon { }
  .pcc-title { font-family: var(--kwd-font-body); font-size: 0.95rem; font-weight: 700; color: var(--kwd-dark); margin: 0; }
  .pcc-desc { font-size: 0.83rem; color: var(--kwd-brown); line-height: 1.6; margin: 0; }

  /* ── Timeline ── */
  .proc-timeline {
    max-width: 680px;
    margin: 2.5rem auto 0;
    position: relative;
  }
  .proc-timeline::before {
    content: '';
    position: absolute;
    left: 80px;
    top: 10px;
    bottom: 10px;
    width: 2px;
    background: rgba(255,255,255,0.1);
  }
  .proc-tl-item {
    display: grid;
    grid-template-columns: 80px 16px 1fr;
    gap: 0 1.25rem;
    align-items: flex-start;
    margin-bottom: 1.75rem;
    position: relative;
  }
  .proc-tl-day {
    font-size: 0.72rem;
    font-weight: 700;
    color: rgba(255,255,255,0.4);
    text-align: right;
    padding-top: 0.1rem;
    line-height: 1.4;
  }
  .proc-tl-dot {
    width: 16px;
    height: 16px;
    background: rgba(255,255,255,0.15);
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.15rem;
    border: 2px solid rgba(255,255,255,0.25);
  }
  .proc-tl-dot--active {
    background: rgba(251,232,166,0.3);
    border-color: var(--kwd-yellow);
  }
  .proc-tl-dot--launch {
