---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/legal-information/",
      "url": "https://www.kiwiwebdesign.co.nz/legal-information/",
      "name": "Legal Information | Kiwi Web Design",
      "description": "Legal and advertiser transparency information for Kiwi Web Design, operated by Ika Tech Limited in Auckland, New Zealand.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/legal-information/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/legal-information/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Legal Information" }
      ]
    },
    {
      "@type": "LocalBusiness",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "legalName": "Ika Tech Limited",
      "alternateName": "Kiwi Web Design",
      "url": "https://kiwiwebdesign.co.nz",
      "email": "hi@kiwiwebdesign.co.nz",
      "telephone": "+64210396580",
      "founder": {
        "@type": "Person",
        "@id": "https://www.kiwiwebdesign.co.nz/#charlie",
        "name": "Charlie Chao"
      },
      "identifier": {
        "@type": "PropertyValue",
        "propertyID": "NZBN",
        "value": "9429052816840"
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road, Grey Lynn",
        "addressLocality": "Auckland",
        "addressCountry": "NZ"
      },
      "sameAs": [
        "https://www.facebook.com/profile.php?id=61559560322941",
        "https://www.instagram.com/kiwi_web_design/",
        "https://www.linkedin.com/company/108270459/",
        "https://www.youtube.com/@Kiwiwebdesign",
        "https://www.sortlist.com/agency/kiwi-web-design",
        "https://www.designrush.com/agency/profile/kiwi-web-design",
        "https://techreviewer.co/companies/kiwi-web-design",
        "https://www.trustindex.io/reviews/kiwiwebdesign.co.nz",
        "https://www.openpr.com/news/archive/277321/Ika-Tech-Limited-T-A-Kiwi-Web-Design.html"
      ]
    }
  ]
};
---

<Layout
  title="Legal Information | Kiwi Web Design"
  description="Legal entity, trading name, NZBN, contact details, services, and advertiser transparency information for Kiwi Web Design."
  canonicalURL="https://www.kiwiwebdesign.co.nz/legal-information/"
  schema={schema}
>
  <main class="legal-wrap">
    <header class="legal-header">
      <nav class="legal-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true"> / </span>
        <span aria-current="page">Legal Information</span>
      </nav>
      <h1>Legal Information</h1>
      <p>Business identity and advertiser transparency details for Kiwi Web Design.</p>
    </header>

    <section class="legal-card" aria-labelledby="business-details">
      <h2 id="business-details">Business Details</h2>
      <dl>
        <div>
          <dt>Legal entity</dt>
          <dd>Ika Tech Limited</dd>
        </div>
        <div>
          <dt>Trading name</dt>
          <dd>Kiwi Web Design</dd>
        </div>
        <div>
          <dt>NZBN</dt>
          <dd>9429052816840</dd>
        </div>
        <div>
          <dt>Location</dt>
          <dd>Auckland, New Zealand</dd>
        </div>
        <div>
          <dt>Business address</dt>
          <dd>147 Great North Road, Grey Lynn, Auckland, New Zealand</dd>
        </div>
        <div>
          <dt>Email</dt>
          <dd><a href="mailto:hi@kiwiwebdesign.co.nz">hi@kiwiwebdesign.co.nz</a></dd>
        </div>
        <div>
          <dt>Phone</dt>
          <dd><a href="tel:+64210396580">021 039 6580</a></dd>
        </div>
        <div>
          <dt>Website</dt>
          <dd><a href="https://kiwiwebdesign.co.nz">https://kiwiwebdesign.co.nz</a></dd>
        </div>
      </dl>
    </section>

    <section class="legal-section">
      <h2>Services</h2>
      <p>Kiwi Web Design provides website design, SEO, Google Ads, Meta Ads, website hosting, and website maintenance services for New Zealand businesses.</p>
    </section>

    <section class="legal-section">
      <h2>Advertiser Transparency</h2>
      <p>Kiwi Web Design advertises its own website design, SEO, paid advertising, hosting, and maintenance services. Kiwi Web Design does not claim to represent Google, Meta, OpenAI, or any other third-party platform.</p>
    </section>
  </main>
</Layout>

<style>
  .legal-wrap {
    max-width: 820px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 5rem;
  }

  .legal-breadcrumb {
    font-size: 0.8rem;
    color: var(--kwd-brown);
    margin-bottom: 1.5rem;
  }
  .legal-breadcrumb a {
    color: var(--kwd-brown);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .legal-header {
    border-bottom: 2px solid rgba(0,0,0,0.08);
    padding-bottom: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .legal-header h1 {
    font-family: var(--kwd-font-heading);
    font-size: clamp(1.9rem, 3.8vw, 2.8rem);
    color: var(--kwd-dark);
    line-height: 1.15;
    margin: 0 0 0.6rem;
  }
  .legal-header p,
  .legal-section p {
    color: var(--kwd-brown);
    line-height: 1.8;
    margin: 0;
  }

  .legal-card,
  .legal-section {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 10px;
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .legal-card h2,
  .legal-section h2 {
    font-size: 1.25rem;
    color: var(--kwd-dark);
    margin: 0 0 1rem;
  }

  dl {
    margin: 0;
    display: grid;
    gap: 0;
  }
  dl div {
    display: grid;
    grid-template-columns: minmax(150px, 0.42fr) 1fr;
    gap: 1rem;
    padding: 0.8rem 0;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  dl div:last-child {
    border-bottom: 0;
  }
  dt {
    font-weight: 800;
    color: var(--kwd-dark);
  }
  dd {
    margin: 0;
    color: var(--kwd-brown);
    line-height: 1.6;
  }
  a {
    color: var(--kwd-dark);
    font-weight: 700;
  }

  @media (max-width: 620px) {
    dl div {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
