---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/small-business-web-design-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/small-business-web-design-auckland/",
      "name": "Small Business Web Design Auckland | Affordable & Fast | Kiwi Web Design",
      "description": "Affordable small business websites in Auckland. Fast to build, easy to manage, and designed to generate enquiries — not just look good. Local support included.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/small-business-web-design-auckland/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/small-business-web-design-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Small Business Web Design Auckland" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const features = [
  {
    icon: "⚡",
    title: "Fast to Build",
    desc: "Most small business sites launch within 2–3 weeks. We keep the process lean and focused — no endless meetings, no drawn-out approval chains.",
    items: ["Fixed-price quotes", "2–3 week timeline", "Clear milestones", "No scope creep"],
  },
  {
    icon: "📱",
    title: "Mobile-First",
    desc: "Over 60% of web traffic is mobile. Every site we build is designed for phones first and optimised for all screen sizes.",
    items: ["Mobile-first design", "Touch-friendly navigation", "Fast mobile load times", "Tested on real devices"],
  },
  {
    icon: "🔍",
    title: "SEO Ready",
    desc: "Proper page structure, title tags, schema markup, and Search Console setup built in from the start — not bolted on as an afterthought.",
    items: ["On-page SEO setup", "Schema markup", "XML sitemap", "Search Console submission"],
  },
  {
    icon: "📞",
    title: "Built to Convert",
    desc: "Clear calls to action, trust signals, and a contact form that's easy to find. Every page designed to turn visitors into enquiries.",
    items: ["Strategic CTAs", "Enquiry forms", "Phone click tracking", "Trust signal placement"],
  },
  {
    icon: "🔧",
    title: "Easy to Manage",
    desc: "WordPress with a clean setup means you can update text, add images, and publish blog posts without needing a developer. Training included.",
    items: ["WordPress CMS", "Easy content editing", "Included training", "Credentials handover"],
  },
  {
    icon: "🛎️",
    title: "Local Support",
    desc: "We're Auckland-based. If something needs fixing, you're calling a local business that knows your site — not raising a ticket with an offshore helpdesk.",
    items: ["Auckland-based team", "Direct contact", "30-day post-launch support", "Ongoing plans available"],
  },
];

const industries = [
  "Trades & contractors",
  "Professional services",
  "Retail & hospitality",
  "Health & wellness",
  "Construction & real estate",
  "Education & coaching",
  "Automotive services",
  "Beauty & personal care",
];

const faqs = [
  { q: "How much does a small business website cost in Auckland?", a: "Our small business websites start from around $1,500–$2,500 for a straightforward 5–8 page site. Price depends on the number of pages, whether you need a blog, booking system, or eCommerce functionality. We provide a fixed-price quote upfront so there are no surprises." },
  { q: "How long does it take to build a small business website?", a: "Most simple small business sites launch within 2–3 weeks from project start, assuming content (text and images) is ready. Larger or more complex sites take 3–5 weeks. We'll give you a specific timeline at the quoting stage." },
  { q: "Do I need to provide my own content?", a: "You'll need to provide information about your business — services, pricing if you want it on the site, and any photos you have. If you don't have photos, we can use high-quality licensed stock imagery. We also help with page structure and copywriting guidance." },
  { q: "Will my website show up on Google?", a: "We set up the SEO foundations — proper page structure, meta titles, sitemap submission, and Google Search Console — so Google can find and index your site. Ranking for competitive keywords takes longer and is a separate SEO engagement, but your site will be properly discoverable from launch day." },
  { q: "What's the difference between this and a DIY website builder like Wix or Squarespace?", a: "Website builders are fast and cheap but give you less flexibility, weaker SEO, and a monthly fee forever. A custom <a href=\"/wordpress-website-design-auckland/\">WordPress site</a> is an asset you own outright — no ongoing platform fees, full control over design and functionality, and better SEO performance. For most small businesses, a professionally built WordPress site pays for itself quickly. Pair it with <a href=\"/seo-auckland/\">SEO services</a> and you have a compounding asset." },
];
---

<Layout
  title="Small Business Web Design Auckland | Affordable & Fast | Kiwi Web Design"
  description="Affordable small business websites in Auckland. Fast to build, easy to manage, and designed to generate enquiries — not just look good. Local support included."
  canonicalURL="https://www.kiwiwebdesign.co.nz/small-business-web-design-auckland/"
  schema={schema}
>

  <PageHero
    eyebrow="Small Business Web Design Auckland"
    title="Affordable websites that generate real enquiries."
    subtitle="Custom WordPress websites for Auckland small businesses — built fast, designed to convert, and easy to manage. From $1,500. Most sites live in 2–3 weeks."
    imgSrc="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/10/Small-Business-Auckland.jpg"
    imgAlt="Small business web design Auckland by Kiwi Web Design"
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "See Our Work", href: "/testimonials-reviews/" }}
  />

  <!-- Features -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="What's Included"
        title="Everything a small business website needs."
        subtitle="We build sites that work — not just look good. Here's what every project includes."
      />
      <ServiceGrid items={features} cols={3} />
    </div>
  </section>

  <!-- Who we work with -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <SectionHeader
        eyebrow="Who We Work With"
        title="We build sites for Auckland small businesses across every industry."
        align="left"
      />
      <p class="who-intro">If you serve customers in Auckland and need a website that generates enquiries, we've probably built one for a business like yours. Our clients are sole traders, small teams, and owner-operated businesses who want a professional online presence without agency prices. View our <a href="/small-business-website-design-auckland/">full web design packages</a> for pricing and inclusions, or see <a href="/local-seo-for-auckland-small-businesses/">local SEO</a> if you need to rank in local searches too.</p>
      <div class="industries-grid">
        {industries.map(ind => (
          <div class="industry-chip">{ind}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why KWD -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <div class="why-grid">
        <div class="why-text">
          <p class="why-eyebrow">Why Kiwi Web Design</p>
          <h2 class="why-heading">Built locally. Priced for small business.</h2>
          <p class="why-body">We're not a large agency with account managers and mark-ups. We're a small Auckland-based team that builds websites for small businesses — which means faster communication, better value, and a designer who actually understands your market.</p>
          <p class="why-body">Every site we build comes with a fixed price, a clear timeline, and training so you can manage it yourself. No ongoing retainers required — though we're here when you need us.</p>
        </div>
        <div class="why-stats">
          <div class="why-stat">
            <span class="why-stat-num">2–3</span>
            <span class="why-stat-lbl">Week average timeline</span>
          </div>
          <div class="why-stat">
            <span class="why-stat-num">100+</span>
            <span class="why-stat-lbl">Auckland businesses served</span>
          </div>
          <div class="why-stat">
            <span class="why-stat-num">Fixed</span>
            <span class="why-stat-lbl">Price — no hourly billing</span>
          </div>
          <div class="why-stat">
            <span class="why-stat-num">Local</span>
            <span class="why-stat-lbl">Auckland-based support</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Small Business Website Questions"
        subtitle="Common questions from Auckland small business owners about getting a new website."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design Packages</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress</a>
        <a href="/seo-auckland/" class="rps-link">SEO Services</a>
        <a href="/local-seo-for-auckland-small-businesses/" class="rps-link">Local SEO</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready for a website that actually works?"
    subtitle="Free consultation — we'll scope your project and give you a fixed-price quote within 24 hours."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View Our Work", href: "/testimonials-reviews/" }}
  />

</Layout>

<style>
  .who-intro {
    font-size: 0.9375rem;
    color: var(--kwd-brown);
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }
  .industries-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .industry-chip {
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.45rem 1rem;
    border-radius: 999px;
    background: var(--kwd-cream);
    border: 1.5px solid rgba(0,0,0,0.1);
    color: var(--kwd-dark);
  }

  /* Why section */
  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .why-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-yellow);
    margin-bottom: 0.75rem;
  }
  .why-heading {
    font-family: var(--kwd-font-heading);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    color: #fff;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }
  .why-body {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.75;
    margin-bottom: 0.75rem;
  }
  .why-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .why-stat {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .why-stat-num {
    font-family: var(--kwd-font-heading);
    font-size: 2rem;
    color: var(--kwd-yellow);
    line-height: 1;
  }
  .why-stat-lbl {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.4;
  }

  @media (max-width: 760px) {
    .why-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .why-stats { grid-template-columns: repeat(2, 1fr); }
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
