---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import Icon from '../components/Icon.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/wordpress-ai-tools-integration-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/wordpress-ai-tools-integration-auckland/",
      "name": "WordPress + AI Tools Integration Auckland",
      "description": "Connect WordPress with AI chatbots, automations & AEO-ready schema. Auckland specialists at Kiwi Web Design.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/wordpress-ai-tools-integration-auckland/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/wordpress-ai-tools-integration-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "WordPress AI Tools Integration" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const integrations = [
  {
    icon: "💬",
    title: "AI Live Chat & Chatbots",
    desc: "Add an AI-powered chat widget that answers common questions, qualifies leads, and books appointments, 24/7, without a human on call.",
    items: ["Tidio AI, Crisp, Intercom", "Custom FAQ training", "Lead capture flows", "Handoff to human agent"],
  },
  {
    icon: "🤖",
    title: "Automation Workflows",
    desc: "Connect your WordPress site to Zapier, Make (Integromat), or n8n to automate lead follow-ups, CRM updates, email sequences, and more.",
    items: ["Zapier / Make / n8n setup", "CRM integrations (HubSpot, etc.)", "Automated email sequences", "Form-to-CRM pipelines"],
  },
  {
    icon: "🏷️",
    title: "AEO-Ready Schema Markup",
    desc: "Answer Engine Optimisation schema so your WordPress content is structured for AI Overviews, featured snippets, and chatbot citations.",
    items: ["FAQ & HowTo schema", "speakable markup", "LocalBusiness schema", "Product & Service schema"],
  },
  {
    icon: "📝",
    title: "AI Writing Assistant Integration",
    desc: "Integrate AI writing tools directly into your WordPress editor so your team can draft, rewrite, and improve content without leaving the CMS.",
    items: ["Bertha AI setup", "Jetpack AI (if applicable)", "Custom ChatGPT workflow", "Prompt template library"],
  },
  {
    icon: "🔍",
    title: "AI-Powered Site Search",
    desc: "Replace WordPress's basic search with AI-powered semantic search that understands what visitors are looking for, even if they don't use the exact right words.",
    items: ["Algolia / SearchWP integration", "Semantic search setup", "Search analytics", "Autocomplete & suggestions"],
  },
  {
    icon: "📊",
    title: "Analytics & AI Insights",
    desc: "Connect Google Analytics 4, Search Console, and AI-powered reporting tools to give you clear, actionable insights about your site's performance.",
    items: ["GA4 eCommerce events", "Search Console API setup", "Looker Studio dashboards", "AI-generated monthly summaries"],
  },
];

const useCases = [
  { icon: "🔧", industry: "Tradies", use: "AI chatbot qualifies quote requests after hours, books callback time, and sends auto-confirmation SMS." },
  { icon: "💆", industry: "Salons & clinics", use: "AI chat answers 'do you offer X?' questions and links directly to your online booking system." },
  { icon: "⚖️", industry: "Professional services", use: "AI assistant handles initial enquiry triage, collecting key information before your team follows up." },
  { icon: "🛒", industry: "eCommerce", use: "Chatbot assists with product questions, order tracking, and returns, reducing support ticket volume." },
];

const process = [
  { step: "1", title: "Discovery & Tool Selection", desc: "We review your current WordPress setup, your business workflows, and which AI tools will provide the best ROI for your specific situation." },
  { step: "2", title: "Integration & Configuration", desc: "We install, connect, and configure the chosen tools, trained on your business information, pricing, FAQs, and tone of voice." },
  { step: "3", title: "Test & Refine", desc: "We test every integration end-to-end, from chatbot conversations to automation triggers, and refine the responses and flows." },
  { step: "4", title: "Handover & Training", desc: "We hand over with a written guide and training session so your team can manage and update the AI tools themselves." },
];

const faqs = [
  { q: "Do I need to build a new website to add AI tools?", a: "No. We can integrate AI tools into your existing <a href=\"/wordpress-website-design-auckland/\">WordPress site</a>. A rebuild isn't required, we assess what you have and integrate the right tools on top of it. If you do need a new build, our <a href=\"/ai-content-setup-for-websites/\">AI content setup service</a> can be included as part of the project." },
  { q: "What AI chatbot do you recommend?", a: "For most small businesses, we recommend Tidio or Crisp, they're affordable, easy to train, and have good AI capabilities. For more complex needs or custom AI agents, we build on more advanced platforms. We recommend based on your specific use case and budget." },
  { q: "Will AI chatbots replace my team?", a: "No, they handle the repetitive, after-hours, and high-volume enquiries so your team can focus on conversations that actually need a human. Think of it as a first filter, not a replacement." },
  { q: "What is AEO and how does schema markup help?", a: "AEO (Answer Engine Optimisation) is the practice of structuring content so AI-powered tools, Google AI Overviews, ChatGPT, Perplexity, can extract and cite your answers. Schema markup (specifically FAQ, HowTo, and speakable properties) tells AI systems exactly which parts of your page are direct answers to common questions. This works hand-in-hand with our <a href=\"/ai-seo-for-auckland-small-businesses/\">AI SEO service</a>, the two complement each other directly." },
  { q: "How much does WordPress AI integration cost?", a: "It depends on the scope. Adding a basic AI chatbot starts from $299 + GST. A full suite of integrations (chatbot + automation workflows + schema + analytics) typically runs $800–$1,800 + GST as a one-off setup, with optional monthly management." },
];
---

<Layout
  title="WordPress + AI Tools Integration Auckland | Chatbots, Automations & Schema"
  description="Connect WordPress with AI chatbots, automations & AEO-ready schema. Auckland specialists at Kiwi Web Design."
  canonicalURL="https://www.kiwiwebdesign.co.nz/wordpress-ai-tools-integration-auckland/"
  schema={schema}
>

  <PageHero
    eyebrow="WordPress AI Integration Auckland"
    title="Make your WordPress site work harder with AI."
    subtitle="AI chatbots, automation workflows, AEO-ready schema markup, and AI writing tools, all integrated into your existing WordPress site by Auckland specialists."
    ctaPrimary={{ text: "Book a Free Consult", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Integrations", href: "#integrations" }}
  />

  <!-- Integrations -->
  <section class="section" style="background: var(--kwd-cream);" id="integrations">
    <div class="container">
      <SectionHeader
        eyebrow="AI Integrations"
        title="What we connect to your WordPress site."
        subtitle="Purpose-built integrations that solve real business problems, not tech for tech's sake."
      />
      <ServiceGrid items={integrations} cols={3} />
    </div>
  </section>

  <!-- Use cases -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="Real Use Cases"
        title="How Auckland businesses use AI on their WordPress sites."
        light={true}
      />
      <div class="wpai-usecases">
        {useCases.map(({ icon, industry, use }) => (
          <div class="wpai-usecase">
            <div class="wpai-uc-top">
              <span class="wpai-uc-icon"><Icon name={icon} size={24} /></span>
              <strong class="wpai-uc-industry">{industry}</strong>
            </div>
            <p class="wpai-uc-desc">{use}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="Integrated and running in days, not months."
        subtitle="A structured four-step process from tool selection to handover."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="WordPress AI Integration Questions"
        subtitle="Common questions from Auckland businesses about adding AI to their WordPress sites."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress Design</a>
        <a href="/ai-seo-for-auckland-small-businesses/" class="rps-link">AI SEO</a>
        <a href="/ai-content-setup-for-websites/" class="rps-link">AI Content Setup</a>
        <a href="/affordable-seo-auckland/" class="rps-link">SEO Services</a>
        <a href="/wordpress-maintenance-auckland/" class="rps-link">WordPress Maintenance</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to add AI to your WordPress site?"
    subtitle="Free consultation, we'll recommend the right integrations for your business and budget."
    ctaPrimary={{ text: "Book a Free Consult", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See AI SEO Too", href: "/ai-seo-for-auckland-small-businesses/" }}
  />

</Layout>

<style>
  .wpai-usecases {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .wpai-usecase {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .wpai-uc-top { display: flex; align-items: center; gap: 0.6rem; }
  .wpai-uc-icon { }
  .wpai-uc-industry { font-size: 0.875rem; font-weight: 700; color: var(--kwd-yellow); }
  .wpai-uc-desc { font-size: 0.84rem; color: rgba(255,255,255,0.65); line-height: 1.6; margin: 0; }

  @media (max-width: 900px) { .wpai-usecases { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 580px) { .wpai-usecases { grid-template-columns: 1fr; } }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
