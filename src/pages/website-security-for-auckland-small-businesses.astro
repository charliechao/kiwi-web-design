---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/website-security-for-auckland-small-businesses/",
      "url": "https://www.kiwiwebdesign.co.nz/website-security-for-auckland-small-businesses/",
      "name": "Website Security Auckland | SSL, Firewall & Malware Protection",
      "description": "Website security for Auckland small businesses — SSL certificates, firewall setup, malware scanning, and login protection to keep your site safe and trusted.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/website-security-for-auckland-small-businesses/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/website-security-for-auckland-small-businesses/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Website Security Auckland" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const threats = [
  {
    icon: "🦠",
    title: "Malware injections",
    desc: "Attackers inject malicious code into WordPress files to redirect visitors, display spam, or steal data. Usually enters through outdated plugins or themes.",
  },
  {
    icon: "🔓",
    title: "Brute force login attacks",
    desc: "Automated bots attempt thousands of username and password combinations against your WordPress login. Without protection, they can eventually succeed.",
  },
  {
    icon: "⚠️",
    title: "Outdated software vulnerabilities",
    desc: "Each unpatched plugin, theme, or WordPress version is a potential entry point. Attackers actively scan for known vulnerabilities in outdated software.",
  },
  {
    icon: "🔒",
    title: "Expired SSL certificates",
    desc: "An expired SSL causes browsers to show 'Not Secure' warnings — which destroys visitor trust and can tank your Google rankings overnight.",
  },
];

const services = [
  {
    icon: "🔐",
    title: "SSL Certificate Management",
    desc: "SSL installed, configured, and monitored — we handle renewals before they expire so your site never shows a 'Not Secure' warning.",
    items: ["SSL installation", "Renewal monitoring", "Mixed content fixes", "HTTPS redirect setup"],
  },
  {
    icon: "🛡️",
    title: "Web Application Firewall",
    desc: "A WAF blocks malicious traffic — bots, scrapers, exploit attempts — before it reaches your site. Acts as the first line of defence against automated attacks.",
    items: ["WAF configuration", "Bot protection", "Bad IP blocking", "Real-time threat monitoring"],
  },
  {
    icon: "🔍",
    title: "Malware Scanning",
    desc: "Regular automated scans check your site's files and database for malware signatures, backdoors, and suspicious code. Issues are flagged immediately.",
    items: ["File integrity monitoring", "Database scanning", "Backdoor detection", "Alert notifications"],
  },
  {
    icon: "🔑",
    title: "Login Protection",
    desc: "Two-factor authentication, login attempt limits, CAPTCHA, and hidden login URLs — multiple layers that make brute force attacks impractical.",
    items: ["Two-factor authentication", "Login attempt limits", "CAPTCHA integration", "Login URL hardening"],
  },
  {
    icon: "🔄",
    title: "Security Updates",
    desc: "WordPress core, plugin, and theme updates applied regularly to close known vulnerabilities before attackers can exploit them.",
    items: ["WordPress core updates", "Plugin updates", "Theme updates", "Pre-update backups"],
  },
  {
    icon: "🛎️",
    title: "Security Hardening",
    desc: "Configuration-level hardening that removes attack surface: disabling file editing, restricting XML-RPC, hiding WordPress version info, and more.",
    items: ["File edit disabled", "XML-RPC management", "Directory browsing off", "Security headers"],
  },
];

const faqs = [
  { q: "How likely is my small business website to get hacked?", a: "More likely than most people expect. Automated bots scan the entire internet continuously looking for vulnerable WordPress installations. If your plugins are outdated or your passwords are weak, it's a matter of when, not if. Small business sites are targeted precisely because they're often less well-protected than large corporate sites." },
  { q: "What happens if my website gets hacked?", a: "At minimum, Google may blacklist your site and display a warning to visitors — killing your traffic overnight. Depending on the type of attack, your site may show spam, redirect visitors to malicious sites, or be used to send spam emails. Recovery requires malware removal, patch work, and often a restore from backup. It's far cheaper to prevent this than fix it." },
  { q: "Do I need security if I have a simple brochure site with no login?", a: "Yes. All WordPress sites have a login page, even if your visitors never use it. Attackers target the backend, not the front end. Even a simple site can be compromised and used to send spam, host phishing pages, or attack other sites — all without you noticing." },
  { q: "Is security included in your maintenance plans?", a: "Yes — our Standard and Premium maintenance plans include full security monitoring, WAF, malware scanning, and login protection. Basic plan includes SSL monitoring and updates. All plans include daily backups." },
  { q: "What if I think my site has already been hacked?", a: "Contact us immediately. We can diagnose the infection, clean the malware, restore from a clean backup if needed, and harden the site to prevent reinfection. The sooner we act, the less damage occurs." },
];
---

<Layout
  title="Website Security Auckland | SSL, Firewall & Malware Protection"
  description="Website security for Auckland small businesses — SSL certificates, firewall setup, malware scanning, and login protection to keep your site safe and trusted."
  canonicalURL="https://www.kiwiwebdesign.co.nz/website-security-for-auckland-small-businesses/"
  schema={schema}
>

  <PageHero
    eyebrow="Website Security"
    title="Protect your website before something goes wrong."
    subtitle="SSL, firewall, malware scanning, and login protection for Auckland small businesses. Security that runs quietly in the background — so you never have to deal with a hacked site."
    imgSrc="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/11/website-security-auckland-dashboard-style.jpg"
    imgAlt="Website security monitoring dashboard for Auckland small business"
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View Maintenance Plans", href: "/wordpress-maintenance-auckland/" }}
  />

  <!-- Threats -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="Common Threats"
        title="What we protect your site against."
        subtitle="WordPress sites face real, automated threats every day. These are the most common."
      />
      <div class="threat-grid">
        {threats.map(({ icon, title, desc }) => (
          <div class="threat-card">
            <span class="threat-icon">{icon}</span>
            <div>
              <strong class="threat-title">{title}</strong>
              <p class="threat-desc">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="What We Do"
        title="Layered security — multiple protections working together."
        subtitle="No single security measure is enough. We implement multiple layers that work together."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Website Security Questions"
        subtitle="Common questions from Auckland business owners about keeping their WordPress site secure."
      />
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Don't wait until your site gets hacked."
    subtitle="Get a security audit — we'll identify any vulnerabilities and show you exactly what needs fixing."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View Maintenance Plans", href: "/wordpress-maintenance-auckland/" }}
  />

</Layout>

<style>
  .threat-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .threat-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 14px;
    padding: 1.5rem;
  }
  .threat-icon { font-size: 1.75rem; flex-shrink: 0; width: 2.25rem; text-align: center; }
  .threat-title { display: block; font-size: 0.9rem; font-weight: 700; color: var(--kwd-dark); margin-bottom: 0.35rem; }
  .threat-desc { font-size: 0.83rem; color: var(--kwd-brown); line-height: 1.6; margin: 0; }

  @media (max-width: 700px) {
    .threat-grid { grid-template-columns: 1fr; }
  }
</style>
