---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/website-hosting-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/website-hosting-auckland/",
      "name": "Website Hosting Auckland | Managed WordPress Hosting NZ",
      "description": "Fast, secure, managed website hosting for Auckland small businesses. Daily backups, SSL, performance tuning & local support. Get reliable hosting today.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/website-hosting-auckland/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/website-hosting-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Website Hosting Auckland" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const hostingPlans = [
  {
    name: "Starter",
    price: "$49/mo",
    note: "+ GST",
    desc: "Fast, reliable hosting for straightforward WordPress sites.",
    items: [
      "NZ-based server",
      "SSL certificate included",
      "Daily backups (14-day)",
      "Uptime monitoring",
      "WordPress optimised stack",
      "Email support",
    ],
    highlight: false,
    href: "/website-designer-auckland/",
  },
  {
    name: "Managed",
    price: "$99/mo",
    note: "+ GST",
    desc: "Hosting plus WordPress maintenance — updates, security, and monitoring included.",
    items: [
      "Everything in Starter",
      "Daily backups (30-day)",
      "Monthly WP core + plugin updates",
      "Security scanning & firewall",
      "Performance caching setup",
      "Priority support",
      "Monthly status report",
    ],
    highlight: true,
    tag: "Recommended",
    href: "/website-designer-auckland/",
  },
  {
    name: "Full Care",
    price: "$199/mo",
    note: "+ GST",
    desc: "Hosting, maintenance, and 2 hours of content changes every month.",
    items: [
      "Everything in Managed",
      "2 hours content changes/mo",
      "Google Analytics summary",
      "Same-day support response",
      "Staging environment",
      "Quarterly performance review",
    ],
    highlight: false,
    href: "/website-designer-auckland/",
  },
];

const features = [
  {
    icon: "🇳🇿",
    title: "NZ-Based Servers",
    desc: "Your site is hosted on servers in New Zealand — giving NZ visitors faster load times than overseas hosting providers.",
    items: ["Local NZ servers", "Low latency for NZ traffic", "GDPR & NZ Privacy Act aligned", "NZ support hours"],
  },
  {
    icon: "⚡",
    title: "Performance Stack",
    desc: "We use a WordPress-optimised hosting stack with server-side caching, CDN, and PHP 8.x — so your site loads fast from day one.",
    items: ["LiteSpeed / Redis cache", "Global CDN", "PHP 8.x", "HTTP/3 support"],
  },
  {
    icon: "🔒",
    title: "Security & SSL",
    desc: "SSL certificates, automatic HTTPS, WordPress firewall, and malware scanning — your site is protected at the server level, not just the application level.",
    items: ["Free SSL certificate", "Automatic HTTPS redirect", "Server-level firewall", "Malware scanning"],
  },
  {
    icon: "💾",
    title: "Daily Backups",
    desc: "Automated daily backups with offsite storage. If anything goes wrong, we restore your site to any point within the retention window in minutes.",
    items: ["Daily automated backups", "Offsite storage", "14–30 day retention", "One-click restore"],
  },
  {
    icon: "📈",
    title: "Uptime Monitoring",
    desc: "24/7 uptime monitoring alerts us the moment your site goes down. We investigate and resolve issues before you even notice.",
    items: ["24/7 uptime checks", "Instant downtime alerts", "Response within 1–2 hours", "Incident logging"],
  },
  {
    icon: "🛎️",
    title: "Local Support",
    desc: "You're dealing with Charlie in Auckland — not an overseas helpdesk. Fast, personal support from someone who knows your site.",
    items: ["Auckland-based support", "Email & phone support", "Priority for managed clients", "No ticket system"],
  },
];

const reasons = [
  { icon: "❌", label: "Cheap hosting (Godaddy, HostGator, etc.)", issues: ["Overseas servers — slow NZ load times", "Shared resources with thousands of sites", "No WordPress optimisation", "Minimal support when things go wrong"] },
  { icon: "✅", label: "Kiwi Web Design managed hosting", issues: ["NZ-based servers", "Isolated, optimised environment", "WordPress-specific stack", "Local support that knows your site"] },
];

const faqs = [
  { q: "Why not just use a cheap hosting provider?", a: "Cheap hosting (like GoDaddy, HostGator, or Bluehost) puts your site on shared servers with thousands of other sites, often overseas. You get slow NZ load times, no real support, and no WordPress optimisation. The $5–$15/month you save costs you in lost leads from a slow, insecure site. Pair fast hosting with a <a href=\"/wordpress-maintenance-auckland/\">WordPress maintenance plan</a> for complete peace of mind." },
  { q: "Do you host non-WordPress sites?", a: "Our managed hosting is optimised for <a href=\"/wordpress-website-design-auckland/\">WordPress</a>. For other technologies (static sites, custom apps), get in touch and we'll advise on the right hosting solution." },
  { q: "Can I migrate from my current host?", a: "Yes. We handle full WordPress migrations — files, databases, and DNS updates. We run the new site in parallel before cutting over to ensure zero downtime." },
  { q: "What happens if my site goes down?", a: "Our monitoring alerts us immediately. We investigate and resolve hosting issues as a priority — typically within 1–2 hours during business hours. For critical issues, we're on it as fast as possible." },
  { q: "Is the SSL certificate really free?", a: "Yes. SSL certificates (Let's Encrypt) are included in all hosting plans at no extra cost. We manage renewal automatically so you never have to worry about an expired SSL." },
  { q: "Can I keep my existing email if I move hosting?", a: "Yes. Website hosting and email hosting are separate. We migrate your website without touching your email setup. If you want business email hosting too, we can quote for that separately." },
];
---

<Layout
  title="Website Hosting Auckland | Managed WordPress Hosting NZ"
  description="Fast, secure, managed website hosting for Auckland small businesses. Daily backups, SSL, performance tuning & local support. Get reliable hosting today."
  canonicalURL="https://www.kiwiwebdesign.co.nz/website-hosting-auckland/"
  schema={schema}
>

  <PageHero
    eyebrow="Website Hosting Auckland"
    title="Fast, NZ-based hosting managed by people who know your site."
    subtitle="Managed WordPress hosting for Auckland small businesses. NZ servers, daily backups, SSL, security, and support from a local team — not an overseas helpdesk."
    badgeText="From $49/month + GST"
    ctaPrimary={{ text: "Get a Hosting Plan", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Plans", href: "#plans" }}
    centered={true}
  />

  <!-- Why managed hosting -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="Why It Matters"
        title="Cheap hosting costs you more than you save."
        subtitle="The difference between managed NZ hosting and a $10/month shared plan isn't just speed — it's customer experience, security, and lost leads."
      />
      <div class="hosting-compare">
        {reasons.map(({ icon, label, issues }) => (
          <div class:list={['hosting-compare-col', icon === '✅' && 'hosting-compare-col--good']}>
            <div class="hosting-compare-header">
              <span>{icon}</span>
              <strong>{label}</strong>
            </div>
            <ul>
              {issues.map((issue) => <li>{issue}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Plans -->
  <section class="section" id="plans">
    <div class="container">
      <SectionHeader
        eyebrow="Hosting Plans"
        title="Simple, flat-fee hosting plans."
        subtitle="NZ-based, WordPress-optimised, fully managed. No lock-in contracts."
      />
      <div class="hosting-plans">
        {hostingPlans.map((plan) => (
          <div class:list={['hosting-plan', plan.highlight && 'hosting-plan--featured']}>
            {plan.tag && <span class="hosting-plan-tag">{plan.tag}</span>}
            <p class="hosting-plan-name">{plan.name}</p>
            <div class="hosting-plan-price-wrap">
              <span class="hosting-plan-price">{plan.price}</span>
              <span class="hosting-plan-note">{plan.note}</span>
            </div>
            <p class="hosting-plan-desc">{plan.desc}</p>
            <ul class="hosting-plan-list">
              {plan.items.map((item) => <li>{item}</li>)}
            </ul>
            <a href={plan.href} class:list={['hosting-plan-btn', plan.highlight && 'hosting-plan-btn--featured']}>
              Get Started
            </a>
          </div>
        ))}
      </div>
      <p class="hosting-plans-note">All plans exclude GST. No lock-in — cancel anytime with 30 days notice.</p>
    </div>
  </section>

  <!-- Features -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="What's Included"
        title="Everything in our hosting stack."
        subtitle="Server-level features that give your website the performance and security it deserves."
      />
      <ServiceGrid items={features} cols={3} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Hosting Questions Answered"
        subtitle="Common questions about moving to managed NZ hosting."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/wordpress-maintenance-auckland/" class="rps-link">WordPress Maintenance</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress Web Design</a>
        <a href="/wordpress-website-rebuilds-auckland/" class="rps-link">WordPress Rebuilds</a>
        <a href="/analytics-reporting-for-auckland-small-business-websites/" class="rps-link">Analytics & Reporting</a>
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design Packages</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to move to fast, managed NZ hosting?"
    subtitle="Free migration — we'll move your site over and have it running faster in 48 hours."
    ctaPrimary={{ text: "Get a Hosting Plan", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Maintenance Plans", href: "/wordpress-maintenance-auckland/" }}
  />

</Layout>

<style>
  .hosting-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .hosting-compare-col {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.08);
    border-radius: 16px;
    padding: 1.75rem;
  }
  .hosting-compare-col--good {
    background: var(--kwd-dark);
    border-color: var(--kwd-dark);
  }
  .hosting-compare-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--kwd-dark);
    margin-bottom: 1.25rem;
  }
  .hosting-compare-col--good .hosting-compare-header { color: #fff; }
  .hosting-compare-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .hosting-compare-col li {
    font-size: 0.875rem;
    color: var(--kwd-brown);
    padding-left: 1.25rem;
    position: relative;
  }
  .hosting-compare-col li::before { content: "—"; position: absolute; left: 0; color: #c0b8b4; }
  .hosting-compare-col--good li { color: rgba(255,255,255,0.75); }
  .hosting-compare-col--good li::before { content: "✓"; color: var(--kwd-yellow); font-weight: 700; }

  .hosting-plans {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
    margin-top: 2.5rem;
  }
  .hosting-plan {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.08);
    border-radius: 18px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
  }
  .hosting-plan--featured { background: var(--kwd-dark); border-color: var(--kwd-dark); }
  .hosting-plan-tag {
    display: inline-block;
    background: var(--kwd-yellow);
    color: var(--kwd-dark);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 1rem;
    align-self: flex-start;
  }
  .hosting-plan-name { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin: 0 0 0.5rem; }
  .hosting-plan--featured .hosting-plan-name { color: rgba(255,255,255,0.5); }
  .hosting-plan-price-wrap { display: flex; align-items: baseline; gap: 0.4rem; margin-bottom: 0.75rem; }
  .hosting-plan-price { font-family: var(--kwd-font-heading); font-size: 2.25rem; color: var(--kwd-dark); line-height: 1; }
  .hosting-plan--featured .hosting-plan-price { color: var(--kwd-yellow); }
  .hosting-plan-note { font-size: 0.8rem; color: var(--kwd-brown); }
  .hosting-plan--featured .hosting-plan-note { color: rgba(255,255,255,0.45); }
  .hosting-plan-desc { font-size: 0.85rem; color: var(--kwd-brown); line-height: 1.6; margin: 0 0 1.25rem; }
  .hosting-plan--featured .hosting-plan-desc { color: rgba(255,255,255,0.6); }
  .hosting-plan-list { list-style: none; padding: 0; margin: 0 0 1.75rem; display: flex; flex-direction: column; gap: 0.5rem; flex: 1; }
  .hosting-plan-list li { font-size: 0.84rem; color: var(--kwd-dark); padding-left: 1.3rem; position: relative; }
  .hosting-plan-list li::before { content: "✓"; position: absolute; left: 0; color: var(--kwd-brown); font-weight: 700; }
  .hosting-plan--featured .hosting-plan-list li { color: rgba(255,255,255,0.8); }
  .hosting-plan--featured .hosting-plan-list li::before { color: var(--kwd-yellow); }
  .hosting-plan-btn { display: block; text-align: center; padding: 0.875rem; border-radius: 8px; font-weight: 700; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.06em; background: var(--kwd-cream); color: var(--kwd-dark); transition: background 0.2s; }
  .hosting-plan-btn:hover { background: #e8e7da; }
  .hosting-plan-btn--featured { background: var(--kwd-yellow); }
  .hosting-plan-btn--featured:hover { background: var(--kwd-gold); }
  .hosting-plans-note { text-align: center; font-size: 0.82rem; color: var(--kwd-brown); margin-top: 1.5rem; }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }

  @media (max-width: 960px) {
    .hosting-plans { grid-template-columns: 1fr; max-width: 480px; margin-inline: auto; }
    .hosting-compare { grid-template-columns: 1fr; }
  }
</style>
