---
import Layout from '../../layouts/Layout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import TestimonialGrid from '../../components/TestimonialGrid.astro';
import Icon from '../../components/Icon.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["WebPage", "ContactPage"],
      "@id": "https://www.kiwiwebdesign.co.nz/zh/website-designer-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/zh/website-designer-auckland/",
      "name": "免费咨询报价 | 联系奥克兰网页设计团队 | Kiwi Web Design",
      "description": "联系 Kiwi Web Design — 奥克兰 Grey Lynn 的专业网页设计团队。为中小企业提供网站设计、SEO 及 Google Ads 服务，覆盖全新西兰。",
      "inLanguage": "zh-Hans",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/zh/website-designer-auckland/#breadcrumb" },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".contact-eyebrow", ".contact-info h1", ".contact-lead"]
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/zh/website-designer-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "首页", "item": "https://www.kiwiwebdesign.co.nz/zh/" },
        { "@type": "ListItem", "position": 2, "name": "联系我们", "item": "https://www.kiwiwebdesign.co.nz/zh/website-designer-auckland/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "奥克兰网页设计",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "City", "name": "Auckland" },
        { "@type": "Country", "name": "New Zealand" }
      ],
      "priceRange": "$$",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "bestRating": "5",
        "ratingCount": "50"
      },
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.kiwiwebdesign.co.nz/favicon.png",
        "width": 512,
        "height": 512
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "奥克兰网页设计与数字营销服务",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "奥克兰网站设计" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "奥克兰 SEO 优化" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "奥克兰 Google Ads" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "AI SEO 与 GEO 优化" } }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Kiwi Web Design 多久回复咨询？",
          "acceptedAnswer": { "@type": "Answer", "text": "我们在 1 个工作日内回复所有咨询。如有紧急项目，可直接致电或发短信至 021 039 6580。" }
        },
        {
          "@type": "Question",
          "name": "初次咨询真的免费吗？",
          "acceptedAnswer": { "@type": "Answer", "text": "是的，完全免费，无任何附加条件。我们会先了解您的业务、目标和需求，再提供报价方案。" }
        },
        {
          "@type": "Question",
          "name": "Kiwi Web Design 是否为奥克兰以外的企业提供服务？",
          "acceptedAnswer": { "@type": "Answer", "text": "可以。我们总部位于 Grey Lynn，奥克兰，但通过视频通话为全新西兰的企业提供服务。如有需要，我们也可在奥克兰当面会谈。" }
        },
        {
          "@type": "Question",
          "name": "一个网站项目通常需要多长时间？",
          "acceptedAnswer": { "@type": "Answer", "text": "大多数中小企业网站在项目启动后 2–6 周内上线。电商及定制化项目则需 8–12 周，具体视复杂程度而定。" }
        },
        {
          "@type": "Question",
          "name": "第一次沟通前需要准备什么？",
          "acceptedAnswer": { "@type": "Answer", "text": "无需正式准备。只需思考您的业务是做什么的、目标客户是谁，以及您喜欢哪些网站风格，其余的我们会在咨询中引导您。" }
        }
      ]
    }
  ]
};

const reasons = [
  { icon: "MessageCircle", title: "免费咨询", desc: "先沟通，再报价。我们在了解您的业务、客户和目标之前，不会给出任何价格。" },
  { icon: "MapPin", title: "总部位于 Grey Lynn", desc: "地址：147 Great North Road。方便在奥克兰任何地方当面会谈，也可通过视频通话。" },
  { icon: "Zap", title: "快速交付", desc: "大多数项目在 2–3 周内上线。我们行动迅速，并全程保持沟通。" },
  { icon: "BadgeDollarSign", title: "透明定价", desc: "开工前告知您总费用。没有隐藏收费，没有意外账单。" },
];

const reviews = [
  { name: "Zane Barrett", company: "Barrett Access Scaffolding", text: "专业、高效，真正花时间了解我们的业务。对结果非常满意。" },
  { name: "Jack", company: "Show Me Shorts", text: "解决方案实用聪明，专业友善，有问题时回复也很及时。" },
  { name: "Steven Liu", company: "客户", text: "体验非常出色。设计简洁、现代、易用 — 正是我所期望的。" },
  { name: "Gina Dellabarca", company: "客户", text: "网站审查全面且有帮助，信息清晰，沟通顺畅。" },
];
---

<Layout
  lang="zh-Hans"
  title="免费咨询报价 | 联系奥克兰网页设计团队 | Kiwi Web Design"
  description="联系 Kiwi Web Design — 奥克兰 Grey Lynn 的专业网页设计团队。网站设计、SEO 及 Google Ads，专为中小企业打造。1 个工作日内回复。"
  canonicalURL="https://www.kiwiwebdesign.co.nz/zh/website-designer-auckland/"
  alternateUrl="https://www.kiwiwebdesign.co.nz/website-designer-auckland/"
  schema={schema}
>

  <!-- Hero with form -->
  <section class="contact-hero">
    <div class="container contact-layout">

      <!-- Left: info -->
      <div class="contact-info">
        <p class="contact-eyebrow">联系我们</p>
        <h1>打造一个能为您带来客户的网站。</h1>
        <p class="contact-lead">无论您已准备好开始，还是只是想了解更多 — 欢迎随时联系我们。我们始终提供真实诚恳的建议，即使这意味着为您推荐其他方案。不确定自己需要什么？请查看我们的<a href="/solutions-auckland-kiwi-web-design/" class="cl-link">全部服务</a>或<a href="/website-design-process-in-auckland/" class="cl-link">设计流程</a>。</p>

        <ul class="contact-details">
          <li>
            <span class="cd-icon"><Icon name="Mail" size={18} /></span>
            <div>
              <span class="cd-label">邮箱</span>
              <a href="mailto:Hi@KiwiWebDesign.co.nz">Hi@KiwiWebDesign.co.nz</a>
            </div>
          </li>
          <li>
            <span class="cd-icon"><Icon name="Phone" size={18} /></span>
            <div>
              <span class="cd-label">电话 / 短信</span>
              <a href="tel:+64210396580">021 039 6580</a>
            </div>
          </li>
          <li>
            <span class="cd-icon"><Icon name="MapPin" size={18} /></span>
            <div>
              <span class="cd-label">办公地址</span>
              <a href="https://www.google.com/maps/search/?api=1&query=147+Great+North+Road+Grey+Lynn+Auckland" target="_blank" rel="noopener noreferrer">
                147 Great North Road, Grey Lynn, Auckland
              </a>
            </div>
          </li>
        </ul>

        <div class="contact-reasons">
          {reasons.map(({ icon, title, desc }) => (
            <div class="cr-item">
              <span class="cr-icon"><Icon name={icon} size={20} /></span>
              <div>
                <strong class="cr-title">{title}</strong>
                <p class="cr-desc">{desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: form -->
      <div class="contact-form-wrap" id="contact">
        <h2 class="contact-form-title">发送留言</h2>
        <p class="contact-form-sub">我们将在 1 个工作日内回复。带 * 的字段为必填项。</p>
        <form class="contact-form" id="contact-form" name="contact" method="POST" action="https://api.web3forms.com/submit">
          <input type="hidden" name="access_key" value="e0a725e4-f764-4536-826c-df981c8bdf3b" />
          <input type="hidden" name="subject" value="New enquiry from KWD contact form (Chinese)" />
          <input type="hidden" name="from_name" value="Kiwi Web Design Website" />
          <input type="hidden" name="submitted_at" id="contact-submitted-at" value="" />
          <input type="checkbox" name="botcheck" class="form-botcheck" tabindex="-1" autocomplete="off" />
          <div class="form-row">
            <label class="form-label">
              姓名 <span class="req">*</span>
              <input type="text" name="name" placeholder="例：王伟" required />
            </label>
          </div>
          <div class="form-row form-row-2">
            <label class="form-label">
              邮箱 <span class="req">*</span>
              <input type="email" name="email" placeholder="您的邮箱地址" required />
            </label>
            <label class="form-label">
              电话
              <input type="tel" name="mobile" placeholder="021 000 0000" />
            </label>
          </div>
          <div class="form-row">
            <label class="form-label">
              企业名称
              <input type="text" name="business" placeholder="您的企业名称" />
            </label>
          </div>
          <div class="form-row">
            <label class="form-label">
              您需要什么服务？
              <select name="service">
                <option value="">请选择服务类型...</option>
                <option value="website">新建网站</option>
                <option value="seo">SEO 优化</option>
                <option value="google-ads">Google Ads</option>
                <option value="website-seo">网站 + SEO</option>
                <option value="full-package">全套增长方案</option>
                <option value="other">其他 / 暂不确定</option>
              </select>
            </label>
          </div>
          <div class="form-row">
            <label class="form-label">
              留言 <span class="req">*</span>
              <textarea name="message" rows="4" placeholder="请简单介绍您的企业以及您希望实现的目标..." required></textarea>
            </label>
          </div>
          <button type="submit" class="form-submit" id="contact-submit">发送留言 →</button>
          <p id="contact-status" aria-live="polite" style="display:none" class="form-status"></p>
          <p class="form-privacy">我们尊重您的隐私，您的个人信息绝不会被共享或出售。</p>
        </form>
      </div>

    </div>
  </section>

  <!-- Industries we serve -->
  <section class="related-strip">
    <div class="container">
      <p class="rps-label">我们服务的行业</p>
      <div class="rps-links">
        <a href="/tradie-website-design-auckland/" class="rps-link">建筑与工程</a>
        <a href="/how-kiwi-web-design-helps-auckland-beauty-industry/" class="rps-link">美容与健康</a>
        <a href="/how-kiwi-web-design-helps-auckland-restaurants/" class="rps-link">餐厅与咖啡馆</a>
        <a href="/how-kiwi-web-design-helps-auckland-healthcare/" class="rps-link">医疗健康</a>
        <a href="/how-kiwi-web-design-helps-auckand-lawyers/" class="rps-link">律师与专业服务</a>
        <a href="/industries-we-serve-in-auckland/" class="rps-link">查看全部行业 →</a>
      </div>
    </div>
  </section>

  <!-- Areas we serve -->
  <section class="related-strip">
    <div class="container">
      <p class="rps-label">我们服务的地区</p>
      <div class="rps-links">
        <a href="/central-auckland-web-design/" class="rps-link">奥克兰市区</a>
        <a href="/north-shore-website-design/" class="rps-link">北岸</a>
        <a href="/west-auckland-web-design/" class="rps-link">西区</a>
        <a href="/east-auckland-web-design/" class="rps-link">东区</a>
        <a href="/south-auckland-web-design/" class="rps-link">南区</a>
      </div>
    </div>
  </section>

  <!-- Popular starting points -->
  <section class="related-strip">
    <div class="container">
      <p class="rps-label">热门服务</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">网站套餐</a>
        <a href="/seo-auckland/" class="rps-link">SEO 优化</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
        <a href="/wordpress-maintenance-auckland/" class="rps-link">WordPress 维护</a>
        <a href="/ecommerce-website-auckland/" class="rps-link">电商网站</a>
        <a href="/faq/" class="rps-link">常见问题</a>
      </div>
    </div>
  </section>

  <!-- FAQ section -->
  <section class="contact-faq">
    <div class="container">
      <p class="rps-label">联系前常见问题</p>
      <div class="faq-list">
        <details class="faq-item">
          <summary class="faq-q">你们多久回复咨询？</summary>
          <p class="faq-a">我们在 1 个工作日内回复所有咨询。如有紧急事项，可直接致电或发短信至 <a href="tel:+64210396580">021 039 6580</a>。</p>
        </details>
        <details class="faq-item">
          <summary class="faq-q">初次咨询真的免费吗？</summary>
          <p class="faq-a">是的 — 完全免费，无任何附加条件。我们会先了解您的业务和目标，如果双方合适，再推进项目；如果不合适，我们也会坦诚告知。</p>
        </details>
        <details class="faq-item">
          <summary class="faq-q">你们是否为奥克兰以外的企业提供服务？</summary>
          <p class="faq-a">可以。我们总部在 Grey Lynn，但通过视频通话为全新西兰的企业服务。奥克兰客户也可随时到我们 Great North Road 的办公室当面会谈。</p>
        </details>
        <details class="faq-item">
          <summary class="faq-q">网站项目通常需要多长时间？</summary>
          <p class="faq-a">大多数中小企业网站在项目启动后 2–6 周内上线。电商及定制化项目则需 8–12 周，具体视规模和复杂程度而定。</p>
        </details>
        <details class="faq-item">
          <summary class="faq-q">第一次沟通前需要准备什么？</summary>
          <p class="faq-a">无需正式准备。只需思考您的业务是做什么的、您的最佳客户是谁，以及您喜欢哪些网站风格，其余的我们会在咨询中引导您。</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader eyebrow="客户评价" title="奥克兰企业对我们的真实反馈。" />
      <TestimonialGrid items={reviews} cols={2} />
    </div>
  </section>

  <!-- Final trust strip -->
  <section class="contact-final">
    <div class="container contact-final-inner">
      <div class="cf-stat">
        <span class="cf-num">4.9★</span>
        <span class="cf-label">Google 平均评分</span>
      </div>
      <div class="cf-stat">
        <span class="cf-num">50+</span>
        <span class="cf-label">服务奥克兰企业数</span>
      </div>
      <div class="cf-stat">
        <span class="cf-num">免费</span>
        <span class="cf-label">初次咨询</span>
      </div>
      <div class="cf-stat">
        <span class="cf-num">Grey Lynn</span>
        <span class="cf-label">奥克兰本地团队</span>
      </div>
    </div>
  </section>

  <script>
    (function () {
      const form = document.getElementById('contact-form') as HTMLFormElement | null;
      const btn = document.getElementById('contact-submit') as HTMLButtonElement | null;
      const status = document.getElementById('contact-status') as HTMLElement | null;
      const submittedAt = document.getElementById('contact-submitted-at') as HTMLInputElement | null;
      if (!form || !btn || !status) return;

      const minSubmitSeconds = 3;
      if (submittedAt) submittedAt.value = String(Date.now());

      function setStatus(msg: string, isError: boolean) {
        status!.textContent = msg;
        status!.style.display = 'block';
        status!.className = 'form-status ' + (isError ? 'form-status--error' : 'form-status--success');
      }

      function countUrls(value: string) {
        return (value.match(/(?:https?:\/\/|www\.)/gi) || []).length;
      }

      function hasSuspiciousPattern(value: string) {
        return /(.)\1{7,}/.test(value);
      }

      function validateSubmission() {
        const formData = new FormData(form!);
        const name = String(formData.get('name') || '').trim();
        const message = String(formData.get('message') || '').trim();
        const startedAt = Number(formData.get('submitted_at') || 0);
        const botcheck = formData.get('botcheck');
        if (botcheck) return '提交被拦截，请刷新页面后重试。';
        if (!startedAt || ((Date.now() - startedAt) / 1000) < minSubmitSeconds) {
          return '请稍等片刻再发送留言。';
        }
        if (name.length < 2) return '请输入您的姓名。';
        if (message.length < 10) return '请提供更多详情，以便我们更好地为您服务。';
        if (countUrls(message) > 1 || hasSuspiciousPattern(message)) {
          return '留言包含可疑内容，请修改后重试。';
        }
        return '';
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const validationError = validateSubmission();
        if (validationError) {
          setStatus(validationError, true);
          return;
        }
        btn.disabled = true;
        btn.textContent = '发送中…';
        status.style.display = 'none';
        try {
          const res  = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify(Object.fromEntries(new FormData(form))),
          });
          const data = await res.json();
          if (data.success) {
            setStatus('感谢您的留言！我们会在24小时内回复您。', false);
            form.reset();
            if (submittedAt) submittedAt.value = String(Date.now());
          } else {
            setStatus(data.message || '提交失败，请稍后重试。', true);
          }
        } catch {
          setStatus('网络错误 — 请检查您的网络连接后重试。', true);
        } finally {
          btn.disabled = false;
          btn.textContent = '发送留言 →';
        }
      });
    })();
  </script>
  <script is:inline src="https://web3forms.com/client/script.js" async defer></script>

</Layout>

<style>
  .contact-hero {
    background: var(--kwd-dark);
    padding: 4.5rem 0;
  }
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Info side */
  .contact-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-yellow);
    margin-bottom: 1rem;
  }
  .contact-info h1 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    color: #fff;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }
  .contact-lead {
    font-size: 1rem;
    color: rgba(255,255,255,0.68);
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 500px;
  }

  .contact-details {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .contact-details li {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }
  .cd-icon {
    width: 2.25rem;
    height: 2.25rem;
    background: rgba(255,255,255,0.08);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--kwd-yellow);
  }
  .cd-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--kwd-yellow);
    margin-bottom: 0.15rem;
  }
  .contact-details a {
    color: rgba(255,255,255,0.8);
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .contact-details a:hover { color: var(--kwd-yellow); }

  .contact-reasons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .cr-item {
