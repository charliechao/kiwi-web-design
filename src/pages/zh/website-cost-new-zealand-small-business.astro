  #kwd-website-cost-nz .kwd-faq {
    margin-top: 3rem;
  }
  #kwd-website-cost-nz .kwd-faq h2 {
    font-size: 1.55rem;
    margin-bottom: 1.25rem;
    color: var(--kwd-dark);
  }
  #kwd-website-cost-nz .kwd-accordion {
    border-top: 1px solid #d5cfc5;
    border-bottom: 1px solid #d5cfc5;
  }
  #kwd-website-cost-nz .kwd-accordion-item {
    border-bottom: 1px solid #d5cfc5;
  }
  #kwd-website-cost-nz .kwd-accordion-item:last-child {
    border-bottom: none;
  }
  #kwd-website-cost-nz .kwd-faq-button {
    width: 100%;
    background: transparent;
    border: none;
    text-align: left;
    padding: 1rem 0;
    font-size: 1.02rem;
    font-weight: 600;
    color: var(--kwd-dark);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    cursor: pointer;
    font-family: var(--kwd-font-body);
  }
  #kwd-website-cost-nz .kwd-faq-button span:first-child {
    flex: 1;
  }
  #kwd-website-cost-nz .kwd-faq-icon {
    font-size: 1.4rem;
    color: var(--kwd-brown);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }
  #kwd-website-cost-nz .kwd-faq-button[aria-expanded="true"] .kwd-faq-icon {
    transform: rotate(45deg);
  }
  #kwd-website-cost-nz .kwd-faq-panel {
    padding: 0 0 1rem;
    font-size: 0.97rem;
    color: var(--kwd-dark);
    line-height: 1.8;
  }
  #kwd-website-cost-nz .kwd-internal-links {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #d5cfc5;
  }
  #kwd-website-cost-nz .kwd-internal-links h3 {
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
    color: var(--kwd-dark);
  }
  #kwd-website-cost-nz .kwd-internal-links ul {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0;
    color: var(--kwd-dark);
    display: grid;
    gap: 0.4rem;
  }
  #kwd-website-cost-nz .kwd-author-box {
    margin-top: 3rem;
    padding: 1.75rem;
    border-radius: 14px;
    background: var(--kwd-dark);
    color: #ffffff;
    display: grid;
    gap: 0.75rem;
  }
  #kwd-website-cost-nz .kwd-author-box p {
    margin: 0;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.82);
  }
  #kwd-website-cost-nz .kwd-author-box a {
    color: var(--kwd-yellow);
    text-decoration: underline;
  }
  #kwd-website-cost-nz .kwd-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--kwd-yellow);
    color: #000 !important;
    font-weight: 700;
    padding: 0.85rem 1.5rem;
    border-radius: 6px;
    transition: transform 0.2s ease, background 0.2s ease;
    text-decoration: none !important;
    width: fit-content;
    font-family: var(--kwd-font-body);
    letter-spacing: 0.02em;
    font-size: 0.9rem;
  }
  #kwd-website-cost-nz .kwd-cta-button:hover,
  #kwd-website-cost-nz .kwd-cta-button:focus {
    transform: translateY(-2px);
    background: var(--kwd-gold);
    color: var(--kwd-dark);
  }
  #kwd-website-cost-nz button,
  #kwd-website-cost-nz input,
  #kwd-website-cost-nz select {
    font-family: var(--kwd-font-body);
  }
  #kwd-website-cost-nz button:focus-visible,
  #kwd-website-cost-nz a:focus-visible,
  #kwd-website-cost-nz input:focus-visible,
  #kwd-website-cost-nz select:focus-visible {
    outline: 3px solid var(--kwd-yellow);
    outline-offset: 2px;
  }
  @media (min-width: 760px) {
    #kwd-website-cost-nz .kwd-inline-fields {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    #kwd-website-cost-nz .kwd-case-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
  @media (max-width: 640px) {
    #kwd-website-cost-nz {
      padding: 1.5rem 0.75rem;
    }
    #kwd-website-cost-nz .kwd-container {
      padding: 2rem 1.5rem;
    }
  }
</style>

<script is:inline>
  (function () {
    const section = document.getElementById("kwd-website-cost-nz");
    if (!section) return;
    const calculator = section.querySelector("#kwd-cost-calculator");
    if (!calculator) return;

    const siteTypeRadios = calculator.querySelectorAll('input[name="kwd-site-type"]');
    const pagesGroup = calculator.querySelector("#kwd-pages-group");
    const pagesInput = calculator.querySelector("#kwd-pages");
    const productsGroup = calculator.querySelector("#kwd-products-group");
    const productsInput = calculator.querySelector("#kwd-products");
    const hostingSelect = calculator.querySelector("#kwd-hosting");
    const gstToggle = calculator.querySelector("#kwd-gst-toggle");
    const breakdownList = calculator.querySelector("#kwd-breakdown-list");
    const totalLabel = calculator.querySelector("#kwd-total-label");
    const totalValue = calculator.querySelector("#kwd-total");
    const addOnCheckboxes = Array.from(calculator.querySelectorAll(".kwd-addon"));
    const paymentCheckbox = calculator.querySelector("#kwd-add-payment");

    const baseCosts = {
      "one-page": 899,
      "small-business": 2490,
      ecommerce: 3890,
      custom: 7900
    };

    const addOnCosts = {
      bookings:    { label: "在线预约/预定功能", amount: 350 },
      blog:        { label: "博客设置", amount: 250 },
      seo:         { label: "基础SEO设置", amount: 400 },
      payment:     { label: "支付网关设置", amount: 300 },
      integration: { label: "第三方系统集成", amount: 700 }
    };

    const hostingCosts = {
      none:    { label: "主机托管/维护：不需要", amount: 0 },
      basic:   { label: "主机托管/维护：基础版", amount: 300 },
      business:{ label: "主机托管/维护：商业版", amount: 588 },
      managed: { label: "主机托管/维护：全托管版", amount: 1188 }
    };

    const siteTypeLabels = {
      "one-page": "单页网站 - 落地页或活动页面",
      "small-business": "小企业网站（5-8页）- 新西兰常见的服务型网站",
      ecommerce: "小型电商 - 100件商品以内",
      custom: "定制/复杂开发 - 系统集成、定制交互体验"
    };

    function formatCurrency(value) {
      return "$" + Math.round(value).toLocaleString("en-NZ");
    }

    function getSiteType() {
      for (const radio of siteTypeRadios) {
        if (radio.checked) return radio.value;
      }
      return "small-business";
    }

    function setHiddenField(id, value) {
      const field = document.getElementById(id);
      if (field) field.value = value;
    }

    function updateVisibility() {
      const siteType = getSiteType();
      const showPageInput = siteType === "one-page" || siteType === "small-business";
      const showProductInput = siteType === "ecommerce";

      pagesGroup.hidden = !showPageInput;
      pagesInput.required = showPageInput;
      productsGroup.hidden = !showProductInput;
      productsInput.required = showProductInput;

      if (!showProductInput) {
        paymentCheckbox.checked = false;
        paymentCheckbox.disabled = true;
      } else {
        paymentCheckbox.disabled = false;
      }
    }

    function updateEstimate() {
      const siteType = getSiteType();
      let subtotal = 0;
      const breakdown = [];
      const selectedAddOns = [];
      let pageCount = "不适用";
      let productCount = "不适用";

      const base = baseCosts[siteType] || 0;
      subtotal += base;
      breakdown.push({ label: "基础项目", amount: base });

      if (siteType === "one-page" || siteType === "small-business") {
        const pages = Math.max(0, parseInt(pagesInput.value, 10) || 0);
        pageCount = String(pages);
        const includedPages = siteType === "one-page" ? 1 : 5;
        const extraPages = Math.max(0, pages - includedPages);
        const pageCost = extraPages * 180;
        if (pageCost > 0) {
          subtotal += pageCost;
          breakdown.push({ label: "额外页面 (" + extraPages + ")", amount: pageCost });
        }
      }

      if (siteType === "ecommerce") {
        const products = Math.max(0, parseInt(productsInput.value, 10) || 0);
        productCount = String(products);
        const productBrackets = Math.max(0, Math.ceil((products - 20) / 20));
        const productCost = productBrackets * 350;
        if (productCost > 0) {
          subtotal += productCost;
          breakdown.push({ label: "额外产品批次 (" + productBrackets + " × 20)", amount: productCost });
        }
      }

      addOnCheckboxes.forEach(function (checkbox) {
        if (checkbox.checked) {
          const cost = addOnCosts[checkbox.value];
          if (cost) {
            subtotal += cost.amount;
            selectedAddOns.push(cost.label);
            breakdown.push({ label: cost.label, amount: cost.amount });
          }
        }
      });

      const hostingChoice = hostingSelect.value;
      const hosting = hostingCosts[hostingChoice];
      if (hosting) {
        subtotal += hosting.amount;
        if (hosting.amount > 0) {
          breakdown.push({ label: hosting.label, amount: hosting.amount });
        }
      }

      const gstOn = gstToggle.checked;
      const total = gstOn ? subtotal * 1.15 : subtotal;
      totalLabel.textContent = gstOn ? "预估总价（含GST）" : "预估总价（不含GST）";
      totalValue.textContent = formatCurrency(total);

      // Keep the hidden form field in sync so submissions include the current estimate
      const totalText = formatCurrency(total) + (gstOn ? "（含GST）" : "（不含GST）");
      const breakdownText = breakdown
        .map(function (item) { return item.label + ": " + formatCurrency(item.amount); })
        .join("; ");
      setHiddenField("kwd-calc-estimate-field", "网站类型: " + siteType + " | 预估: " + totalText);
      setHiddenField("kwd-calc-site-type-field", siteTypeLabels[siteType] || siteType);
      setHiddenField("kwd-calc-pages-field", pageCount);
      setHiddenField("kwd-calc-products-field", productCount);
      setHiddenField("kwd-calc-addons-field", selectedAddOns.length ? selectedAddOns.join(", ") : "无");
      setHiddenField("kwd-calc-hosting-field", hosting ? hosting.label + " (" + formatCurrency(hosting.amount) + "/年)" : "未选择");
      setHiddenField("kwd-calc-gst-field", gstOn ? "是" : "否");
      setHiddenField("kwd-calc-breakdown-field", breakdownText);
      setHiddenField("kwd-calc-total-field", totalText);

      breakdownList.innerHTML = breakdown
        .map(function (item) {
          return "<li><span>" + item.label + "</span><span>" + formatCurrency(item.amount) + "</span></li>";
        })
        .join("");
    }

    siteTypeRadios.forEach(function (radio) {
      radio.addEventListener("change", function () { updateVisibility(); updateEstimate(); });
    });
    [pagesInput, productsInput].forEach(function (input) {
      input.addEventListener("input", updateEstimate);
    });
    addOnCheckboxes.forEach(function (checkbox) {
      checkbox.addEventListener("change", updateEstimate);
    });
    hostingSelect.addEventListener("change", updateEstimate);
    gstToggle.addEventListener("change", updateEstimate);

    updateVisibility();
    updateEstimate();

    // Smooth scroll for TOC links
    const tocLinks = section.querySelectorAll('.kwd-toc a[href^="#"]');
    tocLinks.forEach(function (link) {
      link.addEventListener("click", function (event) {
        const targetId = link.getAttribute("href");
        if (!targetId) return;
        const target = document.querySelector(targetId);
        if (target) {
          event.preventDefault();
          target.scrollIntoView({ behavior: "smooth", block: "start" });
          history.replaceState(null, "", targetId);
        }
      });
    });

    if (window.location.hash) {
      const target = document.querySelector(window.location.hash);
      if (target) {
        setTimeout(function () {
          target.scrollIntoView({ behavior: "smooth", block: "start" });
        }, 200);
      }
    }

    // ── Inline quote form submit ──
    const calcForm = document.getElementById("kwd-calc-contact-form");
    const qfBtn    = document.getElementById("kwd-qf-btn");
    const qfStatus = document.getElementById("kwd-qf-status");

    function showQFStatus(msg, isError) {
      qfStatus.textContent = msg;
      qfStatus.className = "kwd-qf-status " + (isError ? "is-error" : "is-success");
      qfStatus.hidden = false;
    }

    if (calcForm && qfBtn && qfStatus) {
      calcForm.addEventListener("submit", async function (e) {
        e.preventDefault();

        // Honeypot bot check
        const botcheck = calcForm.querySelector('[name="botcheck"]');
        if (botcheck && botcheck.checked) return;

        const name    = (document.getElementById("kwd-qf-name").value || "").trim();
        const contact = (document.getElementById("kwd-qf-contact").value || "").trim();

        if (name.length < 2) {
          showQFStatus("请输入你的姓名。", true);
          return;
        }
        if (contact.length < 5) {
          showQFStatus("请输入你的电话号码或邮箱地址。", true);
          return;
        }

        qfBtn.disabled = true;
        qfBtn.textContent = "发送中…";
        qfStatus.hidden = true;

        updateEstimate();

        const leadTracking = window.kwdLeadTracking;
        const leadContext = leadTracking
          ? await leadTracking.prepare(calcForm, "website_cost_calculator_zh")
          : null;
        const payload = {};
        new FormData(calcForm).forEach(function (val, key) { payload[key] = val; });

        fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: { "Content-Type": "application/json", "Accept": "application/json" },
          body: JSON.stringify(payload)
        })
          .then(function (res) { return res.json(); })
          .then(function (data) {
            if (data.success) {
              showQFStatus("谢谢！Charlie 会在2个工作小时内联系你。", false);
              calcForm.reset();
              updateEstimate();
              if (leadContext && leadTracking) {
                leadTracking.trackLead(leadContext, 'kwd-calc-contact-form', 'website_cost_calculator_zh');
              }
            } else {
              showQFStatus(data.message || "出现问题，请重试。", true);
            }
          })
          .catch(function () {
            showQFStatus("网络错误，请重试，或直接致电 021 039 6580。", true);
          })
          .finally(function () {
            qfBtn.disabled = false;
            qfBtn.textContent = "发送我的联系方式 →";
          });
      });
    }

    // FAQ accordion
    const faqButtons = section.querySelectorAll(".kwd-faq-button");
    faqButtons.forEach(function (button, index) {
      const panelId = button.getAttribute("aria-controls");
      const panel = panelId ? document.getElementById(panelId) : null;
      button.id = "kwd-faq-q" + (index + 1);
      if (panel) {
        panel.setAttribute("aria-labelledby", button.id);
      }
      button.addEventListener("click", function () {
        const expanded = button.getAttribute("aria-expanded") === "true";
        button.setAttribute("aria-expanded", String(!expanded));
        if (panel) panel.hidden = expanded;
      });
    });
  })();
</script>
