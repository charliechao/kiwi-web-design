---
import Layout from '../../layouts/Layout.astro';
import CTABanner from '../../components/CTABanner.astro';
import { Image } from 'astro:assets';
import about3Img from '../../assets/general/about3.jpg';
import about4Img from '../../assets/general/about4.jpg';

const contactPage = '/zh/website-designer-auckland/';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/zh/google-ads/",
      "url": "https://www.kiwiwebdesign.co.nz/zh/google-ads/",
      "name": "奥克兰Google广告服务 | SEM竞价推广 | Kiwi Web Design",
      "description": "奥克兰Google广告管理团队，服务全新西兰华人企业与本地小企业。帮助企业设置、管理和优化Google广告，固定月费起$399。",
      "inLanguage": "zh-Hans",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/zh/google-ads/#breadcrumb" },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".zh-ga-snippet", ".zh-eyebrow", ".zh-subtitle"]
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/zh/google-ads/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "首页", "item": "https://www.kiwiwebdesign.co.nz/zh/" },
        { "@type": "ListItem", "position": 2, "name": "Google广告", "item": "https://www.kiwiwebdesign.co.nz/zh/google-ads/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "奥克兰网页设计",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "City", "name": "Auckland" },
        { "@type": "Country", "name": "New Zealand" }
      ],
      "priceRange": "$$"
    },
    {
      "@type": "Service",
      "@id": "https://www.kiwiwebdesign.co.nz/zh/google-ads/#service",
      "name": "奥克兰Google广告管理",
      "serviceType": "Google Ads Management",
      "category": "Digital Marketing",
      "description": "为奥克兰中小企业提供Google广告投放与管理服务。涵盖搜索广告、本地服务广告、再营销广告和转化追踪。固定月费起$399。",
      "provider": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "areaServed": [
        { "@type": "City", "name": "Auckland" },
        { "@type": "Country", "name": "New Zealand" }
      ],
      "url": "https://www.kiwiwebdesign.co.nz/zh/google-ads/",
      "offers": [
        {
          "@type": "Offer",
          "name": "广告账户初始设置",
          "price": "499",
          "priceCurrency": "NZD",
          "description": "一次性Google广告账户设置费"
        },
        {
          "@type": "Offer",
          "name": "每月管理费",
          "price": "399",
          "priceCurrency": "NZD",
          "priceSpecification": { "@type": "PriceSpecification", "price": "399", "priceCurrency": "NZD", "unitCode": "MON" },
          "description": "持续每月Google广告管理--固定费用，非按广告费比例收费"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Google广告多快能产生询盘？",
          "acceptedAnswer": { "@type": "Answer", "text": "广告通过审核后通常很快就能开始获得曝光和点击。实际询盘速度取决于行业竞争、广告预算、关键词、落地页质量和转化追踪设置。" }
        },
        {
          "@type": "Question",
          "name": "Google广告管理费是多少？",
          "acceptedAnswer": { "@type": "Answer", "text": "Kiwi Web Design收取固定月度管理费，起价$399/月，另加一次性初始设置费起$499。这与您的广告投放预算分开计算。大多数奥克兰服务型企业建议广告预算最低$500/月。" }
        },
        {
          "@type": "Question",
          "name": "需要多少广告预算？",
          "acceptedAnswer": { "@type": "Answer", "text": "对大多数奥克兰服务型企业来说，每月$500-$1,500的广告投入是合理的起点。竞争激烈的行业（如法律或装修）可能需要更多。我们会提前坦诚告知您在特定市场竞争所需的预算。" }
        },
        {
          "@type": "Question",
          "name": "Google广告和SEO哪个更适合我？",
          "acceptedAnswer": { "@type": "Answer", "text": "两者用途不同。Google广告适合更快获得曝光和询盘，但需要持续广告预算。SEO见效慢一些，但能积累长期自然流量。很多成长型企业会两者结合。" }
        },
        {
          "@type": "Question",
          "name": "你们能接管我现有的Google广告账户吗？",
          "acceptedAnswer": { "@type": "Answer", "text": "可以。我们可以审计并接管您现有的广告系列，也可以为从零开始的企业全新设置账户。无论哪种情况，我们都会先进行免费审计，了解现状和改进空间。" }
        },
        {
          "@type": "Question",
          "name": "你们按广告费比例收费吗？",
          "acceptedAnswer": { "@type": "Answer", "text": "不。Kiwi Web Design收取固定月度管理费，而不是按广告费百分比收费。这样你更容易控制成本，也不会因为广告预算提高而自动增加管理费。初始设置费起$499，月度管理费起$399。" }
        }
      ]
    }
  ]
};

const adServices = [
  {
    icon: "🔍",
    title: "搜索广告",
    desc: "当客户正在Google上搜索你的服务时，让广告出现在合适的位置。我们会设置关键词、匹配方式和广告文案。",
    items: ["关键词和匹配方式", "竞争对手差距分析", "否定关键词列表", "广告文案测试"],
  },
  {
    icon: "🏙️",
    title: "本地服务广告",
    desc: "适合服务型企业争取更多本地曝光。我们会根据你的行业和地区判断是否适合使用本地服务广告。",
    items: ["LSA设置与资质认证", "预算优化", "好评获取支持", "询盘质量追踪"],
  },
  {
    icon: "🎯",
    title: "再营销广告",
    desc: "重新触达曾经访问过网站、但还没有联系你的客户，让品牌在他们考虑时继续出现。",
    items: ["受众列表创建", "展示再营销", "YouTube再营销", "动态广告创意"],
  },
  {
    icon: "📊",
    title: "转化追踪",
    desc: "清楚知道哪些广告带来了电话、表单和销售机会，避免只看点击、不知道效果。",
    items: ["Google标签管理器设置", "电话追踪", "表单提交追踪", "电商收入追踪"],
  },
  {
    icon: "🛒",
    title: "购物广告",
    desc: "适合电商企业，把产品数据整理好，让商品更容易出现在Google购物相关位置。",
    items: ["Google Merchant Center设置", "产品数据优化", "智能购物广告系列", "广告支出回报优化"],
  },
  {
    icon: "📈",
    title: "持续优化",
    desc: "广告不是设置完就不管。我们会每月看数据、调关键词、改文案、优化预算。",
    items: ["每月效果审查", "出价策略优化", "质量得分提升", "广告投放时段精调"],
  },
];

const whyUs = [
  {
    icon: "🚫",
    title: "尽量少浪费预算",
    desc: "通过关键词、否定关键词和落地页优化，把预算更多花在真正有搜索意向的客户身上。",
  },
  {
    icon: "📍",
    title: "奥克兰本地团队，服务全新西兰",
    desc: "我们会根据你的城市、行业和目标客户设置广告系列，不用一套模板套所有行业。",
  },
  {
    icon: "🔎",
    title: "透明数据报告",
    desc: "你每月会看到投放金额、询盘情况、获客成本和我们正在做的优化，不需要自己猜效果。",
  },
  {
    icon: "🏁",
    title: "启动速度快",
    desc: "相比SEO，Google广告通常能更快开始获得曝光和点击。我们会先把账户、追踪和落地页基础设置好。",
  },
];

const process = [
  { step: "1", title: "免费广告审计", desc: "先看你现有广告账户，或从零评估市场、关键词和预算是否合理。" },
  { step: "2", title: "制定广告策略", desc: "确定关键词、广告文案、落地页、预算和转化追踪，不盲目开跑。" },
  { step: "3", title: "设置与上线", desc: "搭建广告系列，安装转化追踪，确认无误后上线。" },
  { step: "4", title: "管理与优化", desc: "每月看数据、调预算、加否定关键词、测试文案，并汇报结果。" },
];

const industries = [
  "工程与装修（水电、建筑）",
  "医疗与牙科",
  "律师事务所与专业服务",
  "美容与健康沙龙",
  "餐饮与酒店",
  "电商与零售",
  "清洁与物业服务",
  "汽车与机械服务",
];

const reviews = [
  { name: "Zane Barrett", company: "Barrett Access Scaffolding", text: "Charlie负责了我们的Google广告推广，第一周就开始有询盘了。报告清晰，没有专业术语，而且他真心在意效果。" },
  { name: "Jack", company: "Show Me Shorts", text: "他们从一开始就把广告搭建得很规范--追踪了转化、合理管控预算，投资回报率一直很稳。正是我们需要的。" },
];

const faqs = [
  { q: "Google广告多快能产生询盘？", a: "广告上线并通过审核后，通常很快就能开始获得曝光和点击。实际询盘速度取决于行业竞争、预算、落地页质量和转化追踪设置。" },
  { q: "Google广告管理费是多少？", a: "我们的管理费起价$399/月，另加您的广告投放预算。具体费用取决于您的预算和广告系列复杂程度。对大多数新西兰服务型企业，建议广告预算最低$500/月以产生有意义的效果。" },
  { q: "需要多少广告预算？", a: "对大多数新西兰服务型企业来说，每月$500-$1,500的广告投入是合理的起点。竞争激烈的行业（如法律或工程）可能需要更多预算。我们会提前坦诚告知您在特定市场竞争所需的具体投入。" },
  { q: "Google广告和SEO哪个更适合我？", a: "两者用途不同。Google广告适合更快获得曝光和询盘，但需要持续广告预算。SEO见效慢一些，但能积累长期自然流量。很多新西兰成长型企业会两者结合。" },
  { q: "你们能接管我现有的Google广告账户吗？", a: "可以。我们可以审计并接管您现有的广告系列管理，也可以为从零开始的企业全新设置账户。无论哪种情况，我们都会先进行审计，了解现状与改进空间。" },
  { q: "你们的收费结构是怎样的？", a: "我们收取固定月度管理费，而不是按广告费百分比收费。这样你更容易控制成本，也不会因为广告预算提高而自动增加管理费。初始设置费起$499，月度管理费起$399。" },
];
---

<Layout
  title="奥克兰Google广告服务 SEM竞价推广 Kiwi Web Design"
  description="奥克兰Google广告管理团队，服务全新西兰华人企业与小企业。帮助企业设置、管理和优化Google广告，固定月费起$399。"
  canonicalURL="https://www.kiwiwebdesign.co.nz/zh/google-ads/"
  schema={schema}
  lang="zh-Hans"
  alternateUrl="https://www.kiwiwebdesign.co.nz/google-ads/"
>

  <!-- Hero -->
  <section class="zh-ga-hero">
    <div class="container zh-ga-hero-inner">
      <div class="zh-ga-hero-text">
        <p class="zh-eyebrow">奥克兰 Google 广告服务</p>
        <h1 class="zh-ga-title">想更快拿到询盘，可以先从Google广告开始。</h1>
        <p class="zh-subtitle">我们帮新西兰华人企业和本地小企业设置、管理和优化Google广告，把预算更多花在真正有搜索意向的客户身上。</p>
        <div class="zh-ga-hero-btns">
          <a href={contactPage} class="btn-zh-primary">预约免费咨询</a>
          <a href="#process" class="btn-zh-outline">了解服务流程</a>
        </div>
        <p class="zh-note">初始设置起 NZ$499 · 固定月费，不按广告费比例收取</p>
      </div>
      <div class="zh-ga-hero-stats">
        <div class="zh-stat">
          <span class="zh-stat-num">快速</span>
          <span class="zh-stat-lbl">通过审核后开始获得曝光</span>
        </div>
        <div class="zh-stat">
          <span class="zh-stat-num">$399</span>
          <span class="zh-stat-lbl">月度管理费起价</span>
        </div>
        <div class="zh-stat">
          <span class="zh-stat-num">固定</span>
          <span class="zh-stat-lbl">月费，非按广告费比例</span>
        </div>
        <div class="zh-stat">
          <span class="zh-stat-num">5★</span>
          <span class="zh-stat-lbl">Google 评分</span>
        </div>
      </div>
    </div>
  </section>

  <!-- AI citability snippet -->
  <div class="zh-ga-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> 为新西兰华人企业和本地小企业提供Google广告管理服务，月度管理费固定起价 <strong>$399</strong>，不按广告费百分比收费。一次性初始设置费起 <strong>$499</strong>。服务包括搜索广告、本地服务广告、再营销、购物广告和转化追踪。广告通过审核后通常能较快开始获得曝光和点击，实际询盘取决于预算、行业竞争和落地页质量。公司位于奥克兰 Grey Lynn，Google评分 <strong>5★</strong>。</p>
    </div>
  </div>

  <!-- Why Google Ads -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <div class="zh-section-header">
        <p class="zh-section-eyebrow">为什么选择 Google 广告</p>
        <h2 class="zh-section-title">想更快获得曝光，Google广告是很直接的方式。</h2>
        <p class="zh-section-subtitle">当客户正在搜索你的服务时，广告可以让你更快出现在他们面前，并且按点击付费。</p>
      </div>
      <div class="zh-why-grid">
        {whyUs.map(item => (
          <div class="zh-why-card">
            <span class="zh-why-icon">{item.icon}</span>
            <h3 class="zh-why-title">{item.title}</h3>
            <p class="zh-why-desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <div class="zh-section-header">
        <p class="zh-section-eyebrow">我们的服务</p>
        <h2 class="zh-section-title">从设置到账户优化，我们一起管理。</h2>
        <p class="zh-section-subtitle">关键词、广告文案、落地页建议、转化追踪和月度优化都会一起考虑。</p>
      </div>
      <div class="zh-services-grid">
        {adServices.map(svc => (
          <div class="zh-service-card">
            <span class="zh-service-icon">{svc.icon}</span>
            <h3 class="zh-service-title">{svc.title}</h3>
            <p class="zh-service-desc">{svc.desc}</p>
            <ul class="zh-service-list">
              {svc.items.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <div class="zh-section-header" style="color: #fff;">
        <p class="zh-section-eyebrow" style="color: var(--kwd-yellow);">服务行业</p>
        <h2 class="zh-section-title" style="color: #fff;">我们服务的行业。</h2>
      </div>
      <div class="zh-industries">
        {industries.map(item => (
          <div class="zh-industry-item">
            <svg class="zh-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);" id="process">
    <div class="container">
      <div class="zh-section-header">
        <p class="zh-section-eyebrow">服务流程</p>
        <h2 class="zh-section-title">先把账户和追踪搭好，再上线投放。</h2>
        <p class="zh-section-subtitle">Google广告启动速度快，但基础设置要认真做，后面数据才有参考价值。</p>
      </div>
      <div class="zh-process-steps">
        {process.map((step, i) => (
          <div class="zh-process-step">
            <span class="zh-step-num">{step.step}</span>
            <div class="zh-step-body">
              <h3 class="zh-step-title">{step.title}</h3>
              <p class="zh-step-desc">{step.desc}</p>
            </div>
            {i < process.length - 1 && <div class="zh-step-connector" aria-hidden="true" />}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team photo band -->
  <section class="zh-ga-team-band">
    <Image src={about3Img} alt="Kiwi Web Design团队为奥克兰企业管理Google广告系列" width={1600} height={640} class="zh-ga-band-img" />
    <div class="zh-ga-band-overlay">
      <div class="container">
        <p class="zh-ga-band-eyebrow">你广告背后的团队</p>
        <h2 class="zh-ga-band-title">我们像管理自己的钱一样，管理每一分广告预算。</h2>
        <a href="/zh/website-designer-auckland/" class="zh-ga-band-link">立即获取免费广告策略咨询 →</a>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section">
    <div class="container">
      <div class="zh-pricing-card">
        <div class="zh-pricing-left">
          <p class="zh-pricing-eyebrow">服务定价</p>
          <h2 class="zh-pricing-title">简单透明的固定费用。</h2>
          <p class="zh-pricing-desc">我们收取固定月度管理费，而不是按广告费百分比收费。这样你更容易控制成本，也不会因为广告预算提高而自动增加管理费。</p>
          <div class="zh-pricing-tiers">
            <div class="zh-tier">
              <span class="zh-tier-price">起价 $499</span>
              <span class="zh-tier-label">一次性广告系列初始设置费</span>
            </div>
            <div class="zh-tier">
              <span class="zh-tier-price">起价 $399/月</span>
              <span class="zh-tier-label">持续月度管理费</span>
            </div>
            <div class="zh-tier">
              <span class="zh-tier-price">$500+/月</span>
              <span class="zh-tier-label">建议广告投放预算（另计）</span>
            </div>
          </div>
        </div>
        <div class="zh-pricing-right">
