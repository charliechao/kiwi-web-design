      "primaryImageOfPage": { "@id": "https://www.kiwiwebdesign.co.nz/zh/local-seo-for-auckland-small-businesses/#primaryimage" },
      "image": [
        { "@id": "https://www.kiwiwebdesign.co.nz/zh/local-seo-for-auckland-small-businesses/#primaryimage" },
        { "@id": "https://www.kiwiwebdesign.co.nz/zh/local-seo-for-auckland-small-businesses/#strategyimage" },
        { "@id": "https://www.kiwiwebdesign.co.nz/zh/local-seo-for-auckland-small-businesses/#consultationimage" }
      ],
      "inLanguage": "zh-Hans",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/zh/local-seo-for-auckland-small-businesses/#breadcrumb" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": [".local-snippet", "h1"] }
    },
    {
      "@type": "BreadcrumbList",
