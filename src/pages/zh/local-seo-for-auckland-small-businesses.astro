    },
    {
      "@type": "Service",
      "@id": "https://www.kiwiwebdesign.co.nz/zh/local-seo-for-auckland-small-businesses/#service",
      "name": "奥克兰本地SEO优化",
      "serviceType": "本地搜索引擎优化",
      "category": "数字营销",
      "provider": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "areaServed": [
        { "@type": "Place", "name": "Auckland" },
        { "@type": "Place", "name": "New Zealand" }
      ],
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "500",
        "highPrice": "2000",
        "priceCurrency": "NZD",
        "priceSpecification": { "@type": "PriceSpecification", "valueAddedTaxIncluded": false, "unitCode": "MON" }
