---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ServiceGrid from '../../components/ServiceGrid.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import TestimonialGrid from '../../components/TestimonialGrid.astro';
import CTABanner from '../../components/CTABanner.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import { Image } from 'astro:assets';
import about3Img from '../../assets/general/about3.jpg';
import seoConsultationImg from '../../assets/zh/seo-auckland-chinese-business-consultation.png';
import seoReportImg from '../../assets/zh/seo-auckland-monthly-report-workspace.png';
import seoLocalConsultImg from '../../assets/zh/seo-auckland-local-search-cafe-consultation.png';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/zh/seo-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/zh/seo-auckland/",
      "name": "奥克兰SEO优化服务 | 搜索引擎优化 | Kiwi Web Design",
      "description": "奥克兰SEO优化团队，服务新西兰华人企业与本地小企业。SEO优化起价$500/月，包含Google地图排名、网站内容、技术SEO和月度报告。",
      "inLanguage": "zh-Hans",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/zh/seo-auckland/#breadcrumb" },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".seo-snippet", ".seo-statbar-inner"]
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/zh/seo-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "首页", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "中文服务", "item": "https://www.kiwiwebdesign.co.nz/zh/" },
        { "@type": "ListItem", "position": 3, "name": "SEO优化", "item": "https://www.kiwiwebdesign.co.nz/zh/seo-auckland/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "奥克兰网页设计",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "City", "name": "Auckland" },
        { "@type": "Country", "name": "New Zealand" }
      ],
      "priceRange": "$$",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "bestRating": "5",
        "ratingCount": "50"
      },
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.kiwiwebdesign.co.nz/favicon.png",
        "width": 512,
        "height": 512
      }
    },
    {
      "@type": "Service",
      "@id": "https://www.kiwiwebdesign.co.nz/zh/seo-auckland/#service",
      "name": "奥克兰SEO优化服务",
      "serviceType": "Search Engine Optimisation",
      "category": "Digital Marketing",
      "description": "为新西兰华人企业与本地小企业提供SEO优化服务。涵盖Google地图排名、页面优化、内容创作、外链建设和月度报告。起价$500/月。",
      "provider": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "areaServed": [
        { "@type": "City", "name": "Auckland" },
        { "@type": "Country", "name": "New Zealand" }
      ],
      "url": "https://www.kiwiwebdesign.co.nz/zh/seo-auckland/",
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "500",
        "highPrice": "2500",
        "priceCurrency": "NZD",
        "priceSpecification": { "@type": "PriceSpecification", "price": "500", "priceCurrency": "NZD", "unitCode": "MON" }
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "奥克兰SEO优化需要多长时间才能看到效果？",
          "acceptedAnswer": { "@type": "Answer", "text": "大多数企业会在2-3个月内看到一些初步变化，6-12个月更容易看到稳定效果。SEO不是一开就立刻见效的广告，它需要把网站基础、内容和本地信号慢慢做扎实。" }
        },
        {
          "@type": "Question",
          "name": "新西兰小企业SEO费用是多少？",
          "acceptedAnswer": { "@type": "Answer", "text": "SEO套餐起价$500/月，根据行业竞争程度和工作范围可升至$2,500/月。每个合作都从免费审核开始，确保报价准确。" }
        },
        {
          "@type": "Question",
          "name": "本地SEO和普通SEO有什么区别？",
          "acceptedAnswer": { "@type": "Answer", "text": "本地SEO主要针对带地区意图的搜索，例如「奥克兰水管工」或「附近咖啡馆」。它会重点处理Google商家资料、本地目录、评价和Google地图排名。普通SEO更偏向网站整体内容和全国性搜索。" }
        },
        {
          "@type": "Question",
          "name": "我已经在投放Google广告，还需要做SEO吗？",
          "acceptedAnswer": { "@type": "Answer", "text": "两者作用不同。Google广告适合更快拿到曝光和询盘，但需要持续广告预算。SEO见效更慢，但能积累长期自然流量。很多企业会先用广告带来询盘，同时用SEO打长期基础。" }
        },
        {
          "@type": "Question",
          "name": "你们能保证Google首页排名吗？",
          "acceptedAnswer": { "@type": "Answer", "text": "不能。任何负责任的SEO团队都不应该保证某个固定排名。我们能保证的是把该做的基础、内容、本地信号和数据追踪认真做好，并用清楚的月度报告说明进展。" }
        },
        {
          "@type": "Question",
          "name": "你们是否服务奥克兰以外的企业？",
          "acceptedAnswer": { "@type": "Answer", "text": "可以。我们在奥克兰，也为新西兰其他城市的企业做SEO。奥克兰客户可以面谈，其他地区可以远程合作。" }
        }
      ]
    }
  ]
};

const seoServices = [
  {
    icon: "📍",
    title: "奥克兰本地SEO",
    desc: "让附近正在找服务的客户更容易看到你。我们会优化Google商家资料、本地目录和带地区的关键词。",
    items: ["Google商家资料优化", "本地目录和引用", "Google地图排名", "地区关键词策略"],
  },
  {
    icon: "⚙️",
    title: "技术SEO",
    desc: "先把网站速度、结构、索引和手机端体验处理好，避免因为技术问题影响排名。",
    items: ["网站速度优化", "核心网页指标改善", "Schema结构化数据", "移动端适配优化"],
  },
  {
    icon: "✍️",
    title: "内容与页面SEO",
    desc: "研究客户真正会搜的词，再把页面内容写清楚。既让Google看得懂，也让客户读得明白。",
    items: ["关键词研究分析", "SEO内容创作", "Meta标签优化", "内部链接结构"],
  },
  {
    icon: "🔗",
    title: "外链建设",
    desc: "通过相关的新西兰目录、合作资源和内容机会提升网站可信度，不买垃圾链接，不走短期捷径。",
    items: ["新西兰相关目录收录", "本地商业合作伙伴关系", "内容型外链获取", "权威度持续建设"],
  },
  {
    icon: "📊",
    title: "数据分析与报告",
    desc: "每月用清楚的报告说明排名、自然流量和询盘变化，少讲术语，多讲下一步怎么做。",
    items: ["Google Analytics 4配置", "Search Console监控", "月度排名追踪", "询盘来源归因"],
  },
  {
    icon: "🛒",
    title: "电商SEO",
    desc: "优化WooCommerce和Shopify的产品页、分类页和结构，让有购买意向的自然流量更容易进来。",
    items: ["产品页面优化", "类目结构优化", "产品Schema标记", "Google购物曝光"],
  },
];

const process = [
  { step: "1", title: "免费SEO审核", desc: "先看你现在的网站、排名、关键词机会和竞争对手情况。" },
  { step: "2", title: "制定优先级", desc: "找出最值得先做的关键词和页面，不为了流量数字而做无关内容。" },
  { step: "3", title: "逐步优化", desc: "技术修复、内容更新、本地信号和外链机会会按优先级推进。" },
  { step: "4", title: "月度报告", desc: "用清楚的报告说明排名、流量和询盘变化，以及下个月要做什么。" },
];

const reviews = [
  { name: "Zane Barrett", company: "Barrett Access Scaffolding", text: "Charlie花时间真正了解我们的业务，打造了一个实际能带来排名的网站。我们获得了以前从来没有的询盘，这些都是通过SEO找到我们的。" },
  { name: "Jack", company: "Show Me Shorts", text: "SEO工作非常专业彻底。他们把所有事情都解释得很清楚，我能看到我们Google排名的实实在在的改善。" },
];

const faqs = [
  { q: "奥克兰SEO优化需要多长时间才能看到效果？", a: "大多数企业会在2-3个月内看到一些初步变化，6-12个月更容易看到稳定效果。SEO不是一开就立刻见效的广告，它需要把网站基础、内容和本地信号慢慢做扎实。" },
  { q: "新西兰小企业SEO费用是多少？", a: "我们的SEO套餐起价$500/月，根据行业竞争程度和工作范围可升至$2,500/月。每个合作都从免费审核开始，确保报价准确。" },
  { q: "本地SEO和普通SEO有什么区别？", a: "本地SEO主要针对带地区意图的搜索，例如「奥克兰水管工」或「附近咖啡馆」。它会重点处理Google商家资料、本地目录、评价和Google地图排名。普通SEO更偏向网站整体内容和全国性搜索。详细内容可查看我们的<a href=\"/local-seo-for-auckland-small-businesses/\">奥克兰本地SEO</a>服务页面。" },
  { q: "我已经在投放Google广告，还需要做SEO吗？", a: "两者作用不同。<a href=\"/google-ads/\">Google广告</a>适合更快拿到曝光和询盘，但需要持续广告预算。SEO见效更慢，但能积累长期自然流量。很多企业会先用广告带来询盘，同时用SEO打长期基础。" },
  { q: "你们能保证Google首页排名吗？", a: "不能。任何负责任的SEO团队都不应该保证某个固定排名。我们能保证的是把该做的基础、内容、本地信号和数据追踪认真做好，并用清楚的月度报告说明进展。" },
  { q: "你们是否服务奥克兰以外的企业？", a: "可以。我们在奥克兰，也为新西兰其他城市的企业做SEO。奥克兰客户可以面谈，其他地区可以远程合作。" },
];
---

<Layout
  title="奥克兰SEO优化服务 搜索引擎优化 Kiwi Web Design"
  description="奥克兰SEO优化团队，服务新西兰华人企业与本地小企业。SEO优化起价$500/月，包含Google地图排名、网站内容、技术SEO和月度报告。"
  canonicalURL="https://www.kiwiwebdesign.co.nz/zh/seo-auckland/"
  schema={schema}
  lang="zh-Hans"
  alternateUrl="https://www.kiwiwebdesign.co.nz/affordable-seo-auckland/"
>

  <PageHero
    eyebrow="奥克兰SEO优化服务"
    title="让真正想找你的客户，在Google上找到你。"
    subtitle="我们帮新西兰华人企业和本地小企业做SEO优化，包括Google地图排名、网站内容、技术SEO和月度报告。起价$500/月，先审核，再建议。"
    ctaPrimary={{ text: "获取免费SEO审核", href: "/zh/website-designer-auckland/" }}
    ctaSecondary={{ text: "查看价格", href: "#pricing" }}
    centered={true}
  />

  <!-- AI citability snippet -->
  <div class="seo-snippet">
    <div class="container">
  <p><strong>Kiwi Web Design</strong> 为新西兰华人企业与本地小企业提供SEO优化服务，<strong>起价$500/月</strong>。服务包括本地SEO、Google商家资料优化、技术SEO、内容优化和月度报告。公司位于奥克兰 Grey Lynn，支持全新西兰远程合作，Google评分 <strong>4.9★</strong>。SEO通常需要持续投入，大多数企业会先看到基础改善，再逐步积累稳定排名和询盘。</p>
    </div>
  </div>

  <!-- Premium visual intro -->
  <section class="seo-visual-intro">
    <div class="container seo-visual-intro-grid">
      <figure class="seo-hero-media">
        <Image
          src={seoConsultationImg}
          alt="奥克兰华人企业主与SEO顾问一起查看搜索排名和网站数据"
          width={1536}
          height={864}
          class="seo-hero-media-img"
          loading="eager"
          decoding="async"
        />
      </figure>
      <div class="seo-visual-panel">
        <p class="seo-panel-eyebrow">SEO不是玄学</p>
        <h2>先看业务、网站和真实搜索，再决定该怎么做。</h2>
        <p>我们会先了解你的客户怎么找服务、现在网站卡在哪里、Google商家资料是否完整，再把技术SEO、内容和本地信号按优先级排出来。</p>
        <div class="seo-panel-points">
          <span>关键词和页面优先级</span>
          <span>Google地图与本地信号</span>
          <span>月度数据复盘</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Stat bar -->
  <div class="seo-statbar">
    <div class="container seo-statbar-inner">
      <div class="ssb-item"><span class="ssb-num">93%</span><span class="ssb-lbl">很多客户会先从搜索开始了解企业</span></div>
      <span class="ssb-sep" aria-hidden="true"></span>
      <div class="ssb-item"><span class="ssb-num">14.6%</span><span class="ssb-lbl">SEO线索常见成交率参考</span></div>
      <span class="ssb-sep" aria-hidden="true"></span>
      <div class="ssb-item"><span class="ssb-num">4.9★</span><span class="ssb-lbl">Google综合评分</span></div>
      <span class="ssb-sep" aria-hidden="true"></span>
      <div class="ssb-item"><span class="ssb-num">起价$500/月</span><span class="ssb-lbl">SEO套餐起步价格</span></div>
    </div>
  </div>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="我们的SEO服务"
        title="先把基础做好，再一步步提高排名。"
    subtitle="从技术修复到内容、本地信号和报告，重点是让真正有需求的客户更容易找到你。"
      />
      <ServiceGrid items={seoServices} cols={3} />
    </div>
  </section>

  <!-- Results strip (dark) -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader eyebrow="真实成果" title="SEO做得扎实，询盘才会慢慢稳定。" light={true} />
      <div class="seo-results">
        <div class="seo-result">
          <span class="sr-num">+87%</span>
          <span class="sr-label">自然搜索流量增长</span>
          <span class="sr-industry">管道工程企业</span>
        </div>
        <div class="seo-result">
          <span class="sr-num">+64%</span>
          <span class="sr-label">网站访问量增长</span>
          <span class="sr-industry">餐饮行业</span>
        </div>
        <div class="seo-result">
          <span class="sr-num">+92%</span>
          <span class="sr-label">新患者询盘增长</span>
          <span class="sr-industry">牙科诊所</span>
        </div>
        <div class="seo-result">
          <span class="sr-num">3–6月</span>
          <span class="sr-label">平均见效时间</span>
          <span class="sr-industry">大多数奥克兰企业</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Reporting visual -->
  <section class="section seo-report-section">
    <div class="container seo-report-grid">
      <div class="seo-report-copy">
        <p class="seo-about-eyebrow">月度报告</p>
        <h2>不是只发一堆排名截图，而是告诉你下一步该做什么。</h2>
        <p>SEO报告会把排名、自然流量、电话和表单询盘放在一起看。你会知道这个月做了什么、哪些页面有变化、下个月最值得先优化哪里。</p>
        <ul class="seo-about-list">
          <li>关键词排名和自然流量变化</li>
          <li>Google商家资料和地图表现</li>
          <li>电话、表单和询盘来源追踪</li>
        </ul>
      </div>
      <figure class="seo-report-media">
        <Image
          src={seoReportImg}
          alt="奥克兰小企业SEO月度报告和搜索表现数据"
          width={1536}
          height={864}
          class="seo-report-img"
          loading="eager"
          decoding="async"
        />
      </figure>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="合作流程"
        title="从审核到成果，流程清晰。"
        subtitle="每次SEO合作都从免费审核开始，让我们准确知道该修复什么、该建立什么。"
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- About split -->
  <section class="section seo-about-section">
    <div class="container">
      <div class="seo-about-split">
        <div class="seo-about-img-wrap">
          <Image src={seoLocalConsultImg} alt="奥克兰华人小企业主与SEO顾问讨论本地搜索和Google地图排名" width={1536} height={864} class="seo-about-img" loading="eager" decoding="async" />
        </div>
        <div class="seo-about-content">
          <p class="seo-about-eyebrow">为何选择我们</p>
          <h2>SEO要围绕你的业务来做，不能只套模板。</h2>
          <p>我们不是卖完套餐就不管。每个客户的行业、竞争对手和客户搜索习惯都不一样，所以策略也要按实际情况调整。</p>
          <ul class="seo-about-list">
            <li>合作前先做免费审核</li>
            <li>不靠长期合同锁住客户</li>
            <li>月度报告清楚易懂，少讲术语</li>
            <li>奥克兰本地团队，也服务全新西兰</li>
            <li>看排名，也看电话、表单和真实询盘</li>
          </ul>
          <a href="/zh/website-designer-auckland/" class="seo-about-btn">预约免费SEO审核 →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section" id="pricing">
    <div class="container">
      <SectionHeader
        eyebrow="价格方案"
        title="奥克兰企业SEO价格"
        subtitle="无合同锁定。每次合作都从免费审核开始。"
      />
      <div class="seo-pkg-grid">
        <div class="seo-pkg">
          <h3>入门SEO</h3>
