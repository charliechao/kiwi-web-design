const seoServices = [
  {
    icon: "📍",
    title: "奥克兰本地SEO",
    desc: "在Google地图和本地Pack中占据主导地位。我们优化您的Google商家资料，建立本地引用，针对地理位置关键词进行定向优化。",
    items: ["Google商家资料优化", "本地引用与目录收录", "地图Pack排名提升", "地理定向关键词策略"],
  },
  {
    icon: "⚙️",
    title: "技术SEO",
    desc: "一个快速、结构良好、Google能够抓取和索引的网站。我们修复阻碍您排名的技术问题。",
    items: ["网站速度优化", "核心网页指标改善", "Schema结构化数据", "移动端适配优化"],
  },
  {
    icon: "✍️",
    title: "内容与页面SEO",
    desc: "关键词研究与内容创作，将您的页面与买家意图紧密连接——同时针对Google和您的潜在客户进行优化。",
    items: ["关键词研究分析", "SEO内容创作", "Meta标签优化", "内部链接结构"],
  },
  {
    icon: "🔗",
    title: "外链建设",
    desc: "来自相关新西兰资源的高质量外链，以可持续的方式提升网站权威度——不走捷径，不使用垃圾链接。",
    items: ["新西兰相关目录收录", "本地商业合作伙伴关系", "内容型外链获取", "权威度持续建设"],
  },
  {
    icon: "📊",
    title: "数据分析与报告",
    desc: "清晰的月度报告，展示实际进展——排名变化、自然流量和产生的询盘。无术语，直观明了。",
    items: ["Google Analytics 4配置", "Search Console监控", "月度排名追踪", "询盘来源归因"],
  },
  {
    icon: "🛒",
    title: "电商SEO",
    desc: "WooCommerce和Shopify商店的产品页面和类目页面优化，驱动能够产生转化的自然流量。",
    items: ["产品页面优化", "类目结构优化", "产品Schema标记", "Google购物曝光"],
  },
];

const process = [
  { step: "1", title: "免费SEO审核", desc: "我们审查您当前的排名、网站健康状况、关键词差距和竞争对手情况。零费用，无义务。" },
  { step: "2", title: "定制策略", desc: "一份专注于能带来合格询盘的关键词的定制计划——而不是单纯追求流量数字。" },
  { step: "3", title: "执行优化", desc: "技术修复、内容创作、本地信号优化和外链建设——系统性地逐步推进。" },
  { step: "4", title: "月度报告", desc: "清晰易读的报告，展示排名的变化以及我们下一步的计划。" },
];

const reviews = [
  { name: "Zane Barrett", company: "Barrett Access Scaffolding", text: "Charlie花时间真正了解我们的业务，打造了一个实际能带来排名的网站。我们获得了以前从来没有的询盘，这些都是通过SEO找到我们的。" },
  { name: "Jack", company: "Show Me Shorts", text: "SEO工作非常专业彻底。他们把所有事情都解释得很清楚，我能看到我们Google排名的实实在在的改善。" },
];

const faqs = [
  { q: "奥克兰SEO优化需要多长时间才能看到效果？", a: "大多数奥克兰企业在2-3个月内会看到初步变化，在6-12个月内会有明显效果。SEO是随时间积累的——投入越长，效果越强劲、越稳定。" },
  { q: "新西兰小企业SEO费用是多少？", a: "我们的SEO套餐起价$500/月，根据行业竞争程度和工作范围可升至$2,500/月。每个合作都从免费审核开始，确保报价准确。" },
  { q: "本地SEO和普通SEO有什么区别？", a: "本地SEO针对基于地理位置的搜索——如「奥克兰水管工」或「附近咖啡馆」。它包含您的Google商家资料、本地引用和地图Pack排名。普通SEO专注于更广泛的全国性知名度，不区分地理位置。详细内容可查看我们的<a href=\"/local-seo-for-auckland-small-businesses/\">奥克兰本地SEO</a>服务页面。" },
  { q: "我已经在投放Google广告，还需要做SEO吗？", a: "两者的运作方式不同。<a href=\"/google-ads/\">Google广告</a>一旦停止付费就立即失效。SEO建立有机排名，随时间积累免费流量。大多数企业两者结合效果最佳——广告获取即时客户，SEO实现长期增长。" },
  { q: "你们能保证Google首页排名吗？", a: "任何有道德的SEO机构都无法保证特定排名。我们能保证的是在对您的本地市场最重要的信号上进行专注、透明的努力，并辅以清晰的月度报告。" },
  { q: "你们是否服务奥克兰以外的企业？", a: "我们总部位于奥克兰，但也为新西兰各地企业提供服务。本地SEO专业知识在奥克兰最强，但技术SEO和内容SEO适用于新西兰各地。" },
];
---

<Layout
  title="奥克兰SEO优化服务 | 搜索引擎优化 | Kiwi Web Design"
  description="奥克兰小企业SEO优化服务，起价$500/月。Google地图排名、精准关键词、中英文月度报告。无合同锁定，免费SEO审核。"
  canonicalURL="https://www.kiwiwebdesign.co.nz/zh/seo-auckland/"
  schema={schema}
  lang="zh-Hans"
  alternateUrl="https://www.kiwiwebdesign.co.nz/affordable-seo-auckland/"
>

  <PageHero
    eyebrow="奥克兰SEO优化服务"
    title="让正在搜索您的客户真正找到您。"
    subtitle="为奥克兰小企业提供专业SEO优化服务。我们针对您客户真正使用的关键词，建立有机排名，将搜索流量转化为真实询盘——起价$500/月，无合同锁定。"
    ctaPrimary={{ text: "获取免费SEO审核", href: "/zh/website-designer-auckland/" }}
    ctaSecondary={{ text: "查看价格", href: "#pricing" }}
    centered={true}
  />

  <!-- AI citability snippet -->
  <div class="seo-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> 为奥克兰小企业提供SEO优化服务，<strong>起价$500/月</strong>，无合同锁定。服务涵盖本地SEO、Google商家资料优化、技术SEO、内容创作和外链建设。公司位于奥克兰Grey Lynn，Google评分 <strong>4.9★</strong>，服务50+新西兰客户。大多数企业在2-3个月内看到初步效果，6-12个月内实现持续增长。</p>
    </div>
  </div>

  <!-- Stat bar -->
  <div class="seo-statbar">
    <div class="container seo-statbar-inner">
      <div class="ssb-item"><span class="ssb-num">93%</span><span class="ssb-lbl">网络体验始于搜索引擎</span></div>
      <span class="ssb-sep" aria-hidden="true"></span>
      <div class="ssb-item"><span class="ssb-num">14.6%</span><span class="ssb-lbl">SEO潜在客户成交率 vs 外呼1.7%</span></div>
      <span class="ssb-sep" aria-hidden="true"></span>
      <div class="ssb-item"><span class="ssb-num">4.9★</span><span class="ssb-lbl">Google综合评分</span></div>
      <span class="ssb-sep" aria-hidden="true"></span>
      <div class="ssb-item"><span class="ssb-num">起价$500/月</span><span class="ssb-lbl">SEO套餐起步价格</span></div>
    </div>
  </div>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="我们的SEO服务"
        title="排名提升与客户转化所需的一切。"
        subtitle="从技术修复到内容创作和本地信号优化——为奥克兰企业提供完整的SEO解决方案。"
      />
      <ServiceGrid items={seoServices} cols={3} />
    </div>
  </section>

  <!-- Results strip (dark) -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader eyebrow="真实成果" title="我们客户通过SEO实现的增长。" light={true} />
      <div class="seo-results">
        <div class="seo-result">
          <span class="sr-num">+87%</span>
          <span class="sr-label">自然搜索流量增长</span>
          <span class="sr-industry">管道工程企业</span>
        </div>
        <div class="seo-result">
          <span class="sr-num">+64%</span>
          <span class="sr-label">网站访问量增长</span>
          <span class="sr-industry">餐饮行业</span>
        </div>
        <div class="seo-result">
          <span class="sr-num">+92%</span>
          <span class="sr-label">新患者询盘增长</span>
          <span class="sr-industry">牙科诊所</span>
        </div>
        <div class="seo-result">
          <span class="sr-num">3–6月</span>
          <span class="sr-label">平均见效时间</span>
          <span class="sr-industry">大多数奥克兰企业</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="合作流程"
        title="从审核到成果，流程清晰。"
        subtitle="每次SEO合作都从免费审核开始，让我们准确知道该修复什么、该建立什么。"
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- About split -->
  <section class="section seo-about-section">
    <div class="container">
      <div class="seo-about-split">
        <div class="seo-about-img-wrap">
          <Image src={aboutImg} alt="SEO专家为奥克兰企业制定关键词策略" width={560} height={700} class="seo-about-img" />
        </div>
        <div class="seo-about-content">
          <p class="seo-about-eyebrow">为何选择我们</p>
          <h2>围绕您的业务定制的SEO，而不是套用模板。</h2>
          <p>我们不是卖完套餐就不管了。每位奥克兰客户都能获得基于其行业、竞争对手和客户搜索行为的专属策略——每个月都会重新审查和调整。</p>
          <ul class="seo-about-list">
            <li>合作前免费审核，无需承担任何义务</li>
            <li>无合同锁定——留下来是因为真的有效</li>
            <li>月度报告清晰易懂，无技术术语</li>
            <li>奥克兰本地知识，而非海外外包团队</li>
            <li>以真实询盘而非仅仅排名数字衡量成果</li>
          </ul>
          <a href="/zh/website-designer-auckland/" class="seo-about-btn">预约免费SEO审核 →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section" id="pricing">
    <div class="container">
      <SectionHeader
        eyebrow="价格方案"
        title="奥克兰企业SEO价格"
        subtitle="无合同锁定。每次合作都从免费审核开始。"
      />
      <div class="seo-pkg-grid">
        <div class="seo-pkg">
          <h3>入门SEO</h3>
          <p class="seo-price">起价$500<span class="seo-period">/月</span></p>
          <p class="seo-pkg-desc">适合竞争程度较低领域的小企业，希望建立Google搜索知名度。</p>
          <ul class="seo-pkg-list">
            <li>Google商家资料优化</li>
            <li>最多5个页面的页面SEO</li>
            <li>本地引用建设</li>
            <li>月度报告</li>
          </ul>
          <a href="/zh/website-designer-auckland/" class="seo-pkg-btn">立即开始</a>
        </div>
        <div class="seo-pkg seo-pkg-highlight">
          <span class="seo-pkg-tag">最受欢迎</span>
          <h3>成长SEO</h3>
          <p class="seo-price">起价$1,000<span class="seo-period">/月</span></p>
          <p class="seo-pkg-desc">适合竞争激烈的奥克兰市场，希望通过自然搜索持续获得客户询盘。</p>
          <ul class="seo-pkg-list">
            <li>完整技术SEO审核与修复</li>
            <li>全站页面优化</li>
            <li>本地SEO + Google商家资料</li>
            <li>内容创作（每月2篇）</li>
            <li>外链建设</li>
            <li>月度绩效报告</li>
          </ul>
          <a href="/zh/website-designer-auckland/" class="seo-pkg-btn seo-pkg-btn-accent">立即开始</a>
        </div>
        <div class="seo-pkg">
          <h3>权威SEO</h3>
          <p class="seo-price">起价$2,500<span class="seo-period">/月</span></p>
          <p class="seo-pkg-desc">适合高度竞争的细分市场——在您的行业类别中占据搜索主导地位。</p>
          <ul class="seo-pkg-list">
            <li>包含成长SEO全部内容</li>
            <li>内容策略与支柱页面</li>
            <li>高级外链建设</li>
            <li>竞争对手差距分析</li>
            <li>转化率优化</li>
            <li>每周报告</li>
          </ul>
          <a href="/zh/website-designer-auckland/" class="seo-pkg-btn">立即开始</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section" style="background: var(--kwd-cream);">
