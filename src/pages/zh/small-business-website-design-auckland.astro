  { icon: "Sparkles",        title: "美容与健康",        desc: "美发、美容、水疗和诊所网站，重点把服务、价格和预约方式讲清楚。", href: "/how-kiwi-web-design-helps-auckland-beauty-industry/" },
  { icon: "UtensilsCrossed", title: "餐饮业",             desc: "菜单页面、订座链接、Google地图和营业信息，让客户更容易找到并下单。", href: "/how-kiwi-web-design-helps-auckland-restaurants/" },
  { icon: "HeartPulse",      title: "医疗健康",           desc: "物理治疗、牙科、全科诊所。支持在线预约的专业设计，清晰展示服务项目。", href: "/how-kiwi-web-design-helps-auckland-healthcare/" },
  { icon: "Briefcase",       title: "专业服务",           desc: "律师、会计师、咨询顾问。建立权威形象，赢得新客户信任的专业设计。", href: "/how-kiwi-web-design-helps-auckand-lawyers/" },
  { icon: "ShoppingCart",    title: "电商与零售",         desc: "WooCommerce和Shopify商店，专为销售而建。产品页面、结账流程和支付网关一体化。", href: "/ecommerce-website-auckland/" },
