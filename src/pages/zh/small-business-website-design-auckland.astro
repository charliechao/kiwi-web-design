    items: [
      "网站结构和页面设计",
      "适合中文/英文内容的布局",
      "基础本地SEO",
      "移动端速度优化",
      "联系表单与询盘设置",
    ],
    cta: "获取报价",
    href: "/zh/website-designer-auckland/",
    highlight: false,
  },
  {
    name: "Lead Growth Engine",
    price: "起价$2,690",
    note: "+ GST",
    desc: "适合想把网站、SEO、AI搜索和Google广告一起规划的企业，用更完整的方式增加询盘。",
    items: [
      "网站和询盘路径规划",
      "本地SEO和AI SEO设置",
