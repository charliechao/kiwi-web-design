    ],
    cta: "获取报价",
    href: "/zh/website-designer-auckland/",
    highlight: false,
  },
];

const faqs = [
  { q: "奥克兰小企业建设网站需要多少钱？", a: "我们的套餐与英文首页保持一致：Launch & Get Found 起价 $1,290 + GST，Lead Growth Engine 起价 $2,690 + GST，Sales Accelerator 起价 $3,890 + GST。项目开始前会给固定报价，把包含内容讲清楚。" },
  { q: "建设网站需要多长时间？", a: "大多数项目在收到内容后2-3周内完成。功能更复杂的网站可能需要4-6周。我们会提前告诉你时间表。" },
  { q: "我需要自己准备内容吗？", a: "你最了解自己的业务，所以服务介绍、照片和基本资料最好由你提供。但我们会帮你整理网站结构，也可以协助撰写文案和选择图片。" },
  { q: "网站建成后我能自己更新内容吗？", a: "可以。我们会做交接培训，让你可以自己更新文字、图片和页面内容。你也可以选择维护计划，让我们帮你处理日常修改。" },
  { q: "你们提供主机托管和维护服务吗？", a: "提供。我们可以根据网站类型安排合适的主机、更新、备份、安全防护以及内容修改支持，也可以和网站建设项目一起规划。" },
  { q: "你们能改版或重建我现有的网站吗？", a: "可以。我们承接旧网站重建、改版和平台迁移，包括从Wix、Squarespace或其他旧网站系统迁移，并尽量保留原有<a href=\"/zh/seo-auckland/\">SEO</a>数据和重要内容。" },
