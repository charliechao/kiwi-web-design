---
import Layout from '../../layouts/Layout.astro';
import CTABanner from '../../components/CTABanner.astro';
import charlieImg from '../../assets/general/Kiwi-Web-Design-Owner-Charlie.jpeg';

const contactPage = '/zh/website-designer-auckland/';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["WebPage", "AboutPage"],
      "@id": "https://www.kiwiwebdesign.co.nz/zh/about-us/",
      "url": "https://www.kiwiwebdesign.co.nz/zh/about-us/",
      "name": "关于我们 | 奥克兰本地网页设计团队 | Kiwi Web Design",
      "description": "了解Kiwi Web Design创始人Charlie Chao。奥克兰本地网页设计师，专为中小企业和华人企业提供快速、高转化率的网站，起价$1,290。",
      "inLanguage": "zh-Hans",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#charlie" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/zh/about-us/#breadcrumb" },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".zh-about-h1", ".zh-about-lead", ".zh-story-title"]
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/zh/about-us/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "首页", "item": "https://www.kiwiwebdesign.co.nz/zh/" },
        { "@type": "ListItem", "position": 2, "name": "关于我们", "item": "https://www.kiwiwebdesign.co.nz/zh/about-us/" }
      ]
    },
    {
      "@type": "Person",
      "@id": "https://www.kiwiwebdesign.co.nz/#charlie",
      "name": "Charlie Chao",
      "givenName": "Charlie",
      "familyName": "Chao",
      "jobTitle": "创始人 & 网页设计师",
      "description": "Charlie Chao 是 Kiwi Web Design 的创始人，奥克兰网页设计机构，专为中小企业和华人企业提供高性价比、高转化率的网站服务。常驻奥克兰Grey Lynn。",
      "worksFor": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "url": "https://www.kiwiwebdesign.co.nz/zh/about-us/",
      "image": {
        "@type": "ImageObject",
        "url": "https://www.kiwiwebdesign.co.nz/Kiwi-Web-Design-Owner-Charlie.jpeg",
        "width": 480,
        "height": 640
      },
      "sameAs": [
        "https://www.linkedin.com/in/gocharlie/",
        "https://www.kiwiwebdesign.co.nz/about-us/"
      ],
      "knowsAbout": ["Web Design", "WordPress", "Local SEO", "Google Ads", "Small Business Marketing", "Auckland Businesses"],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "addressCountry": "NZ"
      },
      "email": "hi@kiwiwebdesign.co.nz",
      "telephone": "+64-21-039-6580"
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "奥克兰网页设计",
      "description": "奥克兰网页设计公司，由Charlie Chao创立，专为中小企业和华人企业提供高性价比、高转化率网站服务。常驻Grey Lynn，奥克兰。",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "foundingDate": "2023",
      "founder": { "@id": "https://www.kiwiwebdesign.co.nz/#charlie" },
      "sameAs": ["https://www.linkedin.com/in/gocharlie/"],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "addressCountry": "NZ"
      },
      "email": "hi@kiwiwebdesign.co.nz",
      "telephone": "+64-21-039-6580",
      "priceRange": "$$",
      "areaServed": "Auckland, New Zealand"
    }
  ]
};

const values = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>`,
    title: "效果优先",
    desc: "一个无法带来询盘的网站，无论看上去多漂亮都不算成功。我们用网站为您带来的客户量和实际收入衡量项目成效。",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: "诚实建议",
    desc: "我们只告诉您真正需要的--即使这意味着项目规模比您计划的小，或者推荐其他供应商。我们不会过度销售。",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    title: "快速行动",
    desc: "大多数客户在2-3周内上线。我们相信快速让您出现在客户面前--然后持续迭代--而非在规划阶段耗费数月时间。",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
    title: "本地优先",
    desc: "我们扎根Grey Lynn。可以和客户当面见面，深度了解奥克兰市场，真心关注本地企业的成功。这不是一家海外运营公司。",
  },
];

const services = [
  { label: "网页设计", href: "/zh/small-business-website-design-auckland/" },
  { label: "SEO优化", href: "/zh/seo-auckland/" },
  { label: "Google广告", href: "/zh/google-ads/" },
  { label: "本地SEO", href: "/zh/local-seo-for-auckland-small-businesses/" },
  { label: "中文首页", href: "/zh/" },
  { label: "免费咨询", href: contactPage },
];

const stats = [
  { number: "100+", label: "奥克兰企业客户" },
  { number: "4.9★", label: "Google 平均评分" },
  { number: "2–3周", label: "平均交付时间" },
  { number: "Grey Lynn", label: "奥克兰本地，可面谈" },
];

const reviews = [
  { name: "Zane Barrett", company: "Barrett Access Scaffolding", text: "专业、响应迅速，真正花时间了解我们的业务。对结果非常满意。绝对推荐Charlie。" },
  { name: "Jack", company: "Show Me Shorts", text: "提供实用的解决方案。专业、友好，我每次有问题都能得到快速回复。正是我希望从本地设计师那里得到的体验。" },
  { name: "Steven Liu", company: "客户", text: "体验非常出色。设计简洁、现代、用户友好--完全符合我的期望。" },
  { name: "Gina Dellabarca", company: "客户", text: "全面而实用的网站审计建议。信息清晰，整个过程沟通顺畅。" },
];
---

<Layout
  title="关于我们 | 奥克兰本地网页设计团队 | Kiwi Web Design"
  description="了解Kiwi Web Design创始人Charlie Chao。奥克兰本地网页设计师，专为中小企业和华人企业提供快速、高转化率的网站，起价$1,290。"
  canonicalURL="https://www.kiwiwebdesign.co.nz/zh/about-us/"
  schema={schema}
  lang="zh-Hans"
  alternateUrl="https://www.kiwiwebdesign.co.nz/about-us/"
>

  <!-- Hero -->
  <section class="zh-au-hero">
    <div class="container zh-au-hero-inner">
      <div class="zh-au-hero-text">
        <p class="zh-au-eyebrow">关于 Kiwi Web Design</p>
        <h1 class="zh-about-h1">一位真正在意您结果的网页设计师。</h1>
        <p class="zh-about-lead">我是Charlie--Kiwi Web Design的创始人。我创办这家公司，是因为我一直看到奥克兰中小企业被昂贵、缓慢或低效的网站所困扰，无法从网络上获得任何业务。</p>
        <p class="zh-about-lead">我相信每一家小企业都值得拥有一个快速、现代的网站，像他们自己一样努力工作--而不需要付大公司的价格或等待数月的周期。</p>
        <div class="zh-au-hero-ctas">
          <a href={contactPage} class="btn-zh-primary">预约免费咨询</a>
          <a href="#story" class="btn-zh-ghost">了解我的故事 ↓</a>
        </div>
        <a
          href="https://www.linkedin.com/in/gocharlie/"
          target="_blank"
          rel="noopener noreferrer"
          class="zh-linkedin"
          aria-label="Charlie Chao LinkedIn主页"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>
      <div class="zh-au-hero-img-wrap">
        <img
          src={charlieImg.src}
          alt="Charlie Chao, Kiwi Web Design 创始人，奥克兰网页设计师"
          class="zh-au-portrait"
          width="480"
          height="640"
          loading="eager"
        />
        <div class="zh-au-hero-badge">
          <span class="zh-ahb-num">4.9★</span>
          <span class="zh-ahb-label">Google 评分</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats strip -->
  <section class="zh-au-stats-strip">
    <div class="container zh-au-stats-grid">
      {stats.map(({ number, label }) => (
        <div class="zh-au-stat">
          <span class="zh-au-stat-num">{number}</span>
          <span class="zh-au-stat-label">{label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Story -->
  <section class="section" id="story">
    <div class="container zh-story-wrap">
      <div class="zh-story-text">
        <p class="zh-story-eyebrow">创业故事</p>
        <h2 class="zh-story-title">为什么我创办了 Kiwi Web Design。</h2>
        <p>在创立 KWD 之前，我在奥克兰从事数字营销和网页项目工作。我一次又一次发现同样的问题：小企业--<a href="/tradie-website-design-auckland/" style="color: var(--kwd-dark); text-decoration: underline; text-underline-offset: 2px;">工程承包商</a>、<a href="/how-kiwi-web-design-helps-auckland-restaurants/" style="color: var(--kwd-dark); text-decoration: underline; text-underline-offset: 2px;">咖啡馆老板</a>、<a href="/how-kiwi-web-design-helps-auckland-healthcare/" style="color: var(--kwd-dark); text-decoration: underline; text-underline-offset: 2px;">医疗服务提供者</a>--要么花了太多钱却得到太少，要么有一个把自己拖累的DIY网站。</p>
        <p>大型代理公司收取大公司的费用。海外自由职业者不了解奥克兰市场。模板建站平台做出来的网站和其他人一模一样。这些选择都没有真正服务好奥克兰小企业主。</p>
        <p>于是我围绕一个简单的理念创建了 Kiwi Web Design：以中小企业能接受的价格，为奥克兰小企业提供专业、注重效果的网站，同时提供大型代理公司无法给予的用心服务和良好沟通。</p>
        <p>我住在 Grey Lynn。我可以和客户约好喝咖啡面谈。我亲自回复每一封邮件。每个项目都遵循清晰透明的建站流程--我真心希望您的网站能为您创造业务。</p>
        <p>对于奥克兰华人企业主，我还特别了解在新西兰经营华人业务的挑战与机遇--无论是触达本地华人社区，还是拓展更广泛的新西兰市场。</p>
      </div>
      <div class="zh-story-sidebar">
        <div class="zh-story-card">
          <p class="zh-asc-label">我的专注领域</p>
          <ul class="zh-asc-list">
            <li>加载快速且排名靠前的 WordPress 网站</li>
            <li>让奥克兰企业被本地客户找到的 SEO</li>
            <li>真正产生询盘的 Google 广告系列</li>
            <li>透明定价，无隐性费用</li>
            <li>平实语言--不用行话或专业术语</li>
            <li>快速交付--通常确认方案后2-3周上线</li>
          </ul>
        </div>
        <div class="zh-story-card zh-story-card--dark">
          <p class="zh-asc-label zh-asc-label--light">办公地址</p>
          <p class="zh-asc-address">147 Great North Road<br />Grey Lynn, Auckland</p>
          <a
            href="https://www.google.com/maps/search/?api=1&query=147+Great+North+Road+Grey+Lynn+Auckland"
            target="_blank"
            rel="noopener noreferrer"
            class="zh-asc-map-link"
          >
            在 Google 地图上查看 →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <div class="zh-section-header" style="color: #fff;">
        <p class="zh-section-eyebrow" style="color: var(--kwd-yellow);">我们的工作方式</p>
        <h2 class="zh-section-title" style="color: #fff;">指导每个项目的核心价值观。</h2>
        <p class="zh-section-subtitle" style="color: rgba(255,255,255,0.65);">这些不是营销词汇--而是我努力在每次客户合作中坚守的原则。</p>
      </div>
      <div class="zh-values">
        {values.map(({ icon, title, desc }) => (
          <div class="zh-value">
            <span class="zh-value-icon" set:html={icon} />
            <h3 class="zh-value-title">{title}</h3>
            <p class="zh-value-desc">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <div class="zh-section-header">
        <p class="zh-section-eyebrow">服务项目</p>
        <h2 class="zh-section-title">Kiwi Web Design 提供的服务。</h2>
        <p class="zh-section-subtitle">奥克兰成长型中小企业建立和扩大线上业务所需的一切。</p>
      </div>
      <div class="zh-services-links">
        {services.map(({ label, href }) => (
          <a href={href} class="zh-service-link">
            {label}
            <span class="zh-sl-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section">
    <div class="container">
      <div class="zh-section-header">
        <p class="zh-section-eyebrow">客户评价</p>
        <h2 class="zh-section-title">奥克兰企业主怎么说。</h2>
        <p class="zh-section-subtitle">真实客户，真实成果。</p>
      </div>
      <div class="zh-reviews-grid">
        {reviews.map(r => (
          <div class="zh-review-card">
            <p class="zh-review-text">"{r.text}"</p>
            <div class="zh-review-author">
              <span class="zh-review-name">{r.name}</span>
              <span class="zh-review-company">{r.company}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">相关服务</p>
      <div class="rps-links">
        <a href="/zh/small-business-website-design-auckland/" class="rps-link">网页设计</a>
        <a href="/zh/seo-auckland/" class="rps-link">SEO优化</a>
        <a href="/zh/google-ads/" class="rps-link">Google广告</a>
        <a href="/zh/" class="rps-link">中文首页</a>
      </div>
    </div>
  </section>

  <!-- Contact strip -->
  <section class="zh-contact-strip">
    <div class="container zh-contact-inner">
      <div>
        <h2>想要合作？</h2>
        <p>免费咨询--可在 Grey Lynn 当面见面，或视频通话。无任何强制承诺，只有诚实的建议。</p>
      </div>
      <div class="zh-contact-actions">
        <a href={contactPage} class="zh-contact-btn-primary">预约咨询</a>
        <a href="mailto:hi@kiwiwebdesign.co.nz" class="zh-contact-btn-secondary">hi@kiwiwebdesign.co.nz</a>
        <a href="https://www.linkedin.com/in/gocharlie/" target="_blank" rel="noopener noreferrer" class="zh-contact-btn-secondary" aria-label="Charlie Chao LinkedIn">LinkedIn →</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="准备好获得一个真正带来询盘的网站了吗？"
    subtitle="和Charlie聊聊--没有压力，没有行话，只有关于您业务真正需要什么的诚实建议。"
    ctaPrimary={{ text: "预约免费咨询", href: contactPage }}
    ctaSecondary={{ text: "查看我们的服务", href: "/zh/small-business-website-design-auckland/" }}
  />

</Layout>

<style>
  /* Hero */
  .zh-au-hero {
    background: var(--kwd-dark);
    padding: 5rem 0 0;
    overflow: hidden;
  }
  .zh-au-hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: end;
  }
  .zh-au-hero-text {
    padding-bottom: 5rem;
  }
  .zh-au-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-yellow);
    margin-bottom: 1rem;
  }
  .zh-about-h1 {
    font-family: var(--kwd-font-heading);
    font-size: clamp(2rem, 4vw, 3.25rem);
    color: #fff;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }
  .zh-about-lead {
    font-size: 1rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.75;
    margin-bottom: 1rem;
    max-width: 520px;
  }
  .zh-about-lead:last-of-type { margin-bottom: 2.5rem; }
  .zh-au-hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .btn-zh-primary {
    display: inline-block;
    background: var(--kwd-yellow);
    color: var(--kwd-dark);
    padding: 0.875rem 2rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.875rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .btn-zh-primary:hover { opacity: 0.9; }
  .btn-zh-ghost {
    display: inline-block;
    color: rgba(255,255,255,0.65);
    padding: 0.875rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s;
  }
  .btn-zh-ghost:hover { color: #fff; }
  .zh-linkedin {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: rgba(255,255,255,0.55);
    font-size: 0.82rem;
    font-weight: 600;
    padding: 0.5rem 0;
    text-decoration: none;
    transition: color 0.2s;
  }
  .zh-linkedin:hover { color: var(--kwd-yellow); }

  .zh-au-hero-img-wrap {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .zh-au-portrait {
    display: block;
    max-height: 560px;
    width: auto;
    object-fit: cover;
    border-radius: 20px 20px 0 0;
    filter: brightness(0.95) saturate(0.9);
  }
  .zh-au-hero-badge {
    position: absolute;
    bottom: 2rem;
    left: -1rem;
    background: var(--kwd-yellow);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .zh-ahb-num {
    font-family: var(--kwd-font-heading);
    font-size: 1.75rem;
    color: var(--kwd-dark);
    line-height: 1;
  }
  .zh-ahb-label {
    font-size: 0.7rem;
    font-weight: 700;
