---
import Layout from '../../layouts/Layout.astro';
import CTABanner from '../../components/CTABanner.astro';

const contactPage = '/zh/website-designer-auckland/';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/zh/",
      "url": "https://www.kiwiwebdesign.co.nz/zh/",
      "name": "奥克兰网站开发与网页设计 | 中文服务 | Kiwi Web Design",
      "description": "奥克兰华人网站开发与网页设计专家。为新西兰华人中小企业提供专业网站开发、SEO优化和Google广告服务。价格透明，快速交付。",
      "inLanguage": "zh-Hans",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/zh/#breadcrumb" },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".zh-snippet", ".zh-eyebrow", ".zh-subtitle"]
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/zh/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "中文服务", "item": "https://www.kiwiwebdesign.co.nz/zh/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": ["奥克兰网页设计", "奥克兰网站开发"],
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "City", "name": "Auckland" },
        { "@type": "Country", "name": "New Zealand" }
      ],
      "priceRange": "$$",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "bestRating": "5",
        "ratingCount": "50"
      },
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.kiwiwebdesign.co.nz/favicon.png",
        "width": 512,
        "height": 512
      }
    },
    {
      "@type": "Service",
      "@id": "https://www.kiwiwebdesign.co.nz/zh/#service",
      "name": "奥克兰网站开发与网页设计",
      "serviceType": "网站开发",
      "description": "为奥克兰华人及中小企业提供专业网站开发、WordPress建站、SEO优化和Google广告管理服务。",
      "provider": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "areaServed": [
        { "@type": "City", "name": "Auckland" },
        { "@type": "Country", "name": "New Zealand" }
      ],
      "offers": [
        { "@type": "Offer", "name": "基础官网开发", "price": "1290", "priceCurrency": "NZD" },
        { "@type": "Offer", "name": "标准官网开发", "price": "2500", "priceCurrency": "NZD" },
        { "@type": "Offer", "name": "电商网站开发", "price": "4500", "priceCurrency": "NZD" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "网站开发费用是多少？",
          "acceptedAnswer": { "@type": "Answer", "text": "一个标准的5-8页小企业网站开发价格在$1,500-$3,500 NZD之间。具体价格取决于页面数量、功能需求（如预约系统、电商功能）等。我们会在项目开始前提供详细的固定价格报价。" }
        },
        {
          "@type": "Question",
          "name": "网站开发需要多长时间？",
          "acceptedAnswer": { "@type": "Answer", "text": "大多数小企业网站在内容（文字和图片）准备好后，2-3周内可以上线。更复杂的网站或电商网站需要3-5周。我们会在报价阶段给出具体时间表。" }
        },
        {
          "@type": "Question",
          "name": "我需要准备哪些内容？",
          "acceptedAnswer": { "@type": "Answer", "text": "您需要提供：企业Logo、品牌颜色偏好、需要的页面列表，以及相关文字和图片。如果没有专业照片，我们可以使用高质量的版权图片。" }
        },
        {
          "@type": "Question",
          "name": "网站开发完成后我能自己更新内容吗？",
          "acceptedAnswer": { "@type": "Answer", "text": "可以。我们使用WordPress系统，并提供培训。网站交付后，您可以自行更新文字、添加图片、发布博客文章，无需依赖开发人员。" }
        },
        {
          "@type": "Question",
          "name": "你们只服务华人客户吗？",
          "acceptedAnswer": { "@type": "Answer", "text": "不是。Kiwi Web Design为所有奥克兰小企业提供服务，包括各行各业的华人和非华人企业主。我们理解华人企业主的需求，同时也具备服务更广泛客户群的能力。" }
        }
      ]
    }
  ]
};

const services = [
  {
    icon: "🌐",
    title: "网站开发",
    desc: "为奥克兰华人企业定制专业WordPress网站开发。设计精美，加载快速，在手机和电脑上完美显示。",
    items: ["固定价格报价", "2-3周完成交付", "移动端优先设计", "SEO基础设置"],
  },
  {
    icon: "🔍",
    title: "本地SEO优化",
    desc: "帮助您的企业在Google搜索结果中排名靠前。针对奥克兰本地市场优化，吸引更多潜在客户。",
    items: ["关键词研究分析", "Google商家资料优化", "本地引用建设", "每月排名报告"],
  },
  {
    icon: "📣",
    title: "Google广告",
    desc: "精准投放Google广告，让您的企业出现在搜索结果首页。按效果付费，控制广告预算。",
    items: ["广告账户设置", "关键词竞价策略", "广告文案撰写", "效果数据追踪"],
  },
  {
    icon: "📧",
    title: "企业邮箱设置",
    desc: "为您的企业配置专业邮箱（Microsoft 365或Google Workspace），提升企业形象和可信度。",
    items: ["Microsoft 365配置", "Google Workspace设置", "所有设备同步", "DNS记录配置"],
  },
];

const devProcess = [
  { step: "01", title: "免费咨询与报价", desc: "了解您的业务需求和目标客户，分析竞争环境。通常在24小时内提供详细的固定价格报价，全程中文沟通。" },
  { step: "02", title: "设计与网站开发", desc: "根据您的品牌风格进行网页设计，经您确认后开始正式开发。随时提供进度更新，欢迎反馈意见。" },
  { step: "03", title: "测试与修改完善", desc: "网站开发完成后进行全面测试——手机端、桌面端、各主流浏览器。根据您的反馈进行修改，直到满意为止。" },
  { step: "04", title: "上线与操作培训", desc: "网站正式上线，并提供中文操作培训视频和文档。域名、主机账户、网站代码全部归您所有。" },
];

const caseStudies = [
  {
    name: "Barrett Access Scaffolding",
    tag: "建筑与施工",
    result: "+125% 询盘量",
    desc: "为奥克兰脚手架公司重建专业网站，结合Google广告精准投放，月均询盘量增长125%，项目持续增长。",
    href: "/case-study-scaffolding/",
  },
  {
    name: "Beauty Touch Auckland",
    tag: "美容与护理",
    result: "3周内上线",
    desc: "为奥克兰美容院设计品牌网站，3周内完成全部网站开发并正式上线，在线预约量显著提升。",
    href: "/beauty-touch-case-study/",
  },
];

const pricingTiers = [
  { name: "起步官网", price: "起价 $1,290", pages: "3–5页", desc: "单页或小型官网，联系表单，移动端适配，SEO基础设置", popular: false },
  { name: "标准官网", price: "起价 $2,500", pages: "5–8页", desc: "完整小企业官网，博客，预约表单，Google Analytics，SEO优化", popular: true },
  { name: "电商网站", price: "起价 $4,500", pages: "含产品目录", desc: "在线商店，产品管理，支付系统（Stripe/PayPal），库存管理", popular: false },
];

const reasons = [
  {
    num: "01",
    title: "了解华人市场",
    body: "我们深度了解奥克兰华人商业环境，能够帮助您的企业在本地华人社区和更广泛的新西兰市场建立专业形象。",
  },
  {
    num: "02",
    title: "透明定价，无隐性收费",
    body: "项目开始前提供书面固定价格报价。不按小时计费，不添加额外费用。报价即最终价格。",
  },
  {
    num: "03",
    title: "快速交付，本地支持",
    body: "大多数小企业网站2-3周内上线。我们是奥克兰本地团队，有问题直接联系，无需等待海外客服。",
  },
  {
    num: "04",
    title: "网站您完全拥有",
    body: "我们交付的网站完全归您所有——域名、主机账户、代码全部归您。不使用任何锁定您的专有平台。",
  },
];

const faqs = [
  {
    q: "网站开发费用是多少？",
    a: "一个标准的5-8页小企业网站开发价格在$1,500-$3,500 NZD之间。具体价格取决于页面数量、功能需求（如预约系统、电商功能）等。我们会在项目开始前提供详细的固定价格报价。",
  },
  {
    q: "网站开发需要多长时间？",
    a: "大多数小企业网站在内容（文字和图片）准备好后，2-3周内可以上线。更复杂的网站或电商网站需要3-5周。我们会在报价阶段给出具体时间表。",
  },
  {
    q: "我需要准备哪些内容？",
    a: "您需要提供：企业Logo、品牌颜色偏好、需要的页面列表，以及相关文字和图片。如果没有专业照片，我们可以使用高质量的版权图片。",
  },
  {
    q: "网站开发完成后我能自己更新内容吗？",
    a: "可以。我们使用WordPress系统，并提供培训。网站交付后，您可以自行更新文字、添加图片、发布博客文章，无需依赖开发人员。",
  },
  {
    q: "你们只服务华人客户吗？",
    a: "不是。Kiwi Web Design为所有奥克兰小企业提供服务，包括各行各业的华人和非华人企业主。我们理解华人企业主的需求，同时也具备服务更广泛客户群的能力。",
  },
];
---

<Layout
  title="奥克兰网站开发与网页设计 | 中文服务 | Kiwi Web Design"
  description="奥克兰华人网站开发专家。为新西兰华人中小企业提供专业网站开发、网页设计、SEO优化和Google广告服务。价格透明，快速交付。"
  canonicalURL="https://www.kiwiwebdesign.co.nz/zh/"
  schema={schema}
  lang="zh-Hans"
  alternateUrl="https://www.kiwiwebdesign.co.nz/"
>

  <!-- Hero -->
  <section class="zh-hero">
    <div class="container zh-hero-inner">
      <div class="zh-hero-text">
        <p class="zh-eyebrow">奥克兰华人网站开发与网页设计服务</p>
        <h1 class="zh-title">奥克兰网站开发，<br />让您的生意脱颖而出。</h1>
        <p class="zh-subtitle">为奥克兰华人中小企业提供专业网站开发、SEO优化和数字营销服务。价格透明，快速交付，本地团队支持。</p>
        <div class="zh-hero-btns">
          <a href={contactPage} class="btn-zh-primary">免费咨询</a>
          <a href="/zh/small-business-website-design-auckland/" class="btn-zh-outline">查看服务详情</a>
        </div>
        <p class="zh-note">大多数网站2-3周内上线 · 固定价格，无隐性收费</p>
      </div>
      <div class="zh-hero-stats">
        <div class="zh-stat">
          <span class="zh-stat-num">100+</span>
          <span class="zh-stat-lbl">奥克兰企业客户</span>
        </div>
        <div class="zh-stat">
          <span class="zh-stat-num">2–3</span>
          <span class="zh-stat-lbl">周平均交付时间</span>
        </div>
        <div class="zh-stat">
          <span class="zh-stat-num">固定</span>
          <span class="zh-stat-lbl">价格，不按小时计费</span>
        </div>
        <div class="zh-stat">
          <span class="zh-stat-num">本地</span>
          <span class="zh-stat-lbl">奥克兰团队支持</span>
        </div>
      </div>
    </div>
  </section>

  <!-- AI citability snippet -->
  <div class="zh-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> 是奥克兰本地网站开发与网页设计公司，由华裔创始人 Charlie Chao 创立，专为奥克兰华人及中小企业提供中文网站开发服务。业务涵盖网站开发（起价 <strong>$1,290 NZD</strong>）、本地 SEO 优化（起价 <strong>$500/月</strong>）和 Google 广告管理。公司地址：Grey Lynn，奥克兰，可全程中文沟通，固定报价无隐性收费，Google 评分 <strong>4.9★</strong>。</p>
    </div>
  </div>

  <!-- Services -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <div class="zh-section-header">
        <p class="zh-section-eyebrow">我们的服务</p>
        <h2 class="zh-section-title">奥克兰网站开发 · 一站式数字营销服务</h2>
        <p class="zh-section-subtitle">从网站开发到搜索优化，我们帮助奥克兰华人企业在网上建立专业形象，吸引更多客户。</p>
      </div>
      <div class="zh-services-grid">
        {services.map(svc => (
          <div class="zh-service-card">
            <span class="zh-service-icon">{svc.icon}</span>
            <h3 class="zh-service-title">{svc.title}</h3>
            <p class="zh-service-desc">{svc.desc}</p>
            <ul class="zh-service-list">
              {svc.items.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Development process -->
  <section class="section">
    <div class="container" style="max-width: 900px;">
      <div class="zh-section-header">
        <p class="zh-section-eyebrow">网站开发流程</p>
        <h2 class="zh-section-title">从咨询到上线，全程中文沟通。</h2>
        <p class="zh-section-subtitle">清晰的网站开发流程，让您随时了解项目进度，无任何意外费用。</p>
      </div>
      <div class="zh-process">
        {devProcess.map(step => (
          <div class="zh-process-step">
            <span class="zh-process-num">{step.step}</span>
            <div class="zh-process-content">
              <h3 class="zh-process-title">{step.title}</h3>
              <p class="zh-process-desc">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About / Why KWD -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container zh-about-wrap">
      <div class="zh-about-text">
        <p class="zh-section-eyebrow" style="color: var(--kwd-brown);">关于我们</p>
        <h2 class="zh-about-title">Kiwi Web Design — 奥克兰本地网站开发团队</h2>
        <p class="zh-about-body">Kiwi Web Design由Charlie Chao创立，专注于为奥克兰小企业和个体经营者提供高性价比的网站开发和数字营销服务。</p>
        <p class="zh-about-body">我们不是大型代理公司——我们是一个小型本地团队，直接与客户沟通，提供更快的响应速度和更好的性价比。每个网站开发项目都有固定价格报价、明确的时间表，以及完整的网站管理培训。</p>
        <p class="zh-about-body">无论您是餐饮、零售、贸易、专业服务还是其他行业，我们都有丰富的相关经验，帮助您的企业在线上取得成功。</p>
        <a href={contactPage} class="btn-zh-dark">预约免费咨询</a>
      </div>
      <div class="zh-reasons">
        {reasons.map(r => (
          <div class="zh-reason">
            <span class="zh-reason-num">{r.num}</span>
            <div>
              <h3 class="zh-reason-title">{r.title}</h3>
              <p class="zh-reason-body">{r.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Case studies -->
  <section class="section">
    <div class="container" style="max-width: 900px;">
      <div class="zh-section-header">
        <p class="zh-section-eyebrow">客户案例</p>
        <h2 class="zh-section-title">真实项目，可查证的结果。</h2>
        <p class="zh-section-subtitle">我们为奥克兰各行业企业完成了100+个网站开发项目，以下是部分案例。</p>
      </div>
      <div class="zh-case-grid">
        {caseStudies.map(cs => (
          <a href={cs.href} class="zh-case-card">
            <div class="zh-case-top">
              <span class="zh-case-tag">{cs.tag}</span>
              <span class="zh-case-result">{cs.result}</span>
            </div>
            <h3 class="zh-case-name">{cs.name}</h3>
            <p class="zh-case-desc">{cs.desc}</p>
            <span class="zh-case-link">查看详情 →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container" style="max-width: 900px;">
      <div class="zh-section-header" style="color: #fff;">
        <p class="zh-section-eyebrow" style="color: var(--kwd-yellow);">网站开发价格</p>
        <h2 class="zh-section-title" style="color: #fff;">透明报价，固定价格，不按小时计费。</h2>
        <p class="zh-section-subtitle" style="color: rgba(255,255,255,0.65);">以下为常见网站开发套餐参考价格（NZD，含GST另算）。具体报价以项目需求为准。</p>
      </div>
      <div class="zh-pricing-grid">
        {pricingTiers.map(tier => (
          <div class={`zh-pricing-card${tier.popular ? ' zh-pricing-card--popular' : ''}`}>
            {tier.popular && <span class="zh-popular-badge">最受欢迎</span>}
            <p class="zh-pricing-name">{tier.name}</p>
            <p class="zh-pricing-price">{tier.price}</p>
            <p class="zh-pricing-pages">{tier.pages}</p>
            <p class="zh-pricing-desc">{tier.desc}</p>
          </div>
        ))}
      </div>
      <p class="zh-pricing-note">所有套餐均含：域名配置、移动端适配、SEO基础设置、网站操作培训。<a href={contactPage} class="zh-pricing-cta-link">获取精确报价 →</a></p>
    </div>
  </section>

  <!-- Industries -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <div class="zh-section-header">
        <p class="zh-section-eyebrow">服务行业</p>
        <h2 class="zh-section-title">各行各业，皆有经验</h2>
        <p class="zh-section-subtitle">我们为奥克兰各行业的华人企业提供网站开发服务，包括但不限于：</p>
