      </figure>
      <div class="zh-services-grid">
        {services.map(svc => (
          <div class="zh-service-card">
            <span class="zh-service-icon" aria-hidden="true">
              <Icon name={svc.icon} size={28} class="zh-service-svg" />
            </span>
            <h3 class="zh-service-title">{svc.title}</h3>
            <p class="zh-service-desc">{svc.desc}</p>
            <ul class="zh-service-list">
              {svc.items.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Development process -->
  <section class="section">
    <div class="container" style="max-width: 900px;">
      <div class="zh-section-header">
        <p class="zh-section-eyebrow">网站开发流程</p>
