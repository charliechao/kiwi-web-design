---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTABanner from '../components/CTABanner.astro';
import PageVisual from '../components/PageVisual.astro';
import testimonialsImage from '../assets/services/kiwi-web-design-testimonials-auckland.jpg';

const reviews = [
  {
    name: "Zane Barrett",
    business: "Barrett Access Scaffolding",
    industry: "Scaffolding",
    rating: 5,
    text: "Professional, responsive, and they really took the time to understand our business.",
    service: "Website Design",
  },
  {
    name: "Jack",
    business: "Show Me Shorts",
    industry: "Film & Arts",
    rating: 5,
    text: "They understood what I needed from the beginning and offered smart, practical solutions.",
    service: "Website Support",
  },
  {
    name: "Steven Liu",
    business: "Auckland client",
    industry: "Small Business",
    rating: 5,
    text: "Clean, modern, and user-friendly. The attention to detail really stood out.",
    service: "Website Design",
  },
  {
    name: "Gina Dellabarca",
    business: "Auckland client",
    industry: "Business Services",
    rating: 5,
    text: "Clear information, great communication, and a genuinely helpful audit.",
    service: "Website Audit",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/testimonials-reviews/",
      "url": "https://www.kiwiwebdesign.co.nz/testimonials-reviews/",
      "name": "Client Reviews & Testimonials | Kiwi Web Design Auckland",
      "description": "Read reviews from Auckland businesses who've worked with Kiwi Web Design. Tradies, restaurants, healthcare, and professional services, see what clients say.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/testimonials-reviews/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/testimonials-reviews/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Reviews" }
      ]
    }
  ]
};
---

<Layout
  title="Client Reviews & Testimonials | Kiwi Web Design Auckland"
  description="Read reviews from Auckland businesses who've worked with Kiwi Web Design. Tradies, restaurants, healthcare, and professional services, see what clients say."
  canonicalURL="https://www.kiwiwebdesign.co.nz/testimonials-reviews/"
  schema={schema}
>

  <!-- Hero -->
  <section class="rev-hero">
    <div class="container">
      <p class="rev-hero-eyebrow">Client Reviews</p>
      <h1>What Auckland businesses say about working with us.</h1>
      <p class="rev-hero-sub">Feedback from Auckland clients who value clear communication, practical advice, and websites built around their business. Learn more <a href="/about-us/" style="color: rgba(255,255,255,0.85); text-decoration: underline;">about us</a> and how we work.</p>

      <!-- Aggregate stats -->
      <div class="rev-agg">
        <div class="rev-agg-item">
          <div class="rev-stars">★★★★★</div>
          <span class="rev-agg-score">5.0</span>
          <span class="rev-agg-label">Google rating</span>
        </div>
        <div class="rev-agg-divider"></div>
        <div class="rev-agg-item">
          <span class="rev-agg-score">Google</span>
          <span class="rev-agg-label">verified review source</span>
        </div>
        <div class="rev-agg-divider"></div>
        <div class="rev-agg-item">
          <span class="rev-agg-score">Direct</span>
          <span class="rev-agg-label">work with Charlie</span>
        </div>
        <div class="rev-agg-divider"></div>
        <div class="rev-agg-item">
          <span class="rev-agg-score">100%</span>
          <span class="rev-agg-label">fixed-price quotes</span>
        </div>
      </div>
    </div>
  </section>

  <PageVisual
    imgSrc={testimonialsImage.src}
    imgAlt="Kiwi Web Design client review and testimonial visual"
    imgTitle="Client reviews and testimonials Kiwi Web Design Auckland"
    eyebrow="Client Trust"
    title="Reviews are stronger when the page feels as credible as the words."
    caption="See what clients say about communication, practical advice, and working directly with Charlie."
  />

  <!-- Reviews grid -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="Client Testimonials"
        title="Straight from our clients."
        subtitle="Selected feedback from Auckland clients about working with Kiwi Web Design."
      />
      <div class="rev-grid">
        {reviews.map((review) => (
          <div class="rev-card">
            <div class="rev-card-top">
              <div class="rev-stars-sm">{"★".repeat(review.rating)}</div>
              <span class="rev-industry">{review.industry}</span>
            </div>
            <blockquote class="rev-text">"{review.text}"</blockquote>
            <div class="rev-card-footer">
              <div class="rev-avatar">{review.name.charAt(0)}</div>
              <div class="rev-author-info">
                <strong class="rev-author-name">{review.name}</strong>
                <span class="rev-author-biz">{review.business}</span>
              </div>
              <span class="rev-service-tag">{review.service}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Google review prompt -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <div class="rev-google-wrap">
        <div>
          <p class="rev-google-eyebrow">Verified on Google</p>
          <h2>Check the complete review record on Google.</h2>
          <p>The selected feedback above is also published on our Google Business Profile. Visit Google to read the current rating and complete review record directly. Clients work with us through our <a href="/small-business-website-design-auckland/">web design packages</a>, <a href="/affordable-seo-auckland/">SEO services</a>, and <a href="/website-designer-auckland/">direct enquiries</a>.</p>
          <a href="https://www.google.com/maps/place/Kiwi+Web+Design" class="rev-google-btn" target="_blank" rel="noopener noreferrer">Read our Google reviews →</a>
        </div>
        <div class="rev-google-card">
          <div class="rev-gc-logo">G</div>
          <div class="rev-gc-rating">
            <div class="rev-stars rev-stars--gold">★★★★★</div>
            <span class="rev-gc-score">5.0 / 5.0</span>
          </div>
          <p class="rev-gc-count">Current reviews available on Google</p>
          <p class="rev-gc-category">Web design agency · Auckland, NZ</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Industries served -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Industries"
        title="We've built websites for these industries."
        subtitle="Each with genuinely different requirements, and each delivered on time, at a fixed price."
      />
      <div class="rev-industries">
        {[
          { icon: "🔧", label: "Tradies & Construction" },
          { icon: "⚕️", label: "Healthcare & Medical" },
          { icon: "⚖️", label: "Legal & Professional Services" },
          { icon: "💅", label: "Beauty & Wellness" },
          { icon: "🍽️", label: "Restaurants & Cafes" },
          { icon: "🏗️", label: "Property & Real Estate" },
          { icon: "📚", label: "Education & Tutoring" },
          { icon: "🛒", label: "eCommerce & Retail" },
        ].map(({ icon, label }) => (
          <div class="rev-ind-chip">
            <span>{icon}</span>
            <span>{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design Packages</a>
        <a href="/about-us/" class="rps-link">About Us</a>
        <a href="/website-designer-auckland/" class="rps-link">Contact</a>
        <a href="/affordable-seo-auckland/" class="rps-link">SEO Services</a>
        <a href="/faq/" class="rps-link">FAQ</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to be the next success story?"
    subtitle="Free consultation, no obligation. We'll tell you exactly what your site needs and what it will cost."
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Our Work", href: "/industries-we-serve-in-auckland/" }}
  />

</Layout>

<style>
  /* ── Hero ── */
  .rev-hero {
    background: var(--kwd-dark);
    color: #fff;
    padding: 4.5rem 0 3rem;
    text-align: center;
  }
  .rev-hero-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-yellow);
    margin: 0 0 1rem;
  }
  .rev-hero h1 {
    font-family: var(--kwd-font-heading);
    font-size: clamp(1.875rem, 4vw, 2.875rem);
    color: #fff;
    margin: 0 0 1rem;
    line-height: 1.2;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  .rev-hero-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.68);
    line-height: 1.65;
    max-width: 520px;
    margin: 0 auto 2.5rem;
  }

  /* ── Aggregate stats ── */
  .rev-agg {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 1.5rem 2.5rem;
    max-width: 680px;
    margin: 0 auto;
  }
  .rev-agg-item { display: flex; flex-direction: column; align-items: center; gap: 0.2rem; text-align: center; }
  .rev-stars { font-size: 1.1rem; color: var(--kwd-yellow); letter-spacing: 0.05em; }
  .rev-agg-score { font-family: var(--kwd-font-heading); font-size: 1.75rem; color: #fff; line-height: 1; }
  .rev-agg-label { font-size: 0.72rem; color: rgba(255,255,255,0.45); text-transform: uppercase; letter-spacing: 0.06em; }
  .rev-agg-divider { width: 1px; height: 2.5rem; background: rgba(255,255,255,0.12); }

  /* ── Reviews grid ── */
  .rev-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
    align-items: start;
  }
  .rev-card {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 16px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .rev-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .rev-stars-sm { font-size: 0.9rem; color: #f59e0b; letter-spacing: 0.03em; }
  .rev-industry {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--kwd-brown);
    background: var(--kwd-cream);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }
  .rev-text {
    font-size: 0.875rem;
    color: var(--kwd-dark);
    line-height: 1.7;
    margin: 0;
    font-style: italic;
    flex: 1;
  }
  .rev-card-footer {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 0.875rem;
    border-top: 1px solid rgba(0,0,0,0.06);
    flex-wrap: wrap;
  }
  .rev-avatar {
    width: 36px;
    height: 36px;
    background: var(--kwd-dark);
    color: var(--kwd-yellow);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
    flex-shrink: 0;
  }
  .rev-author-info { flex: 1; min-width: 0; }
  .rev-author-name { display: block; font-size: 0.82rem; font-weight: 700; color: var(--kwd-dark); }
  .rev-author-biz { display: block; font-size: 0.75rem; color: var(--kwd-brown); }
  .rev-service-tag {
    font-size: 0.68rem;
    background: rgba(251,232,166,0.4);
    color: var(--kwd-dark);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-weight: 600;
    white-space: nowrap;
  }

  /* ── Google section ── */
  .rev-google-wrap {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
  }
  .rev-google-eyebrow { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--kwd-yellow); margin-bottom: 0.75rem; }
  .rev-google-wrap h2 { font-size: clamp(1.4rem, 2.5vw, 1.875rem); color: #fff; margin-bottom: 0.75rem; line-height: 1.25; }
  .rev-google-wrap p { font-size: 0.9rem; color: rgba(255,255,255,0.65); line-height: 1.7; margin-bottom: 1rem; }
  .rev-google-btn {
    display: inline-block;
    background: rgba(255,255,255,0.08);
    color: var(--kwd-yellow);
    border: 1px solid rgba(255,255,255,0.15);
    padding: 0.6rem 1.25rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
  }
  .rev-google-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 2rem;
    text-align: center;
    min-width: 220px;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    align-items: center;
  }
  .rev-gc-logo {
    width: 48px;
    height: 48px;
    background: #4285F4;
    color: #fff;
    font-size: 1.5rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rev-gc-rating { display: flex; flex-direction: column; align-items: center; gap: 0.2rem; }
  .rev-stars--gold { color: #f59e0b; font-size: 1.1rem; }
  .rev-gc-score { font-family: var(--kwd-font-heading); font-size: 1.5rem; color: #fff; line-height: 1; }
  .rev-gc-count { font-size: 0.78rem; color: rgba(255,255,255,0.5); margin: 0; }
  .rev-gc-category { font-size: 0.75rem; color: rgba(255,255,255,0.35); margin: 0; }

  /* ── Industry chips ── */
  .rev-industries {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
    justify-content: center;
  }
  .rev-ind-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--kwd-cream);
    border: 1.5px solid rgba(0,0,0,0.08);
    border-radius: 50px;
    padding: 0.5rem 1.1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--kwd-dark);
  }

  /* ── Responsive ── */
  @media (max-width: 1000px) {
    .rev-grid { grid-template-columns: repeat(2, 1fr); }
    .rev-google-wrap { grid-template-columns: 1fr; gap: 2rem; }
    .rev-google-card { min-width: auto; }
  }
  @media (max-width: 640px) {
    .rev-grid { grid-template-columns: 1fr; }
    .rev-agg { flex-direction: column; gap: 1rem; }
    .rev-agg-divider { width: 3rem; height: 1px; }
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
