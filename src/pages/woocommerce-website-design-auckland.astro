---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import heroImg from '../assets/general/shopping-cart-for-eCommerce-1.jpg';
import Icon from '../components/Icon.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/woocommerce-website-design-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/woocommerce-website-design-auckland/",
      "name": "WooCommerce Website Design Auckland | NZ Online Stores",
      "description": "Fast, secure WooCommerce stores for Auckland businesses. NZ payments (AfterPay, POLi, Laybuy), shipping & GST set up. Own your store outright, no monthly platform fee. From $3,890 + GST.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/woocommerce-website-design-auckland/#breadcrumb" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": [".woo-snippet", "h1"] }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/woocommerce-website-design-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "WooCommerce Website Design Auckland", "item": "https://www.kiwiwebdesign.co.nz/woocommerce-website-design-auckland/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "Place", "name": "Auckland" },
        { "@type": "Place", "name": "New Zealand" }
      ],
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "ratingCount": "50", "bestRating": "5" },
      "logo": { "@type": "ImageObject", "url": "https://www.kiwiwebdesign.co.nz/favicon.png", "width": 512, "height": 512 }
    },
    {
      "@type": "Service",
      "@id": "https://www.kiwiwebdesign.co.nz/woocommerce-website-design-auckland/#service",
      "name": "WooCommerce Website Design Auckland",
      "serviceType": "WooCommerce Website Design",
      "category": "eCommerce",
      "provider": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "areaServed": [
        { "@type": "Place", "name": "Auckland" },
        { "@type": "Place", "name": "New Zealand" }
      ],
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "3890",
        "highPrice": "8000",
        "priceCurrency": "NZD",
        "priceSpecification": { "@type": "PriceSpecification", "valueAddedTaxIncluded": false }
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Why WooCommerce over Shopify?", "acceptedAnswer": { "@type": "Answer", "text": "WooCommerce is the right choice if you want full ownership with no monthly platform fee, maximum design flexibility, and the ability to build rich content alongside your store. It also has superior NZ payment gateway support (AfterPay, Laybuy, POLi) and integrates natively with WordPress." } },
        { "@type": "Question", "name": "Is WooCommerce hard to manage?", "acceptedAnswer": { "@type": "Answer", "text": "Not for day-to-day tasks. Adding products, processing orders, and checking reports is straightforward. We include a handover training session, and the WordPress block editor makes content management easy. Anything technical is handled under our WordPress maintenance plan." } },
        { "@type": "Question", "name": "How many products can WooCommerce handle?", "acceptedAnswer": { "@type": "Answer", "text": "WooCommerce scales to tens of thousands of products with the right hosting. Our standard packages include up to 20 products. Larger catalogues are quoted separately." } },
        { "@type": "Question", "name": "Can you migrate my existing store to WooCommerce?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We handle full migrations from Shopify, Wix eCommerce, Squarespace Commerce, or other platforms, preserving products, customer data, and order history where possible." } },
        { "@type": "Question", "name": "Do you set up the Xero integration?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We set up the Xero WooCommerce integration so orders, invoices, and payments sync automatically. Same for MYOB if that's your accounting platform." } },
        { "@type": "Question", "name": "What does a WooCommerce store cost?", "acceptedAnswer": { "@type": "Answer", "text": "WooCommerce store packages start from $3,890 + GST for up to 20 products. This includes store design, payment gateway setup (Stripe, AfterPay, Laybuy, POLi), NZ shipping configuration, GST setup, and Analytics. Fixed price, no surprises." } }
      ]
    }
  ]
};

const services = [
  {
    icon: "🏗️",
    title: "Custom WooCommerce Design",
    desc: "A storefront designed around your brand, not a generic template. Category pages, product pages, and checkout flow all custom-built for conversion.",
    items: ["Custom WordPress theme", "Brand-matched design", "Mobile-first storefront", "Conversion-optimised layouts"],
  },
  {
    icon: "💳",
    title: "NZ Payment Setup",
    desc: "All the payment methods your NZ customers expect, Stripe, PayPal, AfterPay, Laybuy, Zip, POLi, and bank transfer.",
    items: ["Stripe & PayPal", "AfterPay / Laybuy / Zip", "POLi internet banking", "Manual / bank transfer"],
  },
  {
    icon: "📦",
    title: "Shipping & Delivery",
    desc: "NZ shipping rules configured from day one, flat rates, weight-based, free shipping thresholds, rural delivery surcharges, and click-and-collect.",
    items: ["NZ courier rates", "Rural delivery rules", "Free shipping thresholds", "Click & collect option"],
  },
  {
    icon: "🧾",
    title: "GST & Invoicing",
    desc: "GST-inclusive pricing, automatic invoice generation, tax reports, and correct NZ tax class configuration for all products.",
    items: ["GST-inclusive display", "Automated invoice emails", "Tax class configuration", "GST reporting"],
  },
  {
    icon: "🔌",
    title: "Integrations & Plugins",
    desc: "Connect your store to the tools you already use, accounting (Xero, MYOB), email marketing, loyalty programs, and more.",
    items: ["Xero / MYOB integration", "Mailchimp / Klaviyo", "Loyalty & rewards", "Live chat / support"],
  },
  {
    icon: "📊",
    title: "Analytics & Tracking",
    desc: "GA4 eCommerce tracking, Google Ads conversion events, and Facebook Pixel, so you know exactly what's selling and where buyers come from.",
    items: ["GA4 eCommerce events", "Google Ads tracking", "Facebook / Meta Pixel", "Revenue reporting"],
  },
];

const nzSetup = [
  { icon: "🏦", label: "Stripe (NZD)", desc: "Card payments in NZD with instant setup" },
  { icon: "💸", label: "AfterPay", desc: "Buy now pay later, popular with NZ shoppers" },
  { icon: "🏷️", label: "Laybuy", desc: "NZ-founded BNPL, popular for fashion & lifestyle" },
  { icon: "🏧", label: "POLi", desc: "Direct bank transfer for customers avoiding card fees" },
  { icon: "📬", label: "NZ Post / CourierPost", desc: "Rate tables for NZ domestic shipping" },
  { icon: "🌏", label: "Rural delivery", desc: "Automatic rural surcharge rules" },
  { icon: "🏪", label: "Click & Collect", desc: "Local pickup option for Auckland customers" },
  { icon: "🧾", label: "GST 15%", desc: "GST-inclusive pricing with NZ tax class" },
];

const process = [
  { step: "1", title: "Discovery & Planning", desc: "We understand your products, pricing, fulfilment model, and growth plans. We plan the store structure and get sign-off before building." },
  { step: "2", title: "Design & Prototype", desc: "We design your storefront, homepage, category pages, product templates, and checkout. You review on a staging URL before we proceed." },
  { step: "3", title: "Build, Integrate & QA", desc: "We build the store, configure payment gateways, shipping zones, GST, and run end-to-end purchase flow testing on all devices." },
  { step: "4", title: "Launch & Handover", desc: "We migrate to your domain, configure Analytics and Search Console, and train you on daily store management." },
];

const faqs = [
  { q: "Why WooCommerce over Shopify?", a: "WooCommerce is the right choice if you want full ownership with no monthly platform fee, maximum design flexibility, and the ability to build rich content alongside your store. It also has superior NZ payment gateway support and integrates natively with <a href=\"/wordpress-website-design-auckland/\">WordPress</a>, so your blog, landing pages, and store are one unified website. Compare both options on our <a href=\"/ecommerce-website-auckland/\">eCommerce hub page</a>." },
  { q: "Is WooCommerce hard to manage?", a: "Not for day-to-day tasks. Adding products, processing orders, and checking reports is straightforward. We include a handover training session, and the WordPress block editor makes content management easy. Anything technical (updates, new features) is handled under our <a href=\"/wordpress-maintenance-auckland/\">WordPress maintenance plan</a>." },
  { q: "How many products can WooCommerce handle?", a: "WooCommerce scales to tens of thousands of products with the right hosting. Our standard packages include up to 20 products. Larger catalogues are quoted separately, the cost is mainly the time to populate and organise them." },
  { q: "Can you migrate my existing store to WooCommerce?", a: "Yes. We handle full migrations from <a href=\"/shopify-website-design-auckland/\">Shopify</a>, Wix eCommerce, Squarespace Commerce, or other platforms, preserving products, customer data, and order history where possible." },
  { q: "Do you set up the Xero integration?", a: "Yes. We set up the Xero WooCommerce integration so orders, invoices, and payments sync automatically. Same for MYOB if that's your accounting platform." },
  { q: "What does a WooCommerce store cost?", a: "Our WooCommerce store packages start from $3,890 + GST for up to 20 products. This includes store design, payment gateway setup, NZ shipping configuration, GST setup, and Analytics. We give you a fixed quote upfront. You may also want to consider adding <a href=\"/seo-for-ecommerce/\">eCommerce SEO</a> to drive organic traffic from day one." },
];
---

<Layout
  title="WooCommerce Website Design Auckland | NZ Online Stores"
  description="Fast, secure WooCommerce stores for Auckland businesses. NZ payments, shipping & GST set up. Affordable and built to sell."
  canonicalURL="https://www.kiwiwebdesign.co.nz/woocommerce-website-design-auckland/"
  schema={schema}
>

  <PageHero
    eyebrow="WooCommerce Auckland"
    title="WooCommerce stores built for the NZ market."
    subtitle="Custom WooCommerce websites with NZ payment gateways (AfterPay, POLi, Laybuy), NZ shipping rules, and GST configured from day one. You own the store outright, no monthly platform fee."
    badgeText="From $3,890 + GST"
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "Compare Platforms", href: "/ecommerce-website-auckland/" }}
    imgSrc={heroImg.src}
    imgAlt="WooCommerce website design Auckland"
  />

  <!-- AI citability snippet -->
  <div class="woo-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> builds WooCommerce stores for Auckland and NZ businesses from <strong>$3,890 + GST</strong>. Every store includes NZ payment gateways (Stripe, AfterPay, Laybuy, POLi), NZ shipping rules, GST configuration, and Xero integration. No monthly platform fee, you own the store outright. 4.9★ Google rating from 50+ clients.</p>
    </div>
  </div>

  <!-- Services -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="What We Build"
        title="Complete WooCommerce store setup."
        subtitle="Everything your store needs from design to launch, NZ-specific out of the box."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- NZ Setup -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="NZ-Ready Setup"
        title="Built for New Zealand from day one."
        light={true}
        subtitle="We configure every NZ-specific element as standard, no extra cost, no add-ons."
      />
      <div class="woo-nz-grid">
        {nzSetup.map(({ icon, label, desc }) => (
          <div class="woo-nz-item">
            <span class="woo-nz-icon"><Icon name={icon} size={24} /></span>
            <div>
              <strong class="woo-nz-label">{label}</strong>
              <p class="woo-nz-desc">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WooCommerce vs Shopify callout -->
  <section class="section">
    <div class="container">
      <div class="woo-vs-card">
        <div class="woo-vs-left">
          <p class="woo-vs-eyebrow">WooCommerce vs Shopify</p>
          <h2>Own your store completely.</h2>
          <p>Shopify charges a monthly platform fee ($49–$399 NZD/month) on top of transaction fees. WooCommerce has no platform fee, you pay for hosting and that's it. Over 3 years, that's a significant saving for a growing store.</p>
          <p>Beyond cost, WooCommerce gives you complete control, move hosts, change agencies, extend with any plugin. You're not locked into a proprietary ecosystem.</p>
          <a href="/ecommerce-website-auckland/" class="woo-vs-link">Compare all eCommerce options →</a>
        </div>
        <div class="woo-vs-right">
          <div class="woo-vs-compare">
            {[
              ["Monthly platform fee", "None", "$49–$399/mo"],
              ["Transaction fees (own gateway)", "0%", "0.5–2%"],
              ["Design flexibility", "Total", "Limited by theme"],
              ["NZ payment options", "All of them", "Shopify Payments + limited"],
              ["Content / SEO capability", "Full WordPress", "Basic"],
              ["You own the store", "Yes", "Shopify owns the data"],
            ].map(([feature, woo, shopify]) => (
              <div class="woo-vs-row">
                <span class="woo-vs-feature">{feature}</span>
                <span class="woo-vs-good">{woo}</span>
                <span class="woo-vs-neutral">{shopify}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="From brief to first sale in 2–4 weeks."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="WooCommerce Questions Answered"
        subtitle="Common questions from Auckland businesses about building with WooCommerce."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/ecommerce-website-auckland/" class="rps-link">eCommerce Hub</a>
        <a href="/shopify-website-design-auckland/" class="rps-link">Shopify</a>
        <a href="/seo-for-ecommerce/" class="rps-link">eCommerce SEO</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to launch your WooCommerce store?"
    subtitle="Free consultation, we'll plan your store, give you a fixed quote, and have it live in 2–4 weeks."
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Shopify Instead", href: "/shopify-website-design-auckland/" }}
  />

</Layout>

<style>
  .woo-snippet { background: #fff8e1; border-left: 4px solid var(--kwd-yellow); padding: 1rem 0; }
  .woo-snippet p { margin: 0; font-size: 0.95rem; line-height: 1.65; color: var(--kwd-dark); }

  .woo-nz-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 2.5rem;
  }
  .woo-nz-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 1.25rem;
  }
  .woo-nz-icon { flex-shrink: 0; }
  .woo-nz-label { display: block; font-size: 0.875rem; font-weight: 700; color: #fff; margin-bottom: 0.2rem; }
  .woo-nz-desc { font-size: 0.78rem; color: rgba(255,255,255,0.55); margin: 0; line-height: 1.4; }

  .woo-vs-card {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    background: var(--kwd-dark);
    border-radius: 20px;
    padding: 3rem;
    color: #fff;
    align-items: start;
  }
  .woo-vs-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-yellow);
    margin-bottom: 0.75rem;
  }
  .woo-vs-left h2 { font-size: clamp(1.5rem, 2.5vw, 2rem); color: #fff; margin-bottom: 0.75rem; }
  .woo-vs-left p { font-size: 0.9rem; color: rgba(255,255,255,0.65); line-height: 1.7; margin-bottom: 0.75rem; }
  .woo-vs-link { font-size: 0.875rem; font-weight: 700; color: var(--kwd-yellow); }

  .woo-vs-compare { display: flex; flex-direction: column; gap: 0; border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); }
  .woo-vs-row {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    align-items: center;
  }
  .woo-vs-row:last-child { border-bottom: none; }
  .woo-vs-row:hover { background: rgba(255,255,255,0.03); }
  .woo-vs-feature { font-size: 0.82rem; color: rgba(255,255,255,0.7); }
  .woo-vs-good { font-size: 0.82rem; font-weight: 700; color: var(--kwd-yellow); }
  .woo-vs-neutral { font-size: 0.82rem; color: rgba(255,255,255,0.4); }

  @media (max-width: 960px) {
    .woo-nz-grid { grid-template-columns: repeat(2, 1fr); }
    .woo-vs-card { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  @media (max-width: 580px) {
    .woo-nz-grid { grid-template-columns: 1fr; }
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
