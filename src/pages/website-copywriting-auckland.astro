---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import heroImg from '../assets/general/pexels-photo-4348404-4348404-scaled-1.jpg';
import Icon from '../components/Icon.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/website-copywriting-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/website-copywriting-auckland/",
      "name": "Website Copywriting Auckland | Web Copy for Small Businesses",
      "description": "Clear and effective website copywriting for small businesses in Auckland. Improve conversions with practical content that fits your brand.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/website-copywriting-auckland/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/website-copywriting-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Website Copywriting Auckland" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const services = [
  {
    icon: "🏠",
    title: "Homepage Copy",
    desc: "Your homepage has about 8 seconds to communicate who you are, who you help, and why they should stay. We write homepage copy that hooks visitors and drives them deeper into your site.",
    items: ["Value proposition headline", "Subheadline & supporting copy", "Benefits section", "Social proof section"],
  },
  {
    icon: "📋",
    title: "Service Page Copy",
    desc: "Each service page is a mini sales letter. We write service pages that speak to the specific pains of that buyer, explain your process, address objections, and end with a clear CTA.",
    items: ["Problem-aware opening", "Service description", "How it works", "FAQ & CTA"],
  },
  {
    icon: "🎯",
    title: "Landing Page Copy",
    desc: "High-conversion landing pages for Google Ads campaigns, lead magnets, or product launches, designed with a single focused goal.",
    items: ["Headline & subheadline testing", "Benefit-focused body copy", "Objection handling", "CTA optimisation"],
  },
  {
    icon: "👤",
    title: "About Page Copy",
    desc: "The About page is often the second most visited page on a site, but it's usually the weakest. We write About copy that builds genuine trust and connection.",
    items: ["Founder story", "Mission & values", "Social proof", "Human, non-corporate tone"],
  },
  {
    icon: "✍️",
    title: "Blog & SEO Articles",
    desc: "Long-form, keyword-targeted articles that rank on Google and establish your expertise. Fully researched, human-reviewed, and structured for AI citability.",
    items: ["Keyword research included", "1,000–2,500 words", "Internal linking", "Meta title & description"],
  },
  {
    icon: "📧",
    title: "Email Sequences",
    desc: "Welcome sequences, enquiry follow-ups, and re-engagement emails that turn leads into clients. Written in your brand voice and tested for open rates.",
    items: ["Welcome sequence (3–5 emails)", "Lead nurture flows", "Follow-up sequences", "Subject line variants"],
  },
];

const principles = [
  { icon: "🎯", title: "Clarity first", desc: "We write for the reader, not to impress. Plain English that communicates quickly and clearly, every word earns its place." },
  { icon: "🔍", title: "SEO baked in", desc: "Copy that ranks. Every page we write includes keyword research, proper heading structure, and natural keyword placement." },
  { icon: "📣", title: "Conversion-focused", desc: "Every page has a job to do. We write toward a specific action, a call, a form submission, a purchase, not just to fill space." },
  { icon: "🇳🇿", title: "NZ English & voice", desc: "We write in authentic NZ English, not American-inflected copy. Your Auckland customers will notice the difference." },
];

const process = [
  { step: "1", title: "Brief & Research", desc: "We interview you (or fill out a written brief) to understand your business, your customers, your key messages, and your tone of voice." },
  { step: "2", title: "Keyword Research", desc: "For SEO pages, we identify the primary and supporting keywords your target customers are searching for and map them to pages." },
  { step: "3", title: "First Draft", desc: "We write the first draft and deliver it in Google Docs for easy commenting and collaboration." },
  { step: "4", title: "Revise & Finalise", desc: "You review and provide feedback. We revise and deliver the final version ready to publish, or we can upload it to your site directly." },
];

const faqs = [
  { q: "Do you write copy for new websites or existing ones?", a: "Both. We frequently write copy for new <a href=\"/wordpress-website-design-auckland/\">WordPress website builds</a> (included as an add-on to the build), and we also do standalone copy projects for existing sites that aren't converting." },
  { q: "How do you capture my brand voice?", a: "We start with a brief (written or a 30-minute call) covering your tone, your customers, your key messages, and any examples of writing you like or dislike. We'll also review your existing materials. The first draft captures our interpretation, revisions refine it." },
  { q: "Do you offer copywriting in NZ English specifically?", a: "Yes. All copy is written in New Zealand English, correct spelling, NZ idioms where appropriate, and an understanding of the Auckland market. No American-inflected 'optimized' or 'organize'." },
  { q: "How many revisions are included?", a: "All copywriting projects include one full round of revisions. Additional revisions are available at our hourly rate. In our experience, most projects are finalised within one round when the brief is thorough." },
  { q: "Can you write copy that will rank on Google?", a: "Yes. All page and article copy includes keyword research, proper heading structure, natural keyword placement, and meta title/description. We write for humans first and search engines second, because that's what Google rewards. For deeper SEO work, see our <a href=\"/affordable-seo-auckland/\">SEO services</a> and <a href=\"/wordpress-seo-optimisation/\">WordPress SEO optimisation</a>." },
  { q: "How much does website copywriting cost in Auckland?", a: "A single page (homepage, About, or service page) runs $200–$400 + GST. A full website copy package (5–8 pages) runs $900–$1,800 + GST. Blog articles start from $250 + GST per piece. We give you a fixed quote based on page count and length." },
];
---

<Layout
  title="Website Copywriting Auckland | Web Copy for Small Businesses"
  description="Clear and effective website copywriting for small businesses in Auckland. Improve conversions with practical content that fits your brand."
  canonicalURL="https://www.kiwiwebdesign.co.nz/website-copywriting-auckland/"
  schema={schema}
>

  <PageHero
    eyebrow="Website Copywriting Auckland"
    title="Words that work. Copy that converts."
    subtitle="Professional website copywriting for Auckland small businesses, homepages, service pages, landing pages, and blog articles. Clear, conversion-focused, and SEO-structured."
    ctaPrimary={{ text: "Get a Copy Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Services", href: "#services" }}
    imgSrc={heroImg.src}
    imgAlt="Website copywriting Auckland"
  />

  <!-- Principles -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="How We Write"
        title="Copy that's clear, searchable, and built to convert."
        subtitle="Four principles that guide everything we write."
      />
      <div class="copy-principles">
        {principles.map(({ icon, title, desc }) => (
          <div class="copy-principle">
            <span class="cp-icon"><Icon name={icon} size={24} /></span>
            <h3 class="cp-title">{title}</h3>
            <p class="cp-desc">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" id="services">
    <div class="container">
      <SectionHeader
        eyebrow="Copywriting Services"
        title="Every page on your site. Written properly."
        subtitle="From homepage to blog, we cover every content type your business needs."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- Why copy matters -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <div class="copy-why-wrap">
        <div class="copy-why-text">
          <p class="copy-why-eyebrow">Why Copy Matters</p>
          <h2>A beautiful site with weak copy doesn't convert.</h2>
          <p>Design gets visitors to stay. Copy gets them to act. The words on your homepage determine whether a visitor calls you, fills out a form, or bounces to a competitor.</p>
          <p>Most small business owners write their own copy, which usually means it's too generic, too jargon-heavy, or too focused on features rather than what the customer cares about. Professional copywriting fixes this.</p>
        </div>
        <div class="copy-why-stats">
          <div class="copy-why-stat"><span class="cws-num">8s</span><span class="cws-label">Average time before a visitor decides to stay or leave</span></div>
          <div class="copy-why-stat"><span class="cws-num">55%</span><span class="cws-label">of visitors spend less than 15 seconds on a page</span></div>
          <div class="copy-why-stat"><span class="cws-num">3×</span><span class="cws-label">higher conversion rate for benefit-focused vs feature-focused copy</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="Brief to published in 5–7 business days."
        subtitle="A clear, collaborative process for every copy project."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Copywriting Questions Answered"
        subtitle="Common questions from Auckland businesses about professional web copy."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design Packages</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress Web Design</a>
        <a href="/affordable-seo-auckland/" class="rps-link">SEO Services Auckland</a>
        <a href="/wordpress-seo-optimisation/" class="rps-link">WordPress SEO</a>
        <a href="/landing-pages-funnels-on-wordpress/" class="rps-link">Landing Pages</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready for copy that actually converts?"
    subtitle="Get a fixed quote, we'll tell you exactly what each page will cost before we start."
    ctaPrimary={{ text: "Get a Copy Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Web Design Packages", href: "/small-business-website-design-auckland/" }}
  />

</Layout>

<style>
  .copy-principles {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .copy-principle {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 14px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .cp-icon { }
  .cp-title { font-family: var(--kwd-font-body); font-size: 0.95rem; font-weight: 700; color: var(--kwd-dark); margin: 0; }
  .cp-desc { font-size: 0.83rem; color: var(--kwd-brown); line-height: 1.6; margin: 0; }

  .copy-why-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .copy-why-eyebrow { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--kwd-yellow); margin-bottom: 0.75rem; }
  .copy-why-text h2 { font-size: clamp(1.5rem, 2.5vw, 2rem); color: #fff; margin-bottom: 0.75rem; }
  .copy-why-text p { font-size: 0.9rem; color: rgba(255,255,255,0.65); line-height: 1.7; margin-bottom: 0.75rem; }

  .copy-why-stats { display: flex; flex-direction: column; gap: 1rem; }
  .copy-why-stat {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .cws-num { font-family: var(--kwd-font-heading); font-size: 2rem; color: var(--kwd-yellow); flex-shrink: 0; min-width: 70px; line-height: 1; }
  .cws-label { font-size: 0.85rem; color: rgba(255,255,255,0.65); line-height: 1.5; }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }

  @media (max-width: 900px) {
    .copy-principles { grid-template-columns: repeat(2, 1fr); }
    .copy-why-wrap { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  @media (max-width: 580px) {
    .copy-principles { grid-template-columns: 1fr; }
  }
</style>
