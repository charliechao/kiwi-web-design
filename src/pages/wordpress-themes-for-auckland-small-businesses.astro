---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import heroImg from '../assets/general/Website-Solutsions-Auckland.jpg';
import Icon from '../components/Icon.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/wordpress-themes-for-auckland-small-businesses/",
      "url": "https://www.kiwiwebdesign.co.nz/wordpress-themes-for-auckland-small-businesses/",
      "name": "WordPress Theme Selection & Customisation Auckland | Kiwi Web Design",
      "description": "WordPress theme selection and customisation for Auckland small businesses. We choose a fast, flexible theme and configure it for your brand, SEO, and content needs.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/wordpress-themes-for-auckland-small-businesses/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/wordpress-themes-for-auckland-small-businesses/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "WordPress Theme Selection & Customisation Auckland" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const themeProblems = [
  { icon: "🐌", title: "Slow load times", desc: "Bloated themes load dozens of unused scripts and styles. On mobile, this can mean 5+ second load times — and visitors who leave before the page renders." },
  { icon: "💔", title: "Hard to update without breaking", desc: "Some themes are so complex that any content edit risks breaking the layout. Owners end up afraid to touch their own site." },
  { icon: "⚠️", title: "Abandoned and vulnerable", desc: "Premium theme marketplaces are full of themes that looked great in 2019 but haven't been updated since. Outdated themes are a security risk." },
  { icon: "📱", title: "Poor mobile experience", desc: "A theme that looks fine on desktop can be a mess on mobile — wrapping poorly, sizing incorrectly, or requiring pinch-to-zoom to read." },
];

const services = [
  {
    icon: "🔍",
    title: "Theme Selection",
    desc: "We assess your business type, content needs, and performance requirements to recommend the right theme — lightweight, well-maintained, and flexible enough for your use case.",
    items: ["Business type assessment", "Performance benchmarking", "Maintenance record check", "Compatibility review"],
  },
  {
    icon: "🎨",
    title: "Brand Customisation",
    desc: "Colours, fonts, logo, button styles, and layout — configured to match your brand and visual identity without requiring code changes every time something needs updating.",
    items: ["Colour palette setup", "Font selection & loading", "Logo & header config", "Button & link styles"],
  },
  {
    icon: "📱",
    title: "Mobile Optimisation",
    desc: "We test and configure the theme across multiple device sizes — ensuring text is readable, navigation works cleanly, and CTAs are tappable on all screen widths.",
    items: ["Responsive breakpoints", "Mobile navigation", "Typography scaling", "CTA sizing & placement"],
  },
  {
    icon: "⚡",
    title: "Performance Configuration",
    desc: "Theme settings adjusted for speed: disabling unused scripts, configuring font loading, enabling lazy loading, and removing features that add weight without adding value.",
    items: ["Unused scripts disabled", "Font loading optimised", "Lazy load configured", "Bloat removed"],
  },
  {
    icon: "🔍",
    title: "SEO Foundation",
    desc: "Theme-level SEO settings: heading hierarchy, schema markup support, Open Graph meta, and clean HTML output — the foundation your SEO plugin needs to work properly.",
    items: ["Heading structure audit", "Schema compatibility", "Open Graph support", "Clean HTML output"],
  },
  {
    icon: "🔄",
    title: "Theme Audits",
    desc: "Already have a theme that's causing problems? We audit your current theme for performance, security, and update status — and recommend whether to fix it or replace it.",
    items: ["Current theme audit", "Speed assessment", "Security check", "Recommendation report"],
  },
];

const faqs = [
  { q: "Should I use a free or premium WordPress theme?", a: "Free themes from the official WordPress repository can be excellent — GeneratePress and Astra are well-maintained, fast, and flexible. Premium themes from marketplaces like ThemeForest vary wildly in quality and are often bloated. The key factors are: active maintenance, update frequency, performance benchmarks, and whether the developer has a track record. We can recommend specific themes for your use case — and these are the themes we use on every <a href=\"/wordpress-website-design-auckland/\">WordPress website we build</a>." },
  { q: "What's wrong with page builder themes?", a: "Nothing inherently — but many page builder themes (built around Elementor, WPBakery, or Divi) are very slow, generate messy code, and create dependency on the builder. If the builder is discontinued or has a major security issue, your entire site design is at risk. We prefer themes that work with the native WordPress block editor for most small business sites." },
  { q: "Can I change my theme without rebuilding the whole site?", a: "Switching themes typically affects the visual layout significantly — the content (text, images, pages) stays in place, but headers, footers, and design elements need to be reconfigured in the new theme. It's a significant project, not a one-click change. We can assess your specific situation and give you a realistic picture of what's involved." },
  { q: "How often should a WordPress theme be updated?", a: "A well-maintained theme releases updates regularly — at minimum when major WordPress versions are released. If your theme hasn't had an update in 12+ months and you're running the latest version of WordPress, that's a compatibility and security risk. We check update history before recommending any theme." },
  { q: "Can you improve my existing theme rather than replacing it?", a: "Often, yes. Performance issues can be addressed through caching and script management, styling issues through CSS overrides, and layout issues through configuration. A full theme replacement is only necessary if the theme is fundamentally unsuitable or abandoned. We'll tell you honestly which situation you're in. Either way, the right <a href=\"/wordpress-plugins-for-small-businesses-in-auckland/\">WordPress plugins</a> working alongside a well-configured theme can make a significant difference. View our <a href=\"/small-business-website-design-auckland/\">web design packages</a> to see what a full rebuild looks like." },
];
---

<Layout
  title="WordPress Theme Selection & Customisation Auckland | Kiwi Web Design"
  description="WordPress theme selection and customisation for Auckland small businesses. We choose a fast, flexible theme and configure it for your brand, SEO, and content needs."
  canonicalURL="https://www.kiwiwebdesign.co.nz/wordpress-themes-for-auckland-small-businesses/"
  schema={schema}
>

  <PageHero
    eyebrow="WordPress Themes"
    title="A theme that's fast, flexible, and actually fits your business."
    subtitle="Theme selection and customisation for Auckland small businesses. We find the right foundation, configure it for your brand and performance needs, and make sure it stays manageable."
    imgSrc={heroImg.src}
    imgAlt="WordPress theme selection and customisation for Auckland small businesses"
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View Web Design Services", href: "/small-business-website-design-auckland/" }}
  />

  <!-- Common problems -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="Common Theme Problems"
        title="Why many Auckland sites underperform — and how we fix it."
        subtitle="These are the most common theme-related issues we see on existing sites."
      />
      <div class="theme-problems-grid">
        {themeProblems.map(({ icon, title, desc }) => (
          <div class="theme-problem-card">
            <span class="theme-problem-icon"><Icon name={icon} size={24} /></span>
            <div>
              <strong class="theme-problem-title">{title}</strong>
              <p class="theme-problem-desc">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="What We Do"
        title="Selection, customisation, and optimisation."
        subtitle="A theme that performs well and represents your brand starts with the right choices."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="WordPress Theme Questions"
        subtitle="Common questions from Auckland business owners about choosing and managing WordPress themes."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress Design</a>
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design Packages</a>
        <a href="/wordpress-plugins-for-small-businesses-in-auckland/" class="rps-link">WordPress Plugins</a>
        <a href="/wordpress-seo-optimisation/" class="rps-link">WordPress SEO</a>
        <a href="/wordpress-maintenance-auckland/" class="rps-link">WordPress Maintenance</a>
        <a href="/wordpress-ai-tools-integration-auckland/" class="rps-link">AI Tools Integration</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Is your theme holding your site back?"
    subtitle="Free consultation — we'll assess your current theme and tell you exactly what it's costing you in speed, security, and flexibility."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View Web Design Services", href: "/small-business-website-design-auckland/" }}
  />

</Layout>

<style>
  .theme-problems-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .theme-problem-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 14px;
    padding: 1.5rem;
  }
  .theme-problem-icon { flex-shrink: 0; width: 2.25rem; text-align: center; }
  .theme-problem-title { display: block; font-size: 0.9rem; font-weight: 700; color: var(--kwd-dark); margin-bottom: 0.35rem; }
  .theme-problem-desc { font-size: 0.83rem; color: var(--kwd-brown); line-height: 1.6; margin: 0; }

  @media (max-width: 700px) {
    .theme-problems-grid { grid-template-columns: 1fr; }
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
