---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import heroImg from '../assets/general/Calendar-e1756877877640.png';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/booking-appointment-websites-with-wordpress/",
      "url": "https://www.kiwiwebdesign.co.nz/booking-appointment-websites-with-wordpress/",
      "name": "Booking & Appointment Websites with WordPress",
      "description": "Get an affordable WordPress booking website for your salon, tradie, or consulting business in Auckland. Accept bookings & payments online with Kiwi Web Design.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/booking-appointment-websites-with-wordpress/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/booking-appointment-websites-with-wordpress/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Booking & Appointment Websites" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const features = [
  {
    icon: "📅",
    title: "Online Booking Calendar",
    desc: "A self-service booking calendar that lets customers choose their date, time, and service — without calling you.",
    items: ["Real-time availability", "Service duration rules", "Buffer time between bookings", "Timezone handling"],
  },
  {
    icon: "💳",
    title: "Online Payment at Booking",
    desc: "Collect deposits or full payment at the time of booking. Reduces no-shows and secures your time before the appointment.",
    items: ["Stripe & PayPal support", "Deposit or full payment", "Automatic receipts", "Refund management"],
  },
  {
    icon: "📱",
    title: "Automated Reminders",
    desc: "Email and SMS reminders sent automatically before appointments — reducing no-shows without any manual work.",
    items: ["24-hour email reminder", "SMS reminder (optional)", "Follow-up email post-booking", "Cancellation notifications"],
  },
  {
    icon: "👤",
    title: "Staff & Resource Management",
    desc: "For businesses with multiple staff or rooms — each team member has their own calendar and customers can book with a specific person.",
    items: ["Individual staff calendars", "Room / resource booking", "Staff availability rules", "Admin overview calendar"],
  },
  {
    icon: "🔗",
    title: "Calendar Integrations",
    desc: "Sync bookings to Google Calendar so you always know what's in your diary — no double-handling.",
    items: ["Google Calendar sync", "Outlook sync", "Two-way sync support", "iCal export"],
  },
  {
    icon: "📊",
    title: "Booking Analytics",
    desc: "See which services are booked most, where customers are coming from, and your no-show rate — so you can make data-informed decisions.",
    items: ["Booking volume reports", "Revenue tracking", "Source attribution", "No-show tracking"],
  },
];

const useCases = [
  { icon: "💆", name: "Salons & beauty clinics", plugin: "Trafft / Bookly", detail: "Service menu, staff selection, deposit at booking, SMS reminders" },
  { icon: "⚕️", name: "Healthcare & clinics", plugin: "Trafft / Simply Schedule", detail: "HIPAA-aware setup, intake forms, multiple practitioners" },
  { icon: "🔧", name: "Tradies (quote bookings)", plugin: "WPForms / Gravity Forms", detail: "Date/time preference form, job type, address capture" },
  { icon: "⚖️", name: "Consultants & coaches", plugin: "Simply Schedule / Amelia", detail: "Zoom link auto-generated, Stripe payment, package booking" },
  { icon: "🏋️", name: "Fitness & yoga studios", plugin: "Trafft / Amelia", detail: "Class schedules, multiple bookings per slot, membership tiers" },
  { icon: "🐾", name: "Pet services", plugin: "Bookly Pro", detail: "Pet information collection, multiple pets, staff preference" },
];

const plugins = [
  { name: "Trafft", best: "Best overall — salons, clinics, multi-staff", free: false },
  { name: "Amelia", best: "Events + appointments, feature-rich", free: false },
  { name: "Simply Schedule Appointments", best: "Simple, clean, consults & coaching", free: true },
  { name: "Bookly Pro", best: "High-volume salons, NZ payment support", free: false },
  { name: "WPForms + Stripe", best: "Quote request + payment, tradies", free: false },
];

const process = [
  { step: "1", title: "Requirements & Plugin Selection", desc: "We review your services, staff, and booking workflow to select the right plugin and configuration for your specific business model." },
  { step: "2", title: "Calendar & Services Setup", desc: "We configure your services, durations, pricing, staff calendars, and availability rules within the booking plugin." },
  { step: "3", title: "Payment & Reminders", desc: "We integrate your payment gateway, set up automated email and SMS reminders, and connect to Google Calendar." },
  { step: "4", title: "Test & Train", desc: "We run test bookings end-to-end, verify payment flow and notifications, and train you on managing your calendar day-to-day." },
];

const faqs = [
  { q: "Which WordPress booking plugin do you recommend?", a: "It depends on your business type. For salons and clinics, Trafft or Amelia are excellent — see our <a href=\"/how-kiwi-web-design-helps-auckland-beauty-industry/\">beauty industry page</a> for more. For consultants and coaches, Simply Schedule Appointments is clean and easy. For tradies needing a quote-request form rather than real-time booking, WPForms with Stripe works well. We recommend based on your specific needs and budget." },
  { q: "Can customers pay a deposit at the time of booking?", a: "Yes. All major booking plugins support deposit requirements — either a fixed amount or a percentage of the service price. This is very effective at reducing no-shows and is standard for salons, clinics, and consulting businesses." },
  { q: "Will this integrate with my Google Calendar?", a: "Yes. All plugins we recommend support Google Calendar sync — new bookings appear automatically in your diary and availability is kept in sync. A strong <a href=\"/local-seo-for-auckland-small-businesses/\">local SEO presence</a> also helps drive more organic traffic to your booking page." },
  { q: "Can I have different staff with their own availability?", a: "Yes. Multi-staff booking is supported by Trafft, Amelia, and Bookly Pro. Each team member has their own calendar, hours, and service list. Customers can select a specific staff member or be assigned automatically. This setup is popular for <a href=\"/how-kiwi-web-design-helps-auckland-healthcare/\">healthcare clinics</a> with multiple practitioners." },
  { q: "Can I accept bookings for classes or group sessions?", a: "Yes. Amelia and Trafft support event and group bookings with a maximum capacity per session. This works well for yoga, fitness, and training businesses." },
  { q: "How much does a booking website cost?", a: "A booking website with a single-staff calendar, 1 payment method, and email reminders starts from $1,490 + GST. Multi-staff setups, SMS reminders, and complex configurations are quoted based on scope. We give you a fixed price before we start. See our full <a href=\"/wordpress-website-design-auckland/\">WordPress website packages</a> for context." },
];
---

<Layout
  title="Booking & Appointment Websites with WordPress Auckland"
  description="Get an affordable WordPress booking website for your salon, tradie, or consulting business in Auckland. Accept bookings & payments online with Kiwi Web Design."
  canonicalURL="https://www.kiwiwebdesign.co.nz/booking-appointment-websites-with-wordpress/"
  schema={schema}
>

  <PageHero
    eyebrow="Booking Websites Auckland"
    title="Let your website take bookings while you work."
    subtitle="WordPress booking websites for Auckland salons, clinics, consultants, and tradies — online calendar, payment, and automated reminders. No more back-and-forth on the phone."
    badgeText="From $1,490 + GST"
    ctaPrimary={{ text: "Get a Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Features", href: "#features" }}
    imgSrc={heroImg.src}
    imgAlt="Booking appointment website WordPress Auckland"
  />

  <!-- Features -->
  <section class="section" style="background: var(--kwd-cream);" id="features">
    <div class="container">
      <SectionHeader
        eyebrow="Booking Features"
        title="Everything your booking system needs."
        subtitle="Self-service booking that works for you — and for your customers."
      />
      <ServiceGrid items={features} cols={3} />
    </div>
  </section>

  <!-- Use cases -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="Who It's For"
        title="We've built booking sites for these businesses."
        light={true}
        subtitle="Different industries have different booking requirements — we configure the right setup for yours."
      />
      <div class="book-usecases">
        {useCases.map(({ icon, name, plugin, detail }) => (
          <div class="book-uc">
            <div class="book-uc-top">
              <span class="book-uc-icon">{icon}</span>
              <strong class="book-uc-name">{name}</strong>
            </div>
            <span class="book-uc-plugin">{plugin}</span>
            <p class="book-uc-detail">{detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Plugin comparison -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Booking Plugins"
        title="Which plugin is right for you?"
        subtitle="We work with all major WordPress booking plugins and recommend based on your specific requirements."
      />
      <div class="book-plugins">
        <div class="book-plugins-table">
          <div class="book-plugins-header">
            <span>Plugin</span>
            <span>Best for</span>
            <span>Pricing</span>
          </div>
          {plugins.map(({ name, best, free }) => (
            <div class="book-plugins-row">
              <strong class="book-plugin-name">{name}</strong>
              <span class="book-plugin-best">{best}</span>
              <span class:list={['book-plugin-price', !free && 'book-plugin-price--paid']}>
                {free ? 'Free / freemium' : 'Paid licence'}
              </span>
            </div>
          ))}
        </div>
        <p class="book-plugins-note">We recommend the right plugin for your business — and the plugin licence cost is separate from our build fee. We'll give you the total cost upfront.</p>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="From brief to taking bookings in 1–2 weeks."
        subtitle="A straightforward four-step process to get your booking system live."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Booking Website Questions Answered"
        subtitle="Common questions from Auckland businesses about WordPress booking systems."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress Web Design</a>
        <a href="/how-kiwi-web-design-helps-auckland-healthcare/" class="rps-link">Healthcare Sites</a>
        <a href="/how-kiwi-web-design-helps-auckland-beauty-industry/" class="rps-link">Beauty Industry</a>
        <a href="/local-seo-for-auckland-small-businesses/" class="rps-link">Local SEO</a>
        <a href="/small-business-website-design-auckland/" class="rps-link">Small Business</a>
        <a href="/landing-pages-funnels-on-wordpress/" class="rps-link">Landing Pages &amp; Funnels</a>
        <a href="/wordpress-maintenance-auckland/" class="rps-link">WordPress Maintenance</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to take bookings online 24/7?"
    subtitle="Free consultation — we'll recommend the right booking setup for your business and give you a fixed quote."
    ctaPrimary={{ text: "Get a Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Web Design Packages", href: "/small-business-website-design-auckland/" }}
  />

</Layout>

<style>
  .book-usecases {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .book-uc {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .book-uc-top { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.25rem; }
  .book-uc-icon { font-size: 1.4rem; }
  .book-uc-name { font-size: 0.9rem; font-weight: 700; color: #fff; }
  .book-uc-plugin { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--kwd-yellow); }
  .book-uc-detail { font-size: 0.83rem; color: rgba(255,255,255,0.6); line-height: 1.55; margin: 0; }

  .book-plugins { margin-top: 2rem; }
  .book-plugins-table { border: 1.5px solid rgba(0,0,0,0.08); border-radius: 14px; overflow: hidden; }
  .book-plugins-header {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    background: var(--kwd-dark);
    padding: 0.875rem 1.25rem;
    gap: 1rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.5);
  }
  .book-plugins-row {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    padding: 0.875rem 1.25rem;
    gap: 1rem;
    border-top: 1px solid rgba(0,0,0,0.06);
    align-items: center;
  }
  .book-plugins-row:hover { background: rgba(0,0,0,0.02); }
  .book-plugin-name { font-size: 0.9rem; font-weight: 700; color: var(--kwd-dark); }
  .book-plugin-best { font-size: 0.84rem; color: var(--kwd-brown); }
  .book-plugin-price { font-size: 0.8rem; color: var(--kwd-brown); }
  .book-plugin-price--paid { color: var(--kwd-dark); font-weight: 600; }
  .book-plugins-note { font-size: 0.82rem; color: var(--kwd-brown); margin-top: 1rem; }

  @media (max-width: 900px) {
    .book-usecases { grid-template-columns: repeat(2, 1fr); }
    .book-plugins-header, .book-plugins-row { grid-template-columns: 1fr 1.5fr; }
    .book-plugins-header span:last-child, .book-plugin-price { display: none; }
  }
  @media (max-width: 580px) { .book-usecases { grid-template-columns: 1fr; } }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
