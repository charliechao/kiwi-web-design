---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/seo-for-ecommerce/",
      "url": "https://www.kiwiwebdesign.co.nz/seo-for-ecommerce/",
      "name": "SEO for eCommerce Websites Auckland | Kiwi Web Design",
      "description": "SEO for eCommerce websites in Auckland and NZ. Drive organic traffic to your online store with product optimisation, technical SEO, and category page strategies.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/seo-for-ecommerce/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/seo-for-ecommerce/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "SEO for eCommerce" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const services = [
  {
    icon: "🛍️",
    title: "Product Page Optimisation",
    desc: "Keyword-rich titles, meta descriptions, structured data markup, and unique descriptions for every product — so Google understands what you're selling and ranks it accordingly.",
    items: ["Title & meta optimisation", "Product schema markup", "Unique product descriptions", "Image alt text"],
  },
  {
    icon: "📂",
    title: "Category & Collection Pages",
    desc: "Category pages are often the highest-traffic, highest-converting pages on an eCommerce site. We optimise them with targeted copy, internal links, and the right schema.",
    items: ["Category page copy", "Keyword targeting", "Internal linking structure", "Breadcrumb schema"],
  },
  {
    icon: "⚙️",
    title: "Technical eCommerce SEO",
    desc: "Faceted navigation, duplicate content from product variations, crawl budget issues — eCommerce sites have unique technical challenges. We identify and fix them.",
    items: ["Crawl budget management", "Canonicalisation", "Faceted nav handling", "Duplicate content audit"],
  },
  {
    icon: "⚡",
    title: "Site Speed & Core Web Vitals",
    desc: "Slow stores lose sales. We optimise images, scripts, and server configuration to hit green Core Web Vitals scores — which also directly improves your Google rankings.",
    items: ["Image compression", "Script optimisation", "LCP & CLS improvements", "Mobile performance"],
  },
  {
    icon: "🔗",
    title: "Internal Linking & Architecture",
    desc: "A well-structured eCommerce site passes link equity from high-authority pages down to product pages. We audit and rebuild your internal link structure to maximise rankings.",
    items: ["Site architecture audit", "Internal link mapping", "Pillar + cluster structure", "Navigation SEO"],
  },
  {
    icon: "📊",
    title: "Tracking & Monthly Reporting",
    desc: "GA4, Search Console, and eCommerce conversion tracking set up properly — so you see exactly which products and categories are driving revenue from organic search.",
    items: ["GA4 eCommerce tracking", "Search Console setup", "Rank tracking", "Monthly reports"],
  },
];

const faqs = [
  { q: "How is eCommerce SEO different from regular SEO?", a: "eCommerce sites have unique challenges: thousands of product pages, duplicate content from product variants, faceted navigation creating crawl issues, and category pages that need both SEO and conversion optimisation. A standard SEO approach misses most of these — eCommerce SEO requires specialist knowledge of how Google crawls and indexes large product catalogues. See how it compares with our broader <a href=\"/seo-auckland/\">SEO services in Auckland</a>." },
  { q: "How long before I see results from eCommerce SEO?", a: "Technical fixes and on-page improvements can show results within 4–8 weeks. Competitive category-level rankings typically take 3–6 months of consistent effort. We focus on quick wins first — fixing technical issues and optimising your best-performing product pages — while building toward longer-term category dominance." },
  { q: "Do you work with WooCommerce and Shopify?", a: "Yes. We work with both. <a href=\"/woocommerce-website-design-auckland/\">WooCommerce</a> and Shopify have different SEO implementations — URL structure, schema, sitemap generation, and plugin ecosystems are all different. We tailor our approach to your platform." },
  { q: "My store already gets traffic from ads. Why do I need SEO?", a: "Ads stop the moment you stop paying. Organic traffic from SEO compounds over time and costs nothing per click. A well-ranked product or category page can deliver consistent revenue for years. Most successful eCommerce businesses combine both — <a href=\"/google-ads/\">Google Ads</a> for immediate sales, SEO for long-term sustainable growth." },
  { q: "Can you help if my store was built by someone else?", a: "Yes. We can audit and optimise any WooCommerce or Shopify store regardless of who built it. We start with a technical audit to identify what's holding your store back, then work through the issues systematically. If you're planning a new <a href=\"/ecommerce-website-auckland/\">eCommerce website</a>, we can build SEO in from day one." },
];
---

<Layout
  title="SEO for eCommerce Websites Auckland | Kiwi Web Design"
  description="SEO for eCommerce websites in Auckland and NZ. Drive organic traffic to your online store with product optimisation, technical SEO, and category page strategies."
  canonicalURL="https://www.kiwiwebdesign.co.nz/seo-for-ecommerce/"
  schema={schema}
>

  <PageHero
    eyebrow="eCommerce SEO"
    title="Get your online store found — without paying for every click."
    subtitle="SEO for eCommerce sites in Auckland and New Zealand. We optimise your product pages, category structure, and technical setup to drive organic traffic that converts."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View SEO Services", href: "/seo-auckland/" }}
    centered={true}
  />

  <!-- What it covers -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="What eCommerce SEO Covers"
        title="More than just keywords — your whole store, optimised."
        subtitle="eCommerce sites need a different approach. Here's what we work on."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- Why it matters -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <SectionHeader
        eyebrow="Why It Matters"
        title="Organic traffic is the most profitable channel for eCommerce."
        align="left"
      />
      <div class="ecom-body">
        <p>Paid ads work — but every order from ads costs you margin. Every order from organic search is essentially free. The challenge is getting there: eCommerce SEO is technically complex, and most generic SEO agencies don't understand the specific problems large product catalogues create.</p>
        <p>We've worked on WooCommerce and Shopify stores from a few dozen products to several hundred. The pattern is consistent: most stores have 3–5 technical issues quietly suppressing their rankings, and a handful of product and category pages that could rank on page 1 with proper optimisation.</p>
        <p>We fix the technical foundations first, then work through the commercial pages most likely to drive revenue. Results compound over time — a well-optimised store builds organic traffic month on month without ongoing ad spend.</p>
        <ul class="ecom-checklist">
          <li>Ideal for WooCommerce and Shopify stores</li>
          <li>Works alongside your existing Google Ads campaigns</li>
          <li>Monthly reporting so you see exactly what's moving</li>
          <li>No lock-in — we work month-to-month</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="eCommerce SEO Questions"
        subtitle="Common questions from Auckland store owners about SEO for online shops."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/ecommerce-website-auckland/" class="rps-link">eCommerce Websites</a>
        <a href="/seo-auckland/" class="rps-link">SEO Services</a>
        <a href="/woocommerce-website-design-auckland/" class="rps-link">WooCommerce</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
        <a href="/analytics-reporting-for-auckland-small-business-websites/" class="rps-link">Analytics</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to grow your store with organic traffic?"
    subtitle="Free consultation — we'll review your store and show you exactly where the opportunities are."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "See All SEO Services", href: "/seo-auckland/" }}
  />

</Layout>

<style>
  .ecom-body p {
    font-size: 0.9375rem;
    color: var(--kwd-brown);
    line-height: 1.75;
    margin-bottom: 0.9rem;
  }
  .ecom-checklist {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ecom-checklist li {
    font-size: 0.9rem;
    color: var(--kwd-dark);
    font-weight: 600;
    padding-left: 1.5rem;
    position: relative;
  }
  .ecom-checklist li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--kwd-brown);
    font-weight: 700;
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
