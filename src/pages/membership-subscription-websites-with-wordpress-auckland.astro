---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import Icon from '../components/Icon.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/membership-subscription-websites-with-wordpress-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/membership-subscription-websites-with-wordpress-auckland/",
      "name": "Membership & Subscription Websites with WordPress (Auckland)",
      "description": "Build a professional membership or subscription website in Auckland. Perfect for clubs, training sites, and business associations.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/membership-subscription-websites-with-wordpress-auckland/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/membership-subscription-websites-with-wordpress-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Membership & Subscription Websites" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const features = [
  {
    icon: "🔐",
    title: "Gated Content & Member Access",
    desc: "Restrict pages, posts, downloads, and entire sections of your site to registered members only. Free, paid, or tiered access levels.",
    items: ["Content restriction by page", "Free vs paid tiers", "Member-only downloads", "Drip content release"],
  },
  {
    icon: "💳",
    title: "Recurring Subscription Payments",
    desc: "Monthly or annual subscription billing through Stripe, automatic renewals, failed payment handling, and member self-service cancellation.",
    items: ["Stripe recurring billing", "Monthly & annual plans", "Failed payment recovery", "Member self-service portal"],
  },
  {
    icon: "🎓",
    title: "Online Courses & Learning",
    desc: "Structured course content with lessons, modules, quizzes, and progress tracking, ideal for coaches, trainers, and educators.",
    items: ["Course builder", "Lesson progress tracking", "Quizzes & assessments", "Completion certificates"],
  },
  {
    icon: "👥",
    title: "Member Directory",
    desc: "A searchable directory of members, great for associations, networks, and community platforms where members want to connect.",
    items: ["Searchable profiles", "Member map", "Category filtering", "Profile self-editing"],
  },
  {
    icon: "💬",
    title: "Member Community & Forums",
    desc: "Private discussion forums or community spaces for members, a high-retention feature that makes membership feel valuable.",
    items: ["Private forums", "Member-to-member messaging", "Activity feeds", "Moderation tools"],
  },
  {
    icon: "📧",
    title: "Member Lifecycle Emails",
    desc: "Automated email sequences for new members (welcome series), expired members (renewal reminders), and disengaged members (re-engagement campaigns).",
    items: ["Welcome sequences", "Renewal reminders", "Re-engagement campaigns", "Mailchimp / Klaviyo integration"],
  },
];

const useCases = [
  { icon: "🏋️", title: "Fitness & Wellness", desc: "Online training programs, workout libraries, nutrition guides, members pay monthly for ongoing access to your content." },
  { icon: "📚", title: "Online Education", desc: "Courses, workshops, and learning communities. Student progress tracking, quizzes, and certificates." },
  { icon: "🤝", title: "Industry Associations", desc: "Member directories, resources, events, and forums for professional networks and industry groups." },
  { icon: "💼", title: "Business Coaching", desc: "Gated resource libraries, group coaching replays, community forums, packaged as a monthly membership." },
  { icon: "🎨", title: "Creative Clubs", desc: "Subscription access to design assets, templates, fonts, illustrations, or photography for creative professionals." },
  { icon: "🍷", title: "Subscription Boxes / Clubs", desc: "Wine clubs, book clubs, product subscriptions, recurring payment plus member-only offers and content." },
];

const plugins = [
  { name: "MemberPress", best: "Best overall, courses, content restriction, subscriptions", notes: "Our first recommendation for most membership sites" },
  { name: "Paid Memberships Pro", best: "Associations, directories, complex tiers", notes: "Open-source core, very flexible" },
  { name: "LearnDash", best: "Online courses and training programmes specifically", notes: "Best LMS for complex course structures" },
  { name: "Restrict Content Pro", best: "Simple content restriction + subscriptions", notes: "Lightweight, good for basic setups" },
];

const process = [
  { step: "1", title: "Membership Model Design", desc: "We map out your tier structure, what's gated vs free, your pricing model, and the member journey from sign-up to renewal." },
  { step: "2", title: "Plugin Selection & Setup", desc: "We select and configure the right membership plugin, MemberPress, Paid Memberships Pro, or LearnDash, and set up all tiers and access rules." },
  { step: "3", title: "Content, Payments & Emails", desc: "We populate initial content, integrate Stripe for recurring payments, and set up automated welcome and renewal email sequences." },
  { step: "4", title: "Test & Launch", desc: "We test the full member journey, sign-up, payment, access, and cancellation, then launch and train you on managing members." },
];

const faqs = [
  { q: "What's the best WordPress plugin for membership sites?", a: "For most membership sites, we recommend MemberPress, it handles content restriction, subscription payments, and online courses in one plugin with excellent documentation. For associations with member directories, Paid Memberships Pro is more flexible. For pure course-focused platforms, LearnDash is the best dedicated LMS. All are built on <a href=\"/wordpress-website-design-auckland/\">WordPress</a>." },
  { q: "Can members pay monthly by credit card?", a: "Yes. We integrate Stripe for recurring monthly or annual payments, automatic renewal, failed payment retry, and member self-service cancellation are all handled automatically. If you also sell products to members, we can integrate <a href=\"/woocommerce-website-design-auckland/\">WooCommerce</a> alongside your membership plugin." },
  { q: "Can I offer a free tier alongside paid tiers?", a: "Yes. Most membership plugins support multiple tiers including a free registered tier. This is a common structure, free members get limited access and see upgrade prompts for premium content." },
  { q: "Is a membership site harder to manage than a regular WordPress site?", a: "Day-to-day management is straightforward, adding content, approving members, viewing payments. The complexity is in the initial setup of tiers and access rules, which we handle. We provide documentation and training so you can manage it confidently from day one." },
  { q: "Can I drip-release content to new members?", a: "Yes. Drip content (releasing content on a schedule after sign-up) is supported by MemberPress and LearnDash. This is great for courses, you release Module 1 on day 1, Module 2 on day 8, etc., to keep members engaged and reduce early cancellations. If you prefer a full product store instead, see our <a href=\"/ecommerce-website-auckland/\">eCommerce options</a>." },
  { q: "How much does a membership website cost?", a: "A basic membership site (one paid tier, content restriction, Stripe payments) starts from $2,690 + GST. A full course platform with multiple tiers, quizzes, and email sequences typically runs $3,500–$5,000 + GST. We give you a fixed quote based on your requirements." },
];
---

<Layout
  title="Membership & Subscription Websites with WordPress Auckland"
  description="Build a professional membership or subscription website in Auckland. Perfect for clubs, training sites, and business associations."
  canonicalURL="https://www.kiwiwebdesign.co.nz/membership-subscription-websites-with-wordpress-auckland/"
  schema={schema}
>

  <PageHero
    eyebrow="Membership Websites Auckland"
    title="Turn your knowledge into recurring revenue."
    subtitle="WordPress membership and subscription websites for Auckland businesses, gated content, recurring payments, online courses, member directories, and community forums."
    badgeText="From $2,690 + GST"
    ctaPrimary={{ text: "Get a Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Use Cases", href: "#usecases" }}
  />

  <!-- Use cases -->
  <section class="section" style="background: var(--kwd-cream);" id="usecases">
    <div class="container">
      <SectionHeader
        eyebrow="Who It's For"
        title="Membership sites across industries."
        subtitle="Any business that creates ongoing value can build a membership model around it."
      />
      <div class="mem-usecases">
        {useCases.map(({ icon, title, desc }) => (
          <div class="mem-uc">
            <span class="mem-uc-icon"><Icon name={icon} size={24} /></span>
            <h3 class="mem-uc-title">{title}</h3>
            <p class="mem-uc-desc">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="What's Included"
        title="Everything a membership site needs."
        subtitle="From payment processing to community features, all built in WordPress."
      />
      <ServiceGrid items={features} cols={3} />
    </div>
  </section>

  <!-- Plugins -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="Membership Plugins"
        title="The right tool for your membership model."
        light={true}
        subtitle="We work with all major WordPress membership plugins and choose based on your specific requirements."
      />
      <div class="mem-plugins">
        {plugins.map(({ name, best, notes }) => (
          <div class="mem-plugin">
            <strong class="mem-plugin-name">{name}</strong>
            <p class="mem-plugin-best">{best}</p>
            <span class="mem-plugin-notes">{notes}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="From concept to launch in 2–4 weeks."
        subtitle="A structured build process for membership sites."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Membership Site Questions Answered"
        subtitle="Common questions from Auckland businesses about WordPress membership sites."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress Web Design</a>
        <a href="/woocommerce-website-design-auckland/" class="rps-link">WooCommerce</a>
        <a href="/ecommerce-website-auckland/" class="rps-link">eCommerce</a>
        <a href="/small-business-website-design-auckland/" class="rps-link">Small Business</a>
        <a href="/wordpress-maintenance-auckland/" class="rps-link">WordPress Maintenance</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to launch your membership site?"
    subtitle="Free consultation, we'll design your membership model and give you a fixed quote."
    ctaPrimary={{ text: "Get a Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See eCommerce Options", href: "/ecommerce-website-auckland/" }}
  />

</Layout>

<style>
  .mem-usecases {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .mem-uc {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 14px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .mem-uc-icon { }
  .mem-uc-title { font-family: var(--kwd-font-body); font-size: 0.95rem; font-weight: 700; color: var(--kwd-dark); margin: 0; }
  .mem-uc-desc { font-size: 0.83rem; color: var(--kwd-brown); line-height: 1.6; margin: 0; }

  .mem-plugins {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 2.5rem;
  }
  .mem-plugin {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .mem-plugin-name { font-size: 0.95rem; font-weight: 700; color: var(--kwd-yellow); }
  .mem-plugin-best { font-size: 0.83rem; color: rgba(255,255,255,0.75); line-height: 1.55; margin: 0; }
  .mem-plugin-notes { font-size: 0.78rem; color: rgba(255,255,255,0.4); margin-top: 0.25rem; }

  @media (max-width: 900px) {
    .mem-usecases { grid-template-columns: repeat(2, 1fr); }
    .mem-plugins { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 580px) {
    .mem-usecases { grid-template-columns: 1fr; }
    .mem-plugins { grid-template-columns: 1fr; }
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
