---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import StatsRow from '../components/StatsRow.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import TestimonialGrid from '../components/TestimonialGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import Icon from '../components/Icon.astro';
import { Image } from 'astro:assets';
import about1 from '../assets/general/about1.jpg';
import about2 from '../assets/general/about2.jpg';
import smallBizAuckland from '../assets/general/Small-Business-Auckland.jpg';
import webSolutions from '../assets/general/Website-Solutsions-Auckland.jpg';
import aucklandCafe from '../assets/general/Auckland-small-business-1.jpg';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/small-business-website-design-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/small-business-website-design-auckland/",
      "name": "Small Business Website Design Auckland | From $1,290 | Kiwi Web Design",
      "description": "Custom websites for Auckland small businesses from $1,290. Built to generate leads, live in 2–3 weeks. Free in-person consultation. Call 021 039 6580.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/small-business-website-design-auckland/#breadcrumb" },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".smb-snippet", ".stats-row"]
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/small-business-website-design-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Small Business Web Design Auckland", "item": "https://www.kiwiwebdesign.co.nz/small-business-website-design-auckland/" }
      ]
    },
    {
      "@type": "Service",
      "@id": "https://www.kiwiwebdesign.co.nz/small-business-website-design-auckland/#service",
      "name": "Small Business Website Design Auckland",
      "serviceType": "Website Design",
      "category": "Web Development",
      "description": "Custom website design for Auckland small businesses. Conversion-focused, mobile-first, delivered in 2–3 weeks from $1,290 + GST. WordPress or custom build.",
      "provider": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "areaServed": [
        { "@type": "City", "name": "Auckland" },
        { "@type": "Country", "name": "New Zealand" }
      ],
      "url": "https://www.kiwiwebdesign.co.nz/small-business-website-design-auckland/",
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "1290",
        "highPrice": "3890",
        "priceCurrency": "NZD",
        "priceSpecification": { "@type": "PriceSpecification", "price": "1290", "priceCurrency": "NZD", "valueAddedTaxIncluded": false }
      }
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Small Business Website Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "City", "name": "Auckland" },
        { "@type": "Country", "name": "New Zealand" }
      ],
      "priceRange": "$$",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "bestRating": "5",
        "ratingCount": "50"
      },
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.kiwiwebdesign.co.nz/favicon.png",
        "width": 512,
        "height": 512
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How much does a website cost for a small business in Auckland?",
          "acceptedAnswer": { "@type": "Answer", "text": "Packages start from $1,290 + GST. Most Auckland small business sites are built on WordPress, though we also deliver fully custom builds depending on your needs. Growth packages typically run $2,690–$3,500. eCommerce sites start from $3,890. Fixed quotes upfront, no surprises." }
        },
        {
          "@type": "Question",
          "name": "How long does it take to build a website?",
          "acceptedAnswer": { "@type": "Answer", "text": "Most projects are completed in 2–3 weeks from when content is received. More complex sites with custom features may take 4–6 weeks. A timeline is provided upfront." }
        },
        {
          "@type": "Question",
          "name": "Will I be able to update the website myself?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. WordPress sites are easy to update without a developer. For custom builds we set up the right editing tools for your needs. A handover session is included with every project. Monthly maintenance plans are also available." }
        },
        {
          "@type": "Question",
          "name": "Do you offer hosting and maintenance for Auckland small businesses?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Managed hosting is available from $49/month and includes updates, backups, security, and 2 hours of content changes per month." }
        },
        {
          "@type": "Question",
          "name": "Can you redesign my existing website?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Full rebuilds, redesigns, and migrations from Wix, Squarespace, or old WordPress themes are all available. We also build from scratch on custom platforms where needed. SEO and content are preserved during the process." }
        }
      ]
    }
  ]
};

const stats = [
  { number: "From $1,290", label: "One-time website packages" },
  { number: "2–3 wks", label: "Typical delivery time" },
  { number: "50+", label: "Auckland businesses helped" },
  { number: "4.9★", label: "Average Google rating" },
];

const included = [
  {
    icon: "🎨",
    title: "Custom Design",
    desc: "No cookie-cutter templates. Your website is designed around your brand, your customers, and your goals, so it looks and feels like you.",
    items: ["Brand-matched colours & fonts", "Mobile-first layouts", "Modern, clean aesthetics", "Competitor differentiation"],
  },
  {
    icon: "⚡",
    title: "WordPress or Custom Build",
    desc: "Most of our builds use WordPress, reliable, flexible, and easy to update. We also build fully custom sites when your project needs something beyond off-the-shelf. No lock-in either way.",
    items: ["Easy content editing", "WordPress or custom CMS", "WooCommerce ready", "Scales as you grow"],
  },
  {
    icon: "🔍",
    title: "SEO-Ready From Day One",
    desc: "Every page we build is structured for search engines. Speed, mobile performance, schema markup, and proper heading structure, all standard.",
    items: ["Fast page speed", "Proper meta tags", "Schema markup", "Google Search Console setup"],
  },
  {
    icon: "📱",
    title: "Mobile Optimised",
    desc: "Over 60% of your traffic is on mobile. We build mobile-first and test across devices so your site works perfectly on every screen.",
    items: ["Responsive layouts", "Touch-friendly navigation", "Mobile page speed", "Cross-device testing"],
  },
  {
    icon: "🔒",
    title: "Secure & Reliable",
    desc: "SSL certificates, regular backups, security hardening, and managed hosting. We handle the technical side so you can focus on your business.",
    items: ["SSL included", "Daily backups", "Uptime monitoring", "Security hardening"],
  },
  {
    icon: "📞",
    title: "Lead-Generation Focus",
    desc: "Your website should be working for you 24/7. We design with clear calls-to-action, fast-loading pages, and conversion-tested layouts.",
    items: ["CTA strategy", "Contact form setup", "Click-to-call integration", "Enquiry tracking"],
  },
];

const industries = [
  { icon: "Wrench",        title: "Tradies",               desc: "Plumbers, electricians, builders, painters. We know what converts for trade businesses in Auckland.", href: "/tradie-website-design-auckland/" },
  { icon: "Sparkles",      title: "Beauty & Wellness",     desc: "Salons, spas, clinics. Booking-integrated sites that showcase your services and keep the chair full.", href: "/how-kiwi-web-design-helps-auckland-beauty-industry/" },
  { icon: "UtensilsCrossed", title: "Restaurants & Cafés", desc: "Menu pages, booking links, Google Maps integration. Hungry customers find you first.", href: "/how-kiwi-web-design-helps-auckland-restaurants/" },
  { icon: "HeartPulse",    title: "Healthcare",             desc: "Physios, dentists, GPs. HIPAA-aware design with online booking and clear service pages.", href: "/how-kiwi-web-design-helps-auckland-healthcare/" },
  { icon: "Briefcase",     title: "Professional Services",  desc: "Lawyers, accountants, consultants. Authority-building design that wins the trust of new clients.", href: "/how-kiwi-web-design-helps-auckand-lawyers/" },
  { icon: "ShoppingCart",  title: "eCommerce & Retail",     desc: "WooCommerce and Shopify stores built to sell. Product pages, checkout flow, and payment gateway setup.", href: "/ecommerce-website-auckland/" },
];

const process = [
  { step: "1", title: "Free Discovery Call", desc: "We start with a conversation, not a quote. We learn about your business, your customers, and what success looks like for you." },
  { step: "2", title: "Strategy & Wireframe", desc: "We map out the site structure, page layout, and content plan. You approve the direction before any design begins." },
  { step: "3", title: "Design & Build", desc: "We design and build your site, on WordPress or a custom platform, depending on your needs. You get a staging link to review and request changes before launch." },
  { step: "4", title: "Launch & Handover", desc: "We go live, set up Google Search Console and Analytics, and walk you through how to make basic updates yourself." },
];

const packages = [
  {
    name: "Starter",
    price: "From $1,290",
    note: "+ GST",
    desc: "Perfect for sole traders and small businesses that need a professional online presence fast.",
    items: [
      "Custom design",
      "Mobile responsive",
      "Contact form",
      "Basic SEO setup",
      "Google Analytics",
      "1 round of revisions",
    ],
    cta: "Get a Quote",
    href: "/website-designer-auckland/",
    highlight: false,
  },
  {
    name: "Growth",
    price: "From $2,690",
    note: "+ GST",
    desc: "For businesses ready to invest in a website that actively generates leads and grows with them.",
    items: [
      "Up to 10 pages",
      "Custom design",
      "Mobile responsive",
      "Lead-gen conversion setup",
      "Full SEO optimisation",
      "Google Analytics + Search Console",
      "2 rounds of revisions",
      "Booking / enquiry integration",
      "1 month post-launch support",
    ],
    cta: "Get a Quote",
    href: "/website-designer-auckland/",
    highlight: true,
    tag: "Most Popular",
  },
  {
    name: "eCommerce",
    price: "From $3,890",
    note: "+ GST",
    desc: "WooCommerce stores ready to sell. Product management, payment gateway, and order notifications.",
    items: [
      "WooCommerce setup",
      "Up to 20 products",
      "Payment gateway integration",
      "Shipping configuration",
      "Product SEO",
      "Order management training",
      "2 rounds of revisions",
      "2 months post-launch support",
    ],
    cta: "Get a Quote",
    href: "/website-designer-auckland/",
    highlight: false,
  },
];

const faqs = [
  { q: "How much does a website cost for a small business in Auckland?", a: "Our packages start from $1,290 + GST. Most sites are built on <a href=\"/wordpress-website-design-auckland/\">WordPress</a>, though we also offer fully custom builds when your project needs it. Growth packages typically run $2,690–$3,500. eCommerce sites start from $3,890. Fixed quote upfront, no surprises. Try our <a href=\"/affordable-web-design-auckland/website-cost-new-zealand-small-business/\">free website cost calculator</a> to estimate your budget." },
  { q: "How long does it take to build a website?", a: "Most projects are completed in 2–3 weeks from when we receive your content. More complex sites with custom features may take 4–6 weeks. We'll give you a timeline upfront and stick to it. See our full <a href=\"/website-design-process-in-auckland/\">website design process</a> for a step-by-step breakdown." },
  { q: "Do I need to provide content?", a: "Ideally yes, you know your business best. But we help with content guidance, structure, and can write copy for you as an add-on. We also source or licence stock images if needed." },
  { q: "Will I be able to update the website myself?", a: "Yes. WordPress sites are easy to manage without a developer, we include a handover session on every project. For custom builds, we set up the right editing tools for your team. Ongoing maintenance plans are available if you'd prefer we handle updates." },
  { q: "Do you offer hosting and maintenance?", a: "Yes. We offer managed hosting from $49/month, covering updates, backups, security, and 2 hours of content changes. Ask us about bundling it with your build." },
  { q: "Can you redesign my existing website?", a: "Yes. We do full rebuilds, redesigns, and migrations from Wix, Squarespace, old WordPress themes, or any other platform. We also build bespoke sites from scratch when a standard CMS isn't the right fit. We preserve your <a href=\"/affordable-seo-auckland/\">SEO</a> and content throughout. After launch, consider adding <a href=\"/local-seo-for-auckland-small-businesses/\">local SEO</a> or <a href=\"/google-ads/\">Google Ads</a> to drive traffic." },
];

const reviews = [
  { name: "Zane Barrett", company: "Barrett Access Scaffolding", text: "From the first call, Charlie understood exactly what we needed. The site was live in 2 weeks and we got our first enquiry the day after launch." },
  { name: "Jack", company: "Show Me Shorts", text: "Really easy to work with. The process was clear, the timeline was met, and the end result looks way better than what we had before." },
  { name: "Steven Liu", company: "Client", text: "Outstanding experience. The design is clean, modern, and user-friendly, exactly what I was hoping for." },
  { name: "Gina Dellabarca", company: "Client", text: "Comprehensive and helpful. Clear information, great communication, and delivered exactly on time." },
];
---

<Layout
  title="Small Business Website Design Auckland | From $1,290 | Kiwi Web Design"
  description="Custom websites for Auckland small businesses from $1,290. WordPress or fully custom build, lead-focused, live in 2–3 weeks. Free consultation. Call 021 039 6580."
  canonicalURL="https://www.kiwiwebdesign.co.nz/small-business-website-design-auckland/"
  schema={schema}
  alternateUrl="https://www.kiwiwebdesign.co.nz/zh/small-business-website-design-auckland/"
>

  <PageHero
    eyebrow="Small Business Web Design Auckland"
    title="Websites built to generate leads. Not just look good."
    subtitle="Affordable websites for Auckland small businesses and tradies, WordPress or fully custom, from $1,290, delivered in 2–3 weeks, with a free in-person consult."
    badgeText="From $1,290 + GST"
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "View Packages", href: "#packages" }}
    centered={true}
  />

  <!-- AI citability snippet -->
  <div class="smb-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> builds custom websites for Auckland small businesses from <strong>$1,290 + GST</strong>, on WordPress or a fully custom platform, depending on your needs. Most projects go live in <strong>2–3 weeks</strong>. Every website includes mobile-first design, SEO foundations, contact form, Google Analytics, and a handover training session. Growth packages from $2,690. eCommerce from $3,890. Fixed quotes upfront, no surprises. Based in Grey Lynn, Auckland, 4.9★ Google rating from 50+ NZ clients.</p>
    </div>
  </div>

  <!-- Stats -->
  <StatsRow items={stats} />

  <!-- What's included -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="What's Included"
        title="Everything your business needs. Nothing you don't."
        subtitle="Every website we build includes these fundamentals, because cutting corners costs you leads."
      />
      <ServiceGrid items={included} cols={3} />
    </div>
  </section>

  <!-- Visual break, who we help -->
  <section class="sbwd-who-section">
    <div class="sbwd-who-img-wrap">
      <Image src={smallBizAuckland} alt="Auckland small business owner at work, the kind of business we build websites for" width={800} height={560} class="sbwd-who-img" />
    </div>
    <div class="sbwd-who-content">
      <p class="sbwd-who-eyebrow">Built for Auckland</p>
      <h2 class="sbwd-who-title">Your customers are searching online. Are you showing up?</h2>
      <p class="sbwd-who-body">Most small business websites in Auckland are losing leads every day, slow, outdated, or just hard to find. We build websites that rank on Google, load fast, and turn visitors into enquiries. Whether you're a café, a tradie, or a professional service, the result is the same: more customers.</p>
      <a href="/website-designer-auckland/" class="sbwd-who-cta">Get a Free Quote →</a>
    </div>
  </section>

  <!-- Industries -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="Industries We Serve"
        title="We know your industry. We know what converts."
        light={true}
      />
      <div class="sbwd-industries">
        {industries.map(({ icon, title, desc, href }) => (
          <a href={href} class="sbwd-ind-card">
            <span class="sbwd-ind-icon"><Icon name={icon} size={26} /></span>
            <div>
              <strong class="sbwd-ind-title">{title}</strong>
              <p class="sbwd-ind-desc">{desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section sbwd-process-section">
    <div class="container">
      <div class="sbwd-process-split">
        <div class="sbwd-process-content">
          <SectionHeader
            eyebrow="How It Works"
            title="Simple process. Predictable results."
            subtitle="We keep things clear and collaborative, you always know what's happening and what's next."
          />
          <ProcessSteps items={process} />
        </div>
        <div class="sbwd-process-img-wrap">
          <Image src={about1} alt="Charlie Chao consulting with an Auckland small business owner on their website strategy" width={600} height={700} class="sbwd-process-img" />
          <div class="sbwd-process-img-pill">Free in-person consult · Auckland-based</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Web design visual -->
  <section class="sbwd-info-split section">
    <div class="container">
      <div class="sbwd-info-img-wrap">
        <Image src={webSolutions} alt="Web designer building an Auckland small business website" width={1200} height={480} class="sbwd-info-img" />
        <div class="sbwd-info-img-badge">
          <span class="sbwd-info-badge-num">2–3 wks</span>
          <span class="sbwd-info-badge-label">avg. delivery</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Packages -->
  <section class="section" style="background: var(--kwd-cream);" id="packages">
    <div class="container">
      <SectionHeader
        eyebrow="Packages & Pricing"
        title="Transparent pricing. No hidden extras."
        subtitle="Fixed-price quotes before we start. You'll always know the total cost."
      />
      <div class="sbwd-packages">
        {packages.map((pkg) => (
          <div class:list={['sbwd-pkg', pkg.highlight && 'sbwd-pkg--featured']}>
            {pkg.tag && <span class="sbwd-pkg-tag">{pkg.tag}</span>}
            <p class="sbwd-pkg-name">{pkg.name}</p>
            <div class="sbwd-pkg-price-wrap">
              <span class="sbwd-pkg-price">{pkg.price}</span>
              <span class="sbwd-pkg-note">{pkg.note}</span>
            </div>
            <p class="sbwd-pkg-desc">{pkg.desc}</p>
            <ul class="sbwd-pkg-list">
              {pkg.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            <a href={pkg.href} class:list={['sbwd-pkg-btn', pkg.highlight && 'sbwd-pkg-btn--featured']}>{pkg.cta}</a>
          </div>
        ))}
      </div>
      <p class="sbwd-pkg-note-bottom">All prices exclude GST. Custom quotes available for larger or complex projects. <a href="/website-designer-auckland/">Get in touch →</a> or <a href="/affordable-web-design-auckland/website-cost-new-zealand-small-business/">try our free website cost calculator</a> to estimate your budget.</p>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section sbwd-testimonials-section">
    <div class="sbwd-testimonials-photo">
      <Image src={about2} alt="Kiwi Web Design Auckland, helping small businesses grow online" width={1400} height={480} class="sbwd-tp-img" />
      <div class="sbwd-tp-overlay">
        <blockquote class="sbwd-tp-quote">
          "From the first call, Charlie understood exactly what we needed. The site was live in 2 weeks and we got our first enquiry the day after launch."
          <cite>- Zane Barrett, Barrett Access Scaffolding</cite>
        </blockquote>
      </div>
    </div>
    <div class="container">
      <SectionHeader eyebrow="Client Reviews" title="What Auckland small businesses say about us." />
      <TestimonialGrid items={reviews} cols={2} />
    </div>
  </section>

  <!-- Auckland café photo strip -->
  <div class="sbwd-cafe-strip">
    <Image src={aucklandCafe} alt="Auckland small business, the kind of local business we help grow online" width={1400} height={420} class="sbwd-cafe-img" />
    <div class="sbwd-cafe-overlay">
      <p class="sbwd-cafe-tag">Serving Auckland businesses since 2019</p>
      <p class="sbwd-cafe-line">From Grey Lynn cafés to North Shore tradies, we build websites that work.</p>
    </div>
  </div>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Web Design Questions Answered"
        subtitle="Common questions from Auckland small business owners before getting started."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/tradie-website-design-auckland/" class="rps-link">Tradie Websites</a>
        <a href="/ecommerce-website-auckland/" class="rps-link">eCommerce Websites</a>
        <a href="/woocommerce-website-design-auckland/" class="rps-link">WooCommerce Design</a>
        <a href="/shopify-website-design-auckland/" class="rps-link">Shopify Design</a>
        <a href="/website-copywriting-auckland/" class="rps-link">Website Copywriting</a>
        <a href="/website-design-process-in-auckland/" class="rps-link">Our Design Process</a>
      </div>
    </div>
  </section>

  <!-- Case studies -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Client case studies</p>
      <div class="rps-links">
        <a href="/case-study-scaffolding/" class="rps-link">Barrett Access Scaffolding, +125% quote requests</a>
        <a href="/beauty-touch-case-study/" class="rps-link">Beauty Touch Auckland, live in 3 weeks</a>
      </div>
    </div>
  </section>

  <!-- Areas we serve -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Areas we serve</p>
      <div class="rps-links">
        <a href="/north-shore-website-design/" class="rps-link">North Shore</a>
        <a href="/south-auckland-web-design/" class="rps-link">South Auckland</a>
        <a href="/west-auckland-web-design/" class="rps-link">West Auckland</a>
        <a href="/east-auckland-web-design/" class="rps-link">East Auckland</a>
        <a href="/central-auckland-web-design/" class="rps-link">Central Auckland</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to get a website that generates leads?"
    subtitle="Free consultation, in person or online, Auckland-wide. Call 021 039 6580 or request a quote below."
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "Learn About SEO Too", href: "/affordable-seo-auckland/" }}
  />

</Layout>

<style>
  /* Industries grid */
  .sbwd-industries {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .sbwd-ind-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 1.5rem;
    text-decoration: none;
