];

const faqs = [
  {
    q: "How much does affordable web design in Auckland cost?",
    a: "At Kiwi Web Design, websites for Auckland tradies and small businesses start from $1,290. Packages include a modern WordPress site, mobile-friendly design, and essential features to help you get found online.",
  },
  {
    q: "What's included in your affordable website packages?",
    a: "Our packages cover design, setup, basic SEO, contact forms, and hosting integration. You also get a free in-person consultation anywhere in Auckland so we can plan your site around your business needs.",
  },
  {
    q: "How long will it take to build my website?",
    a: "Most affordable web design projects are completed in 2–3 weeks. Timeframes depend on how quickly content and photos are provided, but we keep the process simple for busy Auckland business owners.",
  },
  {
    q: "Do you only work with tradies?",
    a: "No, while tradies are our specialty, we design websites for a wide range of Auckland small businesses, from retail to professional services.",
  },
  {
    q: "Can you redesign my current website?",
    a: "Yes. We often move Auckland businesses from older platforms like Wix or Squarespace to WordPress. This improves speed, flexibility, and SEO while keeping costs affordable.",
  },
  {
    q: "Do you offer ongoing support once the website is live?",
    a: "Absolutely. We provide training, hosting support, and affordable monthly maintenance plans so your site stays secure and up to date.",
  },
  {
    q: "Can you add e-commerce or booking features?",
    a: "Absolutely. Whether you're launching an online store or need bookings, memberships, or inventory management, we can build a fully tailored solution. Leveraging our AI‑first workflows, we integrate secure payment gateways, shopping carts, and any custom functionality your business requires — all at affordable costs.",
  },
  {
    q: "Can you help with SEO as well as web design?",
    a: "Definitely. We offer an affordable SEO add-on for local rankings and ongoing growth.",
  },
  {
    q: "Do you provide free in-person consultation?",
    a: "Yes. We can meet with you in person for free to discuss your website needs, if you are based in Auckland. Outside Auckland, we can provide free consultation through phone, email or online meetings.",
  },
  {
    q: "How can you provide such affordable prices without sacrificing quality and services?",
    a: "We're affordable — not cheap. We never compromise on quality. By embracing an AI-first approach in everything we do, we've built a streamlined, highly efficient workflow. This allows us to deliver the same (or better) results as traditional agencies at a fraction of the cost. We simply pass those savings directly on to you.",
  },
  {
    q: "Why choose your agency over other Auckland providers?",
    a: "We offer free in-person or online consultations before you commit to anything. We combine AI-driven efficiency with local Auckland knowledge. Get premium-looking, fully-customised websites at up to 50–70% lower cost. Enjoy transparent pricing, fast turnaround, and full support. We pass the savings directly to you — no hidden fees, no compromises.",
  },
];
---

<Layout
  title="Affordable Web Design in Auckland for Small Businesses"
  description="Affordable web design in Auckland for tradies and small businesses. WordPress packages from $1,290, free in-person consults, delivery in 2 to 3 weeks."
  canonicalURL="https://www.kiwiwebdesign.co.nz/small-business-website-design-auckland/"
  schema={schema}
>

  <!-- Hero -->
  <section class="hero section-dark">
    <div class="container">
      <h1>Affordable Website Design Auckland</h1>
      <p class="subheading">Servicing Auckland wide, including Rodney, Waitakere, Northshore, Auckland CBD, East and South Auckland. Affordable package from $1,290.</p>
      <a href="/website-designer-auckland/" class="btn-primary">Free Consultation</a>
    </div>
  </section>

  <!-- Why Small Businesses Choose Us + office image -->
  <section class="section section-dark hero-panels">
    <div class="container panels-grid">
      <div class="panel-image">
        <img
          src="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/09/office1-1024x683.jpg"
          alt="Kiwi Web Design Auckland office"
          width="1024"
          height="683"
          loading="lazy"
        />
      </div>
      <div class="panel-text">
        <h2>Why Small Businesses Choose Us</h2>
        <p>A professional website helps your business get found, build trust, and win new customers. At Kiwi Web Design, we create affordable, high-quality website designs in Auckland that are designed for small businesses across Auckland and New Zealand. Our goal is to make it simple for you to showcase your services, attract local customers, and grow online without unnecessary costs. We offer free in-person consultations for Auckland businesses.</p>
        <a href="/website-designer-auckland/" class="btn-primary">Book Now</a>
      </div>
    </div>
  </section>

  <!-- What's Included + office image -->
  <section class="section section-dark hero-panels">
    <div class="container panels-grid panels-grid-reverse">
      <div class="panel-text">
        <h2>What's Included</h2>
        <p>When you choose our affordable business website design package, you'll get:</p>
        <ul class="included-list">
          {included.map((item) => <li>{item}</li>)}
        </ul>
        <a href="/website-designer-auckland/" class="btn-primary">Book Now</a>
      </div>
      <div class="panel-image">
        <img
          src="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/09/office2-1024x683.jpg"
          alt="Website design consultation in Auckland"
          width="1024"
          height="683"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Industries We Work With -->
  <section class="section section-cream">
    <div class="container">
      <h2>Industries We Work With</h2>
      <p class="section-intro">Build effective websites, SEO and Google Ads to help Auckland small businesses generate leads.</p>
      <div class="industries-grid">
        {industries.map(({ name, img, imgAlt, desc, link }) => (
          <div class="industry-card">
            <a href={link}>
              <img src={img} alt={imgAlt} width="586" height="391" loading="lazy" class="industry-img" />
            </a>
            <div class="industry-body">
              <h3>{name}</h3>
              <p>{desc}</p>
              <a href={link} class="learn-more">Learn more →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How We Do It -->
  <section class="section section-dark">
    <div class="container">
      <h2>How We Do It</h2>
      <div class="how-grid">
        {howWeDoIt.map(({ icon, title, desc }) => (
          <div class="how-card">
            <div class="how-icon">{icon}</div>
            <h3>{title}</h3>
            <p>{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="section">
    <div class="container">
      <h2>Our Process for Auckland Businesses</h2>
      <p class="section-intro">A simple three-step path made for Auckland businesses. We start with a discovery call, build on WordPress, then review and launch. Clear, quick, and focused on results.</p>
      <div class="process-steps">
        {steps.map(({ num, title, sub, desc, points, deliverables, duration, cta, ctaHref }) => (
          <div class="process-step">
            <div class="step-header">
              <span class="step-num">{num}</span>
              <div>
                <div class="step-title">{title}</div>
                <div class="step-sub">{sub}</div>
              </div>
            </div>
            <div class="step-body">
              <div class="step-main">
                <h3>Step {num}: {title}</h3>
                <p>{desc}</p>
                <ul class="step-points">
                  {points.map((p) => <li>{p}</li>)}
                </ul>
              </div>
              <div class="step-card">
                <strong>Deliverables</strong>
                <ul class="deliverables-list">
                  {deliverables.map((d) => <li>{d}</li>)}
                </ul>
              </div>
            </div>
            <div class="step-footer">
              <a href={ctaHref} class="btn-primary">{cta}</a>
              <span class="step-duration">Typical duration: {duration}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="process-trust">
        <span class="trust-check">✓</span>
        <div>
          <strong>Made for Auckland</strong><br />
          <span>Clear communication, quick turnarounds, and friendly support for Auckland businesses.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-cream">
    <div class="container">
      <h2>FAQ</h2>
      <div class="faq-list">
        {faqs.map(({ q, a }) => (
          <details class="faq-item">
            <summary>{q}</summary>
            <p>{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Regional links -->
  <section class="section">
    <div class="container">
      <h2>Serving All of Auckland</h2>
      <ul class="region-list">
        <li><a href="/north-shore-website-design/">North Shore</a></li>
        <li><a href="/west-auckland-web-design/">West Auckland</a></li>
        <li><a href="/central-auckland-web-design/">Central Auckland</a></li>
        <li><a href="/east-auckland-web-design/">East Auckland</a></li>
        <li><a href="/south-auckland-web-design/">South Auckland</a></li>
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-dark text-center">
    <div class="container">
      <h2>Ready for an affordable website that actually works?</h2>
      <a href="/website-designer-auckland/" class="btn-primary">Book a Free Consultation</a>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero { padding: 5rem 0 3rem; }
  .hero h1 { color: var(--kwd-white); }
  .subheading {
    font-family: var(--kwd-font-body);
    font-size: 1.05rem;
    font-weight: 400;
    color: rgba(255,255,255,0.75);
    max-width: 680px;
    margin-bottom: 2rem;
  }

  /* Hero panels (Why Choose Us + What's Included) */
  .hero-panels { padding-top: 0; }
  .panels-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
    align-items: center;
  }
  .panels-grid-reverse {
    grid-template-columns: 1fr 2fr;
  }
  .panel-image img {
    width: 100%;
    height: 320px;
    object-fit: cover;
    border-radius: 8px;
    display: block;
  }
  .panel-text h2 { color: var(--kwd-white); margin-bottom: 1rem; }
  .panel-text p { color: rgba(255,255,255,0.8); margin-bottom: 1.5rem; }

  /* Included list */
  .included-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: grid;
    gap: 0.6rem;
  }
  .included-list li {
    padding-left: 1.5rem;
    position: relative;
    color: rgba(255,255,255,0.85);
    font-size: 0.95rem;
  }
  .included-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--kwd-yellow);
    font-weight: 700;
  }

  /* Industries */
  .section-intro {
    color: var(--kwd-brown);
    margin-bottom: 2rem;
    max-width: 640px;
  }
  .industries-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .industry-card {
    background: var(--kwd-white);
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
  }
  .industry-img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }
  .industry-body {
    padding: 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .industry-body h3 { font-size: 1rem; margin-bottom: 0.5rem; }
  .industry-body p { font-size: 0.875rem; color: var(--kwd-brown); margin-bottom: 1rem; flex: 1; }
  .learn-more { font-size: 0.875rem; font-weight: 600; color: var(--kwd-dark); }

  /* How We Do It */
  .how-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .how-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 10px;
    padding: 1.75rem 1.5rem;
  }
  .how-icon { font-size: 2rem; margin-bottom: 0.75rem; }
  .how-card h3 { color: var(--kwd-yellow); font-size: 1rem; margin-bottom: 0.5rem; }
  .how-card p { color: rgba(255,255,255,0.75); font-size: 0.9rem; }

  /* Process */
  .process-steps {
    display: grid;
    gap: 2rem;
    margin-top: 2.5rem;
  }
  .process-step {
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 12px;
    padding: 2rem;
    background: var(--kwd-white);
  }
  .step-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  .step-num {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--kwd-dark);
    color: var(--kwd-yellow);
    font-weight: 800;
    font-size: 1.1rem;
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }
  .step-title { font-weight: 700; font-size: 1.05rem; }
  .step-sub { font-size: 0.85rem; color: var(--kwd-brown); }
  .step-body {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2rem;
    margin-bottom: 1.5rem;
  }
  .step-main h3 { margin-bottom: 0.75rem; }
  .step-main p { color: var(--kwd-brown); margin-bottom: 1rem; }
  .step-points {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }
  .step-points li {
    padding-left: 1.4rem;
    position: relative;
    font-size: 0.9rem;
  }
  .step-points li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--kwd-brown);
    font-weight: 700;
  }
  .step-card {
    background: var(--kwd-cream);
    border-radius: 8px;
    padding: 1.25rem;
    align-self: start;
  }
  .step-card strong { display: block; margin-bottom: 0.75rem; }
  .deliverables-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }
  .deliverables-list li {
    padding-left: 1.4rem;
    position: relative;
    font-size: 0.875rem;
    color: var(--kwd-brown);
  }
  .deliverables-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--kwd-dark);
  }
  .step-footer {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(0,0,0,0.08);
  }
