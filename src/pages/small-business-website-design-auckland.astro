---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import StatsRow from '../components/StatsRow.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import TestimonialGrid from '../components/TestimonialGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/small-business-website-design-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/small-business-website-design-auckland/",
      "name": "Affordable Web Design in Auckland for Small Businesses",
      "description": "Affordable web design in Auckland for tradies and small businesses. WordPress packages from $1,290, free in-person consults, delivery in 2 to 3 weeks.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/small-business-website-design-auckland/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/small-business-website-design-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Small Business Web Design Auckland" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const stats = [
  { number: "From $1,290", label: "One-time website packages" },
  { number: "2–3 wks", label: "Typical delivery time" },
  { number: "50+", label: "Auckland businesses helped" },
  { number: "4.9★", label: "Average Google rating" },
];

const included = [
  {
    icon: "🎨",
    title: "Custom Design",
    desc: "No cookie-cutter templates. Your website is designed around your brand, your customers, and your goals — so it looks and feels like you.",
    items: ["Brand-matched colours & fonts", "Mobile-first layouts", "Modern, clean aesthetics", "Competitor differentiation"],
  },
  {
    icon: "⚡",
    title: "Built on WordPress",
    desc: "WordPress powers 43% of the web. It's reliable, flexible, and easy for you to update. No lock-in, no proprietary systems you can't control.",
    items: ["Easy content editing", "Plugin ecosystem", "WooCommerce ready", "Scales as you grow"],
  },
  {
    icon: "🔍",
    title: "SEO-Ready From Day One",
    desc: "Every page we build is structured for search engines. Speed, mobile performance, schema markup, and proper heading structure — all standard.",
    items: ["Fast page speed", "Proper meta tags", "Schema markup", "Google Search Console setup"],
  },
  {
    icon: "📱",
    title: "Mobile Optimised",
    desc: "Over 60% of your traffic is on mobile. We build mobile-first and test across devices so your site works perfectly on every screen.",
    items: ["Responsive layouts", "Touch-friendly navigation", "Mobile page speed", "Cross-device testing"],
  },
  {
    icon: "🔒",
    title: "Secure & Reliable",
    desc: "SSL certificates, regular backups, security hardening, and managed hosting. We handle the technical side so you can focus on your business.",
    items: ["SSL included", "Daily backups", "Uptime monitoring", "WordPress security hardening"],
  },
  {
    icon: "📞",
    title: "Lead-Generation Focus",
    desc: "Your website should be working for you 24/7. We design with clear calls-to-action, fast-loading pages, and conversion-tested layouts.",
    items: ["CTA strategy", "Contact form setup", "Click-to-call integration", "Enquiry tracking"],
  },
];

const industries = [
  { icon: "🔧", title: "Tradies", desc: "Plumbers, electricians, builders, painters. We know what converts for trade businesses in Auckland.", href: "/tradie-website-design-auckland/" },
  { icon: "💆", title: "Beauty & Wellness", desc: "Salons, spas, clinics. Booking-integrated sites that showcase your services and keep the chair full.", href: "/how-kiwi-web-design-helps-auckland-beauty-industry/" },
  { icon: "🍽️", title: "Restaurants & Cafés", desc: "Menu pages, booking links, Google Maps integration. Hungry customers find you first.", href: "/how-kiwi-web-design-helps-auckland-restaurants/" },
  { icon: "⚕️", title: "Healthcare", desc: "Physios, dentists, GPs. HIPAA-aware design with online booking and clear service pages.", href: "/how-kiwi-web-design-helps-auckland-healthcare/" },
  { icon: "⚖️", title: "Professional Services", desc: "Lawyers, accountants, consultants. Authority-building design that wins the trust of new clients.", href: "/how-kiwi-web-design-helps-auckand-lawyers/" },
  { icon: "🛒", title: "eCommerce & Retail", desc: "WooCommerce and Shopify stores built to sell. Product pages, checkout flow, and payment gateway setup.", href: "/ecommerce-website-auckland/" },
];

const process = [
  { step: "1", title: "Free Discovery Call", desc: "We start with a conversation — not a quote. We learn about your business, your customers, and what success looks like for you." },
  { step: "2", title: "Strategy & Wireframe", desc: "We map out the site structure, page layout, and content plan. You approve the direction before any design begins." },
  { step: "3", title: "Design & Build", desc: "We design and build your site in WordPress. You get a staging link to review and request changes before launch." },
  { step: "4", title: "Launch & Handover", desc: "We go live, set up Google Search Console and Analytics, and walk you through how to make basic updates yourself." },
];

const packages = [
  {
    name: "Starter",
    price: "From $1,290",
    note: "+ GST",
    desc: "Perfect for sole traders and small businesses that need a professional online presence fast.",
    items: [
      "Up to 5 pages",
      "Custom WordPress design",
      "Mobile responsive",
      "Contact form",
      "Basic SEO setup",
      "Google Analytics",
      "1 round of revisions",
    ],
    cta: "Get a Quote",
    href: "/website-designer-auckland/",
    highlight: false,
  },
  {
    name: "Growth",
    price: "From $2,490",
    note: "+ GST",
    desc: "For businesses ready to invest in a website that actively generates leads and grows with them.",
    items: [
      "Up to 10 pages",
      "Custom WordPress design",
      "Mobile responsive",
      "Lead-gen conversion setup",
      "Full SEO optimisation",
      "Google Analytics + Search Console",
      "2 rounds of revisions",
      "Booking / enquiry integration",
      "1 month post-launch support",
    ],
    cta: "Get a Quote",
    href: "/website-designer-auckland/",
    highlight: true,
    tag: "Most Popular",
  },
  {
    name: "eCommerce",
    price: "From $3,990",
    note: "+ GST",
    desc: "WooCommerce stores ready to sell. Product management, payment gateway, and order notifications.",
    items: [
      "WooCommerce setup",
      "Up to 20 products",
      "Payment gateway integration",
      "Shipping configuration",
      "Product SEO",
      "Order management training",
      "2 rounds of revisions",
      "2 months post-launch support",
    ],
    cta: "Get a Quote",
    href: "/website-designer-auckland/",
    highlight: false,
  },
];

const faqs = [
  { q: "How much does a website cost for a small business in Auckland?", a: "Our packages start from $1,290 + GST for a 5-page <a href=\"/wordpress-website-design-auckland/\">WordPress website</a>. Growth packages typically run $2,490–$3,500 depending on complexity. eCommerce sites start from $3,990. We give you a fixed quote upfront — no surprises." },
  { q: "How long does it take to build a website?", a: "Most projects are completed in 2–3 weeks from when we receive your content. More complex sites with custom features may take 4–6 weeks. We'll give you a timeline upfront and stick to it. See our full <a href=\"/website-design-process-in-auckland/\">website design process</a> for a step-by-step breakdown." },
  { q: "Do I need to provide content?", a: "Ideally yes — you know your business best. But we help with content guidance, structure, and can write copy for you as an add-on. We also source or licence stock images if needed." },
  { q: "Will I be able to update the website myself?", a: "Yes. WordPress is designed for non-developers. We include a handover session so you can update text, images, and add pages without needing us. We also offer ongoing maintenance plans if you'd prefer we handle it." },
  { q: "Do you offer hosting and maintenance?", a: "Yes. We offer managed WordPress hosting from $49/month and a monthly maintenance plan that includes updates, backups, security, and 2 hours of content changes. Ask us about bundling it with your build." },
  { q: "Can you redesign my existing website?", a: "Yes. We do full WordPress rebuilds, redesigns, and migrations from other platforms (like Wix, Squarespace, or old WordPress themes). We preserve your <a href=\"/seo-auckland/\">SEO</a> and content during the process. After launch, consider adding <a href=\"/local-seo-for-auckland-small-businesses/\">local SEO</a> or <a href=\"/google-ads/\">Google Ads</a> to drive traffic." },
];

const reviews = [
  { name: "Zane Barrett", company: "Barrett Access Scaffolding", text: "From the first call, Charlie understood exactly what we needed. The site was live in 2 weeks and we got our first enquiry the day after launch." },
  { name: "Jack", company: "Show Me Shorts", text: "Really easy to work with. The process was clear, the timeline was met, and the end result looks way better than what we had before." },
  { name: "Steven Liu", company: "Client", text: "Outstanding experience. The design is clean, modern, and user-friendly — exactly what I was hoping for." },
  { name: "Gina Dellabarca", company: "Client", text: "Comprehensive and helpful. Clear information, great communication, and delivered exactly on time." },
];
---

<Layout
  title="Affordable Web Design in Auckland for Small Businesses"
  description="Affordable web design in Auckland for tradies and small businesses. WordPress packages from $1,290, free in-person consults, delivery in 2 to 3 weeks."
  canonicalURL="https://www.kiwiwebdesign.co.nz/small-business-website-design-auckland/"
  schema={schema}
>

  <PageHero
    eyebrow="Small Business Web Design Auckland"
    title="Websites built to generate leads. Not just look good."
    subtitle="Affordable WordPress websites for Auckland small businesses and tradies — from $1,290, delivered in 2–3 weeks, with a free in-person consult."
    badgeText="From $1,290 + GST"
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "View Packages", href: "#packages" }}
    centered={true}
  />

  <!-- Stats -->
  <StatsRow items={stats} />

  <!-- What's included -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="What's Included"
        title="Everything your business needs. Nothing you don't."
        subtitle="Every website we build includes these fundamentals — because cutting corners costs you leads."
      />
      <ServiceGrid items={included} cols={3} />
    </div>
  </section>

  <!-- Industries -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="Industries We Serve"
        title="We know your industry. We know what converts."
        light={true}
      />
      <div class="sbwd-industries">
        {industries.map(({ icon, title, desc, href }) => (
          <a href={href} class="sbwd-ind-card">
            <span class="sbwd-ind-icon">{icon}</span>
            <div>
              <strong class="sbwd-ind-title">{title}</strong>
              <p class="sbwd-ind-desc">{desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="Simple process. Predictable results."
        subtitle="We keep things clear and collaborative — you always know what's happening and what's next."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- Packages -->
  <section class="section" style="background: var(--kwd-cream);" id="packages">
    <div class="container">
      <SectionHeader
        eyebrow="Packages & Pricing"
        title="Transparent pricing. No hidden extras."
        subtitle="Fixed-price quotes before we start. You'll always know the total cost."
      />
      <div class="sbwd-packages">
        {packages.map((pkg) => (
          <div class:list={['sbwd-pkg', pkg.highlight && 'sbwd-pkg--featured']}>
            {pkg.tag && <span class="sbwd-pkg-tag">{pkg.tag}</span>}
            <p class="sbwd-pkg-name">{pkg.name}</p>
            <div class="sbwd-pkg-price-wrap">
              <span class="sbwd-pkg-price">{pkg.price}</span>
              <span class="sbwd-pkg-note">{pkg.note}</span>
            </div>
            <p class="sbwd-pkg-desc">{pkg.desc}</p>
            <ul class="sbwd-pkg-list">
              {pkg.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            <a href={pkg.href} class:list={['sbwd-pkg-btn', pkg.highlight && 'sbwd-pkg-btn--featured']}>{pkg.cta}</a>
          </div>
        ))}
      </div>
      <p class="sbwd-pkg-note-bottom">All prices exclude GST. Custom quotes available for larger or complex projects. <a href="/website-designer-auckland/">Get in touch →</a></p>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section">
    <div class="container">
      <SectionHeader eyebrow="Client Reviews" title="What Auckland small businesses say about us." />
      <TestimonialGrid items={reviews} cols={2} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Web Design Questions Answered"
        subtitle="Common questions from Auckland small business owners before getting started."
      />
    </div>
  </section>

  <!-- Industries we serve -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Industries we serve</p>
      <div class="rps-links">
        <a href="/tradie-website-design-auckland/" class="rps-link">Tradies</a>
        <a href="/how-kiwi-web-design-helps-auckland-beauty-industry/" class="rps-link">Beauty &amp; Wellness</a>
        <a href="/how-kiwi-web-design-helps-auckland-restaurants/" class="rps-link">Restaurants &amp; Cafés</a>
        <a href="/how-kiwi-web-design-helps-auckland-healthcare/" class="rps-link">Healthcare</a>
        <a href="/how-kiwi-web-design-helps-auckand-lawyers/" class="rps-link">Lawyers &amp; Professional Services</a>
        <a href="/industries-we-serve-in-auckland/" class="rps-link">All Industries →</a>
      </div>
    </div>
  </section>

  <!-- Areas we serve -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Areas we serve</p>
      <div class="rps-links">
        <a href="/central-auckland-web-design/" class="rps-link">Central Auckland</a>
        <a href="/north-shore-website-design/" class="rps-link">North Shore</a>
        <a href="/west-auckland-web-design/" class="rps-link">West Auckland</a>
        <a href="/east-auckland-web-design/" class="rps-link">East Auckland</a>
        <a href="/south-auckland-web-design/" class="rps-link">South Auckland</a>
      </div>
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/tradie-website-design-auckland/" class="rps-link">Tradie Websites</a>
        <a href="/ecommerce-website-auckland/" class="rps-link">eCommerce Websites</a>
        <a href="/woocommerce-website-design-auckland/" class="rps-link">WooCommerce Design</a>
        <a href="/shopify-website-design-auckland/" class="rps-link">Shopify Design</a>
        <a href="/website-copywriting-auckland/" class="rps-link">Website Copywriting</a>
        <a href="/website-design-process-in-auckland/" class="rps-link">Our Design Process</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to get a website that generates leads?"
    subtitle="Free consultation — we'll give you honest advice and a fixed quote before we start."
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "Learn About SEO Too", href: "/seo-auckland/" }}
  />

</Layout>

<style>
  /* Industries grid */
  .sbwd-industries {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .sbwd-ind-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 1.5rem;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .sbwd-ind-card:hover {
    background: rgba(255,255,255,0.11);
    border-color: rgba(255,255,255,0.2);
  }
  .sbwd-ind-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
    width: 2.5rem;
    text-align: center;
  }
  .sbwd-ind-title {
    display: block;
    font-size: 0.95rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.3rem;
  }
  .sbwd-ind-desc {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.55;
    margin: 0;
  }

  /* Packages */
  .sbwd-packages {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
    margin-top: 2.5rem;
  }
  .sbwd-pkg {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.08);
    border-radius: 18px;
    padding: 2rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .sbwd-pkg--featured {
    background: var(--kwd-dark);
    border-color: var(--kwd-dark);
  }
  .sbwd-pkg-tag {
    display: inline-block;
    background: var(--kwd-yellow);
    color: var(--kwd-dark);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 1rem;
    align-self: flex-start;
  }
  .sbwd-pkg-name {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--kwd-brown);
    margin: 0 0 0.5rem;
  }
  .sbwd-pkg--featured .sbwd-pkg-name { color: rgba(255,255,255,0.5); }
  .sbwd-pkg-price-wrap {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
  }
  .sbwd-pkg-price {
    font-family: var(--kwd-font-heading);
    font-size: 2rem;
    color: var(--kwd-dark);
    line-height: 1;
  }
  .sbwd-pkg--featured .sbwd-pkg-price { color: var(--kwd-yellow); }
  .sbwd-pkg-note {
    font-size: 0.8rem;
    color: var(--kwd-brown);
  }
  .sbwd-pkg--featured .sbwd-pkg-note { color: rgba(255,255,255,0.45); }
  .sbwd-pkg-desc {
    font-size: 0.85rem;
    color: var(--kwd-brown);
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }
  .sbwd-pkg--featured .sbwd-pkg-desc { color: rgba(255,255,255,0.6); }
  .sbwd-pkg-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .sbwd-pkg-list li {
    font-size: 0.85rem;
    color: var(--kwd-dark);
    padding-left: 1.3rem;
    position: relative;
  }
  .sbwd-pkg-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--kwd-brown);
    font-weight: 700;
  }
  .sbwd-pkg--featured .sbwd-pkg-list li { color: rgba(255,255,255,0.8); }
  .sbwd-pkg--featured .sbwd-pkg-list li::before { color: var(--kwd-yellow); }
  .sbwd-pkg-btn {
    display: block;
    text-align: center;
    padding: 0.875rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--kwd-cream);
    color: var(--kwd-dark);
    transition: background 0.2s;
  }
  .sbwd-pkg-btn:hover { background: #e8e7da; }
  .sbwd-pkg-btn--featured {
    background: var(--kwd-yellow);
    color: var(--kwd-dark);
  }
  .sbwd-pkg-btn--featured:hover { background: var(--kwd-gold); }
  .sbwd-pkg-note-bottom {
    text-align: center;
    font-size: 0.82rem;
    color: var(--kwd-brown);
    margin-top: 1.5rem;
  }
  .sbwd-pkg-note-bottom a { color: var(--kwd-dark); font-weight: 600; }

  @media (max-width: 960px) {
    .sbwd-industries { grid-template-columns: repeat(2, 1fr); }
    .sbwd-packages { grid-template-columns: 1fr; max-width: 480px; margin-inline: auto; }
  }
  @media (max-width: 600px) {
    .sbwd-industries { grid-template-columns: 1fr; }
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>

<!-- Vanta.js NET background for hero -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/vanta@0.5.24/dist/vanta.net.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    VANTA.NET({
      el: '.hero-section',
      mouseControls: true,
      touchControls: true,
      gyroControls: false,
      minHeight: 200,
      minWidth: 200,
      scale: 1.0,
      scaleMobile: 0.75,
      color: 0xf3d97a,
      backgroundColor: 0x2c2927,
      points: 9,
      maxDistance: 22,
      spacing: 17,
    });
  });
</script>
