---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import heroImg from '../assets/general/about3.jpg';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/wordpress-plugins-for-small-businesses-in-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/wordpress-plugins-for-small-businesses-in-auckland/",
      "name": "WordPress Plugins for Auckland Small Businesses | Kiwi Web Design",
      "description": "We choose and configure the right WordPress plugins for your Auckland business — security, SEO, performance, and forms — without the bloat.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/wordpress-plugins-for-small-businesses-in-auckland/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/wordpress-plugins-for-small-businesses-in-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "WordPress Plugins for Small Businesses Auckland" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const pluginCategories = [
  {
    icon: "🔒",
    title: "Security",
    desc: "Wordfence or Sucuri for firewall, malware scanning, and login protection. Every site we build leaves with a security plugin properly configured.",
    items: ["Wordfence / Sucuri", "Firewall rules", "Login protection", "Malware scanning"],
  },
  {
    icon: "🔍",
    title: "SEO",
    desc: "Yoast SEO or RankMath to manage page titles, meta descriptions, schema markup, and sitemaps — giving search engines the information they need to rank your site.",
    items: ["Yoast SEO / RankMath", "Page meta editing", "Schema markup", "XML sitemap"],
  },
  {
    icon: "⚡",
    title: "Performance & Caching",
    desc: "WP Rocket or LiteSpeed Cache to speed up page load times — compressing files, caching pages, and reducing requests to the server.",
    items: ["WP Rocket / LiteSpeed", "Page caching", "Image lazy loading", "Minification"],
  },
  {
    icon: "📋",
    title: "Forms",
    desc: "WPForms or Gravity Forms for contact, quote, and enquiry forms. Properly configured with spam protection, email notifications, and entry logging.",
    items: ["WPForms / Gravity Forms", "reCAPTCHA spam protection", "Email notifications", "Entry logging"],
  },
  {
    icon: "💾",
    title: "Backups",
    desc: "UpdraftPlus or BackupBuddy for automated daily backups stored offsite — so you can recover quickly from any problem.",
    items: ["UpdraftPlus / BackupBuddy", "Automated scheduling", "Offsite storage", "One-click restore"],
  },
  {
    icon: "📊",
    title: "Analytics Integration",
    desc: "GA4 and Google Tag Manager connected properly — tracking pageviews, conversions, and custom events without slowing the site down.",
    items: ["GA4 integration", "Google Tag Manager", "Conversion event setup", "Lightweight implementation"],
  },
];

const faqs = [
  { q: "How many plugins should a WordPress site have?", a: "As few as needed to do what the site requires. More plugins means more potential conflicts, more attack surface, and slower load times. On a typical small business site, we use 8–12 plugins — each chosen for a specific, necessary purpose. We avoid plugin bloat." },
  { q: "Are free plugins safe to use?", a: "Many of the best WordPress plugins are free — Yoast, Wordfence, and UpdraftPlus are all free in their core versions. Safety depends on whether a plugin is actively maintained, has a large user base, and has a good security track record. We don't install plugins with poor reputations or that haven't been updated recently." },
  { q: "What should I do when I see a plugin update notification?", a: "Update plugins regularly — but not without checking first. Occasional updates can conflict with your theme or other plugins. If you're on a maintenance plan, we handle updates for you, testing on a staging environment first. If you're managing updates yourself, we recommend updating one at a time and checking your site after each." },
  { q: "Can you audit the plugins on an existing site?", a: "Yes. We can audit your current plugin setup, identify anything that's outdated, insecure, poorly maintained, or redundant, and recommend replacements or removals. A bloated plugin stack is one of the most common causes of slow and vulnerable WordPress sites. If you're starting fresh, see our <a href=\"/small-business-website-design-auckland/\">web design packages</a> which include a fully configured plugin stack from day one." },
  { q: "Do I need a premium plugin or will the free version do?", a: "Depends on the plugin and your needs. For most small business sites, free versions of security, SEO, and backup plugins are sufficient. Premium versions typically add features like advanced reporting, priority support, or automation. We'll tell you honestly whether a paid upgrade is worth it for your situation." },
];
---

<Layout
  title="WordPress Plugins for Auckland Small Businesses | Kiwi Web Design"
  description="We choose and configure the right WordPress plugins for your Auckland business — security, SEO, performance, and forms — without the bloat."
  canonicalURL="https://www.kiwiwebdesign.co.nz/wordpress-plugins-for-small-businesses-in-auckland/"
  schema={schema}
>

  <PageHero
    eyebrow="WordPress Plugins"
    title="The right plugins — properly configured, nothing wasted."
    subtitle="We choose and set up the plugins your Auckland business site actually needs: security, SEO, caching, forms, and backups — configured correctly, not just installed."
    imgSrc={heroImg.src}
    imgAlt="WordPress plugins configured for Auckland small business websites"
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View Web Design Services", href: "/small-business-website-design-auckland/" }}
  />

  <!-- Plugin categories -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="Essential Plugin Categories"
        title="What every Auckland business site needs."
        subtitle="These are the plugin categories we configure on every build — and why each one matters."
      />
      <ServiceGrid items={pluginCategories} cols={3} />
    </div>
  </section>

  <!-- Philosophy -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <SectionHeader
        eyebrow="Our Approach"
        title="Fewer plugins, better chosen."
        align="left"
      />
      <div class="plugins-body">
        <p>Most over-plugged WordPress sites have the same problems: slow load times, plugin conflicts that break things on updates, and security vulnerabilities from abandoned plugins nobody removed.</p>
        <p>We take a minimal, intentional approach. Every plugin on a <a href="/wordpress-website-design-auckland/">WordPress site we build</a> has a specific job. We avoid plugins that duplicate functionality, haven't been updated recently, or come from developers with poor security track records.</p>
        <p>We also configure each plugin properly. A security plugin installed but never configured is useless. A caching plugin left on default settings may not make much difference. Configuration is where the value actually comes from. Plugin management is also a core part of our <a href="/wordpress-maintenance-auckland/">WordPress maintenance plans</a> — we handle updates and monitor for conflicts so you don't have to.</p>
        <ul class="plugins-checklist">
          <li>8–12 plugins on a typical small business site</li>
          <li>Every plugin configured, not just activated</li>
          <li>Audits available for existing sites with too many plugins</li>
          <li>Plugin updates managed in our maintenance plans</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="WordPress Plugin Questions"
        subtitle="Common questions from Auckland business owners about WordPress plugins."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress Design</a>
        <a href="/wordpress-maintenance-auckland/" class="rps-link">WordPress Maintenance</a>
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design Packages</a>
        <a href="/wordpress-seo-optimisation/" class="rps-link">WordPress SEO</a>
        <a href="/wordpress-themes-for-auckland-small-businesses/" class="rps-link">WordPress Themes</a>
        <a href="/wordpress-ai-tools-integration-auckland/" class="rps-link">AI Tools Integration</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Is your site weighed down by too many plugins?"
    subtitle="Free consultation — we'll audit your current setup and tell you what's helping, what's hurting, and what to do about it."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View Maintenance Plans", href: "/wordpress-maintenance-auckland/" }}
  />

</Layout>

<style>
  .plugins-body p {
    font-size: 0.9375rem;
    color: var(--kwd-brown);
    line-height: 1.75;
    margin-bottom: 0.9rem;
  }
  .plugins-checklist {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .plugins-checklist li {
    font-size: 0.9rem;
    color: var(--kwd-dark);
    font-weight: 600;
    padding-left: 1.5rem;
    position: relative;
  }
  .plugins-checklist li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--kwd-brown);
    font-weight: 700;
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
