---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import StatsRow from '../components/StatsRow.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import PageVisual from '../components/PageVisual.astro';
import gbpImage from '../assets/services/google-business-profile-setup-optimisation-auckland.png';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/google-business-profile-guide-for-auckland-businesses/",
      "url": "https://www.kiwiwebdesign.co.nz/google-business-profile-guide-for-auckland-businesses/",
      "name": "Google Business Profile Guide for Auckland Businesses | 7-Step Setup",
      "description": "Complete guide to setting up and optimising your Google Business Profile for local visibility in Auckland. Covers categories, NAP, photos, reviews, posts, and tracking.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/google-business-profile-guide-for-auckland-businesses/#breadcrumb" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": [".gbp-snippet", "h1"] }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/google-business-profile-guide-for-auckland-businesses/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Google Business Profile Guide", "item": "https://www.kiwiwebdesign.co.nz/google-business-profile-guide-for-auckland-businesses/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "Place", "name": "Auckland" },
        { "@type": "Place", "name": "New Zealand" }
      ],
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5", "ratingCount": "50", "bestRating": "5" },
      "logo": { "@type": "ImageObject", "url": "https://www.kiwiwebdesign.co.nz/favicon.png", "width": 512, "height": 512 }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Do I need a physical storefront to have a Google Business Profile?", "acceptedAnswer": { "@type": "Answer", "text": "No. Service-area businesses (like tradies, cleaners, or mobile services) can hide their address and instead specify the suburbs or regions they serve. You still appear in local search results for those areas." } },
        { "@type": "Question", "name": "How long does it take to verify a Google Business Profile?", "acceptedAnswer": { "@type": "Answer", "text": "Phone and email verification can be instant. Postcard verification typically takes 5–14 business days. Video verification is available for some business types and is usually same-day." } },
        { "@type": "Question", "name": "Why isn't my business showing up in the Google Maps 3-Pack?", "acceptedAnswer": { "@type": "Answer", "text": "The 3-Pack is determined by relevance, distance, and prominence. Common causes for not appearing are: incomplete profile, wrong primary category, few reviews, no website, or strong competition in your area. A local SEO audit can pinpoint exactly what is holding you back." } },
        { "@type": "Question", "name": "Can I manage multiple locations from one account?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Google Business Profile supports multi-location management. You can manage all your locations from one account, with bulk verification available for businesses with 10 or more locations." } },
        { "@type": "Question", "name": "Should I respond to negative reviews?", "acceptedAnswer": { "@type": "Answer", "text": "Always. A professional, calm response to a negative review often impresses potential customers more than the negative review damages. Acknowledge the issue, apologise if warranted, and offer to resolve it offline. Never argue or be defensive." } },
        { "@type": "Question", "name": "Do you offer Google Business Profile management?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We offer ongoing Google Business Profile management as part of our local SEO service, weekly posts, review response, photo updates, and monthly reporting. It can also be bundled with a website maintenance plan." } }
      ]
    }
  ]
};

const stats = [
  { number: "97%", label: "of consumers use Google to find local businesses" },
  { number: "5×", label: "more views for fully-completed GBP listings vs incomplete ones" },
  { number: "Free", label: "Google Business Profile is completely free to set up" },
  { number: "3-Pack", label: "GBP is the key to appearing in Google Maps top 3" },
];

const steps = [
  {
    num: "01",
    title: "Claim & Verify Your Listing",
    content: `Go to <strong>business.google.com</strong> and search for your business name. If it exists, claim it. If not, create it. You'll need to verify ownership, Google typically sends a postcard with a PIN to your business address, or offers phone/email verification for some businesses.`,
    tips: ["Use your exact legal business name", "Choose the physical address or service area correctly", "Don't use a PO Box as your primary address"],
  },
  {
    num: "02",
    title: "Choose the Right Business Category",
    content: `Your primary category is the most important single field in GBP. It tells Google what searches to show your business for. Be specific, 'Plumber' outperforms 'Contractor'. You can add secondary categories too.`,
    tips: ["Be as specific as possible with your primary category", "Add all relevant secondary categories", "Check what categories top-ranking competitors use", "Avoid generic categories like 'Local Business'"],
  },
  {
    num: "03",
    title: "Complete Every Profile Field",
    content: `Fully completed profiles receive 5× more views. Fill in: business name, address/service area, phone, website, hours, attributes (women-led, wheelchair accessible, etc.), and a keyword-rich business description.`,
    tips: ["Write a 750-character description using key service terms", "Set special hours for public holidays", "Add all relevant attributes for your business type", "Enable messaging if you can respond promptly"],
  },
  {
    num: "04",
    title: "Add Photos & Videos",
    content: `Businesses with photos receive 42% more directions requests and 35% more website clicks. Add: exterior and interior photos, team/staff photos, product or service images, and a cover photo that represents your brand.`,
    tips: ["Minimum 3 photos of each type (exterior, interior, team)", "Name photos with descriptive filenames before uploading", "Add at least one video (even a simple walkthrough)", "Update photos seasonally"],
  },
  {
    num: "05",
    title: "Build & Manage Reviews",
    content: `Reviews are the #1 local ranking factor alongside relevance and distance. More reviews, and a higher average rating, drives more calls and visits. Ask every happy customer for a review, make it easy by sharing your direct review link.`,
    tips: ["Create a short.link to your review page and add it to invoices/receipts", "Respond to every review, positive and negative", "Never incentivise or buy fake reviews", "Aim for a steady drip of reviews, not a burst"],
  },
  {
    num: "06",
    title: "Post Weekly Updates",
    content: `GBP Posts appear in your listing and show Google your business is active. Post about: offers, new services, events, before/after jobs, or just useful tips for your customers. Posts stay live for 7 days (Offers stay longer).`,
    tips: ["Post at least once a week", "Include a photo and a call to action in every post", "Use keywords naturally in post text", "Use Offer posts for time-limited promotions"],
  },
  {
    num: "07",
    title: "Monitor Insights & Calls",
    content: `GBP Insights shows how many people viewed your listing, called your number, got directions, and visited your website. Track these monthly to see what's working and where to focus your optimisation.`,
    tips: ["Check insights monthly", "Set up call tracking to attribute phone leads to GBP", "Monitor queries, what searches are triggering your listing?", "Watch for competitor activity in your area"],
  },
];

const faqs = [
  { q: "Do I need a physical storefront to have a Google Business Profile?", a: "No. Service-area businesses (like tradies, cleaners, or mobile services) can hide their address and instead specify the suburbs or regions they serve. You still appear in local search results for those areas." },
  { q: "How long does it take to verify a Google Business Profile?", a: "Phone and email verification can be instant. Postcard verification typically takes 5–14 business days. Video verification is available for some business types and is usually same-day." },
  { q: "Why isn't my business showing up in the Google Maps 3-Pack?", a: "The 3-Pack is determined by relevance, distance, and prominence. If you're not appearing, common causes are: incomplete profile, wrong primary category, few reviews, no website, or strong competition in your area. Our <a href=\"/local-seo-for-auckland-small-businesses/\">local SEO service</a> includes a full GBP audit that pinpoints exactly what's holding you back." },
  { q: "Can I manage multiple locations from one account?", a: "Yes. Google Business Profile supports multi-location management. You can manage all your locations from one account, with bulk verification available for businesses with 10+ locations. A <a href=\"/small-business-website-design-auckland/\">well-designed website</a> with individual location pages also reinforces your local authority." },
  { q: "Should I respond to negative reviews?", a: "Always. A professional, calm response to a negative review often impresses potential customers more than the negative review damages. Acknowledge the issue, apologise if warranted, and offer to resolve it offline. Never argue or be defensive." },
  { q: "Do you offer Google Business Profile management?", a: "Yes. We offer ongoing GBP management as part of our <a href=\"/affordable-seo-auckland/\">SEO service</a>, weekly posts, review response, photo updates, and monthly reporting. Ask us about bundling GBP management with your website maintenance plan." },
];
---

<Layout
  title="Google Business Profile Guide for Auckland Businesses"
  description="Learn how to set up and optimise your Google Business Profile for local visibility in Auckland and NZ: categories, NAP, photos, reviews, posts, tracking."
  canonicalURL="https://www.kiwiwebdesign.co.nz/google-business-profile-guide-for-auckland-businesses/"
  schema={schema}
>

  <!-- Hero -->
  <section class="gbp-hero">
    <div class="container gbp-hero-inner">
      <div>
        <p class="gbp-eyebrow">Google Business Profile Guide</p>
        <h1>Set up your Google Business Profile. Get found in Auckland.</h1>
        <p class="gbp-hero-sub">A complete step-by-step guide to creating, completing, and optimising your Google Business Profile, the single most important free tool for local search visibility.</p>
        <div class="gbp-hero-actions">
          <a href="#steps" class="gbp-btn-primary">Read the Guide ↓</a>
          <a href="/website-designer-auckland/" class="gbp-btn-secondary">Get Expert Help</a>
        </div>
      </div>
      <div class="gbp-hero-badge-wrap">
        <div class="gbp-hero-card">
          <p class="gbp-card-label">Free resource</p>
          <p class="gbp-card-title">Complete GBP setup for Auckland businesses</p>
          <ul class="gbp-card-list">
            <li><span>✓</span> 7-step setup checklist</li>
            <li><span>✓</span> Category selection tips</li>
            <li><span>✓</span> Review strategy</li>
            <li><span>✓</span> Common mistakes to avoid</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <PageVisual
    imgSrc={gbpImage.src}
    imgAlt="Google Business Profile optimisation dashboard for an Auckland business"
    imgTitle="Google Business Profile guide for Auckland businesses"
    eyebrow="Local Search"
    title="Make your Google profile feel as polished as your website."
    caption="A visual local-search section helps break up the guide while reinforcing what Auckland businesses need to improve map visibility."
  />

  <!-- AI citability snippet -->
  <div class="gbp-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> provides a free 7-step Google Business Profile setup guide for Auckland businesses. A fully completed GBP gets 5× more views, drives Google Maps 3-Pack rankings, and is free to create. We also offer professional GBP setup and management as part of our local SEO service for Auckland businesses.</p>
    </div>
  </div>

  <StatsRow items={stats} />

  <!-- Guide steps -->
  <section class="section" id="steps">
    <div class="container gbp-steps-wrap">
      <SectionHeader
        eyebrow="Step-by-Step Guide"
        title="7 steps to a fully optimised Google Business Profile."
        subtitle="Follow these steps in order, each one builds on the last."
      />
      <div class="gbp-steps">
        {steps.map(({ num, title, content, tips }) => (
          <div class="gbp-step">
            <div class="gbp-step-num">{num}</div>
            <div class="gbp-step-body">
              <h3 class="gbp-step-title">{title}</h3>
              <p class="gbp-step-content" set:html={content} />
              <div class="gbp-step-tips">
                <p class="gbp-tips-label">✦ Key tips</p>
                <ul>
                  {tips.map((tip) => <li>{tip}</li>)}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Do it for you CTA -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <div class="gbp-diy-card">
        <div>
          <p class="gbp-diy-eyebrow">Want it done for you?</p>
          <h2 class="gbp-diy-title">We set up and manage your GBP as part of our local SEO service.</h2>
          <p class="gbp-diy-desc">If you'd rather hand this off to an expert, we handle the full GBP setup, photo uploads, weekly posts, review strategy, and monthly reporting, bundled with your local SEO plan.</p>
        </div>
        <div class="gbp-diy-actions">
          <a href="/local-seo-for-auckland-small-businesses/" class="gbp-diy-btn-primary">See Local SEO Plans</a>
          <a href="/website-designer-auckland/" class="gbp-diy-btn-secondary">Book a Free Consult</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Google Business Profile Questions"
        subtitle="Common questions from Auckland businesses about GBP setup and optimisation."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/local-seo-for-auckland-small-businesses/" class="rps-link">Local SEO</a>
        <a href="/affordable-seo-auckland/" class="rps-link">SEO Services</a>
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design</a>
        <a href="/ai-seo-for-auckland-small-businesses/" class="rps-link">AI SEO</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Need help with your Google Business Profile?"
    subtitle="We set up and optimise GBP as part of our local SEO service, get in touch for a free audit."
    ctaPrimary={{ text: "Get a Free GBP Audit", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Local SEO Services", href: "/local-seo-for-auckland-small-businesses/" }}
  />

</Layout>

<style>
  .gbp-snippet { background: #fff8e1; border-left: 4px solid var(--kwd-yellow); padding: 1rem 0; }
  .gbp-snippet p { margin: 0; font-size: 0.95rem; line-height: 1.65; color: var(--kwd-dark); }

  /* Hero */
  .gbp-hero {
    background: var(--kwd-dark);
    padding: 5rem 0;
  }
  .gbp-hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .gbp-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-yellow);
    margin-bottom: 1rem;
  }
  .gbp-hero h1 { font-size: clamp(1.9rem, 3.5vw, 3rem); color: #fff; line-height: 1.1; margin-bottom: 1.25rem; }
  .gbp-hero-sub { font-size: 0.95rem; color: rgba(255,255,255,0.65); line-height: 1.7; margin-bottom: 2rem; max-width: 500px; }
  .gbp-hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .gbp-btn-primary {
    display: inline-block; background: var(--kwd-yellow); color: var(--kwd-dark);
    padding: 0.875rem 2rem; border-radius: 8px; font-weight: 700; font-size: 0.875rem;
    text-transform: uppercase; letter-spacing: 0.07em; transition: background 0.2s;
  }
  .gbp-btn-primary:hover { background: var(--kwd-gold); }
  .gbp-btn-secondary {
    display: inline-block; color: rgba(255,255,255,0.65); padding: 0.875rem 1.5rem;
    font-size: 0.875rem; font-weight: 600; transition: color 0.2s;
  }
  .gbp-btn-secondary:hover { color: #fff; }

  .gbp-hero-card {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 18px;
    padding: 2rem;
  }
  .gbp-card-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-yellow); margin-bottom: 0.5rem; }
  .gbp-card-title { font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 1.25rem; line-height: 1.4; }
  .gbp-card-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .gbp-card-list li { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: rgba(255,255,255,0.8); }
  .gbp-card-list span { color: var(--kwd-yellow); font-weight: 700; }

  /* Steps */
  .gbp-steps-wrap { max-width: 860px; margin-inline: auto; }
  .gbp-steps { display: flex; flex-direction: column; gap: 0; margin-top: 2.5rem; }
  .gbp-step {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1.5rem;
    padding: 2.5rem 0;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    align-items: start;
  }
  .gbp-step:last-child { border-bottom: none; }
  .gbp-step-num {
    font-family: var(--kwd-font-heading);
    font-size: 3rem;
    color: var(--kwd-cream);
    line-height: 1;
    text-align: center;
    background: var(--kwd-dark);
    border-radius: 14px;
    padding: 0.5rem 0;
    flex-shrink: 0;
  }
  .gbp-step-title { font-family: var(--kwd-font-body); font-size: 1.1rem; font-weight: 700; color: var(--kwd-dark); margin: 0 0 0.75rem; }
  .gbp-step-content { font-size: 0.9rem; color: var(--kwd-brown); line-height: 1.7; margin: 0 0 1.25rem; }
  .gbp-step-content strong { color: var(--kwd-dark); }
  .gbp-step-tips {
    background: var(--kwd-cream);
    border-radius: 10px;
    padding: 1rem 1.25rem;
  }
  .gbp-tips-label { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .gbp-step-tips ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.4rem; }
  .gbp-step-tips li { font-size: 0.83rem; color: var(--kwd-dark); padding-left: 1.1rem; position: relative; line-height: 1.5; }
  .gbp-step-tips li::before { content: "→"; position: absolute; left: 0; color: var(--kwd-brown); }

  /* DYI card */
  .gbp-diy-card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 2.5rem;
  }
  .gbp-diy-eyebrow { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--kwd-yellow); margin-bottom: 0.5rem; }
  .gbp-diy-title { font-size: clamp(1.25rem, 2vw, 1.75rem); color: #fff; margin-bottom: 0.75rem; }
  .gbp-diy-desc { font-size: 0.9rem; color: rgba(255,255,255,0.6); line-height: 1.7; margin: 0; max-width: 580px; }
  .gbp-diy-actions { display: flex; flex-direction: column; gap: 0.75rem; flex-shrink: 0; }
  .gbp-diy-btn-primary {
    display: inline-block; background: var(--kwd-yellow); color: var(--kwd-dark);
    padding: 0.875rem 1.75rem; border-radius: 8px; font-weight: 700; font-size: 0.85rem;
    text-transform: uppercase; letter-spacing: 0.07em; text-align: center;
    white-space: nowrap; transition: background 0.2s;
  }
  .gbp-diy-btn-primary:hover { background: var(--kwd-gold); }
  .gbp-diy-btn-secondary {
    display: inline-block; color: rgba(255,255,255,0.6); font-size: 0.875rem;
    font-weight: 600; text-align: center; transition: color 0.2s;
  }
  .gbp-diy-btn-secondary:hover { color: #fff; }

  @media (max-width: 900px) {
    .gbp-hero-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .gbp-step { grid-template-columns: 60px 1fr; }
    .gbp-step-num { font-size: 2rem; }
    .gbp-diy-card { grid-template-columns: 1fr; gap: 2rem; }
    .gbp-diy-actions { flex-direction: row; flex-wrap: wrap; }
  }
  @media (max-width: 580px) {
    .gbp-step { grid-template-columns: 1fr; }
    .gbp-step-num { width: 60px; font-size: 1.75rem; }
  }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
