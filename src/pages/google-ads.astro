---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import TestimonialGrid from '../components/TestimonialGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { Image } from 'astro:assets';
import about3Img from '../assets/general/about3.jpg';
import about4Img from '../assets/general/about4.jpg';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/google-ads/",
      "url": "https://www.kiwiwebdesign.co.nz/google-ads/",
      "name": "Google Ads Management Auckland | Google Ads for Small Business",
      "description": "Google Ads management for Auckland small businesses. Leads in 24–72 hours. Flat-fee from $399/mo, not a % of spend. Free strategy session.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/google-ads/#breadcrumb" },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".ga-snippet", ".ga-statbar-inner"]
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/google-ads/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Google Ads", "item": "https://www.kiwiwebdesign.co.nz/google-ads/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "City", "name": "Auckland" },
        { "@type": "Country", "name": "New Zealand" }
      ],
      "priceRange": "$$",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "bestRating": "5",
        "ratingCount": "50"
      },
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.kiwiwebdesign.co.nz/favicon.png",
        "width": 512,
        "height": 512
      }
    },
    {
      "@type": "Service",
      "@id": "https://www.kiwiwebdesign.co.nz/google-ads/#service",
      "name": "Google Ads Management Auckland",
      "serviceType": "Google Ads Management",
      "category": "Digital Marketing",
      "description": "Google Ads campaign setup and ongoing management for Auckland small businesses. Search, local service, remarketing, shopping, and conversion tracking. Flat-fee management from $399/month.",
      "provider": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "areaServed": [
        { "@type": "City", "name": "Auckland" },
        { "@type": "Country", "name": "New Zealand" }
      ],
      "url": "https://www.kiwiwebdesign.co.nz/google-ads/",
      "offers": [
        {
          "@type": "Offer",
          "name": "Campaign Setup",
          "price": "499",
          "priceCurrency": "NZD",
          "description": "One-time Google Ads campaign setup"
        },
        {
          "@type": "Offer",
          "name": "Monthly Management",
          "price": "399",
          "priceCurrency": "NZD",
          "priceSpecification": { "@type": "PriceSpecification", "price": "399", "priceCurrency": "NZD", "unitCode": "MON" },
          "description": "Ongoing monthly Google Ads management, flat fee, not % of spend"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How quickly can Google Ads start generating leads?",
          "acceptedAnswer": { "@type": "Answer", "text": "Typically within 24–72 hours of a campaign going live. This is one of the key advantages of Google Ads over SEO, you can start generating enquiries immediately once your ads are approved and running." }
        },
        {
          "@type": "Question",
          "name": "How much does Google Ads management cost in Auckland?",
          "acceptedAnswer": { "@type": "Answer", "text": "Kiwi Web Design charges a flat monthly management fee starting from $399/month, plus a one-time setup fee from $499. This is separate from your ad spend budget. A minimum ad spend of $500/month is recommended for most Auckland service businesses." }
        },
        {
          "@type": "Question",
          "name": "What ad spend budget do I need for Google Ads in Auckland?",
          "acceptedAnswer": { "@type": "Answer", "text": "For most Auckland service businesses, $500–$1,500/month in ad spend is a good starting point. Highly competitive industries like legal or trades may require more. We provide honest upfront estimates of what budget is needed to compete in your specific market." }
        },
        {
          "@type": "Question",
          "name": "Should I run Google Ads or focus on SEO?",
          "acceptedAnswer": { "@type": "Answer", "text": "Both serve different purposes. Google Ads delivers immediate leads but requires ongoing spend. SEO takes longer but earns free traffic that compounds over time. For most growing Auckland businesses, we recommend both, Ads first for quick wins while SEO builds. Pairing Ads with well-built conversion landing pages also significantly improves your cost per lead." }
        },
        {
          "@type": "Question",
          "name": "Can you take over my existing Google Ads account?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. We can audit and take over management of existing campaigns, or set up a fresh account for businesses starting from scratch. Either way, we start with a free audit to understand what's working and what isn't." }
        },
        {
          "@type": "Question",
          "name": "Do you charge a percentage of ad spend?",
          "acceptedAnswer": { "@type": "Answer", "text": "No. Kiwi Web Design charges a flat monthly management fee rather than a percentage of your ad spend. This means our incentive is to maximise your results, not to encourage you to spend more on ads. Setup is from NZ$499, then monthly management from $399." }
        }
      ]
    }
  ]
};

const adServices = [
  {
    icon: "🔍",
    title: "Search Campaigns",
    desc: "Appear at the top of Google when people search for exactly what you offer. We build tightly-targeted campaigns that put you in front of high-intent buyers.",
    items: ["Keyword research & match type strategy", "Competitor gap analysis", "Negative keyword lists", "Ad copy A/B testing"],
  },
  {
    icon: "🏙️",
    title: "Local Service Ads",
    desc: "Appear in Google's verified local results, Google Guaranteed or Google Screened. Ideal for service businesses that want maximum local visibility.",
    items: ["LSA setup and verification", "Budget optimisation", "Review generation support", "Lead quality tracking"],
  },
  {
    icon: "🎯",
    title: "Remarketing",
    desc: "Re-engage visitors who left without converting. We show targeted ads to people who've already shown interest in your business.",
    items: ["Audience list creation", "Display remarketing", "YouTube remarketing", "Dynamic ad creative"],
  },
  {
    icon: "📊",
    title: "Conversion Tracking",
    desc: "Know exactly which ads are generating calls, form submissions, and revenue. We set up complete conversion tracking so every dollar is accountable.",
    items: ["Google Tag Manager setup", "Call tracking", "Form submission tracking", "eCommerce revenue tracking"],
  },
  {
    icon: "🛒",
    title: "Shopping Ads",
    desc: "For eCommerce businesses, get your products visible at the top of Google Shopping results with well-structured feed management.",
    items: ["Google Merchant Center setup", "Product feed optimisation", "Smart Shopping campaigns", "ROAS optimisation"],
  },
  {
    icon: "📈",
    title: "Campaign Optimisation",
    desc: "Ongoing management to continuously improve performance. We test, analyse, and refine, reducing cost per lead while increasing volume.",
    items: ["Monthly performance reviews", "Bid strategy optimisation", "Quality score improvement", "Ad schedule fine-tuning"],
  },
];

const whyUs = [
  {
    icon: "🚫",
    title: "No Wasted Ad Spend",
    desc: "We use tight keyword targeting, comprehensive negative keyword lists, and conversion-focused landing pages to make sure your budget reaches buyers, not browsers.",
  },
  {
    icon: "📍",
    title: "Built for Auckland Businesses",
    desc: "Local market knowledge means your campaigns target the right Auckland suburbs and regions. No generic national templates, every campaign is built for your specific audience.",
  },
  {
    icon: "🔎",
    title: "Transparent Reporting",
    desc: "You'll know exactly what's happening with your ads every month. Clear reports showing spend, leads, cost-per-lead, and what we're doing to improve.",
  },
  {
    icon: "🏁",
    title: "Fast Setup, Results Fast",
    desc: "Unlike SEO, Google Ads can generate leads within days of going live. We set up campaigns quickly and correctly so you don't wait months for results.",
  },
];

const process = [
  { step: "1", title: "Free Ads Audit", desc: "We review your existing campaigns (or assess your market from scratch) and identify the biggest opportunities." },
  { step: "2", title: "Campaign Strategy", desc: "We build a campaign plan: keywords, ad copy, landing pages, budgets, and bidding strategy tailored to your goals." },
  { step: "3", title: "Setup & Launch", desc: "Campaigns built, conversion tracking installed, and ads live, typically within 5 business days of briefing." },
  { step: "4", title: "Manage & Optimise", desc: "Ongoing monthly management: testing, bidding adjustments, negative keywords, and reporting to continuously improve ROI." },
];

const industries = [
  "Trades (plumbers, electricians, builders)",
  "Healthcare & dental",
  "Law firms & professional services",
  "Beauty & wellness salons",
  "Restaurants & hospitality",
  "eCommerce & retail",
  "Cleaning & property services",
  "Automotive & mechanical",
];

const reviews = [
  { name: "Zane Barrett", company: "Barrett Access Scaffolding", text: "Charlie ran our Google Ads campaign and the enquiries started coming within the first week. Clear reporting, zero jargon, and they actually care about results." },
  { name: "Jack", company: "Show Me Shorts", text: "They set up our ads properly from the start, tracked conversions, managed the budget carefully, and the ROI has been solid. Exactly what we needed." },
];

const faqs = [
  { q: "How quickly can Google Ads start generating leads?", a: "Typically within 24–72 hours of a campaign going live. This is one of the key advantages of Google Ads over SEO, you can start generating enquiries immediately once your ads are approved and running." },
  { q: "How much does Google Ads management cost?", a: "Our management fee starts from $399/month on top of your ad spend. The total cost depends on your budget and campaign complexity. We recommend a minimum ad spend of $500/month for most Auckland service businesses to see meaningful results." },
  { q: "What ad spend budget do I need?", a: "For most Auckland service businesses, $500–$1,500/month in ad spend is a good starting point. Highly competitive industries like legal or trades may require more. We'll be honest with you upfront about what budget is needed to compete in your market. Use our <a href=\"/google-ads-budget-calculator-nz/\">free Google Ads budget calculator</a> to estimate your CPC, click volume, and cost per lead." },
  { q: "Should I run Google Ads or focus on SEO?", a: "Both serve different purposes. Google Ads delivers immediate leads but requires ongoing spend. <a href=\"/affordable-seo-auckland/\">SEO services</a> take longer but earn free traffic that compounds over time. For most growing Auckland businesses, we recommend both, Ads first for quick wins while SEO builds. Pairing Ads with well-built <a href=\"/landing-pages-funnels-on-wordpress/\">conversion landing pages</a> also significantly improves your cost per lead." },
  { q: "Can you take over my existing Google Ads account?", a: "Yes. We can audit and take over management of your existing campaigns, or we can set up a fresh account if you're starting from scratch. Either way, we'll start with an audit to understand what's working and what isn't." },
  { q: "What's your management fee structure?", a: "We charge a flat monthly management fee rather than a percentage of spend. This means our incentive is to maximise your results, not to encourage you to spend more on ads. Setup is from NZ$499, then monthly management from $399." },
];
---

<Layout
  title="Google Ads Management Auckland | Google Ads for Small Business"
  description="Google Ads management for Auckland small businesses. Leads in 24–72 hours. Flat-fee from $399/mo, not a % of spend. Free strategy session. Call 021 039 6580."
  canonicalURL="https://www.kiwiwebdesign.co.nz/google-ads/"
  schema={schema}
  alternateUrl="https://www.kiwiwebdesign.co.nz/zh/google-ads/"
>

  <PageHero
    eyebrow="Google Ads Auckland"
    title="Get more leads this week with Google Ads."
    subtitle="Targeted Google Ads campaigns for Auckland small businesses. We set up, manage, and optimise campaigns that send high-intent traffic to pages built to convert."
    badgeText="Setup from NZ$499"
    ctaPrimary={{ text: "Book a Free Consultation", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "How It Works", href: "#process" }}
    centered={true}
  />

  <!-- AI citability snippet -->
  <div class="ga-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> manages Google Ads campaigns for Auckland small businesses from <strong>$399/month</strong> flat fee, not a percentage of ad spend. One-time setup from <strong>$499</strong>. Services cover search campaigns, local service ads, remarketing, shopping ads, and conversion tracking. Most campaigns generate leads within <strong>24–72 hours</strong> of going live. Recommended ad spend: $500–$1,500/month. Based in Grey Lynn, Auckland, 4.9★ Google rating.</p>
    </div>
  </div>

  <!-- Why Google Ads -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="Why Google Ads"
        title="The fastest way to generate leads in Auckland."
        subtitle="Google Ads puts your business at the top of search results at the exact moment your customers are looking, and you only pay when they click."
      />
      <ServiceGrid items={whyUs} cols={2} />
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Our Services"
        title="Complete Google Ads management."
        subtitle="From campaign setup to ongoing optimisation, everything needed to run profitable Google Ads."
      />
      <ServiceGrid items={adServices} cols={3} />
    </div>
  </section>

  <!-- Industries -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader eyebrow="Industries" title="Industries we run Google Ads for." light={true} />
      <div class="ga-industries">
        {industries.map((item) => (
          <div class="ga-industry-item">
            <svg class="ga-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);" id="process">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="From brief to live in 5 business days."
        subtitle="We move fast so you can start generating leads without delay."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- Team photo band -->
  <section class="ga-team-band">
    <Image src={about3Img} alt="Kiwi Web Design team managing Google Ads campaigns for Auckland businesses" width={1600} height={640} class="ga-team-band-img" />
    <div class="ga-team-band-overlay">
      <div class="container">
        <p class="ga-band-eyebrow">The team behind your campaigns</p>
        <h2 class="ga-band-title">We manage every dollar like it's our own.</h2>
        <a href="/case-study-scaffolding/" class="ga-band-link">See how we grew Barrett Scaffolding's leads by 125% →</a>
      </div>
    </div>
  </section>

  <!-- Pricing callout -->
  <section class="section">
    <div class="container">
      <div class="ga-pricing-card">
        <div class="ga-pricing-left">
          <p class="ga-pricing-eyebrow">Pricing</p>
          <h2 class="ga-pricing-title">Straightforward, flat-fee management.</h2>
          <p class="ga-pricing-desc">We charge a flat monthly management fee, not a percentage of your ad spend. That means our incentive is always to maximise your results, not your spend.</p>
          <div class="ga-pricing-tiers">
            <div class="ga-tier">
              <span class="ga-tier-price">From $499</span>
              <span class="ga-tier-label">One-time campaign setup</span>
            </div>
            <div class="ga-tier">
              <span class="ga-tier-price">From $399/mo</span>
              <span class="ga-tier-label">Ongoing management fee</span>
            </div>
            <div class="ga-tier">
              <span class="ga-tier-price">$500+/mo</span>
              <span class="ga-tier-label">Recommended ad spend (separate)</span>
            </div>
          </div>
        </div>
        <div class="ga-pricing-right">
          <h3>What's included in management:</h3>
          <ul>
            <li>Keyword research & campaign structure</li>
            <li>Ad copywriting & creative</li>
            <li>Landing page recommendations</li>
            <li>Conversion tracking setup</li>
            <li>Negative keyword management</li>
            <li>Bid optimisation</li>
            <li>Monthly performance report</li>
            <li>Direct access to your account manager</li>
          </ul>
          <a href="/website-designer-auckland/" class="ga-cta-btn">Get a Free Quote</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader eyebrow="Client Reviews" title="What our Google Ads clients say." />
      <TestimonialGrid items={reviews} cols={2} />
    </div>
  </section>

  <!-- Strategy session split -->
  <section class="section ga-consult-section">
    <div class="container">
      <div class="ga-consult-split">
        <div class="ga-consult-img-wrap">
          <Image src={about4Img} alt="Free Google Ads strategy session with an Auckland small business" width={760} height={520} class="ga-consult-img" />
        </div>
        <div class="ga-consult-content">
          <p class="ga-consult-eyebrow">Free Strategy Session</p>
          <h2 class="ga-consult-title">We start with a plan, not a pitch.</h2>
          <p class="ga-consult-desc">Every Google Ads engagement starts with a free audit and strategy session. We map out your market, estimate your cost-per-lead, and give you honest advice, even if Google Ads isn't the right fit for you yet.</p>
          <ul class="ga-consult-list">
            <li>Competitor ad analysis included</li>
            <li>Realistic budget and CPA estimates</li>
            <li>No obligation to proceed</li>
          </ul>
          <a href="/website-designer-auckland/" class="ga-consult-btn">Book Your Free Session →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion items={faqs} title="Google Ads Questions Answered" subtitle="Common questions from Auckland businesses about running Google Ads." />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/paid-ads/" class="rps-link">Paid Ads Auckland</a>
        <a href="/meta-ads/" class="rps-link">Meta Ads Auckland</a>
        <a href="/google-ads-budget-calculator-nz/" class="rps-link">Google Ads Budget Calculator</a>
        <a href="/affordable-seo-auckland/" class="rps-link">SEO Auckland</a>
        <a href="/local-seo-for-auckland-small-businesses/" class="rps-link">Local SEO Auckland</a>
        <a href="/landing-pages-funnels-on-wordpress/" class="rps-link">Landing Pages &amp; Funnels</a>
        <a href="/analytics-reporting-for-auckland-small-business-websites/" class="rps-link">Analytics &amp; Reporting</a>
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design Auckland</a>
      </div>
    </div>
  </section>

  <!-- Case studies -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Client case studies</p>
      <div class="rps-links">
        <a href="/case-study-scaffolding/" class="rps-link">Barrett Access Scaffolding, +125% quote requests</a>
        <a href="/beauty-touch-case-study/" class="rps-link">Beauty Touch Auckland, live in 3 weeks</a>
      </div>
    </div>
  </section>

  <!-- Areas we serve -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Areas we serve</p>
      <div class="rps-links">
        <a href="/north-shore-website-design/" class="rps-link">North Shore</a>
        <a href="/south-auckland-web-design/" class="rps-link">South Auckland</a>
        <a href="/west-auckland-web-design/" class="rps-link">West Auckland</a>
        <a href="/east-auckland-web-design/" class="rps-link">East Auckland</a>
        <a href="/central-auckland-web-design/" class="rps-link">Central Auckland</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to get more leads this week?"
    subtitle="Free strategy session, we'll map your market and estimate your cost-per-lead. Call 021 039 6580 or book online."
    ctaPrimary={{ text: "Book a Free Consultation", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "Learn About SEO Too", href: "/affordable-seo-auckland/" }}
  />

</Layout>

<style>
  .ga-industries {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 2rem;
  }
  .ga-industry-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 0.875rem 1rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.8);
  }
  .ga-check { color: var(--kwd-yellow); flex-shrink: 0; width: 18px; height: 18px; }

  .ga-pricing-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    background: var(--kwd-dark);
    border-radius: 20px;
    padding: 3rem;
    color: #fff;
  }
  .ga-pricing-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-yellow);
    margin-bottom: 0.75rem;
  }
  .ga-pricing-title { font-size: clamp(1.5rem, 2.5vw, 2rem); color: #fff; margin-bottom: 0.75rem; }
  .ga-pricing-desc { font-size: 0.9rem; color: rgba(255,255,255,0.65); line-height: 1.7; margin-bottom: 2rem; }
  .ga-pricing-tiers { display: flex; flex-direction: column; gap: 1rem; }
  .ga-tier { display: flex; flex-direction: column; gap: 0.2rem; padding: 1rem; background: rgba(255,255,255,0.07); border-radius: 10px; border: 1px solid rgba(255,255,255,0.1); }
  .ga-tier-price { font-family: var(--kwd-font-heading); font-size: 1.6rem; color: var(--kwd-yellow); }
  .ga-tier-label { font-size: 0.8rem; color: rgba(255,255,255,0.55); }
  .ga-pricing-right h3 { font-family: var(--kwd-font-body); font-size: 0.95rem; font-weight: 700; color: #fff; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .ga-pricing-right ul { list-style: none; padding: 0; margin: 0 0 2rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .ga-pricing-right li { font-size: 0.875rem; color: rgba(255,255,255,0.72); padding-left: 1.25rem; position: relative; }
  .ga-pricing-right li::before { content: "✓"; position: absolute; left: 0; color: var(--kwd-yellow); font-weight: 700; }
  .ga-cta-btn {
    display: inline-block;
    background: var(--kwd-yellow);
    color: var(--kwd-dark);
    padding: 0.875rem 2rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    transition: background 0.2s;
  }
  .ga-cta-btn:hover { background: var(--kwd-gold); }

  /* Team photo band */
  .ga-team-band {
    position: relative;
    height: 380px;
    overflow: hidden;
  }
  .ga-team-band-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
