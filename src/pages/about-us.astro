---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import TestimonialGrid from '../components/TestimonialGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import charlieImg from '../assets/general/Kiwi-Web-Design-Owner-Charlie.jpeg';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["WebPage", "AboutPage"],
      "@id": "https://www.kiwiwebdesign.co.nz/about-us/",
      "url": "https://www.kiwiwebdesign.co.nz/about-us/",
      "name": "About Charlie Chao | Founder of Kiwi Web Design Auckland",
      "description": "Meet Charlie Chao, founder of Kiwi Web Design. Auckland-based web designer helping small businesses and tradies get fast, lead-generating websites from $1,290.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#charlie" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/about-us/#breadcrumb" },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".about-hero-text h1", ".about-lead", ".about-story-text h2"]
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/about-us/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "About Us" }
      ]
    },
    {
      "@type": "Person",
      "@id": "https://www.kiwiwebdesign.co.nz/#charlie",
      "name": "Charlie Chao",
      "givenName": "Charlie",
      "familyName": "Chao",
      "jobTitle": "Founder & Web Designer",
      "description": "Charlie Chao is the founder of Kiwi Web Design, an Auckland web design agency specialising in affordable, lead-generating websites for small businesses and tradies. Based in Grey Lynn, Auckland, New Zealand.",
      "worksFor": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "url": "https://www.kiwiwebdesign.co.nz/about-us/",
      "image": {
        "@type": "ImageObject",
        "url": "https://www.kiwiwebdesign.co.nz/Kiwi-Web-Design-Owner-Charlie.jpeg",
        "width": 480,
        "height": 640
      },
      "sameAs": [
        "https://www.linkedin.com/in/gocharlie/",
        "https://www.kiwiwebdesign.co.nz/about-us/"
      ],
      "knowsAbout": ["Web Design", "WordPress", "Local SEO", "Google Ads", "Small Business Marketing", "Auckland Businesses"],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "addressCountry": "NZ"
      },
      "email": "hi@kiwiwebdesign.co.nz",
      "telephone": "+64-21-039-6580"
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "description": "Auckland web design agency helping small businesses and tradies get affordable, lead-generating websites. Founded by Charlie Chao, based in Grey Lynn.",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "foundingDate": "2023",
      "founder": { "@id": "https://www.kiwiwebdesign.co.nz/#charlie" },
      "sameAs": [
        "https://www.linkedin.com/in/gocharlie/"
      ],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "addressCountry": "NZ"
      },
      "email": "hi@kiwiwebdesign.co.nz",
      "telephone": "+64-21-039-6580",
      "priceRange": "$$",
      "areaServed": "Auckland, New Zealand"
    }
  ]
};

const values = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>`,
    title: "Results First",
    desc: "A website that doesn't generate enquiries isn't a success — no matter how good it looks. We measure success by the leads and revenue your site generates.",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: "Honest Advice",
    desc: "We'll tell you what you actually need — even if that means a smaller project than you planned, or recommending another provider. You'll never be oversold.",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    title: "Move Fast",
    desc: "Most of our clients are live in 2–3 weeks. We believe in getting you in front of customers quickly — then iterating — rather than spending months in planning.",
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
    title: "Local First",
    desc: "We're based in Grey Lynn. We meet clients in person, understand the Auckland market, and care about local business success. This isn't an overseas operation.",
  },
];

const services = [
  { label: "Web Design", href: "/small-business-website-design-auckland/" },
  { label: "SEO Auckland", href: "/seo-auckland/" },
  { label: "Google Ads", href: "/google-ads/" },
  { label: "WordPress Design", href: "/wordpress-website-design-auckland/" },
  { label: "Local SEO", href: "/local-seo-for-auckland-small-businesses/" },
  { label: "Monthly Subscription", href: "/monthly-subscription/" },
];

const stats = [
  { number: "50+", label: "Auckland businesses helped" },
  { number: "4.9★", label: "Average Google review rating" },
  { number: "2–3 wks", label: "Average delivery time" },
  { number: "Grey Lynn", label: "Auckland-based, in-person consults" },
];

const reviews = [
  { name: "Zane Barrett", company: "Barrett Access Scaffolding", text: "Professional, responsive, and really took the time to understand our business. Couldn't be happier with the results. Would absolutely recommend Charlie." },
  { name: "Jack", company: "Show Me Shorts", text: "Smart, practical solutions. Professional, friendly, and quick to respond whenever I had questions. Exactly what I was hoping for from a local designer." },
  { name: "Steven Liu", company: "Client", text: "Outstanding experience. The design is clean, modern, and user-friendly — exactly what I was hoping for." },
  { name: "Gina Dellabarca", company: "Client", text: "Comprehensive and helpful website audit. Clear information. Great communication throughout the whole process." },
];
---

<Layout
  title="About Charlie Chao | Founder of Kiwi Web Design Auckland"
  description="Meet Charlie Chao, founder of Kiwi Web Design. Auckland-based web designer helping small businesses and tradies get fast, lead-generating websites from $1,290."
  canonicalURL="https://www.kiwiwebdesign.co.nz/about-us/"
  schema={schema}
  alternateUrl="https://www.kiwiwebdesign.co.nz/zh/about-us/"
>

  <!-- Hero -->
  <section class="about-hero">
    <div class="container about-hero-inner">
      <div class="about-hero-text">
        <p class="about-eyebrow">About Kiwi Web Design</p>
        <h1>A web designer who actually cares about your results.</h1>
        <p class="about-lead">I'm Charlie — founder of Kiwi Web Design. I started this business because I kept seeing Auckland small businesses stuck with expensive, slow, or ineffective websites that weren't generating any work.</p>
        <p class="about-lead">I believe every small business deserves a fast, modern website that works as hard as they do — without a big-agency price tag or months-long timelines.</p>
        <div class="about-hero-ctas">
          <a href="/website-designer-auckland/" class="about-btn-primary">Book a Free Consult</a>
          <a href="#story" class="about-btn-secondary">My Story ↓</a>
        </div>
        <a
          href="https://www.linkedin.com/in/gocharlie/"
          target="_blank"
          rel="noopener noreferrer"
          class="about-linkedin"
          aria-label="Charlie Chao on LinkedIn"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>
      <div class="about-hero-img-wrap">
        <img
          src={charlieImg.src}
          alt="Charlie Chao — Founder, Kiwi Web Design Auckland"
          class="about-portrait"
          width="480"
          height="640"
          loading="eager"
        />
        <div class="about-hero-badge">
          <span class="ahb-num">4.9★</span>
          <span class="ahb-label">Google Reviews</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats strip -->
  <section class="about-stats-strip">
    <div class="container about-stats-grid">
      {stats.map(({ number, label }) => (
        <div class="about-stat">
          <span class="about-stat-num">{number}</span>
          <span class="about-stat-label">{label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Story -->
  <section class="section" id="story">
    <div class="container about-story-wrap">
      <div class="about-story-text">
        <p class="about-story-eyebrow">The Story</p>
        <h2>Why I started Kiwi Web Design.</h2>
        <p>Before starting KWD, I worked across digital marketing and web projects in Auckland. I noticed the same problem over and over: small businesses — <a href="/tradie-website-design-auckland/">tradies</a>, <a href="/how-kiwi-web-design-helps-auckland-restaurants/">café owners</a>, <a href="/how-kiwi-web-design-helps-auckland-healthcare/">healthcare providers</a> — were either paying too much for too little, or had DIY sites that were holding them back.</p>
        <p>Big agencies charge big-agency rates. Freelancers from overseas don't know the Auckland market. Template builders create sites that look the same as everyone else. See how we compare in our <a href="/7-best-web-design-agencies-in-auckland-2026/">guide to Auckland web design agencies</a>. None of these options were serving Auckland small business owners well.</p>
        <p>So I built Kiwi Web Design around a simple idea: deliver professional, results-focused <a href="/small-business-website-design-auckland/">websites for Auckland small businesses</a> at a price they can justify, with a level of care and communication that larger agencies don't offer.</p>
        <p>I'm based in Grey Lynn. I meet clients for coffee. I answer my own emails. Every project follows <a href="/website-design-process-in-auckland/">a clear, transparent build process</a> — and I genuinely care whether your website is generating work for you.</p>
      </div>
      <div class="about-story-sidebar">
        <div class="about-story-card">
          <p class="asc-label">What I focus on</p>
          <ul class="asc-list">
            <li><a href="/wordpress-website-design-auckland/" class="asc-link">WordPress websites that load fast and rank well</a></li>
            <li><a href="/local-seo-for-auckland-small-businesses/" class="asc-link">Local SEO that puts Auckland businesses on the map</a></li>
            <li><a href="/google-ads/" class="asc-link">Google Ads campaigns that generate real leads</a></li>
            <li>Transparent pricing with no hidden costs</li>
            <li>Plain English — no jargon or buzzwords</li>
            <li><a href="/website-design-process-in-auckland/" class="asc-link">Fast turnaround — typically 2–3 weeks from brief</a></li>
          </ul>
        </div>
        <div class="about-story-card about-story-card--dark">
          <p class="asc-label asc-label--light">Based at</p>
          <p class="asc-address">147 Great North Road<br />Grey Lynn, Auckland</p>
          <a
            href="https://www.google.com/maps/search/?api=1&query=147+Great+North+Road+Grey+Lynn+Auckland"
            target="_blank"
            rel="noopener noreferrer"
            class="asc-map-link"
          >
            View on Google Maps →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="How We Work"
        title="The values that guide every project."
        light={true}
        subtitle="These aren't marketing words — they're the principles I try to apply to every client engagement."
      />
      <div class="about-values">
        {values.map(({ icon, title, desc }) => (
          <div class="about-value">
            <span class="about-value-icon" set:html={icon} />
            <h3 class="about-value-title">{title}</h3>
            <p class="about-value-desc">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="Services"
        title="What Kiwi Web Design offers."
        subtitle="Everything a growing Auckland small business needs to build and grow its online presence."
      />
      <div class="about-services">
        {services.map(({ label, href }) => (
          <a href={href} class="about-service-link">
            {label}
            <span class="asl-arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Client Reviews"
        title="What Auckland business owners say."
        subtitle="Real clients. Real results."
      />
      <TestimonialGrid items={reviews} cols={2} />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design</a>
        <a href="/seo-auckland/" class="rps-link">SEO Auckland</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
        <a href="/website-design-process-in-auckland/" class="rps-link">Our Process</a>
      </div>
    </div>
  </section>

  <!-- Contact strip -->
  <section class="about-contact-strip">
    <div class="container about-contact-inner">
      <div>
        <h2>Want to work together?</h2>
        <p>Free consultation — in person in Grey Lynn, or on a video call. No obligation, honest advice.</p>
      </div>
      <div class="about-contact-actions">
        <a href="/website-designer-auckland/" class="about-contact-btn-primary">Book a Consult</a>
        <a href="mailto:Hi@KiwiWebDesign.co.nz" class="about-contact-btn-secondary">Hi@KiwiWebDesign.co.nz</a>
        <a href="https://www.linkedin.com/in/gocharlie/" target="_blank" rel="noopener noreferrer" class="about-contact-btn-secondary" aria-label="Charlie Chao on LinkedIn">LinkedIn →</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to get a website that generates leads?"
    subtitle="Chat with Charlie — no pressure, no jargon, just honest advice about what your business needs."
    ctaPrimary={{ text: "Book a Free Consult", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Our Services", href: "/small-business-website-design-auckland/" }}
  />

</Layout>

<style>
  /* Hero */
  .about-hero {
    background: var(--kwd-dark);
    padding: 5rem 0 0;
    overflow: hidden;
  }
  .about-hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: end;
  }
  .about-hero-text {
    padding-bottom: 5rem;
  }
  .about-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-yellow);
    margin-bottom: 1rem;
  }
  .about-hero-text h1 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    color: #fff;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }
  .about-lead {
    font-size: 1rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.7;
    margin-bottom: 1rem;
    max-width: 520px;
  }
  .about-lead:last-of-type { margin-bottom: 2.5rem; }
  .about-hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .about-btn-primary {
    display: inline-block;
    background: var(--kwd-yellow);
    color: var(--kwd-dark);
    padding: 0.875rem 2rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    transition: background 0.2s;
  }
  .about-btn-primary:hover { background: var(--kwd-gold); }
  .about-btn-secondary {
    display: inline-block;
    color: rgba(255,255,255,0.65);
    padding: 0.875rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    transition: color 0.2s;
  }
  .about-btn-secondary:hover { color: #fff; }
  .about-linkedin {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: rgba(255,255,255,0.55);
    font-size: 0.82rem;
    font-weight: 600;
    padding: 0.5rem 0;
    transition: color 0.2s;
  }
  .about-linkedin:hover { color: var(--kwd-yellow); }

  .about-hero-img-wrap {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .about-portrait {
    display: block;
    max-height: 560px;
    width: auto;
    object-fit: cover;
    border-radius: 20px 20px 0 0;
    filter: brightness(0.95) saturate(0.9);
  }
  .about-hero-badge {
    position: absolute;
    bottom: 2rem;
    left: -1rem;
    background: var(--kwd-yellow);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  .ahb-num {
    font-family: var(--kwd-font-heading);
    font-size: 1.75rem;
    color: var(--kwd-dark);
    line-height: 1;
  }
  .ahb-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--kwd-dark);
    opacity: 0.7;
    margin-top: 0.2rem;
  }

  /* Stats strip */
  .about-stats-strip {
    background: #fff;
    padding: 2.5rem 0;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .about-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }
  .about-stat { display: flex; flex-direction: column; gap: 0.25rem; }
  .about-stat-num {
    font-family: var(--kwd-font-heading);
    font-size: 2rem;
    color: var(--kwd-dark);
    line-height: 1;
  }
  .about-stat-label {
    font-size: 0.8rem;
    color: var(--kwd-brown);
    line-height: 1.4;
  }

  /* Story section */
  .about-story-wrap {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 4rem;
    align-items: start;
  }
  .about-story-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--kwd-brown);
    margin-bottom: 0.75rem;
  }
  .about-story-text h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-bottom: 1.25rem;
  }
  .about-story-text p {
    font-size: 0.95rem;
    color: var(--kwd-brown);
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .about-story-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 5rem;
  }
  .about-story-card {
    background: var(--kwd-cream);
    border-radius: 16px;
    padding: 1.75rem;
  }
  .about-story-card--dark {
    background: var(--kwd-dark);
  }
  .asc-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--kwd-brown);
    margin-bottom: 1rem;
  }
  .asc-label--light { color: rgba(255,255,255,0.4); }
  .asc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .asc-list li {
    font-size: 0.875rem;
    color: var(--kwd-dark);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }
  .asc-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--kwd-brown);
    font-weight: 700;
  }
  .asc-link { color: var(--kwd-dark); text-decoration: underline; text-underline-offset: 2px; }
  .asc-link:hover { color: var(--kwd-brown); }
  .asc-address {
    font-size: 1rem;
    color: #fff;
    line-height: 1.6;
    margin-bottom: 1rem;
    font-weight: 600;
  }
  .asc-map-link {
    font-size: 0.85rem;
    color: var(--kwd-yellow);
    font-weight: 600;
    transition: opacity 0.2s;
  }
  .asc-map-link:hover { opacity: 0.75; }

  /* Values */
  .about-values {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .about-value {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .about-value-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(251,232,166,0.12);
    border: 1px solid rgba(251,232,166,0.18);
    border-radius: 12px;
    color: var(--kwd-yellow);
    flex-shrink: 0;
    margin-bottom: 0.25rem;
  }
  .about-value-icon svg { width: 24px; height: 24px; }
  .about-value-title {
    font-family: var(--kwd-font-body);
    font-size: 0.95rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
  }
  .about-value-desc {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
