---
import Layout from '../layouts/Layout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["WebPage", "AboutPage"],
      "@id": "https://www.kiwiwebdesign.co.nz/about-us/",
      "url": "https://www.kiwiwebdesign.co.nz/about-us/",
      "name": "Charlie Chao: A Passion for Helping Businesses",
      "description": "Kiwi Web Design helps Auckland tradies and small businesses with affordable websites built fast and locally.",
      "datePublished": "2025-07-30T03:44:09+00:00",
      "dateModified": "2026-01-29T03:19:58+00:00",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "primaryImageOfPage": { "@id": "https://www.kiwiwebdesign.co.nz/about-us/#primaryimage" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/about-us/#breadcrumb" }
    },
    {
      "@type": "ImageObject",
      "@id": "https://www.kiwiwebdesign.co.nz/about-us/#primaryimage",
      "url": "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/10/Kiwi-Web-Design-Owner-Charlie.jpeg",
      "contentUrl": "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/10/Kiwi-Web-Design-Owner-Charlie.jpeg",
      "width": 768,
      "height": 1024
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/about-us/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "About Us" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/04/android-chrome-512x512-1.png",
        "width": 512,
        "height": 512
      }
    }
  ]
};
---

<Layout
  title="Charlie Chao: A Passion for Helping Businesses"
  description="Kiwi Web Design helps Auckland tradies and small businesses with affordable websites built fast and locally."
  canonicalURL="https://www.kiwiwebdesign.co.nz/about-us/"
  schema={schema}
>

  <!-- About Charlie -->
  <section class="section">
    <div class="container about-grid">
      <div class="about-text">
        <h1>About Me</h1>
        <p>Hi, I'm Charlie Chao — a dad, husband, and the guy behind Kiwi Web Design in Auckland. I was born and raised in China, and I've called Aotearoa New Zealand home since 2002. These days, I'm based in Mt Albert, Auckland. I am the co-founder of Mt Albert Business Association.</p>
        <p>I started doing freelance web design back in 2014, after completing a bootcamp at Yoobee School of Design in Auckland. Between 2015 and 2025, I also worked full-time in banking, finance, and crypto. Now, I'm running my web design agency full-time — and loving it.</p>
        <p>What I enjoy most is meeting and getting to know other small business owners. If you'd like to chat, feel free to reach out or connect with me on LinkedIn. Always happy to talk!</p>
        <a
          href="https://www.linkedin.com/in/gocharlie/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >Connect on LinkedIn</a>
      </div>
      <div class="about-image">
        <img
          src="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/10/Kiwi-Web-Design-Owner-Charlie.jpeg"
          alt="Charlie Chao, founder of Kiwi Web Design Auckland"
          width="768"
          height="1024"
          loading="lazy"
        />
        <img
          src="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/07/Dad-and-Baby.jpg"
          alt="Charlie Chao with family"
          width="600"
          height="600"
          loading="lazy"
          class="photo-secondary"
        />
      </div>
    </div>
  </section>

  <!-- About the company -->
  <section class="section section-cream">
    <div class="container">
      <h2>About Us</h2>
      <p>We are a small team of web experts based in Auckland with over 10 years of experience in website building to help businesses grow online.</p>

      <div class="mission-grid">
        <div class="mission-card">
          <h4>Mission.</h4>
          <p>Our mission is to empower small Kiwi businesses to use the Internet to its full potential by providing affordable, effective, custom design websites and digital marketing solutions.</p>
        </div>
        <div class="mission-card">
          <h4>Vision.</h4>
          <p>Our vision is to become the leading web design agency in providing the best value of web design and digital marketing services to improve Kiwi businesses' productivity and business strength.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-dark text-center">
    <div class="container">
      <h2>Let's work together</h2>
      <p>Free consultation — online or in person across Auckland.</p>
      <a href="/website-designer-auckland/" class="btn-primary">Get in Touch</a>
    </div>
  </section>

</Layout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 4rem;
    align-items: start;
  }
  .about-text h1 { margin-bottom: 1.5rem; }
  .about-text p { color: var(--kwd-brown); margin-bottom: 1rem; }
  .about-image {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .about-image img {
    width: 100%;
    border-radius: 8px;
    display: block;
  }
  .photo-secondary {
    height: 260px;
    object-fit: cover;
    object-position: center top;
  }

  .mission-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-top: 2rem;
  }
  .mission-card {
    background: var(--kwd-white);
    border-radius: 8px;
    padding: 2rem;
    border-left: 4px solid var(--kwd-yellow);
  }
  .mission-card h4 {
    font-family: var(--kwd-font-heading);
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }
  .mission-card p { color: var(--kwd-brown); margin: 0; }

  .text-center { text-align: center; }

  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; }
    .about-image { order: -1; }
    .about-image img { max-height: 400px; object-fit: cover; object-position: top; }
    .mission-grid { grid-template-columns: 1fr; }
  }
</style>
