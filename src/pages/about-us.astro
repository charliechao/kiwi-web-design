---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import TestimonialGrid from '../components/TestimonialGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import charlieImg from '../assets/general/Kiwi-Web-Design-Owner-Charlie.jpeg';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["WebPage", "AboutPage"],
      "@id": "https://www.kiwiwebdesign.co.nz/about-us/",
      "url": "https://www.kiwiwebdesign.co.nz/about-us/",
      "name": "About Charlie Chao | Founder of Kiwi Web Design Auckland",
      "description": "Meet Charlie Chao, founder of Kiwi Web Design. AI-first Auckland web designer helping small businesses get fast, lead-generating websites from $1,290.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#charlie" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/about-us/#breadcrumb" },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".about-hero-text h1", ".about-lead", ".about-story-text h2"]
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/about-us/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "About Us" }
      ]
    },
    {
      "@type": "Person",
      "@id": "https://www.kiwiwebdesign.co.nz/#charlie",
      "name": "Charlie Chao",
      "givenName": "Charlie",
      "familyName": "Chao",
      "jobTitle": "Founder & Web Designer",
      "description": "Charlie Chao is the founder of Kiwi Web Design, an Auckland web design agency specialising in affordable, lead-generating websites for small businesses and tradies. Based in Grey Lynn, Auckland, New Zealand.",
      "worksFor": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "url": "https://www.kiwiwebdesign.co.nz/about-us/",
      "image": {
        "@type": "ImageObject",
        "url": "https://www.kiwiwebdesign.co.nz/Kiwi-Web-Design-Owner-Charlie.jpeg",
        "width": 480,
        "height": 640
      },
      "sameAs": [
        "https://www.linkedin.com/in/gocharlie/",
        "https://www.kiwiwebdesign.co.nz/about-us/"
      ],
      "knowsAbout": ["Web Design", "Website Strategy", "Local SEO", "AI SEO", "Google Ads", "Small Business Marketing", "Auckland Businesses"],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "addressCountry": "NZ"
      },
      "email": "hi@kiwiwebdesign.co.nz",
      "telephone": "+64-21-039-6580"
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "legalName": "Ika Tech Limited",
      "alternateName": "Kiwi Web Design Auckland",
      "description": "Auckland web design agency helping small businesses and tradies get affordable, lead-generating websites. Founded by Charlie Chao, based in Grey Lynn.",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "founder": { "@id": "https://www.kiwiwebdesign.co.nz/#charlie" },
      "identifier": {
        "@type": "PropertyValue",
        "propertyID": "NZBN",
        "value": "9429052816840"
      },
      "sameAs": [
        "https://www.facebook.com/profile.php?id=61559560322941",
        "https://www.instagram.com/kiwi_web_design/",
        "https://www.linkedin.com/company/108270459/",
        "https://www.youtube.com/@Kiwiwebdesign",
        "https://www.sortlist.com/agency/kiwi-web-design",
        "https://www.designrush.com/agency/profile/kiwi-web-design",
        "https://techreviewer.co/companies/kiwi-web-design",
        "https://www.trustindex.io/reviews/kiwiwebdesign.co.nz",
        "https://www.openpr.com/news/archive/277321/Ika-Tech-Limited-T-A-Kiwi-Web-Design.html"
      ],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "addressCountry": "NZ"
      },
      "email": "hi@kiwiwebdesign.co.nz",
      "telephone": "+64-21-039-6580",
      "priceRange": "$$",
      "areaServed": [
        { "@type": "City", "name": "Auckland" },
        { "@type": "Country", "name": "New Zealand" }
      ]
    },
    {
      "@type": "VideoObject",
      "@id": "https://www.kiwiwebdesign.co.nz/about-us/#video-charlie-agency-introduction",
      "name": "Kiwi Web Design agency introduction by Charlie Chao",
      "description": "Charlie Chao introduces Kiwi Web Design, an AI-first Auckland web design agency helping small businesses build affordable, lead-generating websites.",
      "thumbnailUrl": "https://i.ytimg.com/vi/_udF_Vt-7hQ/maxresdefault.jpg",
      "embedUrl": "https://www.youtube.com/embed/_udF_Vt-7hQ",
      "contentUrl": "https://www.youtube.com/watch?v=_udF_Vt-7hQ",
      "inLanguage": "en-NZ",
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#charlie" },
      "publisher": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" }
    }
  ]
