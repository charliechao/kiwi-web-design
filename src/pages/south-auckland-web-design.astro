---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import PageVisual from '../components/PageVisual.astro';
import southAucklandImage from '../assets/general/rainbows-end-south-auckland.jpg';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/south-auckland-web-design/",
      "url": "https://www.kiwiwebdesign.co.nz/south-auckland-web-design/",
      "name": "South Auckland Web Design | Websites for Manukau, Papakura & Pukekohe",
      "description": "Affordable web design for South Auckland tradies and businesses. Serving Manukau, Papakura, Pukekohe, and surrounding areas. Fixed-price WordPress websites.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "about": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/south-auckland-web-design/#breadcrumb" },
      "speakable": { "@type": "SpeakableSpecification", "cssSelector": [".loc-snippet", ".loc-hero-text"] }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/south-auckland-web-design/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "South Auckland Web Design", "item": "https://www.kiwiwebdesign.co.nz/south-auckland-web-design/" }
      ]
    },
    {
      "@type": ["LocalBusiness", "ProfessionalService"],
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "alternateName": "Web Design Auckland",
      "url": "https://www.kiwiwebdesign.co.nz/",
      "telephone": "+64-21-039-6580",
      "email": "hi@kiwiwebdesign.co.nz",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "147 Great North Road",
        "addressLocality": "Grey Lynn",
        "addressRegion": "Auckland",
        "postalCode": "1021",
        "addressCountry": "NZ"
      },
      "areaServed": [
        { "@type": "Place", "name": "Manukau, Auckland" },
        { "@type": "Place", "name": "Papakura, Auckland" },
        { "@type": "Place", "name": "Pukekohe, Auckland" },
        { "@type": "Place", "name": "Papatoetoe, Auckland" },
        { "@type": "Place", "name": "Takanini, Auckland" },
        { "@type": "Place", "name": "Drury, Auckland" },
        { "@type": "Place", "name": "South Auckland" }
      ],
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -36.9940,
        "longitude": 174.8793
      },
      "logo": { "@type": "ImageObject", "url": "https://www.kiwiwebdesign.co.nz/favicon.png", "width": 512, "height": 512 }
    },
    {
      "@type": "Service",
      "@id": "https://www.kiwiwebdesign.co.nz/south-auckland-web-design/#service",
      "name": "Web Design, South Auckland",
      "serviceType": "Website Design",
      "provider": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "areaServed": { "@type": "Place", "name": "South Auckland" },
      "offers": { "@type": "Offer", "price": "1290", "priceCurrency": "NZD", "priceSpecification": { "@type": "PriceSpecification", "price": "1290", "priceCurrency": "NZD", "valueAddedTaxIncluded": false } }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Do you work with tradies in South Auckland specifically?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. South Auckland tradies are a key client group for us. The area has high demand for trades services but many businesses still have no online presence or an outdated site. We build tradie websites specifically to generate phone call enquiries." } },
        { "@type": "Question", "name": "What's the most important thing a South Auckland tradie can do online?", "acceptedAnswer": { "@type": "Answer", "text": "Set up and properly maintain your Google Business Profile, and build a website with suburb-specific service pages. When someone in Papatoetoe searches 'plumber near me', Google serves businesses with a well-maintained GBP and a site that mentions Papatoetoe." } },
        { "@type": "Question", "name": "Are your prices affordable for small South Auckland businesses?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Small business website packages start from $1,290 + GST. We work with businesses of all sizes, and we don't price differently based on location. Fixed price means no surprises, you know the total cost before we start." } },
        { "@type": "Question", "name": "Can you help me get more Google reviews?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We set up Google review request automations as part of our local SEO work. After a job is completed, a review request goes out automatically. South Auckland service businesses with 20+ Google reviews convert significantly better than those with none." } },
        { "@type": "Question", "name": "Do you come to South Auckland for meetings?", "acceptedAnswer": { "@type": "Answer", "text": "Most of our work is done remotely. A 30-minute phone or Zoom call is usually enough to brief a project. If you're in Manukau or Papakura and prefer to meet in person, we can accommodate that." } }
      ]
    }
  ]
};

const services = [
  {
    icon: "🔧",
    title: "Tradie & Trade Business Websites",
    desc: "Plumbers, electricians, builders, and roofers in South Auckland are getting left behind online while competitors from other suburbs show up first. We build tradie sites that rank locally and generate phone calls.",
    items: ["Service area pages (suburb-specific)", "Emergency/24hr call option", "Before/after project gallery", "Google Business Profile setup"],
  },
  {
    icon: "🚗",
    title: "Automotive & Industrial",
    desc: "South Auckland is NZ's automotive and industrial hub. Whether you're a panel beater in Manukau or a parts supplier in Ōtāhuhu, your customers search online first. We build sites that put you in front of them.",
    items: ["Services and specialties", "Fleet/commercial client pages", "Quote request forms", "Location and hours"],
  },
  {
    icon: "🛒",
    title: "Retail & Food Businesses",
    desc: "South Auckland's diverse retail and food landscape is growing fast. A well-structured website with Google Business integration means locals find you, not a chain alternative in Botany.",
    items: ["Menu or product pages", "Google Business integration", "Opening hours", "Online ordering links"],
  },
  {
    icon: "🔍",
    title: "Local SEO, South Auckland",
    desc: "Ranking in South Auckland requires suburb-specific content, 'electrician Papatoetoe', 'builder Papakura', 'mechanic Manukau'. Generic SEO won't cut it. We target the exact suburbs your customers are in.",
    items: ["Suburb-targeted landing pages", "Google Business optimisation", "NZ directory citations", "Review management"],
  },
  {
    icon: "📣",
    title: "Google Ads, South Auckland",
    desc: "Many South Auckland trades businesses aren't running Google Ads at all, which means low competition and lower costs per click than the CBD. We run campaigns that generate calls while your SEO builds.",
    items: ["Low-competition keyword gaps", "South Auckland radius targeting", "Call extension setup", "Landing page builds"],
  },
  {
    icon: "📱",
    title: "No-Fuss, Mobile-Ready Websites",
    desc: "South Auckland customers search from their phones. No complicated admin systems or unnecessary features, just a clean, fast, mobile-first website you can actually update yourself.",
    items: ["Mobile-first design", "WordPress CMS (easy updates)", "Fast load times", "Fixed-price build"],
  },
];

const areas = [
  { name: "Manukau City", note: "NZ's largest suburban city centre. Commercial, industrial, retail, and healthcare." },
  { name: "Papatoetoe", note: "Dense residential catchment. Services, trades, and food businesses." },
  { name: "Papakura", note: "Growing town centre with strong trade and construction activity." },
  { name: "Pukekohe", note: "Franklin District hub, agriculture, trades, retail, and professional services." },
  { name: "Takanini & Drury", note: "Rapidly growing corridor. New businesses establishing before competition intensifies." },
  { name: "Ōtāhuhu", note: "Automotive and industrial hub. Trade and service businesses with high local demand." },
];

const faqs = [
  { q: "Do you work with tradies in South Auckland specifically?", a: "Yes. South Auckland tradies are a key client group for us. The area has high demand for trades services but many businesses in the region still have no online presence or an outdated site that doesn't generate work. We build <a href=\"/small-business-website-design-auckland/\">tradie websites</a> specifically to generate phone call enquiries." },
  { q: "What's the most important thing a South Auckland tradie can do online?", a: "Set up and properly maintain your Google Business Profile, and build a website with suburb-specific service pages. When someone in Papatoetoe searches 'plumber near me', Google serves businesses with a well-maintained GBP and a site that mentions Papatoetoe. Our <a href=\"/local-seo-for-auckland-small-businesses/\">local SEO service</a> handles both." },
  { q: "Are your prices affordable for small South Auckland businesses?", a: "Yes. View our <a href=\"/small-business-website-design-auckland/\">small business website packages</a> starting from $990 + GST. We work with businesses of all sizes, and we don't price differently based on location. Fixed price means no surprises, you know the total cost before we start." },
  { q: "Can you help me get more Google reviews?", a: "Yes. We set up Google review request automations as part of our <a href=\"/local-seo-for-auckland-small-businesses/\">local SEO work</a>. After a job is completed, a review request goes out automatically. South Auckland service businesses with 20+ Google reviews convert significantly better than those with none." },
  { q: "Do you come to South Auckland for meetings?", a: "Most of our work is done remotely. A 30-minute phone or Zoom call is usually enough to brief a project. If you're in Manukau or Papakura and prefer to meet in person, we can accommodate that." },
];
---

<Layout
  title="South Auckland Web Design | Websites for Manukau, Papakura & Pukekohe"
  description="Affordable web design for South Auckland tradies and businesses. Serving Manukau, Papakura, Pukekohe, and surrounding areas. Fixed-price WordPress websites."
  canonicalURL="https://www.kiwiwebdesign.co.nz/south-auckland-web-design/"
  schema={schema}
>

  <!-- Hero -->
  <section class="loc-hero">
    <div class="container">
      <div class="loc-hero-inner">
        <div class="loc-hero-text">
          <p class="loc-hero-eyebrow">South Auckland Web Design</p>
          <h1>South Auckland is growing fast. Get online before your competitors do.</h1>
          <p class="loc-hero-sub">Web design for tradies, automotive, retail, and service businesses in Manukau, Papakura, Pukekohe, and across South Auckland. Affordable, fixed-price, and built to generate work.</p>
          <div class="loc-hero-btns">
            <a href="/website-designer-auckland/" class="loc-btn-primary">Get a Free Quote</a>
            <a href="/small-business-website-design-auckland/" class="loc-btn-outline">View Packages</a>
          </div>
        </div>
        <div class="loc-hero-card">
          <p class="lhc-label">Serving South Auckland</p>
          <ul class="lhc-areas">
            <li>Manukau</li>
            <li>Papatoetoe</li>
            <li>Papakura</li>
            <li>Pukekohe</li>
            <li>Takanini & Drury</li>
            <li>Ōtāhuhu</li>
          </ul>
          <p class="lhc-note">Remote-first. In-person consultations available in South Auckland.</p>
        </div>
      </div>
    </div>
  </section>

  <PageVisual
    imgSrc={southAucklandImage.src}
    imgAlt="South Auckland landmark visual for local website design services"
    imgTitle="South Auckland web design for Manukau Papakura and Pukekohe"
    eyebrow="South Auckland Presence"
    title="A sharper visual cue for businesses serving South Auckland."
    caption="The page now pairs its practical local SEO copy with an image section that gives visitors a clearer sense of place."
  />

  <!-- AI citability snippet -->
  <div class="loc-snippet">
    <div class="container">
      <p><strong>Kiwi Web Design</strong> builds websites for South Auckland tradies and businesses, Manukau, Papakura, Pukekohe, Papatoetoe, and Takanini, from <strong>$1,290 + GST</strong>. Fixed price, delivered in 2–3 weeks, with Google Business Profile setup included and a 5★ Google rating.</p>
    </div>
  </div>

  <!-- South Auckland context -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="The South Auckland Opportunity"
        title="Most South Auckland businesses still aren't online. That's your advantage."
        subtitle="South Auckland has the lowest rate of business website ownership in the Auckland region. For businesses that do invest in a professional online presence, the opportunity to rank and generate work is significant."
      />
      <div class="loc-context">
        <div class="loc-context-text">
          <p>South Auckland is one of NZ's fastest-growing business regions, Drury alone is set to become a major commercial hub over the next decade. But the area still has a disproportionately low rate of businesses with a professional website.</p>
          <p>That means less competition in Google search results for 'plumber Papakura' or 'builder Manukau'. For a tradie or service business willing to invest in a proper website and Google presence, the return is often faster and greater than in more saturated markets like the CBD or North Shore.</p>
          <p>The businesses that get online first in growing South Auckland suburbs build a search presence that becomes increasingly hard for later competitors to displace.</p>
        </div>
        <div class="loc-areas-grid">
          {areas.map(({ name, note }) => (
            <div class="loc-area-card">
              <strong class="lac-name">{name}</strong>
              <p class="lac-note">{note}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="Services"
        title="What South Auckland businesses actually need online."
        subtitle="Simple, effective, and affordable, no unnecessary features, just what generates work."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="South Auckland Web Design Questions"
        subtitle="What South Auckland business owners ask about getting online."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design</a>
        <a href="/local-seo-for-auckland-small-businesses/" class="rps-link">Local SEO</a>
        <a href="/east-auckland-web-design/" class="rps-link">East Auckland</a>
        <a href="/west-auckland-web-design/" class="rps-link">West Auckland</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Get your South Auckland business found on Google."
    subtitle="Fixed-price quote, no surprises. Most South Auckland sites live within 2 weeks."
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See Tradie Websites", href: "/tradie-website-design-auckland/" }}
  />

</Layout>

<style>
  .loc-hero {
    background: var(--kwd-dark);
    color: #fff;
    padding: 4rem 0 3.5rem;
  }
  .loc-hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: start;
  }
  .loc-hero-eyebrow { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--kwd-yellow); margin: 0 0 1rem; }
  .loc-hero-text h1 { font-family: var(--kwd-font-heading); font-size: clamp(1.75rem, 3.5vw, 2.75rem); line-height: 1.18; margin: 0 0 1.1rem; color: #fff; }
  .loc-hero-sub { font-size: 1rem; color: rgba(255,255,255,0.7); line-height: 1.65; max-width: 540px; margin: 0 0 2rem; }
  .loc-hero-btns { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .loc-btn-primary { background: var(--kwd-yellow); color: var(--kwd-dark); padding: 0.75rem 1.75rem; border-radius: 6px; font-weight: 700; text-decoration: none; font-size: 0.95rem; }
  .loc-btn-outline { border: 2px solid rgba(255,255,255,0.35); color: rgba(255,255,255,0.85); padding: 0.75rem 1.75rem; border-radius: 6px; font-weight: 600; text-decoration: none; font-size: 0.95rem; }
  .loc-hero-card { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12); border-radius: 16px; padding: 1.75rem; min-width: 220px; flex-shrink: 0; }
  .lhc-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-yellow); margin: 0 0 0.875rem; }
  .lhc-areas { list-style: none; padding: 0; margin: 0 0 1rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .lhc-areas li { font-size: 0.875rem; color: rgba(255,255,255,0.82); padding-left: 1.1rem; position: relative; }
  .lhc-areas li::before { content: "✓"; position: absolute; left: 0; color: var(--kwd-yellow); font-size: 0.72rem; top: 0.15rem; }
  .lhc-note { font-size: 0.72rem; color: rgba(255,255,255,0.35); margin: 0; line-height: 1.55; }
  .loc-context { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; margin-top: 2.5rem; align-items: start; }
  .loc-context-text p { font-size: 0.9rem; color: var(--kwd-brown); line-height: 1.75; margin-bottom: 0.875rem; }
  .loc-areas-grid { display: flex; flex-direction: column; gap: 0.75rem; }
  .loc-area-card { background: #fff; border: 1.5px solid rgba(0,0,0,0.07); border-radius: 10px; padding: 0.875rem 1.125rem; }
  .lac-name { font-size: 0.875rem; font-weight: 700; color: var(--kwd-dark); display: block; margin-bottom: 0.2rem; }
  .lac-note { font-size: 0.78rem; color: var(--kwd-brown); margin: 0; line-height: 1.5; }
  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
  .loc-snippet { background: #fff8e1; border-left: 4px solid var(--kwd-yellow); padding: 1rem 0; }
  .loc-snippet p { margin: 0; font-size: 0.95rem; line-height: 1.65; color: var(--kwd-dark); }
  @media (max-width: 900px) {
    .loc-hero-inner { grid-template-columns: 1fr; }
    .loc-hero-card { display: none; }
    .loc-context { grid-template-columns: 1fr; }
  }
</style>
