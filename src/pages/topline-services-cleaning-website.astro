---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';

const stats = [
  { fig: "2x", label: "More mobile enquiries" },
  { fig: "4x", label: "Increase in calls" },
  { fig: "85%", label: "Client satisfaction rating" },
];

const deliverables = [
  "Service pages per cleaning type",
  "Coverage area pages",
  "Quote request form",
  "Trust signals (reviews, guarantees)",
  "LocalBusiness schema markup",
  "Mobile-first responsive build",
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/topline-services-cleaning-website/",
      "url": "https://www.kiwiwebdesign.co.nz/topline-services-cleaning-website/",
      "name": "Topline Services, Website Case Study | Kiwi Web Design",
      "description": "How Kiwi Web Design rebuilt Topline Services' cleaning website for mobile-first conversion, doubling mobile enquiries and quadrupling inbound calls.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/topline-services-cleaning-website/#breadcrumb" }
    },
    {
      "@type": "CreativeWork",
      "@id": "https://www.kiwiwebdesign.co.nz/topline-services-cleaning-website/#case-study",
      "name": "Case Study: Topline Services",
      "description": "How Kiwi Web Design helped Topline Services generate more cleaning enquiries with a mobile-first website designed for quick quote requests.",
      "url": "https://www.kiwiwebdesign.co.nz/topline-services-cleaning-website/",
      "creator": { "@id": "https://www.kiwiwebdesign.co.nz/#organization" },
      "about": { "@type": "LocalBusiness", "name": "Topline Services", "address": { "@type": "PostalAddress", "addressLocality": "Auckland", "addressCountry": "NZ" } },
      "genre": "Case Study",
      "keywords": "cleaning company website Auckland, cleaning service website design, residential cleaning website"
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/topline-services-cleaning-website/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Topline Services" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz"
    }
  ]
};
---

<Layout
  title="Topline Services, Website Case Study | Kiwi Web Design"
  description="How Kiwi Web Design rebuilt Topline Services' cleaning website for mobile-first conversion, doubling mobile enquiries and quadrupling inbound calls."
  canonicalURL="https://www.kiwiwebdesign.co.nz/topline-services-cleaning-website/"
  schema={schema}
>

  <!-- Hero -->
  <section class="cs-hero">
    <div class="container">
      <div class="cs-hero-inner">
        <div class="cs-hero-text">
          <div class="cs-tags">
            <span class="cs-tag">Case Study</span>
            <span class="cs-industry">Commercial & Residential Cleaning</span>
          </div>
          <h1>Topline Services, 4x More Inbound Calls</h1>
          <p>An Auckland cleaning business with great reviews and zero online presence to show for it. We rebuilt the site mobile-first with a clear quote path, mobile enquiries doubled and calls quadrupled.</p>
        </div>
        <div class="cs-hero-img">
          <img
            src="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/06/Auckland_Cleaner-e1750284778292.jpg"
            alt="Topline Services cleaning website by Kiwi Web Design Auckland"
            width="700"
            height="500"
            loading="eager"
          />
        </div>
      </div>
    </div>
    <div class="cs-stat-strip">
      <div class="container cs-stat-grid">
        {stats.map(s => (
          <div class="cs-stat-item">
            <span class="cs-stat-fig">{s.fig}</span>
            <span class="cs-stat-lbl">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Overview -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <div class="cs-overview">
        <div class="cs-client-card">
          <div class="cs-client-row">
            <span class="cs-client-label">Client</span>
            <span class="cs-client-value">Topline Services</span>
          </div>
          <div class="cs-client-row">
            <span class="cs-client-label">Industry</span>
            <span class="cs-client-value">Commercial & Residential Cleaning</span>
          </div>
          <div class="cs-client-row">
            <span class="cs-client-label">Location</span>
            <span class="cs-client-value">Auckland, New Zealand</span>
          </div>
          <div class="cs-client-row">
            <span class="cs-client-label">Project Type</span>
            <span class="cs-client-value">Website Rebuild + Lead Gen</span>
          </div>
          <div class="cs-client-row">
            <span class="cs-client-label">Results</span>
            <span class="cs-client-value">4x inbound calls</span>
          </div>
        </div>
        <div class="cs-overview-body">
          <p class="cs-sub-eyebrow">Project Overview</p>
          <h2>A reliable Auckland cleaning company with a website that wasn't generating enquiries.</h2>
          <p>Topline Services is an Auckland-based residential and commercial cleaning provider led by Rebecca, known for reliable scheduling, friendly service, and meticulous attention to detail. The business had strong repeat clients and good word-of-mouth referrals, but the website wasn't playing a role in generating new business at all.</p>
          <p>Homeowners and property managers searching for cleaning services in Auckland were finding competitors with better-structured websites, clearer service pages, and easier ways to request a quote. Topline's old site wasn't matching the quality of the service Rebecca was delivering.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Challenge -->
  <section class="section">
    <div class="container cs-content-narrow">
      <p class="cs-sub-eyebrow">The Challenge</p>
      <h2 class="cs-section-h2">Busy homeowners can't figure out how to book, especially on mobile.</h2>
      <p class="cs-section-p">Cleaning services are searched on mobile, a property manager checking coverage areas on their phone, a homeowner requesting a quote at 9pm after work. The old Topline site loaded slowly on mobile, had no structured service pages, and no clear quote path. Visitors landed on a generic homepage and had to work to find what they needed.</p>
      <p class="cs-section-p">There were no trust signals, no reviews displayed on the site, no service guarantees, no mention of the areas covered. For a business where customers are inviting someone into their home, trust is established before they make contact. The old site wasn't building any of it.</p>
    </div>
  </section>

  <!-- Solution -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container cs-content-narrow">
      <p class="cs-sub-eyebrow">What We Built</p>
      <h2 class="cs-section-h2">A conversion-first cleaning website built for mobile quote requests.</h2>
      <p class="cs-section-p">We rebuilt the site with mobile performance as the primary constraint, fast-loading, thumb-friendly navigation, and a quote request form accessible from every page. Dedicated service pages were created for each cleaning type (residential, end-of-tenancy, commercial, move-in/move-out) with clear descriptions, scope, and coverage area information.</p>
      <p class="cs-section-p">A trust section was added above the fold, displaying Google review stars, a satisfaction guarantee, and the suburbs covered. LocalBusiness schema markup was applied to improve visibility for "cleaning services near me" and suburb-specific searches across Auckland.</p>
      <div class="cs-deliverables">
        {deliverables.map(d => <span class="cs-chip">{d}</span>)}
      </div>
    </div>
  </section>

  <!-- Screenshot -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <div class="cs-screenshot-wrap">
        <img
          src="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/06/Auckland_Cleaner-e1750284778292.jpg"
          alt="Topline Services cleaning website design by Kiwi Web Design"
          width="1200"
          height="700"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Results -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <p class="cs-sub-eyebrow cs-sub-eyebrow-light">The Results</p>
      <h2 class="cs-section-h2 cs-section-h2-light">Mobile enquiries doubled. Calls quadrupled. Exactly what a service business needs.</h2>
      <p class="cs-section-p cs-section-p-light">The rebuilt site immediately converted more visitors into quote requests. Mobile enquiries doubled as the faster, clearer site removed friction for phone users. Inbound calls quadrupled, largely driven by the click-to-call button now visible on every page. Rebecca reported the site change as the biggest factor in growing the client base that quarter.</p>
      <div class="cs-results-grid">
        {stats.map(s => (
          <div class="cs-result-card">
            <div class="cs-result-fig">{s.fig}</div>
            <div class="cs-result-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="section">
    <div class="container">
      <div class="cs-testimonial-wrap">
        <blockquote>"The new site is clean and easy to use. I'm getting more enquiries from mobile, and customers say it's simple to book. Exactly what we needed."</blockquote>
        <p class="cs-testimonial-author">- Rebecca, Topline Services</p>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Need a service website that generates real enquiries?"
    subtitle="Free consultation, we'll show you exactly what's stopping your current site from converting visitors."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "See More Case Studies", href: "/testimonials-reviews/" }}
  />

</Layout>

<style>
  .cs-hero { background: var(--kwd-dark); padding: 5rem 0 0; }
  .cs-hero-inner { display: grid; grid-template-columns: 55% 45%; gap: 3rem; align-items: center; padding-bottom: 3rem; }
  .cs-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
  .cs-tag { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 0.3rem 0.85rem; border-radius: 999px; background: var(--kwd-yellow); color: var(--kwd-dark); }
  .cs-industry { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; padding: 0.3rem 0.85rem; border-radius: 999px; background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.75); }
  .cs-hero-text h1 { font-family: var(--kwd-font-heading); font-size: clamp(2rem, 4vw, 3rem); color: #fff; line-height: 1.15; margin-bottom: 1rem; }
  .cs-hero-text p { font-size: 1rem; color: rgba(255,255,255,0.7); line-height: 1.7; }
  .cs-hero-img img { width: 100%; height: 400px; object-fit: cover; border-radius: 12px; display: block; box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
  .cs-stat-strip { border-top: 1px solid rgba(255,255,255,0.1); }
  .cs-stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); }
  .cs-stat-item { padding: 1.5rem 2rem; border-right: 1px solid rgba(255,255,255,0.1); display: flex; flex-direction: column; gap: 0.25rem; }
  .cs-stat-item:last-child { border-right: none; }
  .cs-stat-fig { font-family: var(--kwd-font-heading); font-size: 2.25rem; color: var(--kwd-yellow); line-height: 1; }
  .cs-stat-lbl { font-size: 0.8rem; color: rgba(255,255,255,0.55); line-height: 1.4; }
  .cs-overview { display: grid; grid-template-columns: 260px 1fr; gap: 3.5rem; align-items: start; }
  .cs-client-card { background: #fff; border: 1.5px solid rgba(0,0,0,0.07); border-radius: 14px; padding: 1.75rem; }
  .cs-client-row { margin-bottom: 1rem; }
  .cs-client-row:last-child { margin-bottom: 0; }
  .cs-client-label { display: block; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.2rem; }
  .cs-client-value { font-size: 0.9rem; color: var(--kwd-dark); font-weight: 600; line-height: 1.4; }
  .cs-sub-eyebrow { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--kwd-brown); margin-bottom: 0.75rem; }
  .cs-sub-eyebrow-light { color: var(--kwd-yellow); }
  .cs-overview-body h2 { font-family: var(--kwd-font-heading); font-size: clamp(1.5rem, 2.5vw, 2rem); color: var(--kwd-dark); line-height: 1.2; margin-bottom: 0.75rem; }
  .cs-overview-body p { font-size: 0.9375rem; color: var(--kwd-brown); line-height: 1.75; margin-bottom: 0.75rem; }
  .cs-section-h2 { font-family: var(--kwd-font-heading); font-size: clamp(1.5rem, 2.5vw, 2rem); color: var(--kwd-dark); line-height: 1.2; margin-bottom: 0.75rem; }
  .cs-section-h2-light { color: #fff; }
  .cs-section-p { font-size: 0.9375rem; color: var(--kwd-brown); line-height: 1.75; margin-bottom: 0.75rem; }
  .cs-section-p-light { color: rgba(255,255,255,0.7); }
  .cs-content-narrow { max-width: 760px; }
  .cs-deliverables { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.5rem; }
  .cs-chip { font-size: 0.8rem; font-weight: 600; padding: 0.4rem 1rem; border-radius: 999px; background: var(--kwd-dark); color: #fff; }
  .cs-results-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-top: 2.5rem; }
  .cs-result-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 2rem 1.5rem; text-align: center; }
  .cs-result-fig { font-family: var(--kwd-font-heading); font-size: 2.75rem; color: var(--kwd-yellow); line-height: 1; margin-bottom: 0.5rem; }
  .cs-result-label { font-size: 0.875rem; color: rgba(255,255,255,0.65); line-height: 1.5; }
  .cs-screenshot-wrap { margin-top: 2rem; }
  .cs-screenshot-wrap img { width: 100%; border-radius: 12px; border: 1.5px solid rgba(0,0,0,0.07); display: block; box-shadow: 0 8px 32px rgba(0,0,0,0.1); }
  .cs-testimonial-wrap { max-width: 760px; margin: 0 auto; text-align: center; }
  .cs-testimonial-wrap blockquote { font-family: var(--kwd-font-heading); font-size: clamp(1.2rem, 2.5vw, 1.625rem); color: var(--kwd-dark); line-height: 1.4; font-style: italic; margin: 0 0 1.5rem; }
  .cs-testimonial-author { font-size: 0.875rem; font-weight: 600; color: var(--kwd-brown); }
  @media (max-width: 900px) {
    .cs-hero-inner { grid-template-columns: 1fr; }
    .cs-hero-img { display: none; }
    .cs-overview { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .cs-stat-grid { grid-template-columns: repeat(2, 1fr); }
    .cs-stat-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .cs-stat-item:last-child { border-bottom: none; }
  }
</style>
