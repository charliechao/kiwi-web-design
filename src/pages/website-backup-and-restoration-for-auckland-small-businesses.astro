---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/website-backup-and-restoration-for-auckland-small-businesses/",
      "url": "https://www.kiwiwebdesign.co.nz/website-backup-and-restoration-for-auckland-small-businesses/",
      "name": "Website Backup & Restoration Auckland | Data Recovery | Kiwi Web Design",
      "description": "Automated daily website backups and fast restoration for Auckland businesses. Never lose your website — we keep secure offsite copies ready to restore.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/website-backup-and-restoration-for-auckland-small-businesses/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/website-backup-and-restoration-for-auckland-small-businesses/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Website Backup & Restoration Auckland" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const scenarios = [
  { icon: "🦠", title: "Malware infection", desc: "A plugin vulnerability lets attackers in. Without a clean backup, you're facing a manual rebuild. With one, you're restored in minutes." },
  { icon: "🔄", title: "Bad plugin update", desc: "A plugin update conflicts with your theme and breaks the site. A daily backup means you roll back to yesterday and carry on." },
  { icon: "✂️", title: "Accidental deletion", desc: "Someone deletes the wrong page, product, or media file. If it happened yesterday, your backup has it." },
  { icon: "🖥️", title: "Server failure", desc: "Hosting providers have outages, hardware failures, and occasionally lose data. An offsite backup means you're never dependent on a single server." },
];

const services = [
  {
    icon: "💾",
    title: "Daily Automated Backups",
    desc: "Your full site — files and database — backed up automatically every 24 hours without any action required from you. Set it once, runs forever.",
    items: ["Full file backup", "Database backup", "Automated scheduling", "Zero manual effort"],
  },
  {
    icon: "☁️",
    title: "Offsite Storage",
    desc: "Backups stored on separate infrastructure from your hosting — so a server failure or account compromise doesn't take your backups down with the site.",
    items: ["Cloud storage (separate provider)", "Encrypted transfer", "Geographic redundancy", "Independent of hosting"],
  },
  {
    icon: "📅",
    title: "Retention History",
    desc: "We keep multiple restore points — not just yesterday's backup but a rolling history. Go back 14 or 30 days depending on your plan.",
    items: ["14-day retention (Basic)", "30-day retention (Standard+)", "Multiple restore points", "Version history"],
  },
  {
    icon: "⚡",
    title: "Fast Restoration",
    desc: "When something goes wrong, we restore your site quickly — usually within a few hours of the request. No waiting days for a recovery process.",
    items: ["One-click restore", "Point-in-time recovery", "Partial restore (files or DB)", "Same-day response"],
  },
  {
    icon: "✅",
    title: "Backup Verification",
    desc: "We check that backups are actually completing and that restore files are valid — not just that a job ran. Broken backups are useless when you need them.",
    items: ["Completion monitoring", "File integrity checks", "Alert on backup failure", "Test restores"],
  },
  {
    icon: "📋",
    title: "Backup Reporting",
    desc: "Monthly status reports include a backup log so you can see that protection is running. No news means no problems — but you'll always know.",
    items: ["Monthly backup log", "Storage usage", "Retention summary", "Success/failure status"],
  },
];

const faqs = [
  { q: "Doesn't my hosting company back up my site?", a: "Most shared hosting plans include server-level backups, but they're often weekly, stored on the same server, and may not include the database. If your hosting account is compromised or suspended, you may lose access to those backups too. An independent daily backup with offsite storage is a separate safety net." },
  { q: "How long does a restore take?", a: "A full site restore from backup typically takes 1–3 hours depending on site size and what went wrong. Partial restores (just the database or just specific files) can be faster. We aim to respond to urgent restore requests the same day." },
  { q: "How far back can I restore?", a: "Basic plan clients have 14 days of history; Standard and Premium clients have 30 days. So if something went wrong three weeks ago and you didn't notice until today, a Standard plan gives you the ability to restore to a point before the problem occurred." },
  { q: "Do I need backups if my site doesn't change often?", a: "Yes. The threat isn't just accidental changes — it's malware infections, server failures, and hosting account issues. These can happen to any site regardless of how frequently content is updated." },
  { q: "Is backup included in your maintenance plans?", a: "Yes. Daily backups with offsite storage are included in all maintenance plans. The retention period varies by plan — 14 days on Basic, 30 days on Standard and Premium." },
];
---

<Layout
  title="Website Backup & Restoration Auckland | Data Recovery | Kiwi Web Design"
  description="Automated daily website backups and fast restoration for Auckland businesses. Never lose your website — we keep secure offsite copies ready to restore."
  canonicalURL="https://www.kiwiwebdesign.co.nz/website-backup-and-restoration-for-auckland-small-businesses/"
  schema={schema}
>

  <PageHero
    eyebrow="Website Backups"
    title="Never lose your website — even if something goes wrong."
    subtitle="Automated daily backups with offsite storage and fast restoration for Auckland small businesses. Because rebuilding from scratch is never the answer."
    imgSrc="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/12/website-backup-restoration-auckland-guide.jpeg"
    imgAlt="Website backup and restoration service for Auckland small businesses"
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View Maintenance Plans", href: "/wordpress-maintenance-auckland/" }}
  />

  <!-- When you need it -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="When Backups Save You"
        title="Things go wrong. Backups mean it's not a disaster."
        subtitle="These are the real situations where a daily backup makes the difference between a 5-minute fix and a major problem."
      />
      <div class="scenario-grid">
        {scenarios.map(({ icon, title, desc }) => (
          <div class="scenario-card">
            <span class="scenario-icon">{icon}</span>
            <div>
              <strong class="scenario-title">{title}</strong>
              <p class="scenario-desc">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="What We Provide"
        title="Daily backups, offsite storage, fast restores."
        subtitle="Everything you need to recover from any site problem quickly and completely."
      />
      <ServiceGrid items={services} cols={3} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Backup & Restoration Questions"
        subtitle="Common questions from Auckland business owners about website backups."
      />
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Is your website being backed up properly?"
    subtitle="Free consultation — we'll check your current backup situation and show you what's actually in place."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View Maintenance Plans", href: "/wordpress-maintenance-auckland/" }}
  />

</Layout>

<style>
  .scenario-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .scenario-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 14px;
    padding: 1.5rem;
  }
  .scenario-icon { font-size: 1.75rem; flex-shrink: 0; width: 2.25rem; text-align: center; }
  .scenario-title { display: block; font-size: 0.9rem; font-weight: 700; color: var(--kwd-dark); margin-bottom: 0.35rem; }
  .scenario-desc { font-size: 0.83rem; color: var(--kwd-brown); line-height: 1.6; margin: 0; }

  @media (max-width: 700px) {
    .scenario-grid { grid-template-columns: 1fr; }
  }
</style>
