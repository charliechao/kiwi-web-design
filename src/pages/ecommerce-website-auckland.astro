---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import StatsRow from '../components/StatsRow.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import ecommerceHeroImg from '../assets/general/shopping-cart-for-eCommerce-1.jpg';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/ecommerce-website-auckland/",
      "url": "https://www.kiwiwebdesign.co.nz/ecommerce-website-auckland/",
      "name": "eCommerce Website Design Auckland | Online Stores for NZ Businesses",
      "description": "Looking for a powerful, affordable ecommerce website in Auckland? Kiwi Web Design builds secure, mobile-friendly online stores with fast turnaround and local support.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/ecommerce-website-auckland/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/ecommerce-website-auckland/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "eCommerce Website Auckland" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const stats = [
  { number: "$5.8B", label: "NZ eCommerce revenue in 2024" },
  { number: "67%", label: "of NZ consumers shop online regularly" },
  { number: "From $3,890", label: "eCommerce website packages" },
  { number: "2–4 wks", label: "Typical store launch time" },
];

const included = [
  {
    icon: "🛒",
    title: "Product Catalogue Setup",
    desc: "We set up your product catalogue with categories, attributes, variations, and descriptions. Up to 20 products included in standard packages.",
    items: ["Product pages & descriptions", "Categories & tags", "Product variations (size, colour)", "Image galleries per product"],
  },
  {
    icon: "💳",
    title: "NZ Payment Gateways",
    desc: "We integrate the payment gateways NZ customers trust — Stripe, PayPal, POLi, AfterPay, Laybuy, and bank transfer options.",
    items: ["Stripe (cards)", "PayPal", "AfterPay / Laybuy", "Direct bank transfer"],
  },
  {
    icon: "📦",
    title: "Shipping & Fulfilment",
    desc: "NZ-specific shipping setup including flat rate, free shipping thresholds, weight-based rules, and courier integrations.",
    items: ["NZ flat rate shipping", "Free shipping thresholds", "Rural delivery surcharges", "Click & Collect option"],
  },
  {
    icon: "🧾",
    title: "GST & Tax Handling",
    desc: "GST-inclusive pricing, tax-exclusive displays, invoice generation, and correct NZ tax configuration out of the box.",
    items: ["GST-inclusive pricing", "Tax reports", "Invoice emails to customers", "NZ tax class setup"],
  },
  {
    icon: "📊",
    title: "Analytics & Conversion Tracking",
    desc: "GA4 eCommerce tracking, Google Search Console, and conversion events so you know exactly what's selling and where traffic comes from.",
    items: ["GA4 eCommerce tracking", "Google Ads conversion events", "Revenue reporting", "Funnel analysis"],
  },
  {
    icon: "🔒",
    title: "Security & Performance",
    desc: "SSL, PCI-compliant payment processing, daily backups, and a fast-loading storefront that keeps customers from bouncing before they buy.",
    items: ["SSL certificate", "PCI-compliant checkout", "Daily backups", "CDN & speed optimisation"],
  },
];

const platforms = [
  {
    name: "WooCommerce",
    tag: "WordPress-based",
    icon: "🟦",
    pros: ["You own everything — no monthly platform fee", "Total design flexibility", "55,000+ plugins", "WP content marketing built in", "Best for NZ payment variety"],
    best: "Best for: businesses wanting full ownership, content-driven stores, or complex product variations.",
    href: "/woocommerce-website-design-auckland/",
  },
  {
    name: "Shopify",
    tag: "Hosted platform",
    icon: "🟩",
    pros: ["Easiest to manage yourself", "Excellent for fashion / DTC brands", "Built-in multi-channel selling", "Shopify Payments available in NZ", "App ecosystem for scaling"],
    best: "Best for: product-focused brands wanting ease of use and rapid scaling.",
    href: "/shopify-website-design-auckland/",
  },
];

const process = [
  { step: "1", title: "Strategy & Platform Choice", desc: "We discuss your products, your customers, and your fulfilment model. Together we choose the right platform (WooCommerce or Shopify) and plan the store structure." },
  { step: "2", title: "Design & UX", desc: "We design your storefront — homepage, category pages, product pages, and checkout flow — optimised for conversion on mobile and desktop." },
  { step: "3", title: "Build, Integrate & Test", desc: "We build the store, set up payment gateways, shipping rules, GST, and test every element of the purchase flow end-to-end before launch." },
  { step: "4", title: "Launch & Train", desc: "We go live, configure Analytics, and walk you through adding products, processing orders, and managing your store day-to-day." },
];

const faqs = [
  { q: "WooCommerce or Shopify — which should I choose?", a: "It depends on your priorities. WooCommerce gives you full ownership with no ongoing platform fees and maximum flexibility. Shopify is easier to manage day-to-day and has excellent multi-channel capabilities. We'll recommend the right one based on your product range, technical comfort, and growth plans." },
  { q: "How many products can the website handle?", a: "Both platforms handle thousands of products. Our standard packages include setup for up to 20 products. We can quote for larger catalogues — the additional cost is mainly for the time to populate and organise the products." },
  { q: "Can you set up AfterPay or Laybuy?", a: "Yes. We set up Buy Now Pay Later options including AfterPay, Laybuy, and Zip as part of your payment gateway configuration. These are popular with NZ shoppers and can meaningfully increase average order value." },
  { q: "Do you handle the product photography?", a: "We don't provide product photography, but we advise on image specifications (dimensions, file size, background) so your existing photos look great on the site. Good product imagery is one of the biggest drivers of conversion, so we'll give you honest guidance." },
  { q: "Will my store show up on Google?", a: "We set up your store with SEO foundations — product schema markup, optimised meta titles and descriptions, proper heading structure, and sitemap submission. For ongoing organic growth, our <a href=\"/seo-for-ecommerce/\">eCommerce SEO service</a> and <a href=\"/google-ads/\">Google Shopping Ads management</a> are available as separate engagements." },
  { q: "How much does an eCommerce website cost in Auckland?", a: "Our eCommerce packages start from $3,890 + GST including store design, product setup (up to 20 products), payment gateway integration, and NZ shipping configuration. For smaller businesses, our <a href=\"/small-business-website-design-auckland/\">web design packages from $1,290</a> cover non-eCommerce sites. Larger catalogues or custom features are quoted separately." },
];
---

<Layout
  title="eCommerce Website Design Auckland | Online Stores for NZ Businesses"
  description="Looking for a powerful, affordable ecommerce website in Auckland? Kiwi Web Design builds secure, mobile-friendly online stores with fast turnaround and local support."
  canonicalURL="https://www.kiwiwebdesign.co.nz/ecommerce-website-auckland/"
  schema={schema}
>

  <PageHero
    eyebrow="eCommerce Website Auckland"
    title="An online store built to sell. Not just to look good."
    subtitle="Affordable eCommerce websites for Auckland businesses — WooCommerce and Shopify stores with NZ payments, shipping, and GST configured from day one."
    badgeText="From $3,890 + GST"
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "Choose Your Platform", href: "#platform" }}
    imgSrc={ecommerceHeroImg.src}
    imgAlt="eCommerce website design Auckland"
  />

  <StatsRow items={stats} />

  <!-- Platform choice -->
  <section class="section" style="background: var(--kwd-cream);" id="platform">
    <div class="container">
      <SectionHeader
        eyebrow="Choose Your Platform"
        title="WooCommerce or Shopify — we build both."
        subtitle="Two great platforms, each with different strengths. We'll help you choose the right one for your business."
      />
      <div class="ec-platforms">
        {platforms.map(({ name, tag, icon, pros, best, href }) => (
          <div class="ec-platform">
            <div class="ec-platform-top">
              <span class="ec-platform-icon">{icon}</span>
              <div>
                <h3 class="ec-platform-name">{name}</h3>
                <span class="ec-platform-tag">{tag}</span>
              </div>
            </div>
            <ul class="ec-platform-pros">
              {pros.map((pro) => (
                <li><span class="ec-check">✓</span>{pro}</li>
              ))}
            </ul>
            <p class="ec-platform-best">{best}</p>
            <a href={href} class="ec-platform-link">Learn more about {name} →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's included -->
  <section class="section">
    <div class="container">
      <SectionHeader
        eyebrow="What's Included"
        title="Everything ready for launch on day one."
        subtitle="NZ-specific setup included as standard — not as an afterthought."
      />
      <ServiceGrid items={included} cols={3} />
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <SectionHeader
        eyebrow="How It Works"
        title="From first call to first sale."
        light={true}
        subtitle="A clear four-step build process so you know what to expect at every stage."
      />
      <ProcessSteps items={process} dark={true} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="eCommerce Questions Answered"
        subtitle="Common questions from Auckland businesses before building their online store."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/woocommerce-website-design-auckland/" class="rps-link">WooCommerce Design</a>
        <a href="/shopify-website-design-auckland/" class="rps-link">Shopify Design</a>
        <a href="/seo-for-ecommerce/" class="rps-link">eCommerce SEO</a>
        <a href="/google-ads/" class="rps-link">Google Shopping Ads</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress Web Design</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready to start selling online?"
    subtitle="Free consultation — we'll recommend the right platform and give you a fixed quote."
    ctaPrimary={{ text: "Get a Free Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "Compare WooCommerce & Shopify", href: "/woocommerce-website-design-auckland/" }}
  />

</Layout>

<style>
  .ec-platforms {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .ec-platform {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.08);
    border-radius: 18px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .ec-platform-top {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .ec-platform-icon { font-size: 2rem; }
  .ec-platform-name {
    font-family: var(--kwd-font-body);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--kwd-dark);
    margin: 0 0 0.2rem;
  }
  .ec-platform-tag {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--kwd-brown);
    background: var(--kwd-cream);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
  }
  .ec-platform-pros {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .ec-platform-pros li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--kwd-dark);
  }
  .ec-check { color: var(--kwd-brown); font-weight: 700; flex-shrink: 0; margin-top: 1px; }
  .ec-platform-best {
    font-size: 0.82rem;
    color: var(--kwd-brown);
    font-style: italic;
    line-height: 1.5;
    padding: 0.75rem 1rem;
    background: var(--kwd-cream);
    border-radius: 8px;
    margin: 0;
  }
  .ec-platform-link {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--kwd-dark);
    transition: opacity 0.2s;
  }
  .ec-platform-link:hover { opacity: 0.65; }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }

  @media (max-width: 760px) {
    .ec-platforms { grid-template-columns: 1fr; }
  }
</style>
