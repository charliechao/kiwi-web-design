---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/how-kiwi-web-design-helps-auckland-restaurants/",
      "url": "https://www.kiwiwebdesign.co.nz/how-kiwi-web-design-helps-auckland-restaurants/",
      "name": "Web Design for Auckland Restaurants & Cafes | Kiwi Web Design",
      "description": "WordPress websites for Auckland restaurants, cafes, and hospitality businesses. Online menus, table reservations, and Google visibility that fills seats.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/how-kiwi-web-design-helps-auckland-restaurants/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/how-kiwi-web-design-helps-auckland-restaurants/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Industries", "item": "https://www.kiwiwebdesign.co.nz/industries-we-serve-in-auckland/" },
        { "@type": "ListItem", "position": 3, "name": "Restaurants & Cafes" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz"
    }
  ]
};

const painPoints = [
  {
    icon: "📄",
    title: "Your menu is a PDF that nobody can read on a phone",
    desc: "A PDF menu is the single biggest website mistake hospitality businesses make. Google can't read it, mobile users hate pinching and zooming, and you can't update it without Adobe Acrobat. A well-structured HTML menu page ranks on Google and takes 30 seconds to update.",
  },
  {
    icon: "📱",
    title: "You're losing bookings after 9pm",
    desc: "People decide where to eat on Saturday night at 10pm on a Tuesday. If they can't make a reservation directly from your site — right now, in two clicks — they'll move on to a restaurant that lets them. Thirty percent of restaurant reservations are made outside business hours.",
  },
  {
    icon: "📍",
    title: "Google shows incomplete or wrong information",
    desc: "If your Google Business Profile shows the wrong hours, an old address, or no photos — or worse, shows a competitor's profile — you're losing walk-ins and drive-bys. Your website and Google Business Profile need to be maintained together.",
  },
  {
    icon: "🍽️",
    title: "The ambiance doesn't translate online",
    desc: "Your fit-out cost $80,000. Your food is beautiful. But if your website looks like a Squarespace free template from 2018, none of that comes through. First-time customers decide whether your restaurant is 'their kind of place' from the website — before they've tasted a thing.",
  },
];

const solutions = [
  {
    icon: "🍽️",
    title: "HTML Menu Pages",
    desc: "A properly structured menu page — readable on mobile, indexable by Google, and editable by you in minutes. Organised by course or category, with dietary labels (GF, V, Vegan) and optional pricing.",
    items: ["Mobile-readable HTML", "Course/category structure", "Dietary labels", "Easy self-management"],
  },
  {
    icon: "📅",
    title: "Table Reservation Integration",
    desc: "Online reservation capability integrated directly into your website — via a booking widget (OpenTable, Resy, or a WordPress plugin) so diners can book a table at any hour without calling.",
    items: ["OpenTable or inline booking form", "Party size + date/time selection", "Confirmation email to guest", "Management dashboard"],
  },
  {
    icon: "📸",
    title: "Food & Atmosphere Photography Integration",
    desc: "A fast-loading gallery section designed to showcase your food and venue. We optimise your existing photography or advise on what shots will make the biggest impact online.",
    items: ["Hero food/venue photo", "Gallery section", "WebP optimisation", "Atmosphere and ambiance focus"],
  },
  {
    icon: "🗺️",
    title: "Google Business Profile Integration",
    desc: "Your website and Google Business Profile work together — consistent NAP (name, address, phone), hours, menu link, and photos so Google shows the right information in map searches.",
    items: ["NAP consistency across site + GBP", "Hours and special events", "Menu URL linked in GBP", "Restaurant schema markup"],
  },
  {
    icon: "🛵",
    title: "Delivery & Ordering Links",
    desc: "If you're on Uber Eats, DoorDash, or a direct ordering platform — we integrate clear ordering buttons so customers can order directly from your site rather than searching on a third-party app.",
    items: ["Uber Eats / DoorDash buttons", "Direct online ordering option", "Takeaway vs dine-in flows", "Special event ordering"],
  },
  {
    icon: "🎉",
    title: "Functions & Events Page",
    desc: "A dedicated page for private dining, corporate functions, or events — with capacity details, menu packages, and a functions enquiry form. Often the highest-margin booking category for a restaurant.",
    items: ["Capacity and room details", "Function menu overview", "Enquiry form with date + headcount", "Catering package description"],
  },
];

const process = [
  { step: "1", title: "Discovery & Visual Brief", desc: "We look at your fit-out, your Instagram, and your competitors to understand the visual tone — whether you're fine dining, modern casual, or neighbourhood café. We get the site to match the experience." },
  { step: "2", title: "Menu Structure & Copy", desc: "We structure your menu page properly — by course or category, with descriptions, dietary labels, and optional pricing. You supply the content; we structure and present it." },
  { step: "3", title: "Build & Reservation Setup", desc: "We build the full site including gallery, menu, functions page, and integrate your reservation system. Google Business Profile is reviewed and updated in the same pass." },
  { step: "4", title: "Launch & Training", desc: "Site goes live. We train you (or your front-of-house manager) on updating the menu, adding special events, and changing seasonal content — takes about 20 minutes." },
];

const faqs = [
  { q: "Can I update my menu myself after the site is built?", a: "Yes — and this is one of the key reasons we build menus as HTML pages rather than PDFs. Updating a menu takes about 2 minutes in WordPress. You change the text, hit publish, and the live site reflects the update immediately. No design skills required. We build on <a href=\"/wordpress-website-design-auckland/\">WordPress</a> so you're always in control." },
  { q: "Do you integrate with OpenTable or reservation systems?", a: "Yes. We can embed an OpenTable booking widget, a Resy widget, or use a standalone <a href=\"/booking-appointment-websites-with-wordpress/\">WordPress booking plugin</a> depending on your setup. All options give you real-time availability management and automatic confirmation emails." },
  { q: "Can you help us rank for 'restaurants near me' searches?", a: "Yes. <a href=\"/local-seo-for-auckland-small-businesses/\">Local restaurant SEO</a> is about your Google Business Profile as much as your website. We optimise both: structured menu pages with schema markup, NAP consistency, photo quality in your GBP, and review management. 'Best Italian restaurant Auckland CBD' type searches are winnable with the right setup." },
  { q: "We have multiple locations — can one website cover all of them?", a: "Yes. Multi-location restaurant websites are something we build with individual location pages for each site — separate addresses, hours, menus, and booking links. Each location page is individually optimised for <a href=\"/local-seo-for-auckland-small-businesses/\">local search</a> in its area." },
  { q: "How much does a restaurant website cost?", a: "A restaurant website with a menu page, gallery, about section, and reservation integration starts from $1,490 + GST. View our <a href=\"/small-business-website-design-auckland/\">web design packages</a> for full pricing. Sites with a functions page, multi-location pages, or custom reservation builds run $1,990–$2,990 + GST. All quotes are fixed price." },
];
---

<Layout
  title="Web Design for Auckland Restaurants & Cafes | Kiwi Web Design"
  description="WordPress websites for Auckland restaurants, cafes, and hospitality businesses. Online menus, table reservations, and Google visibility that fills seats."
  canonicalURL="https://www.kiwiwebdesign.co.nz/how-kiwi-web-design-helps-auckland-restaurants/"
  schema={schema}
>

  <PageHero
    eyebrow="Web Design for Restaurants & Cafes"
    title="Your restaurant deserves a website that fills seats."
    subtitle="WordPress websites for Auckland restaurants, cafes, and bars. Online menus that Google can read, table reservations at any hour, and a design that captures the atmosphere before a guest walks through your door."
    ctaPrimary={{ text: "Get a Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See What's Included", href: "#solutions" }}
    imgSrc="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/11/la-veranda-restaurant-auckland-website.jpg"
    imgAlt="Restaurant website design Auckland"
  />

  <!-- Pain points -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="The Challenge"
        title="Most restaurant websites are costing them customers."
        subtitle="The four most common online mistakes that Auckland hospitality businesses make — and what they're costing you."
      />
      <div class="ind-pain-grid">
        {painPoints.map(({ icon, title, desc }) => (
          <div class="ind-pain-card">
            <span class="ipc-icon">{icon}</span>
            <h3 class="ipc-title">{title}</h3>
            <p class="ipc-desc">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Solutions -->
  <section class="section" id="solutions">
    <div class="container">
      <SectionHeader
        eyebrow="What We Build"
        title="A hospitality website that works as hard as you do."
        subtitle="Every feature your restaurant or café needs to attract diners, take reservations, and rank on Google."
      />
      <ServiceGrid items={solutions} cols={3} />
    </div>
  </section>

  <!-- The PDF menu callout -->
  <section class="section" style="background: var(--kwd-dark);">
    <div class="container">
      <div class="ind-callout">
        <div class="ind-callout-text">
          <p class="ind-callout-eyebrow">The PDF Problem</p>
          <h2>Your PDF menu is invisible to Google and unreadable on a phone.</h2>
          <p>A PDF menu is the most common — and most damaging — mistake we see on Auckland restaurant websites. Google can't parse a PDF to understand what dishes you offer. That means you can't rank for searches like 'restaurants with halal menu Auckland' or 'best pasta Auckland CBD'.</p>
          <p>An HTML menu page takes the same content and makes it fully searchable — by Google and by your customers on mobile. It takes 5 minutes to update and it's readable on any screen without pinching.</p>
        </div>
        <div class="ind-callout-stats">
          <div class="ind-stat"><span class="is-fig">30%</span><span class="is-label">of restaurant reservations are made outside business hours — when your phone isn't answered</span></div>
          <div class="ind-stat"><span class="is-fig">72%</span><span class="is-label">of consumers visit a restaurant's website before dining for the first time</span></div>
          <div class="ind-stat"><span class="is-fig">PDF</span><span class="is-label">menus are invisible to Google — HTML menus can rank for food and cuisine searches</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="How We Work"
        title="From brief to bookings in 1–2 weeks."
        subtitle="We understand that hospitality moves fast. Our build process is designed to keep up."
      />
      <ProcessSteps items={process} />
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Restaurant Website Questions Answered"
        subtitle="What Auckland hospo owners ask before starting a project with us."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design</a>
        <a href="/local-seo-for-auckland-small-businesses/" class="rps-link">Local SEO</a>
        <a href="/booking-appointment-websites-with-wordpress/" class="rps-link">Booking Websites</a>
        <a href="/google-ads/" class="rps-link">Google Ads</a>
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready for a website that fills your tables?"
    subtitle="Free consultation — we'll review your current site and identify exactly what's losing you bookings."
    ctaPrimary={{ text: "Get a Quote", href: "/website-designer-auckland/" }}
    ctaSecondary={{ text: "See All Industries", href: "/industries-we-serve-in-auckland/" }}
  />

</Layout>

<style>
  .ind-pain-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .ind-pain-card {
    background: #fff;
    border: 1.5px solid rgba(0,0,0,0.07);
    border-radius: 14px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ipc-icon { font-size: 1.75rem; }
  .ipc-title { font-family: var(--kwd-font-body); font-size: 0.95rem; font-weight: 700; color: var(--kwd-dark); margin: 0; }
  .ipc-desc { font-size: 0.875rem; color: var(--kwd-brown); line-height: 1.65; margin: 0; }

  .ind-callout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .ind-callout-eyebrow { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--kwd-yellow); margin-bottom: 0.75rem; }
  .ind-callout-text h2 { font-size: clamp(1.4rem, 2.5vw, 1.875rem); color: #fff; margin-bottom: 0.75rem; line-height: 1.25; }
  .ind-callout-text p { font-size: 0.9rem; color: rgba(255,255,255,0.65); line-height: 1.7; margin-bottom: 0.75rem; }
  .ind-callout-stats { display: flex; flex-direction: column; gap: 1rem; }
  .ind-stat {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .is-fig { font-family: var(--kwd-font-heading); font-size: 1.75rem; color: var(--kwd-yellow); flex-shrink: 0; min-width: 72px; line-height: 1; }
  .is-label { font-size: 0.85rem; color: rgba(255,255,255,0.65); line-height: 1.5; }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
  @media (max-width: 900px) {
    .ind-callout { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  @media (max-width: 640px) {
    .ind-pain-grid { grid-template-columns: 1fr; }
  }
</style>
