---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import CTABanner from '../components/CTABanner.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://www.kiwiwebdesign.co.nz/website-training-and-handover/",
      "url": "https://www.kiwiwebdesign.co.nz/website-training-and-handover/",
      "name": "Website Training & Handover Auckland | Learn to Manage Your Site",
      "description": "Structured website training and full handover included with every Kiwi Web Design build. Learn to update your WordPress site confidently with local, in-person support.",
      "inLanguage": "en-NZ",
      "isPartOf": { "@id": "https://www.kiwiwebdesign.co.nz/#website" },
      "breadcrumb": { "@id": "https://www.kiwiwebdesign.co.nz/website-training-and-handover/#breadcrumb" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.kiwiwebdesign.co.nz/website-training-and-handover/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.kiwiwebdesign.co.nz/" },
        { "@type": "ListItem", "position": 2, "name": "Website Training & Handover" }
      ]
    },
    {
      "@type": "Organization",
      "@id": "https://www.kiwiwebdesign.co.nz/#organization",
      "name": "Kiwi Web Design",
      "url": "https://www.kiwiwebdesign.co.nz/"
    }
  ]
};

const trainingItems = [
  {
    icon: "📝",
    title: "Page & Content Editing",
    desc: "How to update text, images, and content on any page — including the homepage, service pages, and about page — using the WordPress block editor.",
    items: ["Block editor basics", "Text & image editing", "Page structure changes", "Saving & publishing"],
  },
  {
    icon: "✍️",
    title: "Blog & News Posts",
    desc: "How to write, format, and publish blog posts — including categories, tags, featured images, and SEO settings using Yoast or RankMath.",
    items: ["Creating new posts", "Categories & tags", "Featured images", "SEO title & meta"],
  },
  {
    icon: "📸",
    title: "Media Library",
    desc: "Uploading, organising, and managing images and files. We cover image sizing, alt text, and how to keep your media library tidy.",
    items: ["Uploading images", "Image sizing guidelines", "Alt text for SEO", "File management"],
  },
  {
    icon: "📋",
    title: "Forms & Enquiries",
    desc: "Where your enquiry form submissions go, how to view them, and how to follow up. We also show you how to update form fields if your requirements change.",
    items: ["Form submission inbox", "Email notification setup", "Form field edits", "Spam filter settings"],
  },
  {
    icon: "🔧",
    title: "Plugin Basics",
    desc: "What the key plugins on your site do, when to update them, and what to do if an update causes something to look wrong.",
    items: ["Key plugins explained", "Safe update process", "What not to delete", "When to call us"],
  },
  {
    icon: "📦",
    title: "Full Credentials Handover",
    desc: "Every login and access credential for your site — WordPress admin, hosting, domain, Google tools — documented and handed over to you securely.",
    items: ["WordPress admin access", "Hosting credentials", "Domain registrar access", "Google tools access"],
  },
];

const faqs = [
  { q: "Is training included with every website build?", a: "Yes. We include a structured handover session with every new website build. We don't just launch the site and disappear — we walk you through managing it so you're confident from day one." },
  { q: "What format is the training?", a: "We prefer in-person or video call sessions so we can walk through your actual site together. We also provide written notes or a short video recording of the session you can refer back to later. The format is flexible — whatever works best for you." },
  { q: "What if I forget how to do something after the training?", a: "That's normal. We include follow-up support after handover — if you get stuck on something we covered, just reach out and we'll help. For ongoing content management support, our <a href=\"/wordpress-maintenance-auckland/\">WordPress maintenance plans</a> include hours for content changes each month." },
  { q: "Do I need to be technical to manage my WordPress site?", a: "No. We configure your site so that day-to-day management — updating text, adding images, publishing blog posts — is straightforward. We avoid unnecessary complexity and make sure the tools you need are easy to find." },
  { q: "What if my team needs to be trained as well?", a: "We can train multiple team members, either together or separately. If you need training for several people, let us know and we'll structure the session accordingly." },
];
---

<Layout
  title="Website Training & Handover Auckland | Learn to Manage Your Site"
  description="Structured website training and full handover included with every Kiwi Web Design build. Learn to update your WordPress site confidently with local, in-person support."
  canonicalURL="https://www.kiwiwebdesign.co.nz/website-training-and-handover/"
  schema={schema}
>

  <PageHero
    eyebrow="Training & Handover"
    title="Your website — and the confidence to manage it yourself."
    subtitle="Every website we build includes a structured handover session and full credentials transfer. We make sure you know how to update your site before we call it done."
    imgSrc="https://www.kiwiwebdesign.co.nz/wp-content/uploads/2025/11/website-training-handover-kiwiwebdesign.jpg"
    imgAlt="Website training and handover session for new WordPress site"
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View Web Design Services", href: "/small-business-website-design-auckland/" }}
  />

  <!-- What we cover -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container">
      <SectionHeader
        eyebrow="What We Cover"
        title="A thorough handover — not a five-minute walkthrough."
        subtitle="We cover everything you'll actually use, in plain English, at your own pace."
      />
      <ServiceGrid items={trainingItems} cols={3} />
    </div>
  </section>

  <!-- Why it matters -->
  <section class="section">
    <div class="container" style="max-width: 860px;">
      <SectionHeader
        eyebrow="Why It Matters"
        title="Your site should work for you — not make you dependent on us."
        align="left"
      />
      <div class="training-body">
        <p>Too many web designers hand over a completed site with a login and a wave. Six months later, the client either can't make basic updates or is paying for every small change because they were never shown how.</p>
        <p>We take the opposite approach. Training and handover is built into every <a href="/wordpress-website-design-auckland/" class="tr-link">WordPress website build</a>. By the end of our session, you'll know how to update your site's content, publish blog posts, manage images, and handle your enquiry forms — without needing to call us every time.</p>
        <p>You'll also have every login credential for every system your site depends on: WordPress, hosting, domain registrar, Google Search Console, Google Analytics. All documented, all in your hands.</p>
        <ul class="training-checklist">
          <li>Included with every new website build</li>
          <li>In-person or video call — your preference</li>
          <li>Written notes or session recording provided</li>
          <li>Follow-up support included after handover</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--kwd-cream);">
    <div class="container" style="max-width: 860px;">
      <FAQAccordion
        items={faqs}
        title="Training & Handover Questions"
        subtitle="Common questions from Auckland business owners about the handover process."
      />
    </div>
  </section>

  <!-- Related services -->
  <section class="related-strip">
    <div class="container" style="max-width: 860px;">
      <p class="rps-label">Related services</p>
      <div class="rps-links">
        <a href="/wordpress-website-design-auckland/" class="rps-link">WordPress Web Design</a>
        <a href="/wordpress-maintenance-auckland/" class="rps-link">WordPress Maintenance</a>
        <a href="/website-hosting-auckland/" class="rps-link">Website Hosting</a>
        <a href="/website-copywriting-auckland/" class="rps-link">Website Copywriting</a>
        <a href="/small-business-website-design-auckland/" class="rps-link">Web Design Packages</a>
      </div>
    </div>
  </section>

  <CTABanner
    variant="yellow"
    title="Ready for a website you can actually manage?"
    subtitle="Free consultation — we'll show you how the build process works and what the handover includes."
    ctaPrimary={{ text: "Work With Us", href: "/work-with-us/" }}
    ctaSecondary={{ text: "View Web Design Services", href: "/small-business-website-design-auckland/" }}
  />

</Layout>

<style>
  .training-body p {
    font-size: 0.9375rem;
    color: var(--kwd-brown);
    line-height: 1.75;
    margin-bottom: 0.9rem;
  }
  .training-checklist {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .training-checklist li {
    font-size: 0.9rem;
    color: var(--kwd-dark);
    font-weight: 600;
    padding-left: 1.5rem;
    position: relative;
  }
  .training-checklist li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--kwd-brown);
    font-weight: 700;
  }
  .tr-link { color: var(--kwd-dark); font-weight: 600; text-decoration: underline; }
  .tr-link:hover { opacity: 0.75; }

  .related-strip { background: var(--kwd-cream); padding: 1.25rem 0; border-top: 1px solid rgba(0,0,0,0.07); }
  .rps-label { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--kwd-brown); margin-bottom: 0.6rem; }
  .rps-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .rps-link { font-size: 0.82rem; font-weight: 600; padding: 0.4rem 0.9rem; border-radius: 999px; background: #fff; border: 1.5px solid rgba(0,0,0,0.1); color: var(--kwd-dark); text-decoration: none; transition: background 0.15s; }
  .rps-link:hover { background: #e8e7db; }
</style>
