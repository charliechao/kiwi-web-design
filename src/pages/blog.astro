  schema={schema}
>
  <!-- TODO: Replace with actual blog listing content from the live site -->
  <section class="section">
    <div class="container">
      <h1>Free Web Design Resources for Small Businesses</h1>
      <p>Tips, guides, and insights for Auckland small business owners on web design, SEO, and digital marketing.</p>
    </div>
  </section>
</Layout>
