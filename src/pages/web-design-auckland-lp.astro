---
// Google Ads landing page — noindex, excluded from sitemap (astro.config.mjs).
// Conversion fires on /web-design-auckland-lp/thank-you/ only.
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { Image } from 'astro:assets';
import charliePhoto from '../assets/general/Kiwi-Web-Design-Owner-Charlie.jpeg';
import beautyTouchPreview from '../assets/general/beauty-salon-website-design-seo-auckland.jpg';

const included = [
  { icon: "MessageCircle", title: "Strategy First", desc: "We map out who your customers are and what the site needs to say before any design starts." },
  { icon: "PenTool", title: "Copywriting Included", desc: "Words that sell your services — you don't have to write a single page yourself." },
  { icon: "Monitor", title: "Custom Design & Build", desc: "No templates. A fast, modern site designed around your business, not squeezed into a theme." },
  { icon: "Smartphone", title: "Mobile Optimised", desc: "Most Auckland customers will find you on their phone. Your site will look sharp there first." },
  { icon: "TrendingUp", title: "SEO-Ready Structure", desc: "Clean headings, service pages, and local SEO foundations so Google understands your business." },
  { icon: "BarChart3", title: "Enquiry Tracking Set Up", desc: "Forms, analytics, and conversion tracking wired in — you'll know exactly where leads come from." },
];

const goodFit = [
  "You run a service business in Auckland and want more enquiries, not just a prettier site",
  "Your current website is outdated, or looks fine but never generates leads",
  "You want one person who handles strategy, design, build, and launch",
  "You're thinking about SEO or Google Ads later and want a site built ready for them",
];

const notFit = [
  "You're looking for the cheapest possible website or a $300 template job",
  "You want a DIY builder site you'll maintain yourself",
  "You want to start before you've decided what the website needs to achieve",
  "You're just collecting quotes with no real timeline",
];

// Verbatim 5-star Google reviews (kiwiwebdesign.co.nz Business Profile).
const reviews = [
  { name: "Eduardo Arnez", company: "Aesthetic Painting & Deco", text: "Charlie from Kiwi Web Design did an outstanding job designing our website. He was incredibly helpful throughout the entire process, offering great ideas and maintaining excellent communication. We're extremely happy with both the look and functionality of the final result. Highly recommend!" },
  { name: "Francesco Moretti", text: "Kiwi Web Design doesn't just build website, they actually focus on getting you found online. Their approach to SEO and AI search made a big difference for us. We're now showing up in more places and getting more enquires." },
  { name: "Charles Haddix", avatar: "/images/reviews/charles-haddix.png", text: "We recently got our website rebuilt by Kiwi Web Design in Auckland, and honestly, it was such a good experience. Charlie made everything really easy to understand and kept us in the loop the whole way through. The new site looks great on both phone and desktop, and we've already noticed more people finding us on Google and getting in touch. Couldn't recommend Kiwi Web Design enough if you're after an affordable, professional web designer in Auckland." },
  { name: "Deborah Shaw", company: "Deborah Shaw Editing", avatar: "/images/reviews/deborah-shaw.png", text: "Charlie is fantastic to work with! I got stuck fiddling around with WordPress blocks, but Charlie came to the rescue. He understood what I was wanting with my website and made my ideas come together. Thank you!" },
  { name: "Zane Barrett", company: "Barrett Access Scaffolding", text: "We recently worked with Kiwiweb to design and launch our new website, and we couldn't be happier with the results. The team was professional, responsive, and really took the time to understand our business. They helped us create a modern, easy-to-navigate site and incorporated some amazing features, including a scaffold cost calculator – the first of its kind in NZ! This has already set us apart in our industry and made quoting so much easier for our clients. Communication was clear and efficient throughout, and any tweaks we needed were handled quickly. I highly recommend Kiwiweb to anyone looking for a web design team that delivers both creativity and functionality." },
  { name: "Steven Liu", company: "Kiwiland Constructions", avatar: "/images/reviews/steven-liu.png", text: "Outstanding Experience with Kiwi Web Design and Charlie! I couldn't be happier with the website that Kiwi Web Design created for me. From start to finish, Charlie was professional, responsive, and incredibly easy to work with. He took the time to understand exactly what I wanted, offered helpful suggestions, and delivered a final product that exceeded my expectations. The design is clean, modern, and user-friendly — exactly what I was hoping for. Charlie made the whole process smooth and stress-free, and he was always quick to answer any questions I had. His attention to detail and commitment to quality really stood out. If you're looking for a reliable, talented web designer who truly cares about your vision, I highly recommend Kiwi Web Design and Charlie. Five stars all the way!" },
  { name: "Jack at Show Me Shorts", avatar: "/images/reviews/jack-show-me-shorts.png", text: "Kiwi Web Design were fantastic to work with. From the very beginning they really took the time to understand what I needed and offered smart, practical solutions. The team were professional, friendly and quick to respond whenever I had questions. If you're looking for a reliable, creative, and genuinely helpful web design team in New Zealand, I'd definitely recommend Kiwi Web Design." },
  { name: "Tony S", company: "Streetfood Network", avatar: "/images/reviews/tony-s.png", text: "Charlie from Kiwi Web Design has been great to work with. He communicates clearly, responds promptly, and makes the process easy to understand. The pricing has been reasonable, and I've appreciated his practical approach to building and improving our Streetfood Network website. I would recommend Kiwi Web Design to any small business looking for reliable website support. Business has since taken off and the Website is amazing!" },
  { name: "Elisabeth Krull", text: "Kiwi Web Design is helping me with an international website. I can highly recommend working with Charlie — both professionally and personally!" },
  { name: "Gina Dellabarca", company: "Showme Short Film Festival", avatar: "/images/reviews/gina-dellabarca.png", text: "They provided a comprehensive and helpful website audit for us. Clear information. Great communication." },
  { name: "Dave G", text: "Charlie was very responsive to my concerns and demonstrated a strong understanding of the issues I raised. Excellent service and support — thank you." },
];

// Full-colour Google "G" logo (official 4-colour mark), reused in the header + each review card.
const googleG = '<path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34C2.85 17.09 2 20.45 2 24s.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/>';
const avatarColors = ['#d93b8f', '#5b8def', '#8b5cf6', '#0ea5a4', '#e0672c', '#3f7d4f', '#c0392b', '#2f6f9f'];

const steps = [
  { num: "1", title: "15-Minute Strategy Call", desc: "We talk about your business, your customers, and whether a new site will actually move the needle. Honest advice, no pressure." },
  { num: "2", title: "Plan & Fixed Quote", desc: "You get a clear proposal: pages, copy, design direction, timeline, and one fixed price. No surprise invoices." },
  { num: "3", title: "Design & Build", desc: "We write, design, and build. You review at each stage. Most sites are live in 2-3 weeks." },
  { num: "4", title: "Launch & Grow", desc: "Analytics and enquiry tracking are live from day one. Add SEO or Google Ads when you're ready." },
];

// Screenshots only, deliberately no outbound links — this page has one job.
// Full set — matches the homepage portfolio (index.astro) plus a couple of LP-only extras.
const portfolio = [
  { src: '/portfolio/barrett-access-scaffolding.webp', alt: 'Barrett Access Scaffolding website by Kiwi Web Design', caption: 'Barrett Access Scaffolding' },
  { src: '/portfolio/prime-industrial.webp', alt: 'Prime Industrial website by Kiwi Web Design', caption: 'Prime Industrial' },
  { src: '/portfolio/the-framers-guild.webp', alt: 'The Framers Guild website by Kiwi Web Design', caption: 'The Framers Guild' },
  { src: '/portfolio/kiwiland-construction.webp', alt: 'Kiwiland Construction website by Kiwi Web Design', caption: 'Kiwiland Construction' },
  { src: '/portfolio/melanoma-specialists.webp', alt: 'Melanoma Specialists website by Kiwi Web Design', caption: 'Melanoma Specialists' },
  { src: '/portfolio/aesthetic-painting.webp', alt: 'Aesthetic Painting website by Kiwi Web Design', caption: 'Aesthetic Painting' },
  { src: beautyTouchPreview.src, alt: 'Beauty Touch Auckland website by Kiwi Web Design', caption: 'Beauty Touch Auckland' },
  { src: '/portfolio/gom.webp', alt: 'Goldwing website by Kiwi Web Design', caption: 'Goldwing' },
  { src: '/portfolio/kebudel.webp', alt: 'Kebudel website by Kiwi Web Design', caption: 'Kebudel' },
  { src: '/portfolio/asc-homes.webp', alt: 'ASC Homes website by Kiwi Web Design', caption: 'ASC Homes' },
  { src: '/portfolio/mt-albert-business.jpg', alt: 'Mt Albert Business Association website by Kiwi Web Design', caption: 'Mt Albert Business Assoc.' },
  { src: '/blog/600-21B675F7-8EB5-45A5-99242870729DC26D.png', alt: 'TopRated.nz platform by Kiwi Web Design', caption: 'TopRated.nz' },
];

const faqs = [
  { q: "How much does a website cost?", a: "Most small business website projects start from $2,000 + GST. The exact price depends on pages and features — you'll get a fixed quote after the strategy call, before anything starts." },
  { q: "How long until my site is live?", a: "Most small business websites go live in 2-3 weeks from project start. If you have a hard deadline, tell us on the call and we'll be straight about whether it's doable." },
  { q: "Is the strategy call really free?", a: "Yes — 15 minutes, no obligation, no quote pressure. If a new website isn't the right move for your business right now, we'll tell you that too." },
  { q: "Do I need SEO or Google Ads as well?", a: "Not on day one. Every site we build is structured ready for SEO and Google Ads, so you can add them later without rebuilding anything." },
  { q: "Will you write the website content?", a: "Yes, we can help draft the content for your website, but you'll need to review and approve it based on your expertise before it goes live." },
  { q: "Can you redesign my existing website?", a: "Yes. If your current site is outdated, slow, hard to update, or not generating enquiries, we can rebuild it with a clearer structure, better copy, and proper tracking." },
  { q: "Do you use templates?", a: "No. We may reuse proven section patterns, but your website is planned, written, designed, and built around your business, services, customers, and goals." },
  { q: "Will I own the website?", a: "Yes. Once the project is paid for, the website belongs to you. We can look after hosting, updates, and improvements, but you are not locked into staying with us." },
  { q: "Can you set up enquiry tracking?", a: "Yes, we can set up enquiry tracking if required." },
  { q: "What do I need before the call?", a: "Just your business name, current website if you have one, and a rough idea of what you want the website to achieve. We can help shape the rest." },
];
---

<Layout
  title="Web Design Auckland | Websites That Generate Enquiries | Kiwi Web Design"
  description="Website design for Auckland small businesses that want more enquiries. Custom design, copywriting, and enquiry tracking included. Projects from $2,000 + GST. Book a free 15-minute strategy call."
  canonicalURL="https://www.kiwiwebdesign.co.nz/web-design-auckland-lp/"
  robots="noindex, nofollow"
  chrome="minimal"
>

  <!-- Minimal LP header: no nav menu, no leak paths — logo, phone, one CTA -->
  <header class="lp-header">
    <div class="container lp-header-inner">
      <span class="lp-logo">
        <img src="/logo-96.webp" alt="Kiwi Web Design" width="44" height="44" loading="eager" />
        <span class="lp-logo-text">Kiwi Web Design</span>
      </span>
      <div class="lp-header-actions">
        <a href="tel:+64210396580" class="lp-header-phone">
          <Icon name="Phone" size={16} />
          <span>021 039 6580</span>
        </a>
        <a href="#lead-form" class="lp-header-cta">Free Strategy Call</a>
      </div>
    </div>
  </header>

  <!-- Hero + form -->
  <section class="lp-hero">
    <span class="lp-orb lp-orb-yellow lp-orb-lg lp-orb--hero-1" aria-hidden="true"></span>
    <span class="lp-orb lp-orb-gold lp-orb-md lp-orb--hero-2" aria-hidden="true"></span>
    <div class="container lp-layout">

      <div class="lp-pitch">
        <p class="lp-eyebrow">Web Design · Auckland</p>
        <h1>Website design for Auckland small businesses that want <span class="lp-title-accent">more&nbsp;enquiries</span></h1>
        <p class="lp-lead">Your website should be your hardest-working salesperson. We design and build sites that explain what you do, rank on Google, and turn visitors into phone calls and enquiries — not just look pretty.</p>

        <ul class="lp-trust">
          <li><span class="lp-trust-icon"><Icon name="BadgeDollarSign" size={18} /></span> Projects from $2,000 + GST — fixed quote up front</li>
          <li><span class="lp-trust-icon"><Icon name="Zap" size={18} /></span> Most sites live in 2-3 weeks</li>
          <li><span class="lp-trust-icon"><Icon name="MapPin" size={18} /></span> Based in Grey Lynn — we meet Auckland clients in person</li>
          <li><span class="lp-trust-icon"><Icon name="Star" size={18} /></span> 5★ Google rating from 50+ NZ businesses</li>
        </ul>
      </div>

      <div class="lp-form-wrap" id="lead-form">
        <h2 class="lp-form-title">Book a <span class="lp-title-accent">free 15-minute</span> strategy call</h2>
        <p class="lp-form-sub">Tell us a bit about your business. We'll review it before we call, so the 15 minutes is about your goals — not a sales script. Fields marked * are required.</p>
        <form class="lp-form" id="lp-form" name="web-design-auckland-lp" method="POST" action="https://api.web3forms.com/submit" data-lp-form>
          <input type="hidden" name="access_key" value="e0a725e4-f764-4536-826c-df981c8bdf3b" />
          <input type="hidden" name="subject" value="New Google Ads LP lead — web design Auckland" />
          <input type="hidden" name="from_name" value="KWD Google Ads Landing Page" />
          <input type="checkbox" name="botcheck" class="lp-botcheck" tabindex="-1" autocomplete="off" />

          <div class="lp-row lp-row-2">
            <label class="lp-label">
              <span class="lp-label-text">Name <span class="req">*</span></span>
              <input type="text" name="name" placeholder="Sarah Johnson" required />
            </label>
            <label class="lp-label">
              <span class="lp-label-text">Business <span class="req">*</span></span>
              <input type="text" name="business" placeholder="Your business name" required />
            </label>
          </div>
          <div class="lp-row lp-row-2">
            <label class="lp-label">
              <span class="lp-label-text">Email <span class="req">*</span></span>
              <input type="email" name="email" placeholder="you@yourbusiness.co.nz" required />
            </label>
            <label class="lp-label">
              <span class="lp-label-text">Phone <span class="req">*</span></span>
              <input type="tel" name="phone" placeholder="021 000 0000" required />
            </label>
          </div>
          <div class="lp-row">
            <label class="lp-label">
              <span class="lp-label-text">Website</span>
              <input type="text" name="website" placeholder="www.yourbusiness.co.nz (optional)" />
            </label>
          </div>
          <div class="lp-row">
            <label class="lp-label lp-label-area">
              <span class="lp-label-text">Goal</span>
              <textarea name="goal" rows="2" placeholder="What are you hoping to achieve? (optional)"></textarea>
            </label>
          </div>

          <button type="submit" class="lp-submit" id="lp-submit" data-lp-submit>Book My Free Strategy Call →</button>
          <p id="lp-status" aria-live="polite" style="display:none" class="lp-form-status" data-lp-status></p>
          <p class="lp-privacy">No obligation. No spam. We reply within 1 business day.</p>
        </form>
      </div>

    </div>
  </section>

  <!-- Google reviews -->
  <section class="lp-section lp-section-dark">
    <span class="lp-orb lp-orb-gold lp-orb-lg lp-orb--reviews" aria-hidden="true"></span>
    <div class="container">
      <div class="lp-reviews-head">
        <span class="lp-reviews-badge">
          <svg class="lp-g" viewBox="0 0 48 48" aria-hidden="true" set:html={googleG} />
          <span class="lp-review-stars" aria-hidden="true">★★★★★</span>
          <strong>5.0</strong>
          <span class="lp-reviews-count">on Google Reviews</span>
        </span>
        <h2 class="lp-sec-title lp-reviews-title">What Auckland <span class="lp-title-accent">business owners say</span></h2>
      </div>
      <div class="lp-carousel">
        <button type="button" class="lp-carousel-btn lp-carousel-prev" id="lp-rev-prev" aria-label="Previous reviews">‹</button>
        <div class="lp-carousel-track" id="lp-reviews-track">
          {reviews.map(({ name, company, avatar, text }, i) => (
            <figure class="lp-review-card">
              <div class="lp-review-top">
                <svg class="lp-g" viewBox="0 0 48 48" aria-hidden="true" set:html={googleG} />
                <span class="lp-review-stars" aria-label="Rated 5 out of 5">★★★★★</span>
              </div>
              <div class="lp-review-textwrap">
                <p class="lp-review-text">{text}</p>
                <button type="button" class="lp-review-more" hidden>Read more</button>
              </div>
              <figcaption class="lp-review-foot">
                {avatar ? (
                  <img class="lp-review-avatar" src={avatar} alt={`${name} avatar`} loading="lazy" width="40" height="40" />
                ) : (
                  <span class="lp-review-avatar" style={`background:${avatarColors[i % avatarColors.length]}`}>{name.charAt(0)}</span>
                )}
                <span class="lp-review-who">
                  <span class="lp-review-name">{name}</span>
                  {company && <span class="lp-review-co">{company}</span>}
                </span>
              </figcaption>
            </figure>
          ))}
        </div>
        <button type="button" class="lp-carousel-btn lp-carousel-next" id="lp-rev-next" aria-label="Next reviews">›</button>
      </div>
    </div>
  </section>

  <!-- Problem -->
  <section class="lp-section lp-section-white">
    <span class="lp-orb lp-orb-gold lp-orb-md lp-orb--problem" aria-hidden="true"></span>
    <div class="container">
      <p class="lp-sec-eyebrow">Sound familiar?</p>
      <h2 class="lp-sec-title">Your website looks fine — so <span class="lp-title-accent">why is the phone quiet?</span></h2>
      <div class="lp-problem-grid">
        <div class="lp-problem-card">
          <span class="lp-problem-icon"><Icon name="Clock" size={22} /></span>
          <h3>It's outdated</h3>
          <p>Built years ago, slow on mobile, and it makes your business look smaller than it is. Customers notice — then call your competitor.</p>
        </div>
        <div class="lp-problem-card">
          <span class="lp-problem-icon"><Icon name="EyeOff" size={22} /></span>
          <h3>Google can't find it</h3>
          <p>No clear service pages, no local SEO structure, no reason for Google to rank you when Aucklanders search for what you do.</p>
        </div>
        <div class="lp-problem-card">
          <span class="lp-problem-icon"><Icon name="PhoneOff" size={22} /></span>
          <h3>It doesn't convert</h3>
          <p>Visitors arrive, look around, and leave. No clear offer, no reason to enquire, no easy next step. Traffic without enquiries is just a stat.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio proof -->
  <section class="lp-section lp-section-cream">
    <span class="lp-orb lp-orb-yellow lp-orb-lg lp-orb--portfolio" aria-hidden="true"></span>
    <div class="container">
      <p class="lp-sec-eyebrow">Recent work</p>
      <h2 class="lp-sec-title">Websites we've built for <span class="lp-title-accent">businesses like yours</span></h2>
      <div class="lp-carousel">
        <button type="button" class="lp-carousel-btn lp-carousel-prev" id="lp-port-prev" aria-label="Previous work">‹</button>
        <div class="lp-carousel-track" id="lp-portfolio-track">
          {portfolio.map(({ src, alt, caption }) => (
            <figure class="lp-portfolio-item">
              <img src={src} alt={alt} loading="lazy" width="640" height="400" />
              <figcaption>{caption}</figcaption>
            </figure>
          ))}
        </div>
        <button type="button" class="lp-carousel-btn lp-carousel-next" id="lp-port-next" aria-label="Next work">›</button>
      </div>
    </div>
  </section>

  <!-- What's included -->
  <section class="lp-section lp-section-cream">
    <div class="container">
      <p class="lp-sec-eyebrow">What's included</p>
      <h2 class="lp-sec-title">Everything a <span class="lp-title-accent">lead-generating website</span> needs — one fixed price</h2>
      <div class="lp-included-grid">
        {included.map(({ icon, title, desc }) => (
          <div class="lp-included-card">
            <span class="lp-included-icon"><Icon name={icon} size={20} /></span>
            <div>
              <strong>{title}</strong>
              <p>{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Fit filter -->
  <section class="lp-section lp-section-white">
    <div class="container">
      <p class="lp-sec-eyebrow">Is this right for you?</p>
      <h2 class="lp-sec-title">We're <span class="lp-title-accent">not the right fit</span> for everyone</h2>
      <div class="lp-fit-grid">
        <div class="lp-fit-col lp-fit-yes">
          <h3><Icon name="CheckCircle" size={20} /> A good fit if…</h3>
          <ul>
            {goodFit.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="lp-fit-col lp-fit-no">
          <h3><Icon name="XCircle" size={20} /> Probably not the right fit if…</h3>
          <ul>
            {notFit.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Credibility -->
  <section class="lp-section lp-section-dark">
    <span class="lp-orb lp-orb-yellow lp-orb-lg lp-orb--cred" aria-hidden="true"></span>
    <div class="container lp-cred-layout">
      <div class="lp-cred-photo">
        <Image src={charliePhoto} alt="Charlie Chao, owner of Kiwi Web Design, Auckland" width={420} loading="lazy" />
      </div>
      <div class="lp-cred-text">
        <p class="lp-sec-eyebrow">Who you'll work with</p>
        <h2>You work with <span class="lp-title-accent">Charlie</span> — the person who actually builds your site</h2>
        <p>No account managers, no offshore handoffs. Kiwi Web Design is run by Charlie Chao from Grey Lynn, Auckland. The person you talk to on the strategy call is the same person who writes, designs, and builds your website — and answers the phone after launch.</p>
        <div class="lp-cred-stats">
          <div><span class="lp-cred-num">5.0★</span><span class="lp-cred-label">Google Rating</span></div>
          <div><span class="lp-cred-num">2-3 wks</span><span class="lp-cred-label">Typical Build</span></div>
          <div><span class="lp-cred-num">1 day</span><span class="lp-cred-label">Reply Time</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="lp-section lp-section-white">
    <div class="container">
      <p class="lp-sec-eyebrow">How it works</p>
      <h2 class="lp-sec-title">From first call to live site, <span class="lp-title-accent">without the runaround</span></h2>
      <div class="lp-steps">
        {steps.map(({ num, title, desc }) => (
          <div class="lp-step">
            <span class="lp-step-num">{num}</span>
            <h3>{title}</h3>
            <p>{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="lp-section lp-section-cream">
    <div class="container">
      <p class="lp-sec-eyebrow">Common questions</p>
      <h2 class="lp-sec-title">Straight answers <span class="lp-title-accent">before you book</span></h2>
      <div class="lp-faq-list">
        {faqs.map(({ q, a }) => (
          <details class="lp-faq-item">
            <summary class="lp-faq-q">{q}</summary>
            <p class="lp-faq-a">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA + second form -->
  <section class="lp-final">
    <span class="lp-orb lp-orb-yellow lp-orb-lg lp-orb--final" aria-hidden="true"></span>
    <div class="container lp-final-grid">
      <div class="lp-final-copy">
        <p class="lp-sec-eyebrow">First steps</p>
        <h2>Fill out the form and <span class="lp-title-accent">we'll be in touch</span></h2>
