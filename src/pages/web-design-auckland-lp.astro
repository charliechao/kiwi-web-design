  <script>
    (function () {
      function setStatus(status: HTMLElement, msg: string, isError: boolean) {
        status.textContent = msg;
        status.style.display = 'block';
        status.className = 'lp-form-status ' + (isError ? 'lp-form-status--error' : 'lp-form-status--success');
      }

      function validateSubmission(form: HTMLFormElement, openedAt: number) {
        const formData = new FormData(form);
        const name = String(formData.get('name') || '').trim();
        if (formData.get('botcheck')) return 'Submission blocked. Please refresh the page and try again.';
        if ((Date.now() - openedAt) / 1000 < 3) return 'Please wait a few seconds before submitting.';
        if (name.length < 2 || !/[a-z]/i.test(name)) return 'Please enter your name.';
        return '';
      }

      document.querySelectorAll<HTMLFormElement>('form[data-lp-form]').forEach((form) => {
        const btn = form.querySelector<HTMLButtonElement>('[data-lp-submit]');
        const status = form.querySelector<HTMLElement>('[data-lp-status]');
        // Timing bot-gate lives in JS only — never sent to Web3Forms
        // (machine-looking payload fields can trip their spam filter).
        const openedAt = Date.now();
        if (!btn || !status) return;

        const defaultBtnText = btn.textContent || 'Send My Details →';

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const validationError = validateSubmission(form, openedAt);
          if (validationError) {
            setStatus(status, validationError, true);
            return;
          }
          btn.disabled = true;
          btn.textContent = 'Sending…';
          status.style.display = 'none';
          try {
            const formData = new FormData(form);
            formData.delete('botcheck');
            const res = await fetch('https://api.web3forms.com/submit', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify(Object.fromEntries(formData)),
            });
            const data = await res.json();
            if (data.success) {
              // Hand lead details to the thank-you page for the conversion event
              // (sessionStorage, not URL params — keeps PII out of logs/history).
              try {
                sessionStorage.setItem('kwd_lp_lead', JSON.stringify({
                  email: String(formData.get('email') || ''),
                  phone: String(formData.get('phone') || ''),
                }));
              } catch { /* storage unavailable — thank-you page still loads, event just has no params */ }
              window.location.href = '/web-design-auckland-lp/thank-you/';
            } else {
              setStatus(status, data.message || 'Something went wrong. Please try again, or call 021 039 6580.', true);
            }
          } catch {
            setStatus(status, 'Network error — please check your connection and try again, or call 021 039 6580.', true);
          } finally {
            btn.disabled = false;
            btn.textContent = defaultBtnText;
          }
        });
      });

      // Hide the sticky mobile CTA while the form is on screen
      const sticky = document.getElementById('lp-sticky-cta');
      const formWrap = document.getElementById('lead-form');
      const header = document.querySelector<HTMLElement>('.lp-header');
      const leadFormLinks = document.querySelectorAll<HTMLAnchorElement>('a[href="#lead-form"]');

      leadFormLinks.forEach((link) => {
        link.addEventListener('click', (event) => {
          if (!formWrap || !window.matchMedia('(max-width: 720px)').matches) return;
          event.preventDefault();
          if (header) {
            header.style.position = 'static';
            header.style.top = 'auto';
          }
          const gap = 20;
          const y = formWrap.getBoundingClientRect().top + window.scrollY - gap;
          window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
          history.replaceState(null, '', '#lead-form');
        });
      });

      if (sticky && formWrap && 'IntersectionObserver' in window) {
        new IntersectionObserver(([entry]) => {
          sticky.classList.toggle('lp-sticky-hidden', entry.isIntersecting);
        }, { threshold: 0.1 }).observe(formWrap);
      }

      // Review cards: show "Read more" only when the clamped text actually overflows.
      function initReviewClamp() {
        document.querySelectorAll<HTMLElement>('.lp-review-card').forEach((card) => {
          if (card.dataset.clampInit) return;
          const textEl = card.querySelector<HTMLElement>('.lp-review-text');
          const moreBtn = card.querySelector<HTMLButtonElement>('.lp-review-more');
          if (!textEl || !moreBtn) return;
          card.dataset.clampInit = '1';
          if (textEl.scrollHeight - textEl.clientHeight > 4) {
            moreBtn.hidden = false;
            moreBtn.addEventListener('click', () => {
              const expanded = card.classList.toggle('is-expanded');
              moreBtn.textContent = expanded ? 'Read less' : 'Read more';
            });
          }
        });
      }
      // Measure after fonts settle (line-heights shift once webfonts load).
      const fontsApi = (document as Document & { fonts?: FontFaceSet }).fonts;
      if (fontsApi?.ready) { fontsApi.ready.then(initReviewClamp); } else { initReviewClamp(); }

      // Generic carousel: one card per step, loops forever, auto-advances slowly.
      // Shared by the reviews carousel and the portfolio carousel.
      function initCarousel(trackId: string, prevId: string, nextId: string, cardSelector: string, autoplayMs = 4500) {
        const track = document.getElementById(trackId);
        const prevBtn = document.getElementById(prevId) as HTMLButtonElement | null;
        const nextBtn = document.getElementById(nextId) as HTMLButtonElement | null;
        if (!track || !prevBtn || !nextBtn) return;

        const stepBy = () => {
          const card = track.querySelector<HTMLElement>(cardSelector);
          return card ? card.getBoundingClientRect().width + 24 : track.clientWidth * 0.9;
        };
        const maxScroll = () => track.scrollWidth - track.clientWidth;
        const advance = (dir: 1 | -1) => {
          if (dir === 1 && track.scrollLeft >= maxScroll() - 2) {
            track.scrollTo({ left: 0, behavior: 'smooth' });
          } else if (dir === -1 && track.scrollLeft <= 2) {
            track.scrollTo({ left: maxScroll(), behavior: 'smooth' });
          } else {
            track.scrollBy({ left: dir * stepBy(), behavior: 'smooth' });
          }
        };

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        let autoplayTimer: ReturnType<typeof setInterval> | null = null;
        const stopAutoplay = () => { if (autoplayTimer) { clearInterval(autoplayTimer); autoplayTimer = null; } };
        const startAutoplay = () => {
          if (prefersReducedMotion || autoplayTimer) return;
          autoplayTimer = setInterval(() => advance(1), autoplayMs);
        };
        const restartAutoplay = () => { stopAutoplay(); startAutoplay(); };

        prevBtn.addEventListener('click', () => { advance(-1); restartAutoplay(); });
        nextBtn.addEventListener('click', () => { advance(1); restartAutoplay(); });
        track.addEventListener('mouseenter', stopAutoplay);
        track.addEventListener('mouseleave', startAutoplay);
        track.addEventListener('touchstart', stopAutoplay, { passive: true });
        track.addEventListener('touchend', () => { stopAutoplay(); setTimeout(startAutoplay, 3000); }, { passive: true });

        startAutoplay();
      }

      initCarousel('lp-reviews-track', 'lp-rev-prev', 'lp-rev-next', '.lp-review-card', 4500);
      initCarousel('lp-portfolio-track', 'lp-port-prev', 'lp-port-next', '.lp-portfolio-item', 3800);
    })();
  </script>
  <script is:inline src="https://web3forms.com/client/script.js" async defer></script>

